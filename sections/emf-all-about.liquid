{%- doc -%}
  ALL ABOUT EMFs — Educational Page Section
  Wax | Wane Store — EMF Protection Line

  DESIGN AESTHETIC: Cyber-punk — dark backgrounds, neon electric accents,
  scanline overlays, circuit board patterns, glitch effects, grid lines.
  Contrast with HARAMOON's glassmorphism — this is intentionally edgier.

  SECTIONS:
  1. Hero — animated glitch headline + tagline + CTA
  2. What Is EMF? — definition + 3 infographic embeds
  3. Video spotlight — 9:16 video with cyber-punk frame
  4. EMF Concepts — from emf_concept metaobjects (cyber cards)
  5. Protection Methods — from emf_protection_method metaobjects
  6. "Mindful Tech Boundaries" overlay image + shop CTA
  7. FAQ — from faq_group metaobjects (EMF category)

  FULLY EDITABLE IN THEME EDITOR:
  - All colors (bg, accent neon, text, card bg, border)
  - All headings and body text
  - All image pickers (swap infographics anytime)
  - Video ID (Shopify video file ID)
  - Padding / spacing on every section
  - Toggle each sub-section on/off
  - CTA button text + link

  STRUCTURED DATA:
  - schema.org/WebPage + Article
  - FAQPage for the FAQ block
  - ItemList for concepts + protection methods
{%- enddoc -%}

{%- assign emf_concepts = shop.metaobjects.emf_concept.values -%}
{%- assign emf_types    = shop.metaobjects.emf_protection_method.values -%}
{%- assign all_faq_entries = shop.metaobjects.faq_group.values -%}
{%- assign emf_faqs       = all_faq_entries | where: 'category', 'EMF Protection' -%}

{%- comment -%} ── STRUCTURED DATA ──────────────────────────────────── {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": ["WebPage", "Article"],
  "name": {{ section.settings.hero_heading | default: 'All About EMFs' | json }},
  "headline": {{ section.settings.hero_heading | default: 'All About EMFs: Understanding Electromagnetic Frequencies' | json }},
  "description": {{ section.settings.hero_subtext | default: 'A complete guide to understanding EMF exposure, the science of shielding, and practical steps to protect yourself and your family.' | json }},
  "url": "{{ shop.url }}{{ page.url }}",
  "publisher": {
    "@type": "Organization",
    "name": "Wax | Wane Store",
    "url": "{{ shop.url }}"
  },
  "mainEntity": [
    {
      "@type": "ItemList",
      "name": "EMF Concepts",
      "itemListElement": [
        {%- for concept in emf_concepts -%}
        {
          "@type": "ListItem",
          "position": {{ forloop.index }},
          "name": {{ concept.display_name | json }},
          "description": {{ concept.simple_explanation | default: concept.concept_name | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    },
    {
      "@type": "ItemList",
      "name": "EMF Protection Methods",
      "itemListElement": [
        {%- for ptype in emf_types -%}
        {
          "@type": "ListItem",
          "position": {{ forloop.index }},
          "name": {{ ptype.display_name | json }},
          "description": {{ ptype.simple_description | default: ptype.method_name | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
    {%- if emf_faqs.size > 0 -%}
    ,{
      "@type": "FAQPage",
      "mainEntity": [
        {%- for faq in emf_faqs -%}
        {
          "@type": "Question",
          "name": {{ faq.question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ faq.answer | json }}
          }
        }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
    {%- endif -%}
  ]
}
</script>

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&family=Poppins:wght@300;400;500;600&display=swap');

  /* ── ROOT VARIABLES ─────────────────────────────────────────── */
  .emf-page {
    --emf-bg:        {{ section.settings.bg_color }};
    --emf-bg2:       {{ section.settings.bg_color_2 }};
    --emf-neon:      {{ section.settings.neon_color }};
    --emf-neon2:     {{ section.settings.neon_color_2 }};
    --emf-text:      {{ section.settings.text_color }};
    --emf-subtext:   {{ section.settings.subtext_color }};
    --emf-card:      {{ section.settings.card_bg }};
    --emf-border:    {{ section.settings.card_border }};
    --emf-heading:   {{ section.settings.heading_color }};
    --ff-mono:       'Share Tech Mono', monospace;
    --ff-display:    'Rajdhani', sans-serif;
    --ff-body:       'Poppins', sans-serif;
    background: var(--emf-bg);
    color: var(--emf-text);
    font-family: var(--ff-body);
    overflow-x: hidden;
  }

  /* ── SCANLINE OVERLAY (global) ──────────────────────────────── */
  .emf-page::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,255,180,0.015) 2px,
      rgba(0,255,180,0.015) 4px
    );
    pointer-events: none;
    z-index: 0;
  }

  /* ── GRID BACKGROUND ────────────────────────────────────────── */
  .emf-grid-bg {
    position: relative;
    background-image:
      linear-gradient(rgba(0,255,180,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,180,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  /* ── SECTION WRAPPER ────────────────────────────────────────── */
  .emf-section {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 2;
  }

  /* ── HERO ───────────────────────────────────────────────────── */
  .emf-hero {
    background: var(--emf-bg);
    padding: {{ section.settings.hero_padding_top }}px 20px {{ section.settings.hero_padding_bottom }}px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .emf-hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--emf-neon), transparent);
  }
  .emf-hero__eyebrow {
    font-family: var(--ff-mono);
    font-size: 11px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--emf-neon);
    margin: 0 0 16px;
    opacity: 0.8;
  }
  .emf-hero__eyebrow::before { content: '> '; }
  .emf-hero__eyebrow::after  { content: ' _'; animation: blink 1s step-end infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  .emf-hero__heading {
    font-family: var(--ff-display);
    font-size: clamp(2.4rem, 7vw, 5.5rem);
    font-weight: 700;
    color: var(--emf-heading);
    line-height: 1.05;
    margin: 0 0 20px;
    letter-spacing: -0.01em;
    text-shadow: 0 0 40px rgba(0,255,180,0.3), 0 0 80px rgba(0,255,180,0.1);
    position: relative;
  }
  /* Glitch effect */
  .emf-hero__heading::before,
  .emf-hero__heading::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
  }
  .emf-hero__heading::before {
    color: var(--emf-neon);
    clip-path: polygon(0 30%, 100% 30%, 100% 50%, 0 50%);
    transform: translateX(-3px);
    animation: glitch1 4s infinite;
    opacity: 0.5;
  }
  .emf-hero__heading::after {
    color: var(--emf-neon2);
    clip-path: polygon(0 60%, 100% 60%, 100% 80%, 0 80%);
    transform: translateX(3px);
    animation: glitch2 4s infinite;
    opacity: 0.4;
  }
  @keyframes glitch1 {
    0%,90%,100% { transform: translateX(0); opacity: 0; }
    92% { transform: translateX(-4px); opacity: 0.5; }
    94% { transform: translateX(4px); opacity: 0.5; }
    96% { transform: translateX(0); opacity: 0; }
  }
  @keyframes glitch2 {
    0%,88%,100% { transform: translateX(0); opacity: 0; }
    90% { transform: translateX(4px); opacity: 0.4; }
    92% { transform: translateX(-4px); opacity: 0.4; }
    94% { transform: translateX(0); opacity: 0; }
  }

  .emf-hero__subtext {
    font-size: clamp(0.95rem, 1.5vw, 1.15rem);
    color: var(--emf-subtext);
    max-width: 600px;
    margin: 0 auto 36px;
    line-height: 1.75;
  }
  .emf-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    background: transparent;
    border: 2px solid var(--emf-neon);
    color: var(--emf-neon);
    font-family: var(--ff-mono);
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .emf-hero__cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--emf-neon);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    z-index: -1;
  }
  .emf-hero__cta:hover::before { transform: translateX(0); }
  .emf-hero__cta:hover { color: var(--emf-bg); }

  /* ── SECTION DIVIDERS ───────────────────────────────────────── */
  .emf-divider {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--emf-border), transparent);
    margin: 0;
  }

  /* ── SECTION HEADERS ────────────────────────────────────────── */
  .emf-block {
    padding: {{ section.settings.block_padding }}px 20px;
    position: relative;
  }
  .emf-block--alt { background: var(--emf-bg2); }

  .emf-block__header {
    text-align: center;
    margin-bottom: 48px;
  }
  .emf-block__eyebrow {
    font-family: var(--ff-mono);
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--emf-neon);
    margin: 0 0 10px;
    opacity: 0.7;
  }
  .emf-block__title {
    font-family: var(--ff-display);
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--emf-heading);
    margin: 0 0 12px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .emf-block__subtitle {
    font-size: 0.95rem;
    color: var(--emf-subtext);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── INFOGRAPHIC GRID ───────────────────────────────────────── */
  .emf-infographic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
    margin-bottom: 16px;
  }
  .emf-infographic-card {
    position: relative;
    border: 1px solid var(--emf-border);
    overflow: hidden;
    background: var(--emf-card);
    transition: all 0.3s ease;
  }
  .emf-infographic-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--emf-neon), var(--emf-neon2));
    z-index: 2;
  }
  .emf-infographic-card::after {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 0 1px rgba(0,255,180,0);
    transition: box-shadow 0.3s ease;
    pointer-events: none;
    z-index: 3;
  }
  .emf-infographic-card:hover::after {
    box-shadow: inset 0 0 0 1px var(--emf-neon);
  }
  .emf-infographic-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 40px rgba(0,255,180,0.15);
  }
  .emf-infographic-card img {
    width: 100%;
    height: auto;
    display: block;
    filter: saturate(0.9) contrast(1.05);
    transition: filter 0.3s ease;
  }
  .emf-infographic-card:hover img { filter: saturate(1.1) contrast(1.1); }
  .emf-infographic-card__caption {
    padding: 14px 18px;
    font-family: var(--ff-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--emf-neon);
    opacity: 0.7;
    border-top: 1px solid var(--emf-border);
  }
  .emf-infographic-card__caption::before { content: '// '; }

  /* ── VIDEO SPOTLIGHT ────────────────────────────────────────── */
  .emf-video-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  @media (max-width: 720px) {
    .emf-video-block { grid-template-columns: 1fr; }
  }
  .emf-video-frame {
    position: relative;
    border: 2px solid var(--emf-border);
    overflow: hidden;
    background: #000;
  }
  .emf-video-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0,255,180,0.08) 0%,
      transparent 50%,
      rgba(0,200,255,0.05) 100%
    );
    pointer-events: none;
    z-index: 2;
  }
  .emf-video-frame video,
  .emf-video-frame iframe {
    width: 100%;
    display: block;
    aspect-ratio: 9/16;
    object-fit: cover;
  }
  .emf-video-corner {
    position: absolute;
    width: 20px;
    height: 20px;
    border-color: var(--emf-neon);
    border-style: solid;
    z-index: 3;
  }
  .emf-video-corner--tl { top: 8px; left: 8px; border-width: 2px 0 0 2px; }
  .emf-video-corner--tr { top: 8px; right: 8px; border-width: 2px 2px 0 0; }
  .emf-video-corner--bl { bottom: 8px; left: 8px; border-width: 0 0 2px 2px; }
  .emf-video-corner--br { bottom: 8px; right: 8px; border-width: 0 2px 2px 0; }

  .emf-video-text__eyebrow {
    font-family: var(--ff-mono);
    font-size: 10px;
    letter-spacing: 0.4em;
    color: var(--emf-neon);
    text-transform: uppercase;
    margin: 0 0 14px;
  }
  .emf-video-text__heading {
    font-family: var(--ff-display);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--emf-heading);
    margin: 0 0 16px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .emf-video-text__body {
    font-size: 0.95rem;
    color: var(--emf-subtext);
    line-height: 1.8;
    margin: 0 0 24px;
  }
  .emf-stat-row {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .emf-stat {
    flex: 1;
    min-width: 100px;
    padding: 14px;
    border: 1px solid var(--emf-border);
    background: var(--emf-card);
    text-align: center;
  }
  .emf-stat__number {
    font-family: var(--ff-mono);
    font-size: 1.6rem;
    color: var(--emf-neon);
    display: block;
    line-height: 1;
    margin-bottom: 4px;
  }
  .emf-stat__label {
    font-size: 0.7rem;
    color: var(--emf-subtext);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ── CONCEPT CARDS ──────────────────────────────────────────── */
  .emf-concepts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }
  .emf-cyber-card {
    background: var(--emf-card);
    border: 1px solid var(--emf-border);
    padding: 24px;
    position: relative;
    transition: all 0.3s ease;
    overflow: hidden;
  }
  .emf-cyber-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 0;
    background: linear-gradient(180deg, var(--emf-neon), var(--emf-neon2));
    transition: height 0.4s ease;
  }
  .emf-cyber-card:hover::before { height: 100%; }
  .emf-cyber-card:hover {
    border-color: var(--emf-neon);
    box-shadow: 0 0 20px rgba(0,255,180,0.1), inset 0 0 20px rgba(0,255,180,0.03);
    transform: translateY(-2px);
  }
  .emf-cyber-card__tag {
    font-family: var(--ff-mono);
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--emf-neon);
    opacity: 0.6;
    margin: 0 0 10px;
  }
  .emf-cyber-card__name {
    font-family: var(--ff-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--emf-heading);
    margin: 0 0 10px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .emf-cyber-card__definition {
    font-size: 0.88rem;
    color: var(--emf-subtext);
    line-height: 1.7;
    margin: 0 0 14px;
  }
  .emf-cyber-card__toggle {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    background: none;
    border: none;
    border-top: 1px solid var(--emf-border);
    padding: 10px 0 0;
    cursor: pointer;
    font-family: var(--ff-mono);
    font-size: 0.75rem;
    color: var(--emf-neon);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: left;
  }
  .emf-cyber-card__toggle svg {
    width: 14px; height: 14px;
    stroke: var(--emf-neon);
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }
  .emf-cyber-card__toggle[aria-expanded="true"] svg { transform: rotate(180deg); }
  .emf-cyber-card__body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }
  .emf-cyber-card__body.is-open { max-height: 400px; }
  .emf-cyber-card__body-inner {
    padding-top: 14px;
    font-size: 0.85rem;
    color: var(--emf-subtext);
    line-height: 1.75;
  }
  .emf-cyber-card__label {
    font-family: var(--ff-mono);
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--emf-neon);
    opacity: 0.6;
    margin: 12px 0 4px;
  }

  /* ── PROTECTION METHODS ─────────────────────────────────────── */
  .emf-protect-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }
  .emf-protect-card {
    background: var(--emf-card);
    border: 1px solid var(--emf-border);
    padding: 24px;
    position: relative;
    transition: all 0.3s ease;
  }
  .emf-protect-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--emf-neon), var(--emf-neon2));
    transform: scaleX(0);
    transition: transform 0.4s ease;
    transform-origin: left;
  }
  .emf-protect-card:hover::after { transform: scaleX(1); }
  .emf-protect-card:hover {
    border-color: var(--emf-neon);
    box-shadow: 0 4px 24px rgba(0,255,180,0.08);
  }
  .emf-protect-card__icon {
    font-size: 1.8rem;
    margin-bottom: 12px;
    display: block;
  }
  .emf-protect-card__name {
    font-family: var(--ff-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--emf-heading);
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .emf-protect-card__desc {
    font-size: 0.85rem;
    color: var(--emf-subtext);
    line-height: 1.7;
    margin: 0 0 12px;
  }
  .emf-protect-card__effectiveness {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--emf-border);
  }
  .emf-protect-card__effectiveness-label {
    font-family: var(--ff-mono);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--emf-subtext);
    opacity: 0.6;
    flex-shrink: 0;
  }
  .emf-protect-card__bar {
    flex: 1;
    height: 4px;
    background: var(--emf-border);
    position: relative;
    overflow: hidden;
  }
  .emf-protect-card__bar-fill {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--emf-neon), var(--emf-neon2));
    transform-origin: left;
    animation: barGrow 1.2s ease forwards;
    animation-play-state: paused;
  }
  .emf-protect-card:hover .emf-protect-card__bar-fill {
    animation-play-state: running;
  }
  @keyframes barGrow { from { transform: scaleX(0); } to { transform: scaleX(1); } }

  /* ── OVERLAY IMAGE BLOCK ────────────────────────────────────── */
  .emf-overlay-block {
    position: relative;
    overflow: hidden;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .emf-overlay-block__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.5) saturate(0.8);
  }
  .emf-overlay-block__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 60px 20px;
    max-width: 600px;
  }
  .emf-overlay-block__eyebrow {
    font-family: var(--ff-mono);
    font-size: 10px;
    letter-spacing: 0.4em;
    color: var(--emf-neon);
    text-transform: uppercase;
    margin: 0 0 16px;
  }
  .emf-overlay-block__heading {
    font-family: var(--ff-display);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 16px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    text-shadow: 0 0 30px rgba(0,255,180,0.4);
  }
  .emf-overlay-block__text {
    font-size: 1rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.75;
    margin: 0 0 28px;
  }
  .emf-overlay-block__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    background: var(--emf-neon);
    color: #0a0f0d;
    font-family: var(--ff-mono);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
  }
  .emf-overlay-block__cta:hover {
    background: var(--emf-neon2);
    box-shadow: 0 0 20px rgba(0,255,180,0.4);
  }

  /* ── FAQ BLOCK ──────────────────────────────────────────────── */
  .emf-faq-list {
    max-width: 760px;
    margin: 0 auto;
  }
  .emf-faq-item {
    border-bottom: 1px solid var(--emf-border);
  }
  .emf-faq-item:first-child { border-top: 1px solid var(--emf-border); }
  .emf-faq-btn {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    background: none;
    border: none;
    padding: 20px 0;
    cursor: pointer;
    text-align: left;
    gap: 16px;
    transition: color 0.2s ease;
  }
  .emf-faq-btn:hover { color: var(--emf-neon); }
  .emf-faq-btn__q {
    font-family: var(--ff-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--emf-heading);
    letter-spacing: 0.02em;
    transition: color 0.2s ease;
  }
  .emf-faq-btn:hover .emf-faq-btn__q { color: var(--emf-neon); }
  .emf-faq-btn svg {
    width: 18px; height: 18px;
    stroke: var(--emf-neon);
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }
  .emf-faq-btn[aria-expanded="true"] svg { transform: rotate(180deg); }
  .emf-faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }
  /* ── SHOP EMF GRID ─────────────────────────────────────── */
  .emf-shop-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 40px;
  }
  @media (max-width: 768px) { .emf-shop-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; } }
  @media (max-width: 480px) { .emf-shop-grid { grid-template-columns: 1fr; } }
  .emf-shop-card {
    display: block;
    text-decoration: none;
    border: 1px solid var(--emf-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--emf-card);
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    position: relative;
  }
  .emf-shop-card:hover {
    transform: translateY(-4px);
    border-color: var(--emf-neon);
    box-shadow: 0 0 20px rgba(0,255,180,0.15);
  }
  .emf-shop-card__img-wrap {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--emf-bg2);
  }
  .emf-shop-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .emf-shop-card:hover .emf-shop-card__img { transform: scale(1.04); }
  .emf-shop-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 60%);
    pointer-events: none;
  }
  .emf-shop-card__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: var(--emf-neon);
  }
  .emf-shop-card__info {
    padding: 16px;
  }
  .emf-shop-card__title {
    font-family: var(--ff-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--emf-heading);
    margin: 0 0 6px;
    line-height: 1.3;
  }
  .emf-shop-card__price {
    font-family: var(--ff-mono);
    font-size: 0.9rem;
    color: var(--emf-neon);
    margin: 0 0 10px;
  }
  .emf-shop-card__cta {
    font-size: 0.8rem;
    color: var(--emf-subtext);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .emf-shop-card:hover .emf-shop-card__cta { color: var(--emf-neon); }

  .emf-faq-answer.is-open { max-height: 600px; }
  .emf-faq-answer__inner {
    padding: 0 0 20px;
    font-size: 1.0rem;
    color: var(--emf-subtext);
    line-height: 1.8;
  }

  /* ── RESPONSIVE ─────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .emf-infographic-grid { grid-template-columns: 1fr; }
    .emf-concepts-grid    { grid-template-columns: 1fr; }
    .emf-protect-grid     { grid-template-columns: 1fr; }
    .emf-stat-row         { gap: 12px; }
  }
{% endstyle %}

