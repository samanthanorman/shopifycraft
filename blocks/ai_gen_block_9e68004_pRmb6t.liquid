{% doc %}
  @prompt
    Create a custom Liquid section for a Craft theme that displays an interactive skincare ingredient taxonomy tree built with D3.js. The section should include:
    
    BRAND STYLING:
    - Primary blue #3498ff as main highlight color
    - White #ffffff backgrounds where needed
    - Dark shade #141615 and grey #53585a for secondary elements
    - Raleway font for headings and content
    - Haramoona logo at the top of the section
    
    TREE STRUCTURE (4 levels):
    - Root: "Skincare Ingredients"
    - Level 1: Ingredient types (Hydrators/Humectants, Emollients/Occlusives, Actives/Treatments, Solvents/Carriers, Emulsifiers/Surfactants, Preservatives/Stabilizers, Botanical Extracts, Peptides, Vitamins)
    - Level 2: Sub-categories (like Hyaluronic Acid Derivatives, Root Extracts)
    - Level 3: Individual ingredient names
    
    FUNCTIONALITY:
    - Interactive D3.js tree visualization
    - Tooltips on hover showing description, function, origin, and derivatives
    - Three control buttons: Expand All, Collapse All, Reset
    - Node color coding: Root (blue), Level-1 (dark grey), Level-2 (black with white text), Level-3 (white with dark text)
    - Color legend
    - Clickable ingredient nodes linking to /pages/ingredients/[ingredient-name-lowercase-with-hyphens]
    - Responsive design with pan and zoom support
    - Mobile and desktop compatibility
    
    TECHNICAL REQUIREMENTS:
    - Include D3.js library via CDN
    - Schema settings for editing section heading and colors
    - Complete Liquid HTML, CSS, and JavaScript code
    - Sample JSON data structure for the ingredient taxonomy
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ingredient-taxonomy-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
    font-family: 'Raleway', sans-serif;
    position: relative;
    overflow: hidden;
  }

  .ai-ingredient-taxonomy__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-ingredient-taxonomy__logo-{{ ai_gen_id }} {
    margin-bottom: 20px;
  }

  .ai-ingredient-taxonomy__logo-{{ ai_gen_id }} img {
    max-height: 60px;
    width: auto;
  }

  .ai-ingredient-taxonomy__title-{{ ai_gen_id }} {
    font-family: 'Raleway', sans-serif;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 10px;
    font-weight: 600;
  }

  .ai-ingredient-taxonomy__subtitle-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-ingredient-taxonomy__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 15px;
    margin-bottom: 30px;
    flex-wrap: wrap;
  }

  .ai-ingredient-taxonomy__control-btn-{{ ai_gen_id }} {
    padding: 10px 20px;
    background-color: {{ block.settings.primary_color }};
    color: #ffffff;
    border: none;
    border-radius: 6px;
    font-family: 'Raleway', sans-serif;
    font-size: 14px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-ingredient-taxonomy__control-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.dark_color }};
  }

  .ai-ingredient-taxonomy__legend-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .ai-ingredient-taxonomy__legend-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: {{ block.settings.text_color }};
  }

  .ai-ingredient-taxonomy__legend-color-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    border-radius: 50%;
  }

  .ai-ingredient-taxonomy__tree-container-{{ ai_gen_id }} {
    width: 100%;
    height: 600px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    background-color: #ffffff;
    position: relative;
    overflow: hidden;
  }

  .ai-ingredient-taxonomy__tooltip-{{ ai_gen_id }} {
    position: absolute;
    background-color: rgba(0, 0, 0, 0.9);
    color: #ffffff;
    padding: 12px;
    border-radius: 6px;
    font-size: 12px;
    max-width: 250px;
    z-index: 1000;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-ingredient-taxonomy__tooltip-title-{{ ai_gen_id }} {
    font-weight: 600;
    margin-bottom: 5px;
  }

  .ai-ingredient-taxonomy__tooltip-content-{{ ai_gen_id }} {
    line-height: 1.4;
  }

  .ai-ingredient-taxonomy__tree-{{ ai_gen_id }} .node circle {
    cursor: pointer;
    stroke-width: 2;
  }

  .ai-ingredient-taxonomy__tree-{{ ai_gen_id }} .node text {
    font-family: 'Raleway', sans-serif;
    font-size: 12px;
    cursor: pointer;
  }

  .ai-ingredient-taxonomy__tree-{{ ai_gen_id }} .link {
    fill: none;
    stroke: {{ block.settings.grey_color }};
    stroke-width: 1.5;
  }

  .ai-ingredient-taxonomy__tree-{{ ai_gen_id }} .node.clickable text {
    text-decoration: underline;
  }

  @media screen and (max-width: 768px) {
    .ai-ingredient-taxonomy-{{ ai_gen_id }} {
      padding: 20px 10px;
    }

    .ai-ingredient-taxonomy__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-ingredient-taxonomy__tree-container-{{ ai_gen_id }} {
      height: 500px;
    }

    .ai-ingredient-taxonomy__controls-{{ ai_gen_id }} {
      gap: 10px;
    }

    .ai-ingredient-taxonomy__control-btn-{{ ai_gen_id }} {
      padding: 8px 16px;
      font-size: 12px;
    }

    .ai-ingredient-taxonomy__legend-{{ ai_gen_id }} {
      gap: 15px;
    }
  }
{% endstyle %}

<script src="https://d3js.org/d3.v7.min.js"></script>

<div class="ai-ingredient-taxonomy-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ingredient-taxonomy__header-{{ ai_gen_id }}">
    {% if block.settings.logo %}
      <div class="ai-ingredient-taxonomy__logo-{{ ai_gen_id }}">
        <img src="{{ block.settings.logo | image_url: width: 200 }}" alt="Haramoona Logo" loading="lazy">
      </div>
    {% endif %}
    
    <h2 class="ai-ingredient-taxonomy__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    <p class="ai-ingredient-taxonomy__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
  </div>

  <div class="ai-ingredient-taxonomy__controls-{{ ai_gen_id }}">
    <button class="ai-ingredient-taxonomy__control-btn-{{ ai_gen_id }}" id="expand-all-{{ ai_gen_id }}">Expand All</button>
    <button class="ai-ingredient-taxonomy__control-btn-{{ ai_gen_id }}" id="collapse-all-{{ ai_gen_id }}">Collapse All</button>
    <button class="ai-ingredient-taxonomy__control-btn-{{ ai_gen_id }}" id="reset-{{ ai_gen_id }}">Reset</button>
  </div>

  <div class="ai-ingredient-taxonomy__legend-{{ ai_gen_id }}">
    <div class="ai-ingredient-taxonomy__legend-item-{{ ai_gen_id }}">
      <div class="ai-ingredient-taxonomy__legend-color-{{ ai_gen_id }}" style="background-color: {{ block.settings.primary_color }};"></div>
      <span>Root</span>
    </div>
    <div class="ai-ingredient-taxonomy__legend-item-{{ ai_gen_id }}">
      <div class="ai-ingredient-taxonomy__legend-color-{{ ai_gen_id }}" style="background-color: {{ block.settings.dark_color }};"></div>
      <span>Categories</span>
    </div>
    <div class="ai-ingredient-taxonomy__legend-item-{{ ai_gen_id }}">
      <div class="ai-ingredient-taxonomy__legend-color-{{ ai_gen_id }}" style="background-color: #000000;"></div>
      <span>Sub-categories</span>
    </div>
    <div class="ai-ingredient-taxonomy__legend-item-{{ ai_gen_id }}">
      <div class="ai-ingredient-taxonomy__legend-color-{{ ai_gen_id }}" style="background-color: #ffffff; border: 1px solid #ccc;"></div>
      <span>Ingredients</span>
    </div>
  </div>

  <div class="ai-ingredient-taxonomy__tree-container-{{ ai_gen_id }}" id="tree-container-{{ ai_gen_id }}">
    <svg class="ai-ingredient-taxonomy__tree-{{ ai_gen_id }}" id="tree-svg-{{ ai_gen_id }}"></svg>
  </div>

  <div class="ai-ingredient-taxonomy__tooltip-{{ ai_gen_id }}" id="tooltip-{{ ai_gen_id }}">
    <div class="ai-ingredient-taxonomy__tooltip-title-{{ ai_gen_id }}"></div>
    <div class="ai-ingredient-taxonomy__tooltip-content-{{ ai_gen_id }}"></div>
  </div>
</div>

