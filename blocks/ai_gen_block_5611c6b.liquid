<script>
  (function() {
    class GlassSkinRoutine{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
        this.setupTouchGestures();
      }

      setupAccessibility() {
        const circles = this.querySelectorAll('.ai-glass-routine-circle-{{ ai_gen_id }}');
        
        circles.forEach((circle) => {
          circle.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              const step = circle.getAttribute('data-step');
              this.announceStep(step, circle.getAttribute('aria-label'));
            }
          });

          circle.addEventListener('click', () => {
            const step = circle.getAttribute('data-step');
            this.announceStep(step, circle.getAttribute('aria-label'));
          });
        });
      }

      announceStep(step, label) {
        const announcement = document.createElement('div');
        announcement.setAttribute('role', 'status');
        announcement.setAttribute('aria-live', 'polite');
        announcement.style.position = 'absolute';
        announcement.style.left = '-10000px';
        announcement.textContent = label;
        
        this.appendChild(announcement);
        setTimeout(() => announcement.remove(), 1000);
      }

      setupTouchGestures() {
        const stepsContainer = this.querySelector('.ai-glass-routine-steps-{{ ai_gen_id }}');
        let startX = 0;
        let scrollLeft = 0;
        let isDown = false;

        stepsContainer.addEventListener('touchstart', (e) => {
          isDown = true;
          startX = e.touches[0].pageX - stepsContainer.offsetLeft;
          scrollLeft = stepsContainer.scrollLeft;
        });

        stepsContainer.addEventListener('touchmove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.touches[0].pageX - stepsContainer.offsetLeft;
          const walk = (x - startX) * 2;
          stepsContainer.scrollLeft = scrollLeft - walk;
        });

        stepsContainer.addEventListener('touchend', () => {
          isDown = false;
        });
      }
    }

    customElements.define('glass-skin-routine-{{ ai_gen_id }}', GlassSkinRoutine{{ ai_gen_id }});
  })();
</script>

