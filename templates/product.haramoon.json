        "step3_emoji": "⚗️",
        "step3_name": "{{ metaobjects.haramoon_101[\"silky-hydration-ampoule-1\"].product_name_type.value }}",
        "step3_timing": "AM + PM",
        "step3_tip": "Press 2–3 drops between palms, then press onto face. Do not rub.",
