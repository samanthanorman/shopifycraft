{% doc %}
  @prompt
    Redesign a trust badges section for a premium K-beauty skincare brand targeting a Gen Z audience. Keep all existing trust badge content but completely modernize the layout and visual design. Display 5-6 trust badges (e.g. Vegan, Cruelty-Free, pH Balanced, Dermatologist Tested, Sensitive Skin Safe, Non-Irritating) in a clean horizontal row on desktop and 2-column grid on mobile. Each badge has: a bold clean SVG icon at the top in bright medical blue (#0066FF or similar), a short bold label in Poppins font in dark charcoal, and a one-line descriptor beneath in Raleway font in a softer grey (e.g. "0.00 Irritation Index", "Seoul Formulated", "All Skin Types"). All badge labels, descriptors, and icons must be editable in theme settings as repeatable blocks. Use a crisp white or very soft cool-white background — clean and clinical like a premium Korean dermatology brand. Add a thin bright medical blue top border or accent line across the full width of the section to frame it. Each badge should have a very subtle hover effect — a soft blue tint background circle behind the icon that expands on hover. Include an optional editable section title in Raleway light weight centered above the badges. Add smooth staggered fade-up animations on scroll for each badge. The overall feel should be editorial and clinical-premium — like Mamonde or IOPE's website — confident, modern, Gen Z K-beauty energy with HARAMOON's bright blue brand color as the sole accent. No gradients, no clutter, no rounded pill shapes — sharp, minimal, trustworthy.
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-badges-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    border-top: {{ block.settings.accent_border_thickness }}px solid {{ block.settings.accent_color }};
  }

  .ai-trust-badges-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-trust-badges-title-{{ ai_gen_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    text-align: center;
    margin: 0 0 {{ block.settings.title_spacing }}px;
    letter-spacing: 0.5px;
  }

  .ai-trust-badges-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: {{ block.settings.badge_spacing }}px;
    align-items: start;
  }

  .ai-trust-badge-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-trust-badge-item-{{ ai_gen_id }}.animate {
    animation: ai-trust-badge-fade-up-{{ ai_gen_id }} 0.6s ease-out forwards;
  }

  .ai-trust-badge-icon-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-trust-badge-icon-bg-{{ ai_gen_id }} {
    position: absolute;
    width: 0;
    height: 0;
    border-radius: 50%;
    background-color: {{ block.settings.accent_color }};
    opacity: 0.1;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
  }

  .ai-trust-badge-item-{{ ai_gen_id }}:hover .ai-trust-badge-icon-bg-{{ ai_gen_id }} {
    width: calc({{ block.settings.icon_size }}px + 20px);
    height: calc({{ block.settings.icon_size }}px + 20px);
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    color: {{ block.settings.accent_color }};
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
  }

  .ai-trust-badge-label-{{ ai_gen_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    margin: 0 0 {{ block.settings.label_spacing }}px;
    line-height: 1.3;
  }

  .ai-trust-badge-description-{{ ai_gen_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.4;
  }

  @keyframes ai-trust-badge-fade-up-{{ ai_gen_id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-trust-badges-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.badge_spacing_mobile }}px;
    }

    .ai-trust-badge-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-trust-badge-item-{{ ai_gen_id }}:hover .ai-trust-badge-icon-bg-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size_mobile }}px + 16px);
      height: calc({{ block.settings.icon_size_mobile }}px + 16px);
    }

    .ai-trust-badges-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-trust-badge-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | times: 0.9 }}px;
    }

    .ai-trust-badge-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<trust-badges-{{ ai_gen_id }} class="ai-trust-badges-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-badges-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <h2 class="ai-trust-badges-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}

    <div class="ai-trust-badges-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign badge_enabled_key = 'badge_' | append: i | append: '_enabled'
          assign badge_icon_key = 'badge_' | append: i | append: '_icon'
          assign badge_label_key = 'badge_' | append: i | append: '_label'
          assign badge_description_key = 'badge_' | append: i | append: '_description'

          assign badge_enabled = block.settings[badge_enabled_key]
          assign badge_icon = block.settings[badge_icon_key]
          assign badge_label = block.settings[badge_label_key]
          assign badge_description = block.settings[badge_description_key]
        %}

        {% if badge_enabled %}
          <div 
            class="ai-trust-badge-item-{{ ai_gen_id }}"
            data-badge-index="{{ forloop.index }}"
          >
            <div class="ai-trust-badge-icon-wrapper-{{ ai_gen_id }}">
              <div class="ai-trust-badge-icon-bg-{{ ai_gen_id }}"></div>
              <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
                {{ badge_icon }}
              </div>
            </div>
            {% if badge_label != blank %}
              <h3 class="ai-trust-badge-label-{{ ai_gen_id }}">{{ badge_label }}</h3>
            {% endif %}
            {% if badge_description != blank %}
              <p class="ai-trust-badge-description-{{ ai_gen_id }}">{{ badge_description }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</trust-badges-{{ ai_gen_id }}>

<script>
  (function() {
    class TrustBadges{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.badges = [];
        this.observer = null;
      }

      connectedCallback() {
        this.badges = this.querySelectorAll('.ai-trust-badge-item-{{ ai_gen_id }}');
        this.setupScrollAnimation();
      }

      setupScrollAnimation() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              this.animateBadges();
              this.observer.unobserve(entry.target);
            }
          });
        }, options);

        this.observer.observe(this);
      }

      animateBadges() {
        this.badges.forEach((badge, index) => {
          setTimeout(() => {
            badge.classList.add('animate');
          }, index * 100);
        });
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('trust-badges-{{ ai_gen_id }}', TrustBadges{{ ai_gen_id }});
  })();
</script>

