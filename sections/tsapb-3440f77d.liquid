<script>
	(() => {
		// Constants
		const DEFAULTS = {
			DESKTOP_BREAKPOINT: 992,
			MOBILE_VISIBLE_ITEMS: 3,
			TRANSITION_DURATION: 450,
			DEBOUNCE_DELAY: 100,
			THEME_EDITOR_DELAY: 50,

			// Active slide scaling
			// To change active slide size increase, modify ACTIVE_SLIDE_SCALE:
			// 1.1 = 10%, 1.15 = 15%, 1.2 = 20%, 1.25 = 25%, etc.
			ACTIVE_SLIDE_SCALE: 1.1,
		};

		// Utilities
		const Utils = {
			isDesktop() {
				return window.innerWidth >= (window.vtlsBreakpoints?.desktop?.minWidth || DEFAULTS.DESKTOP_BREAKPOINT);
			},
		};

		// Base mixin for component initialization
		const VtlsComponentMixin = {
			preventDoubleInit() {
				const attrName = `data-vtls-${this.tagName.toLowerCase()}-initialized`;
				if (this.hasAttribute(attrName)) return true;
				this.setAttribute(attrName, 'true');
				return false;
			},

			cleanupInit() {
				const attrName = `data-vtls-${this.tagName.toLowerCase()}-initialized`;
				this.removeAttribute(attrName);
			},
		};

		// Video Item Component
		class VtlsVideoItem extends HTMLElement {
			constructor() {
				super();
				// Apply mixin
				Object.assign(this, VtlsComponentMixin);

				this.playButton = null;
				this.pauseButton = null;
				this.soundOnButton = null;
				this.soundOffButton = null;
				this.video = null;
				this.observer = null;
				this.userPlayed = false;
				this.isMuted = true;
			}

			connectedCallback() {
				if (this.preventDoubleInit()) return;

				this.initControls();
				this.syncWithGlobalMuteState(); // Sync with carousel's global mute state
				this.setEventListeners();
				this.observeParentClass();
				this.updateVideoState();
			}

			disconnectedCallback() {
				this.cleanupInit();
				this.removeListeners();
				if (this.observer) this.observer.disconnect();
			}

			initControls() {
				this.playButton = this.querySelector('.VtlsVideoCarouselControls__PlayButton');
				this.pauseButton = this.querySelector('.VtlsVideoCarouselControls__PauseButton');
				this.soundOnButton = this.querySelector('.VtlsVideoCarouselSoundButtons__SoundButtonOn');
				this.soundOffButton = this.querySelector('.VtlsVideoCarouselSoundButtons__SoundButtonOff');
				this.video = this.querySelector('.VtlsCdnVideo-desktop');

				if (!this.video) return;
				
				if (this.video.tagName === 'VIDEO') {
					// Controls will be set dynamically in updateVideoState
					this.video.controls = false;
				} else if (this.video.tagName === 'IFRAME') {
					const src = new URL(this.video.src);

				}
			}

			setEventListeners() {
				this.playVideoHandler = () => {
					this.userPlayed = true;
					this.playVideo();
				};
				this.pauseVideoHandler = () => {
					this.pauseVideo();
				};
				this.toggleVideoHandler = () => {
					// Only pause video when clicking on it, don't play
					if (!this.isVideoPaused()) {
						this.pauseVideo();
					}
				};
				this.toggleSoundHandler = () => {
					this.toggleSound();
				};

				this.playButton?.addEventListener('click', this.playVideoHandler);
				this.pauseButton?.addEventListener('click', this.pauseVideoHandler);
				this.soundOnButton?.addEventListener('click', this.toggleSoundHandler);
				this.soundOffButton?.addEventListener('click', this.toggleSoundHandler);

				if (this.video && this.video.tagName === 'VIDEO') {
					this.video.addEventListener('click', this.toggleVideoHandler);
				}

				// Initialize sound button state
				this.updateSoundButtons();
			}

			removeListeners() {
				this.playButton?.removeEventListener('click', this.playVideoHandler);
				this.pauseButton?.removeEventListener('click', this.pauseVideoHandler);
				this.soundOnButton?.removeEventListener('click', this.toggleSoundHandler);
				this.soundOffButton?.removeEventListener('click', this.toggleSoundHandler);

				if (this.video && this.video.tagName === 'VIDEO') {
					this.video.removeEventListener('click', this.toggleVideoHandler);
				}
			}

			isVideoPaused() {
				if (!this.video) return true;
				if (this.video.tagName === 'VIDEO') return this.video.paused;
				return true;
			}

			playVideo() {
				if (!this.userPlayed) return;

				this.executeVideoAction('play');
				this.updateButtons();
			}

			pauseVideo() {
				if (!this.video) return;

				// Reset userPlayed when video is manually paused
				this.userPlayed = false;
				this.executeVideoAction('pause');
				this.updateButtons();
			}

			executeVideoAction(action) {
				if (!this.video) return;

				if (this.video.tagName === 'VIDEO') {
					if (action === 'play') {
						const carousel = this.closest('vtls-video-carousel');
						const globalMuteState = carousel?.getGlobalMuteState?.() ?? true;
						
						this.video.muted = globalMuteState;
						this.isMuted = globalMuteState;
						this.updateSoundButtons();
					}

					const promise = this.video[action]();
					
					// For play action, update buttons when promise resolves
					if (action === 'play' && promise) {
						promise.then(() => {
							this.updateButtons();
						}).catch(() => {
							// If play fails, update buttons to show play button
							this.updateButtons();
						});
					}
				} else if (this.video.tagName === 'IFRAME') {
					if (action === 'play') {
						const carousel = this.closest('vtls-video-carousel');
						const globalMuteState = carousel?.getGlobalMuteState?.() ?? true;
						
						this.isMuted = globalMuteState;
						this.updateSoundButtons();
						
						// Send mute/unmute command to iframe
						if (this.sendPostMessage) {
							this.sendPostMessage(this.isMuted ? 'mute' : 'unmute');
						}
					}
					
					if (this.sendPostMessage) {
						this.sendPostMessage(action);
					}
				}
			}

			updateButtons() {
				if (!this.video) return;

				if (this.isVideoPaused()) {
					this.playButton?.classList.add('VtlsVisible');
					this.pauseButton?.classList.remove('VtlsVisible');
				} else {
					this.playButton?.classList.remove('VtlsVisible');
					this.pauseButton?.classList.add('VtlsVisible');
				}
			}

			updateVideoState() {
				const parent = this.closest('.VtlsVideoCarouselBlock');
				const isActive = parent?.classList.contains('VtlsVideoCarouselBlock--active');
				const carousel = this.closest('vtls-video-carousel');

				const controls = carousel?.dataset.controls || carousel?.getAttribute('data-controls');

				if (!this.video) return;

				// Update controls - same for all videos
				this.updateVideoControls(isActive, controls);

				let autoplay = false;
				if (this.video.tagName === 'VIDEO') {
					autoplay = this.video.autoplay;
				} else if (this.video.tagName === 'IFRAME') {
					const src = new URL(this.video.src);
					autoplay = src.searchParams.get('autoplay') === '1';
				}

				const isIframe = this.video.tagName === 'IFRAME';

				if (!isActive) {
					// Not active - pause the video
					this.executeVideoAction('pause');
					this.updateButtons();
					return;
				}

				if (this.userPlayed) {
					// User manually started video - keep it playing
					this.executeVideoAction('play');
					if (isIframe) {
						setTimeout(() => {
							this.updateButtons();
						}, 100);
					}
				} else if (autoplay) {
					// Autoplay is enabled - start playing
					this.userPlayed = true;
					this.executeVideoAction('play');
					if (isIframe) {
						setTimeout(() => {
							this.updateButtons();
						}, 100);
					}
				} else {
					// No autoplay and no user interaction - ensure video is paused
					this.executeVideoAction('pause');
					this.updateButtons();
				}
			}

			observeParentClass() {
				const parent = this.closest('.VtlsVideoCarouselBlock');
				if (!parent) return;

				this.observer = new MutationObserver(() => {
					this.updateVideoState();
				});

				this.observer.observe(parent, { attributes: true, attributeFilter: ['class'] });
			}


			toggleSound() {
				if (!this.video) return;

				this.isMuted = !this.isMuted;

				if (this.video.tagName === 'VIDEO') {
					this.video.muted = this.isMuted;
				} else if (this.video.tagName === 'IFRAME') {
					this.sendPostMessage(this.isMuted ? 'mute' : 'unmute');
				}

				this.updateSoundButtons();
				
				const carousel = this.closest('vtls-video-carousel');
				if (carousel && carousel.syncSoundState) {
					carousel.syncSoundState(this.isMuted);
				}
			}

			updateSoundButtons() {
				if (!this.soundOnButton || !this.soundOffButton) return;

				if (this.isMuted) {
					this.soundOffButton.style.display = 'block';
					this.soundOnButton.style.display = 'none';
				} else {
					this.soundOffButton.style.display = 'none';
					this.soundOnButton.style.display = 'block';
				}
			}

			setSoundState(isMuted) {
				if (!this.video) return;
				
				this.isMuted = isMuted;
				
				if (this.video.tagName === 'VIDEO') {
					this.video.muted = this.isMuted;
				} else if (this.video.tagName === 'IFRAME') {
					this.sendPostMessage(this.isMuted ? 'mute' : 'unmute');
				}
				
				this.updateSoundButtons();
			}

			syncWithGlobalMuteState() {
				const carousel = this.closest('vtls-video-carousel');
				if (carousel && carousel.getGlobalMuteState) {
					const globalMuteState = carousel.getGlobalMuteState();
					this.setSoundState(globalMuteState);
				}
			}

			updateVideoControls(isActive, controlsEnabled) {
				if (!this.video || this.video.tagName !== 'VIDEO') return;

				// Always use play-pause-button style (never show default video controls)
				this.video.controls = false;
			}
		}

		// Video Carousel Component
		class VtlsVideoCarousel extends HTMLElement {
			constructor() {
				super();
				// Apply mixin
				Object.assign(this, VtlsComponentMixin);

				this.state = {
					isInitialized: false,
					isTransitioning: false,
					currentIndex: 0,
					lastRenderedWidth: window.innerWidth,
					lastRenderedHeight: window.innerHeight,
					aspectRatio: null,
					globalMuteState: true, // Global sound state for all videos
				};

				this.config = {
					slideBySet: 1,
					visibleItemsDesktop: parseInt(this.dataset.videosPerRow),
					visibleItemsMobile: DEFAULTS.MOBILE_VISIBLE_ITEMS,
					transitionDuration: DEFAULTS.TRANSITION_DURATION,
					debounceDelay: DEFAULTS.DEBOUNCE_DELAY,
				};

				this.elements = {};
				this.touchState = { xDown: null, yDown: null, startTime: null };
				this.resizeObserver = null;
				this.debouncedResize = null;
				this.pendingTargetIndex = undefined;
			}

			connectedCallback() {
				if (this.preventDoubleInit()) return;

				requestAnimationFrame(() => {
					this.initElements();
					this.setupEventListeners();
					this.initializeCarousel();
					this.setupResizeObserver();
					
					// Additional check to ensure active slide is properly initialized
					requestAnimationFrame(() => {
						this.ensureActiveSlideScaling();
					});
				});
			}

			disconnectedCallback() {
				this.cleanupInit();
				this.cleanup();
			}

			initElements() {
				this.elements = {
					list: this.querySelector('.VtlsCarouselList'),
					content: this.querySelector('.VtlsCarousel__Content'),
					leftButton: this.querySelector('.VtlsLeftChevron'),
					rightButton: this.querySelector('.VtlsRightChevron'),
					navigation: this.querySelector('.VtlsCarousel__Navigation'),
					items: this.querySelectorAll('.VtlsVideoCarouselBlock'),
				};

				// Check if the page is in RTL mode
				this.isRTL = document.dir === 'rtl' || 
					document.documentElement.dir === 'rtl' || 
					document.body.dir === 'rtl' ||
					window.getComputedStyle(document.documentElement).direction === 'rtl' ||
					window.getComputedStyle(document.body).direction === 'rtl';
			}

			setupEventListeners() {
				// Navigation buttons
				this.elements.leftButton?.addEventListener('click', () => this.navigate('left'));
				this.elements.rightButton?.addEventListener('click', () => this.navigate('right'));

				// NEW FEATURE: Click-to-center functionality
				// When user clicks a non-active video, it becomes active and moves to center
				this.setupVideoClickHandlers();

				// Shopify Theme Editor: Handle block selection
				this.setupThemeEditorHandlers();

				// Touch events - attach to the carousel list for better touch handling
				this.elements.list?.addEventListener('touchstart', this.handleTouchStart.bind(this), {
					passive: true,
				});
				this.elements.list?.addEventListener('touchmove', this.handleTouchMove.bind(this), {
					passive: false,
				});
				this.elements.list?.addEventListener('touchend', this.handleTouchEnd.bind(this), {
					passive: true,
				});

				// Debounced resize
				this.debouncedResize = this.debounce(this.handleResize.bind(this), this.config.debounceDelay);
				window.addEventListener('resize', this.debouncedResize);
			}

			setupResizeObserver() {
				if (window.ResizeObserver) {
					this.resizeObserver = new ResizeObserver(this.debouncedResize);
					this.resizeObserver.observe(this);
				}
			}

			// NEW FEATURE: Setup click handlers for click-to-center functionality
			// Allows users to click any video to make it active and move to center
			setupVideoClickHandlers() {
				this.elements.items.forEach((item) => {
					// Remove any existing click handlers to prevent duplicates
					item.removeEventListener('click', item._videoClickHandler);
					
					// Create and store the click handler
					item._videoClickHandler = (e) => {
						// Don't trigger if already transitioning
						if (this.state.isTransitioning) return;
						
						// Don't trigger if clicking on the active video
						if (item.classList.contains('VtlsVideoCarouselBlock--active')) return;
						
						// Prevent event bubbling to video controls
						const isControlClick = e.target.closest('.VtlsVideoCarouselControls, .VtlsVideoCarouselSoundButtons');
						if (isControlClick) return;
						
						this.navigateToVideo(item);
					};
					
					item.addEventListener('click', item._videoClickHandler);
				});
			}

			// Shopify Theme Editor: Handle block selection to activate video on first click
			setupThemeEditorHandlers() {
				if (typeof window.Shopify === 'undefined' || !window.Shopify.designMode) return;

				this.themeEditorSelectHandler = (event) => {
					if (this.state.isTransitioning) return;
					
					const target = event.target;
					
					this.elements.items.forEach((item) => {
						if (target === item || item.contains(target)) {
							if (item.classList.contains('VtlsVideoCarouselBlock--active')) return;
							setTimeout(() => {
								this.navigateToVideo(item);
							}, 50);
						}
					});
				};
				
				// Add event listener to document (Shopify events bubble to document)
				document.addEventListener('shopify:block:select', this.themeEditorSelectHandler);
			}

			// NEW FEATURE: Navigate to a specific video by clicking it
			// IMPROVED: Single smooth animation directly to target (no intermediate steps)
			navigateToVideo(targetItem) {
				const visibleChildren = this.getVisibleChildren();
				const targetIndex = visibleChildren.indexOf(targetItem);
				const centerIndex = Math.floor(visibleChildren.length / 2);
				
				// Calculate how many steps and in which direction to navigate
				const stepsToCenter = targetIndex - centerIndex;
				
				if (stepsToCenter === 0) return; // Already centered
				
				// Determine direction: positive = right, negative = left
				const direction = stepsToCenter > 0 ? 'right' : 'left';
				const steps = Math.abs(stepsToCenter);
				
				// Use smooth single animation for better UX
				this.smoothScrollToVideo(direction, steps);
			}

			// This prevents intermediate videos from briefly becoming active during scroll
			smoothScrollToVideo(direction, steps) {
				if (steps <= 0 || this.state.isTransitioning) return;
				
				this.state.isTransitioning = true;
				
				
				// Get necessary measurements
				const { baseWidth, centerWidth, peekOffset } = this.getWidths();
				const gap = this.getColumnGap();
				const isDesktop = Utils.isDesktop();
				
				// Calculate total distance to move (multiply single step by number of steps)
				const singleStepDistance = baseWidth + gap;
				const totalDistance = singleStepDistance * steps;
				
				// Execute smooth single animation based on direction
				if (direction === 'right') {
					this.smoothScrollRight(totalDistance, steps, peekOffset, isDesktop, baseWidth, centerWidth);
				} else {
					this.smoothScrollLeft(totalDistance, steps, peekOffset, isDesktop, baseWidth, centerWidth);
				}
			}

			syncSoundState(isMuted) {
				this.state.globalMuteState = isMuted;
				const videoItems = this.querySelectorAll('vtls-video-item');
				
				videoItems.forEach((videoItem) => {
					if (videoItem.setSoundState) {
						videoItem.setSoundState(isMuted);
					}
				});
			}

			getGlobalMuteState() {
				return this.state.globalMuteState;
			}

			// Smooth scroll right: single animation to move multiple slides at once
			smoothScrollRight(totalDistance, steps, peekOffset, isDesktop, baseWidth, centerWidth) {
				// Pre-animate current active to base size
				this.animateCurrentActiveToBase(baseWidth);
				
				// Pre-set the target video to center size (will be visible at the end)
				const visibleChildren = this.getVisibleChildren();
				const centerIndex = Math.floor(visibleChildren.length / 2);
				const targetIndex = centerIndex + steps;
				const targetVideo = visibleChildren[targetIndex];
				
				if (targetVideo) {
					this.setItemSize(targetVideo, centerWidth, centerWidth);
				}
				
				// Calculate target margin
				const targetMargin = isDesktop ? `-${totalDistance}px` : `-${peekOffset + totalDistance}px`;
				
				// Apply smooth transition using CSS class (better performance than inline styles)
				this.addTransitionClass();
				
				// Start animation
				if (this.isRTL) {
					this.elements.list.style.marginRight = targetMargin;
				} else {
					this.elements.list.style.marginLeft = targetMargin;
				}
				
				// Handle completion
				this.handleTransitionEnd(() => {
					// Move DOM elements to maintain infinite scroll
					for (let i = 0; i < steps; i++) {
						this.elements.list.appendChild(this.elements.list.firstElementChild);
					}
					
					// Reset position without transition
					this.removeTransitionClass();
					this.addNoTransitionClass();
					
					if (this.isRTL) {
						this.elements.list.style.marginRight = isDesktop ? '0px' : `-${peekOffset}px`;
					} else {
						this.elements.list.style.marginLeft = isDesktop ? '0px' : `-${peekOffset}px`;
					}
					
					this.forceReflow();
					this.removeNoTransitionClass();
					
					// Handle pending target index from scrollTo method
					if (this.pendingTargetIndex !== undefined) {
						this.activateSpecificSlide(this.pendingTargetIndex);
						this.pendingTargetIndex = undefined;
					} else {
						// Update active slide normally
						this.updateActiveSlide();
					}
					this.state.isTransitioning = false;
				});
			}

			// Smooth scroll left: single animation to move multiple slides at once
			smoothScrollLeft(totalDistance, steps, peekOffset, isDesktop, baseWidth, centerWidth) {
				// Pre-animate current active to base size
				this.animateCurrentActiveToBase(baseWidth);
				
				// Move DOM elements first (reorder for infinite scroll)
				for (let i = 0; i < steps; i++) {
					const lastElement = this.elements.list.lastElementChild;
					this.elements.list.insertBefore(lastElement, this.elements.list.firstElementChild);
				}
				
				// Set initial position (off-screen to the left) without transition
				const targetMargin = isDesktop ? `-${totalDistance}px` : `-${peekOffset + totalDistance}px`;
				this.addNoTransitionClass();
				
				if (this.isRTL) {
					this.elements.list.style.marginRight = targetMargin;
				} else {
					this.elements.list.style.marginLeft = targetMargin;
				}
				
				// Pre-set the target video to center size
				const visibleChildren = this.getVisibleChildren();
				const centerIndex = Math.floor(visibleChildren.length / 2);
				const targetVideo = visibleChildren[centerIndex];
				
				if (targetVideo) {
					this.setItemSize(targetVideo, centerWidth, centerWidth);
					targetVideo.classList.add('VtlsVideoCarouselBlock--active');
				}
				
				this.forceReflow();
				
				// Apply smooth transition using CSS class
				this.removeNoTransitionClass();
				this.addTransitionClass();
				
				// Animate to final position
				if (this.isRTL) {
					this.elements.list.style.marginRight = isDesktop ? '0px' : `-${peekOffset}px`;
				} else {
					this.elements.list.style.marginLeft = isDesktop ? '0px' : `-${peekOffset}px`;
				}
				
				// Handle completion
				this.handleTransitionEnd(() => {
					this.removeTransitionClass();
					
					// Handle pending target index from scrollTo method
					if (this.pendingTargetIndex !== undefined) {
						this.activateSpecificSlide(this.pendingTargetIndex);
						this.pendingTargetIndex = undefined;
					} else {
						// Update active slide normally
						this.updateActiveSlide();
					}
					this.state.isTransitioning = false;
				});
			}

			initializeCarousel() {
				// Initialize aspect ratio cache
				this.getAspectRatio();
				
				this.resizeElements();
				this.updateNavigationVisibility();
				this.setupMobileLayout();
				this.updateActiveSlide();
				
				// Ensure active slide is properly scaled immediately
				setTimeout(() => {
					this.ensureActiveSlideScaling();
				}, 0);
				
				this.waitForContentLoad();
			}

			waitForContentLoad() {
				const mediaElements = Array.from(this.elements.items)
					.slice(0, Math.min(this.getVisibleItems(), this.elements.items.length))
					.map((item) => item.querySelector('video, img'))
					.filter(Boolean);

				if (mediaElements.length === 0) {
					this.finalizeInitialization();
					return;
				}

				let loadedCount = 0;
				const totalElements = mediaElements.length;

				const checkComplete = () => {
					loadedCount++;
					if (loadedCount >= totalElements) {
						this.finalizeInitialization();
					}
				};

				mediaElements.forEach((element) => {
					if (element.tagName.toLowerCase() === 'video') {
						if (element.readyState >= 1) {
							checkComplete();
						} else {
							element.addEventListener('loadedmetadata', checkComplete, { once: true });
						}
					} else if (element.tagName.toLowerCase() === 'img') {
						if (element.complete) {
							checkComplete();
						} else {
							element.addEventListener('load', checkComplete, { once: true });
						}
					}
				});

				// Fallback timeout
				setTimeout(() => this.finalizeInitialization(), 1000);
			}

			finalizeInitialization() {
				if (this.state.isInitialized) return;

				this.state.isInitialized = true;
				
				// Force a reflow before final setup
				this.forceReflow();
				
				// Setup mobile layout first
				this.setupMobileLayout();
				
				// Then update active slide with proper sizing
				this.updateActiveSlide();
				
				// Scroll to default center slide to ensure consistency between desktop and mobile
				const defaultCenterIndex = this.getDefaultCenterSlideIndex();
				this.scrollTo(defaultCenterIndex);
				
				// Double-check active slide sizing after a frame
				requestAnimationFrame(() => {
					this.ensureActiveSlideScaling();
				});
			}

			getVisibleItems() {
				return Utils.isDesktop() ? this.config.visibleItemsDesktop : this.config.visibleItemsMobile;
			}

			getColumnGap() {
				const styles = window.getComputedStyle(this.elements.list);
				const gap = parseFloat(styles.columnGap || styles.gap || '0');
				return Number.isFinite(gap) ? gap : 0;
			}

			getAspectRatio() {
				if (this.state.aspectRatio) return this.state.aspectRatio;
				
				// Prefer aspect ratio from data attribute on the component
				const attributeValue = (this.getAttribute('data-aspect-ratio') || this.dataset.aspectRatio || '').trim();
				if (attributeValue) {
					const attrParts = attributeValue.split('/');
					if (attrParts.length === 2) {
						const numerator = parseFloat(attrParts[0]);
						const denominator = parseFloat(attrParts[1]);
						if (Number.isFinite(numerator) && Number.isFinite(denominator) && denominator !== 0) {
							this.state.aspectRatio = numerator / denominator;
							return this.state.aspectRatio;
						}
					}
					const numeric = parseFloat(attributeValue);
					if (Number.isFinite(numeric) && numeric > 0) {
						this.state.aspectRatio = numeric;
						return this.state.aspectRatio;
					}
				}
				
				return this.state.aspectRatio;
			}

			calculateHeightFromWidth(width) {
				const aspectRatio = this.getAspectRatio();
				return aspectRatio ? Math.round(width / aspectRatio) : 0;
			}

			getDefaultCenterSlideIndex() {
				const totalSlides = this.elements.items.length;
				if (totalSlides === 0) return 0;
				
				// For desktop: center of visible items (e.g., for 5 items, center is index 2)
				const desktopVisibleItems = this.config.visibleItemsDesktop;
				const desktopCenterIndex = Math.floor(desktopVisibleItems / 2);
				
				// Return the index that would be centered on desktop
				return Math.min(desktopCenterIndex, totalSlides - 1);
			}

			activateSpecificSlide(slideIndex) {
				if (!this.elements.items.length) return;
				
				const totalSlides = this.elements.items.length;
				const targetIndex = Math.max(0, Math.min(slideIndex, totalSlides - 1));
				const targetSlide = this.elements.items[targetIndex];
				
				if (!targetSlide) return;
				
				// Clear all active classes first
				this.elements.items.forEach((item) => {
					item.classList.remove('VtlsVideoCarouselBlock--active');
				});
				
				// Get current visible children and find target position
				const visibleChildren = this.getVisibleChildren();
				const { baseWidth, centerWidth } = this.getWidths();
				
				// Set sizes for all visible items
				visibleChildren.forEach((child, index) => {
					const isTarget = child === targetSlide;
					const targetWidth = isTarget ? centerWidth : baseWidth;
					const targetHeight = isTarget ? this.calculateHeightFromWidth(centerWidth) : this.calculateHeightFromWidth(baseWidth);
					
					// Set size with explicit height
					this.setItemSize(child, targetWidth, targetWidth, targetHeight);
				});
				
				// Set target slide as active
				targetSlide.classList.add('VtlsVideoCarouselBlock--active');
				
				// Ensure the target slide gets the correct enlarged size
				this.setItemSize(targetSlide, centerWidth, centerWidth);
			}

			scrollTo(slideIndex) {
				if (this.state.isTransitioning || !this.elements.items.length) return;
				
				// Calculate the target slide position
				const totalSlides = this.elements.items.length;
				const targetIndex = Math.max(0, Math.min(slideIndex, totalSlides - 1));
				
				// Find the target slide element
				const targetSlide = this.elements.items[targetIndex];
				if (!targetSlide) return;
				
				// Check if target slide is already active (centered)
				if (targetSlide.classList.contains('VtlsVideoCarouselBlock--active')) return;
				
				// Get current visible children and find target position
				const visibleChildren = this.getVisibleChildren();
				const currentCenterIndex = Math.floor(visibleChildren.length / 2);
				const targetPosition = visibleChildren.indexOf(targetSlide);
				
				// If target slide is not in visible children, we need to scroll to bring it into view
				if (targetPosition === -1) {
					// Calculate approximate steps needed to bring target into view
					const stepsNeeded = Math.max(0, targetIndex - currentCenterIndex);
					if (stepsNeeded > 0) {
						// Store target index for after scroll completion
						this.pendingTargetIndex = targetIndex;
						this.smoothScrollToVideo('right', stepsNeeded);
					}
					return;
				}
				
				// If target slide is already centered, just activate it
				if (targetPosition === currentCenterIndex) {
					this.activateSpecificSlide(targetIndex);
					return;
				}
				
				// Calculate how many steps to move
				const stepsToMove = targetPosition - currentCenterIndex;
				
				if (stepsToMove === 0) return;
				
				// Store target index for after scroll completion
				this.pendingTargetIndex = targetIndex;
				
				// Use existing navigation logic to move to target
				const direction = stepsToMove > 0 ? 'right' : 'left';
				const steps = Math.abs(stepsToMove);
				
				// Execute the scroll
				this.smoothScrollToVideo(direction, steps);
			}

			ensureActiveSlideScaling() {
				// Always find the center slide and make it active
				const visibleChildren = this.getVisibleChildren();
				const centerIndex = Math.floor(visibleChildren.length / 2);
				const centerSlide = visibleChildren[centerIndex];
				
				if (!centerSlide) {
					this.updateActiveSlide();
					return;
				}

				// Clear all active classes first
				this.elements.items.forEach((item) => {
					item.classList.remove('VtlsVideoCarouselBlock--active');
				});

				// Set center slide as active
				centerSlide.classList.add('VtlsVideoCarouselBlock--active');

				const { centerWidth, baseWidth } = this.getWidths();
				const wrapper = centerSlide.querySelector('.VtlsVideoCarouselBlock__Wrapper');
				
				if (wrapper) {
					// Force the center slide to have the correct enlarged size
					this.setItemSize(centerSlide, centerWidth, centerWidth);
					
					// Ensure the wrapper has the correct dimensions
					wrapper.style.width = `${centerWidth}px`;
					wrapper.style.height = `${this.calculateHeightFromWidth(centerWidth)}px`;
					
					// Also ensure all other visible slides have base size
					visibleChildren.forEach((item) => {
						if (item !== centerSlide) {
							this.setItemSize(item, baseWidth, baseWidth);
						}
					});
					
					// Force a style recalculation
					wrapper.offsetHeight;
				}
			}

			getWidths() {
				const carouselWidth = this.offsetWidth;
				const gap = this.getColumnGap();

				if (Utils.isDesktop()) {
					const visible = this.getVisibleItems();
					const contentWidth = carouselWidth - gap * Math.max(visible - 1, 0);
					const baseWidth = Math.floor(contentWidth / (visible + (DEFAULTS.ACTIVE_SLIDE_SCALE - 1))); // Adjusted for active slide increase
					const centerWidth = Math.round(baseWidth * DEFAULTS.ACTIVE_SLIDE_SCALE); // Active slide scaling
					return { baseWidth, centerWidth, peekOffset: 0 };
				}

				// Mobile: precise centering with equal left/right peeks (~30% each)
				const scaleFactor = DEFAULTS.ACTIVE_SLIDE_SCALE; // center scale factor
				const visibleSideSlides = 0.3; // visible fraction of the side slides (30%)	
				const available = carouselWidth - 2 * gap; // two internal gaps between 3 visible items
				const baseWidth = Math.floor(available / (scaleFactor + 2 * visibleSideSlides));
				const centerWidth = Math.round(baseWidth * scaleFactor);
				// Shift so the center slide is truly centered; left/right peeks equal to k*baseWidth
				const peekOffset = Math.round(baseWidth * (1 - visibleSideSlides));
				return { baseWidth, centerWidth, peekOffset };
			}

			resizeElements() {
				const { baseWidth, centerWidth } = this.getWidths();
				
				// Clear any existing heights and widths to ensure fresh calculations
				this.elements.items.forEach((item) => {
					const wrapper = item.querySelector('.VtlsVideoCarouselBlock__Wrapper');
					if (wrapper) {
						wrapper.style.width = '';
						wrapper.style.height = '';
					}
					item.style.minWidth = '';
					item.style.maxWidth = '';
				});
				
				// Force reflow to ensure DOM updates
				this.forceReflow();
				
				// First apply base sizes to all items
				this.elements.items.forEach((item) => {
					this.setItemSize(item, baseWidth, baseWidth);
				});
				
				// Then apply center size to active item if exists
				const activeItem = this.querySelector('.VtlsVideoCarouselBlock--active');
				if (activeItem) {
					this.setItemSize(activeItem, centerWidth, centerWidth);
				}
			}

			updateActiveSlide() {
				this.clearActiveState();

				const { baseWidth, centerWidth } = this.getWidths();
				const visibleChildren = this.getVisibleChildren();
				const centerIndex = Math.floor(visibleChildren.length / 2);

				// Ensure all items lose active class first
				this.elements.items.forEach((item) => {
					item.classList.remove('VtlsVideoCarouselBlock--active');
				});

				// Set sizes for all visible items
				visibleChildren.forEach((child, index) => {
					const isCenter = index === centerIndex;
					const targetWidth = isCenter ? centerWidth : baseWidth;
					const targetHeight = isCenter ? this.calculateHeightFromWidth(centerWidth) : this.calculateHeightFromWidth(baseWidth);
					
					// Set size with explicit height for center item
					this.setItemSize(child, targetWidth, targetWidth, targetHeight);
				});

				// Set center item as active
				const centerItem = visibleChildren[centerIndex];
				if (centerItem) {
					centerItem.classList.add('VtlsVideoCarouselBlock--active');
					
					// Ensure the center item gets the correct enlarged size immediately
					this.setItemSize(centerItem, centerWidth, centerWidth);
					
					// Force update center item height to ensure it's properly scaled
					setTimeout(() => {
						this.updateCenterItemHeight(centerItem, visibleChildren);
					}, 0);
				}
			}

			updateCenterItemHeight(centerItem, visibleChildren) {
				const wrapper = centerItem.querySelector('.VtlsVideoCarouselBlock__Wrapper');
				if (!wrapper) return;

				const width = this.getElementWidth(wrapper);
				if (width > 0) {
					const calculatedHeight = this.calculateHeightFromWidth(width);
					wrapper.style.height = `${calculatedHeight}px`;
				}
			}

			getElementWidth(wrapper) {
				// Get the current width of the element (computed or style)
				const currentWidth = wrapper.getBoundingClientRect().width;
				return currentWidth > 0 ? currentWidth : parseFloat(wrapper.style.width) || 0;
			}

			clearActiveState() {
				// Clear active class from all items
				this.elements.items.forEach((item) => {
					item.classList.remove('VtlsVideoCarouselBlock--active');
				});
				
				// Reset heights for all items to base size
				const { baseWidth } = this.getWidths();
				this.elements.items.forEach((item) => {
					// Only reset if it's not going to be the center item
					const visibleChildren = this.getVisibleChildren();
					const centerIndex = Math.floor(visibleChildren.length / 2);
					const centerItem = visibleChildren[centerIndex];
					
					if (item !== centerItem) {
						this.setItemSize(item, baseWidth, baseWidth);
					}
				});
			}

			resetItemHeight(item) {
				const wrapper = item.querySelector('.VtlsVideoCarouselBlock__Wrapper');
				if (!wrapper) return;
				
				const width = this.getElementWidth(wrapper);
				if (width > 0) {
					const calculatedHeight = this.calculateHeightFromWidth(width);
					wrapper.style.height = `${calculatedHeight}px`;
				} else {
					wrapper.style.height = '';
				}
			}

			setupMobileLayout() {
				const totalVideos = this.elements.items.length;
				
				if (!Utils.isDesktop()) {
					// For single video, no peek offset needed - center it
					if (totalVideos === 1) {
						if (this.isRTL) {
							this.elements.list.style.marginRight = '0px';
							this.elements.list.style.marginLeft = '0px';
						} else {
							this.elements.list.style.marginLeft = '0px';
							this.elements.list.style.marginRight = '0px';
						}
						this.elements.list.style.justifyContent = 'center';
						return;
					}
					
					const { peekOffset } = this.getWidths();
					// Use appropriate margin property based on RTL
					if (this.isRTL) {
						this.elements.list.style.marginRight = `-${peekOffset}px`;
						this.elements.list.style.marginLeft = '0px';
					} else {
						this.elements.list.style.marginLeft = `-${peekOffset}px`;
						this.elements.list.style.marginRight = '0px';
					}
				} else {
					// Reset appropriate margin property based on RTL
					if (this.isRTL) {
						this.elements.list.style.marginRight = '0px';
						this.elements.list.style.marginLeft = '0px';
					} else {
						this.elements.list.style.marginLeft = '0px';
						this.elements.list.style.marginRight = '0px';
					}
				}
			}

			startSynchronizedAnimation(direction, delta, peekOffset, isDesktop, baseWidth, centerWidth) {
				// Animate current active item to base size
				this.animateCurrentActiveToBase(baseWidth);

				// Handle direction-specific logic
				if (direction === 'right') {
					this.handleRightSlideAnimation(delta, peekOffset, isDesktop, centerWidth, baseWidth);
				} else {
					this.handleLeftSlideAnimation(delta, peekOffset, isDesktop, centerWidth, baseWidth);
				}
			}

			animateCurrentActiveToBase(baseWidth) {
				const currentActiveItem = this.getCurrentActiveItem();
				if (!currentActiveItem) return;

				this.setItemSize(currentActiveItem, baseWidth, baseWidth);
				this.resetItemHeight(currentActiveItem);
				currentActiveItem.classList.remove('VtlsVideoCarouselBlock--active');
			}

			getCurrentActiveItem() {
				const visibleChildren = this.getVisibleChildren();
				return visibleChildren.find((child) => child.classList.contains('VtlsVideoCarouselBlock--active'));
			}

			getVisibleChildren() {
				const children = Array.from(this.elements.list.children);
				return children.slice(0, Math.min(this.getVisibleItems(), children.length));
			}

			setItemSize(item, minWidth, maxWidth, height = null) {
				const wrapper = item.querySelector('.VtlsVideoCarouselBlock__Wrapper');
				if (!wrapper) return;

				item.style.minWidth = `${minWidth}px`;
				item.style.maxWidth = `${maxWidth}px`;
				wrapper.style.width = `${maxWidth}px`;

				if (height !== null) {
					wrapper.style.height = typeof height === 'string' ? height : `${height}px`;
				} else {
					// Calculate height based on aspect ratio
					const calculatedHeight = this.calculateHeightFromWidth(maxWidth);
					wrapper.style.height = `${calculatedHeight}px`;
				}
			}

			handleRightSlideAnimation(delta, peekOffset, isDesktop, centerWidth, baseWidth) {
				const visibleChildren = this.getVisibleChildren();
				const centerIndex = Math.floor(visibleChildren.length / 2);
				const nextActiveItem = visibleChildren[centerIndex + 1] || visibleChildren[centerIndex]?.nextElementSibling;

				if (nextActiveItem) {
					this.setItemSize(nextActiveItem, centerWidth, centerWidth);
					this.setCenterItemHeight(nextActiveItem, visibleChildren, centerWidth, baseWidth);
					nextActiveItem.classList.add('VtlsVideoCarouselBlock--active');
				}

				this.slideRightSynchronized(delta, peekOffset, isDesktop);
			}

			handleLeftSlideAnimation(delta, peekOffset, isDesktop, centerWidth, baseWidth) {
				this.slideLeftWithSynchronizedAnimation(delta, peekOffset, isDesktop, centerWidth, baseWidth);
			}

			setCenterItemHeight(centerItem, visibleChildren, centerWidth, baseWidth) {
				const wrapper = centerItem.querySelector('.VtlsVideoCarouselBlock__Wrapper');
				if (!wrapper) return;

				// Calculate height based on aspect ratio and center width
				if (centerWidth > 0) {
					const calculatedHeight = this.calculateHeightFromWidth(centerWidth);
					wrapper.style.height = `${calculatedHeight}px`;
				}
			}



			navigate(direction) {
				if (this.state.isTransitioning) return;

				this.state.isTransitioning = true;


				// Don't adjust direction - keep the logical direction as intended
				// The RTL handling is done in the margin properties, not in direction

				// Get all necessary values
				const { baseWidth, centerWidth, peekOffset } = this.getWidths();
				const gap = this.getColumnGap();
				const delta = baseWidth + gap;
				const isDesktop = Utils.isDesktop();

				// Start all animations simultaneously
				this.startSynchronizedAnimation(direction, delta, peekOffset, isDesktop, baseWidth, centerWidth);
			}

			slideRightSynchronized(delta, peekOffset, isDesktop) {
				const targetMargin = this.calculateTargetMargin(delta, peekOffset, isDesktop);

				// Apply transition using CSS class
				this.addTransitionClass();
				
				// Use appropriate margin property based on RTL
				if (this.isRTL) {
					this.elements.list.style.marginRight = targetMargin;
					this.elements.list.style.marginLeft = '0px';
				} else {
					this.elements.list.style.marginLeft = targetMargin;
					this.elements.list.style.marginRight = '0px';
				}

				this.handleTransitionEnd(() => {
					this.resetListAfterRightSlide(isDesktop, peekOffset);
					this.state.isTransitioning = false;
				});
			}

			resetListAfterRightSlide(isDesktop, peekOffset) {
				this.removeTransitionClass();
				this.addNoTransitionClass();
				
				// Use appropriate margin property based on RTL
				if (this.isRTL) {
					this.elements.list.style.marginRight = isDesktop ? '0px' : `-${peekOffset}px`;
					this.elements.list.style.marginLeft = '0px';
				} else {
					this.elements.list.style.marginLeft = isDesktop ? '0px' : `-${peekOffset}px`;
					this.elements.list.style.marginRight = '0px';
				}
				
				this.elements.list.appendChild(this.elements.list.firstElementChild);
				this.forceReflow();
				this.removeNoTransitionClass();
			}

			slideLeftWithSynchronizedAnimation(delta, peekOffset, isDesktop, centerWidth, baseWidth) {
				// 1. Move DOM element and set initial position
				this.moveDOMElementForLeftSlide();
				const targetMargin = this.calculateTargetMargin(delta, peekOffset, isDesktop);
				
				// Use appropriate margin property based on RTL
				if (this.isRTL) {
					this.elements.list.style.marginRight = targetMargin;
					this.elements.list.style.marginLeft = '0px';
				} else {
					this.elements.list.style.marginLeft = targetMargin;
					this.elements.list.style.marginRight = '0px';
				}

				// 2. Set the center element as active
				this.setNewCenterActiveItem(centerWidth, baseWidth);

				// 3. Start synchronized animation
				this.startSlideAnimation(isDesktop, peekOffset, () => {
					this.state.isTransitioning = false;
				});
			}

			moveDOMElementForLeftSlide() {
				this.addNoTransitionClass();
				const lastElement = this.elements.list.lastElementChild;
				this.elements.list.insertBefore(lastElement, this.elements.list.firstElementChild);
			}

			calculateTargetMargin(delta, peekOffset, isDesktop) {
				return isDesktop ? `-${delta}px` : `-${peekOffset + delta}px`;
			}

			setNewCenterActiveItem(centerWidth, baseWidth) {
				const visibleChildren = this.getVisibleChildren();
				const centerIndex = Math.floor(visibleChildren.length / 2);
				const newActiveItem = visibleChildren[centerIndex];

				if (newActiveItem) {
					this.setItemSize(newActiveItem, centerWidth, centerWidth);
					this.setCenterItemHeight(newActiveItem, visibleChildren, centerWidth, baseWidth);
					newActiveItem.classList.add('VtlsVideoCarouselBlock--active');
				}
			}

			startSlideAnimation(isDesktop, peekOffset, onComplete) {
				this.forceReflow();
				
				// Apply transition using CSS class
				this.removeNoTransitionClass();
				this.addTransitionClass();
				
				// Use appropriate margin property based on RTL
				if (this.isRTL) {
					this.elements.list.style.marginRight = isDesktop ? '0px' : `-${peekOffset}px`;
					this.elements.list.style.marginLeft = '0px';
				} else {
					this.elements.list.style.marginLeft = isDesktop ? '0px' : `-${peekOffset}px`;
					this.elements.list.style.marginRight = '0px';
				}

				this.handleTransitionEnd(() => {
					this.removeTransitionClass();
					if (onComplete) onComplete();
				});
			}

			handleTransitionEnd(callback) {
				const handleEnd = (e) => {
					// Check for both margin-left and margin-right based on RTL
					const expectedProperty = this.isRTL ? 'margin-right' : 'margin-left';
					if (e.propertyName !== expectedProperty) return;
					this.elements.list.removeEventListener('transitionend', handleEnd);
					callback();
				};

				this.elements.list.addEventListener('transitionend', handleEnd);
			}

			forceReflow() {
				void this.elements.list.offsetWidth;
			}

			// Helper methods for managing transition CSS classes
			// Better performance and maintainability than inline styles
			addTransitionClass() {
				const className = this.isRTL ? 'VtlsCarouselList--animatingRtr' : 'VtlsCarouselList--animatingLtr';
				this.elements.list.classList.add(className);
			}

			removeTransitionClass() {
				this.elements.list.classList.remove('VtlsCarouselList--animatingLtr', 'VtlsCarouselList--animatingRtr');
			}

			addNoTransitionClass() {
				this.elements.list.classList.add('VtlsCarouselList--noTransition');
			}

			removeNoTransitionClass() {
				this.elements.list.classList.remove('VtlsCarouselList--noTransition');
			}

			updateNavigationVisibility() {
				if (!this.elements.navigation) return;

				// Show navigation arrows when there are multiple videos (more than 1)
				// This allows users to scroll through videos even if they all fit on screen
				const hasMultipleVideos = this.elements.items.length > 1;
				this.elements.navigation.style.display = hasMultipleVideos ? 'flex' : 'none';
				this.elements.navigation.classList.toggle('vtlsMultipleVideos', hasMultipleVideos);
			}

			handleResize() {
				const currentWidth = window.innerWidth;
				const currentHeight = window.innerHeight;
				
				// Check if we need to resize (width or height changed)
				if (currentWidth === this.state.lastRenderedWidth && 
					currentHeight === this.state.lastRenderedHeight) return;

				// Clear cached aspect ratio when screen size changes
				this.state.aspectRatio = null;
				
				this.state.lastRenderedWidth = currentWidth;
				this.state.lastRenderedHeight = currentHeight;
				
				// Force re-initialization to properly handle breakpoint changes
				this.resizeElements();
				this.setupMobileLayout();
				this.updateNavigationVisibility();
				
				// Always ensure the center slide is active after resize
				this.updateActiveSlide();
				
				// Scroll to default center slide to maintain consistency between desktop and mobile
				const defaultCenterIndex = this.getDefaultCenterSlideIndex();
				this.scrollTo(defaultCenterIndex);
				
				// Additional check to ensure active slide is properly scaled
				requestAnimationFrame(() => {
					this.ensureActiveSlideScaling();
				});
				
				// Force a reflow to ensure all calculations are based on new dimensions
				this.forceReflow();
			}

			handleTouchStart(evt) {
				const firstTouch = evt.touches[0];
				this.touchState.xDown = firstTouch.clientX;
				this.touchState.yDown = firstTouch.clientY;
				this.touchState.startTime = Date.now();
			}

			handleTouchMove(evt) {
				if (!this.touchState.xDown || !this.touchState.yDown) return;

				// Prevent default only if we're going to handle the swipe
				const xUp = evt.touches[0].clientX;
				const yUp = evt.touches[0].clientY;
				const xDiff = this.touchState.xDown - xUp;
				const yDiff = this.touchState.yDown - yUp;

				// Check if this is a horizontal swipe
				if (Math.abs(xDiff) > Math.abs(yDiff)) {
					evt.preventDefault();
				}
			}

			handleTouchEnd(evt) {
				if (!this.touchState.xDown || !this.touchState.yDown) return;

				const endTime = Date.now();
				const duration = endTime - this.touchState.startTime;
				const xUp = evt.changedTouches[0].clientX;
				const yUp = evt.changedTouches[0].clientY;
				const xDiff = this.touchState.xDown - xUp;
				const yDiff = this.touchState.yDown - yUp;

				// Check if this is a valid swipe
				const isHorizontalSwipe = Math.abs(xDiff) > Math.abs(yDiff);
				const isLongEnough = Math.abs(xDiff) > 30; // Reduced threshold for better responsiveness
				const isFastEnough = duration < 500; // Must complete within 500ms

				if (isHorizontalSwipe && isLongEnough && isFastEnough) {
					// Keep logical swipe direction - swipe right = navigate right, swipe left = navigate left
					// The RTL handling is done in the margin properties
					const swipeDirection = xDiff > 0 ? 'right' : 'left';
					this.navigate(swipeDirection);
				}

				// Reset touch state
				this.touchState.xDown = null;
				this.touchState.yDown = null;
				this.touchState.startTime = null;
			}

			debounce(func, delay) {
				let timeoutId;
				return function (...args) {
					clearTimeout(timeoutId);
					timeoutId = setTimeout(() => func.apply(this, args), delay);
				};
			}

			cleanup() {
				window.removeEventListener('resize', this.debouncedResize);
				if (this.resizeObserver) {
					this.resizeObserver.disconnect();
				}
				
				// NEW FEATURE: Clean up click handlers when component is removed
				this.elements.items?.forEach((item) => {
					if (item._videoClickHandler) {
						item.removeEventListener('click', item._videoClickHandler);
						delete item._videoClickHandler;
					}
				});
				
				// Clean up Theme Editor handler
				if (this.themeEditorSelectHandler) {
					document.removeEventListener('shopify:block:select', this.themeEditorSelectHandler);
					delete this.themeEditorSelectHandler;
				}
			}

			// Method to reinitialize when settings change (useful for theme editor)
			reinitialize() {
				// Save current active slide
				const currentActiveSlide = this.querySelector('.VtlsVideoCarouselBlock--active');
				
				// Clear cached values
				this.state.aspectRatio = null;
				this.state.isInitialized = false;
				
				// Reinitialize the carousel
				this.initializeCarousel();
				
				// NEW FEATURE: Reattach click handlers after reinitializing
				this.setupVideoClickHandlers();
				this.setupThemeEditorHandlers();
				
				// Ensure active slide scaling is maintained
				if (currentActiveSlide) {
					requestAnimationFrame(() => {
						this.ensureActiveSlideScaling();
					});
				}
			}
		}

		// Component registration utility
		const ComponentRegister = {
			components: [
				{ name: 'vtls-video-item', class: VtlsVideoItem },
				{ name: 'vtls-video-carousel', class: VtlsVideoCarousel },
			],

			register() {
				this.components.forEach(({ name, class: ComponentClass }) => {
					if (!customElements.get(name)) {
						customElements.define(name, ComponentClass);
					}
				});
			},

			initThemeEditor() {
				if (typeof window.Shopify === 'undefined' || !window.Shopify.designMode) return;

				new MutationObserver((mutations) => {
					mutations.forEach((mutation) => {
						mutation.addedNodes.forEach((node) => {
							if (node.nodeType === 1 && this.hasCarousel(node)) {
								this.register();
								// Small delay to ensure DOM is ready
								setTimeout(() => this.reinitCarousels(node), DEFAULTS.THEME_EDITOR_DELAY);
							}
						});
					});
				}).observe(document.body, { childList: true, subtree: true });
			},

			hasCarousel(node) {
				return node.querySelector?.('vtls-video-carousel') || node.tagName === 'VTLS-VIDEO-CAROUSEL';
			},

			reinitCarousels(node) {
				const carousels =
					node.querySelectorAll?.('vtls-video-carousel') ||
					(node.tagName === 'VTLS-VIDEO-CAROUSEL' ? [node] : []);
				carousels.forEach((carousel) => {
					if (carousel.reinitialize) {
						carousel.reinitialize();
					} else {
						carousel.connectedCallback?.();
					}
				});
			},
		};

		// Smart registration based on DOM state
		const initComponents = () => {
			ComponentRegister.register();
			ComponentRegister.initThemeEditor();
		};

		// Register based on DOM readiness
		document.readyState === 'loading'
			? document.addEventListener('DOMContentLoaded', initComponents)
			: initComponents();
	})();
</script>
