{% doc %}
  @prompt
    Create a sticky anchor navigation bar section that sits just below the header and remains fixed while scrolling. The bar should be thin (around 50-60px tall), with a clean white or frosted glass background and a subtle bottom border or shadow. Display 5-6 navigation tabs horizontally centered, each with a small SVG icon above a short label (e.g. Overview, Ingredients, Benefits, How to Use, FAQ). One tab should be a highlighted pill-shaped CTA button (e.g. "Add to Cart" or "Shop Now") in a brand accent color. Each tab should be a clickable anchor link that smoothly scrolls to a matching section ID on the page (e.g. #overview, #ingredients, #benefits, #how-to-use, #faq). As the user scrolls, the active tab should highlight with an underline or accent color to show which section they are in (scroll spy behavior). All tab labels, icons, anchor IDs, and the CTA button text and link should be editable in theme settings. The section should be responsive — on mobile, tabs should scroll horizontally without wrapping. Make it compatible for use on product pages, collection pages, and standard pages by allowing it to be added to any template., add fun animation, glow effect, or other engaging aethstically appealing idea to help this section stand out from the rest of the page without changing the colors or content please.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  @keyframes ai-shimmer-{{ ai_gen_id }} {
    0% {
      background-position: -200% center;
    }
    100% {
      background-position: 200% center;
    }
  }

  @keyframes ai-icon-float-{{ ai_gen_id }} {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-3px);
    }
  }

  @keyframes ai-glow-pulse-{{ ai_gen_id }} {
    0%, 100% {
      filter: drop-shadow(0 0 2px currentColor);
    }
    50% {
      filter: drop-shadow(0 0 6px currentColor);
    }
  }

  .ai-sticky-nav-{{ ai_gen_id }} {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    background: {{ block.settings.background_color }};
    backdrop-filter: blur({{ block.settings.blur_amount }}px);
    -webkit-backdrop-filter: blur({{ block.settings.blur_amount }}px);
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    transition: all 0.3s ease;
    display: block;
    position: relative;
    overflow: hidden;
  }

  .ai-sticky-nav-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(240, 216, 74, 0.08) 25%,
      rgba(240, 216, 74, 0.15) 50%,
      rgba(240, 216, 74, 0.08) 75%,
      transparent 100%
    );
    background-size: 200% 100%;
    animation: ai-shimmer-{{ ai_gen_id }} 8s linear infinite;
    pointer-events: none;
    opacity: 0.6;
  }

  .ai-sticky-nav-container-{{ ai_gen_id }} {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }

  .ai-sticky-nav-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.tab_spacing }}px;
    height: {{ block.settings.nav_height }}px;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .ai-sticky-nav-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-sticky-nav-tab-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 8px 16px;
    text-decoration: none;
    color: {{ block.settings.tab_text_color }};
    font-size: {{ block.settings.tab_font_size }}px;
    font-weight: 500;
    white-space: nowrap;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border-bottom: 2px solid transparent;
    flex-shrink: 0;
    position: relative;
  }

  .ai-sticky-nav-tab-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    width: 0;
    height: 2px;
    background: {{ block.settings.tab_active_color }};
    transform: translateX(-50%);
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 0 8px {{ block.settings.tab_active_color }};
  }

  .ai-sticky-nav-tab-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_hover_color }};
    transform: translateY(-2px);
  }

  .ai-sticky-nav-tab-{{ ai_gen_id }}:hover .ai-sticky-nav-icon-{{ ai_gen_id }} {
    animation: ai-icon-float-{{ ai_gen_id }} 1s ease-in-out infinite;
  }

  .ai-sticky-nav-tab-{{ ai_gen_id }}.active {
    color: {{ block.settings.tab_active_color }};
  }

  .ai-sticky-nav-tab-{{ ai_gen_id }}.active::after {
    width: 100%;
  }

  .ai-sticky-nav-tab-{{ ai_gen_id }}.active .ai-sticky-nav-icon-{{ ai_gen_id }} {
    animation: ai-glow-pulse-{{ ai_gen_id }} 2s ease-in-out infinite;
  }

  .ai-sticky-nav-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: all 0.3s ease;
  }

  .ai-sticky-nav-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 24px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    font-size: {{ block.settings.tab_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    white-space: nowrap;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border: none;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }

  .ai-sticky-nav-cta-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s ease, height 0.6s ease;
  }

  .ai-sticky-nav-cta-{{ ai_gen_id }}:hover::before {
    width: 300px;
    height: 300px;
  }

  .ai-sticky-nav-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_bg_color }};
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 6px 20px rgba(240, 216, 74, 0.4);
  }

  .ai-sticky-nav-cta-{{ ai_gen_id }} span {
    position: relative;
    z-index: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-sticky-nav-wrapper-{{ ai_gen_id }} {
      justify-content: flex-start;
      padding: 0 10px;
    }

    .ai-sticky-nav-tab-{{ ai_gen_id }} {
      padding: 6px 12px;
      font-size: {{ block.settings.tab_font_size | times: 0.9 }}px;
    }

    .ai-sticky-nav-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.85 }}px;
      height: {{ block.settings.icon_size | times: 0.85 }}px;
    }

    .ai-sticky-nav-cta-{{ ai_gen_id }} {
      padding: 8px 20px;
      font-size: {{ block.settings.tab_font_size | times: 0.9 }}px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-sticky-nav-{{ ai_gen_id }}::before {
      animation: none;
    }
    .ai-sticky-nav-tab-{{ ai_gen_id }}:hover .ai-sticky-nav-icon-{{ ai_gen_id }} {
      animation: none;
    }
    .ai-sticky-nav-tab-{{ ai_gen_id }}.active .ai-sticky-nav-icon-{{ ai_gen_id }} {
      animation: none;
    }
  }
{% endstyle %}

