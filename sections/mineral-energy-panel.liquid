{% liquid
  assign sec_id = section.id | replace: '_', '' | downcase

  # Field presence checks
  assign has_energy      = false
  assign has_history     = false
  assign has_modern      = false
  assign has_grid        = false
  assign has_pairing     = false

  if metaobject.energy_properties != blank and metaobject.energy_properties.value != blank
    assign has_energy = true
  endif
  if metaobject.history != blank and metaobject.history.value != blank
    assign has_history = true
  endif
  if metaobject.modern_or_scientific_use != blank and metaobject.modern_or_scientific_use.value != blank
    assign has_modern = true
  endif
  if metaobject.grid_design_or_feng_shui_setup != blank and metaobject.grid_design_or_feng_shui_setup.value != blank
    assign has_grid = true
  endif
  if metaobject.best_to_pair_with != blank and metaobject.best_to_pair_with.value != blank and metaobject.best_to_pair_with.value.size > 0
    assign has_pairing = true
  endif

  # Pre-compute mobile sizes
  assign mobile_title_size    = section.settings.title_size | times: 85 | divided_by: 100
  assign mobile_block_pv      = section.settings.block_padding_vertical | times: 80 | divided_by: 100
  assign mobile_block_ph      = section.settings.block_padding_horizontal | times: 75 | divided_by: 100
  assign mobile_hover_pl      = mobile_block_ph | minus: section.settings.hover_border_thickness
  assign mobile_pairing_pv    = section.settings.pairing_padding_vertical | times: 75 | divided_by: 100
  assign mobile_pairing_pb    = section.settings.pairing_padding_bottom | times: 80 | divided_by: 100
  assign mobile_title_pt      = section.settings.title_padding_top | times: 80 | divided_by: 100
  assign mobile_title_pb      = section.settings.title_padding_bottom | times: 80 | divided_by: 100
  assign hover_pl             = section.settings.block_padding_horizontal | minus: section.settings.hover_border_thickness

  # line_height: stored as integer (10–20), divide by 10 at render
  assign lh = section.settings.text_line_height | divided_by: 10.0
  assign label_ls = section.settings.label_letter_spacing | divided_by: 10.0
%}

{% style %}
  .mep-{{ sec_id }} {
    display: block;
    width: 100%;
    background-color: {{ section.settings.background_color }};
    border-top: {{ section.settings.top_border_thickness }}px solid {{ section.settings.accent_color }};
    padding: 0;
  }

  .mep-container-{{ sec_id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0;
  }

  .mep-title-{{ sec_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: {{ section.settings.title_size }}px;
    color: {{ section.settings.accent_color }};
    text-align: center;
    padding: {{ section.settings.title_padding_top }}px 20px {{ section.settings.title_padding_bottom }}px;
    margin: 0;
  }

  /* ── 2-column grid ── */
  .mep-columns-{{ sec_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-bottom: {{ section.settings.divider_thickness }}px solid {{ section.settings.divider_color }};
  }

  .mep-col-{{ sec_id }} {
    padding: 0;
  }

  .mep-col-{{ sec_id }}:first-child {
    border-right: {{ section.settings.divider_thickness }}px solid {{ section.settings.divider_color }};
  }

  .mep-col-header-{{ sec_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: {{ section.settings.col_header_size }}px;
    color: {{ section.settings.accent_color }};
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: {{ section.settings.block_padding_vertical }}px {{ section.settings.block_padding_horizontal }}px {{ section.settings.block_padding_vertical | divided_by: 2 }}px;
    border-bottom: {{ section.settings.divider_thickness }}px solid {{ section.settings.divider_color }};
    margin: 0;
  }

  /* ── Individual content blocks ── */
  .mep-block-{{ sec_id }} {
    padding: {{ section.settings.block_padding_vertical }}px {{ section.settings.block_padding_horizontal }}px;
    border-bottom: {{ section.settings.divider_thickness }}px solid {{ section.settings.divider_color }};
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease, border-left 0.3s ease, padding-left 0.3s ease;
  }

  .mep-block-{{ sec_id }}:last-child {
    border-bottom: none;
  }

  .mep-block-{{ sec_id }}.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .mep-block-{{ sec_id }}:hover {
    border-left: {{ section.settings.hover_border_thickness }}px solid {{ section.settings.accent_color }};
    padding-left: {{ hover_pl }}px;
  }

  .mep-label-{{ sec_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: {{ section.settings.label_size }}px;
    text-transform: uppercase;
    letter-spacing: {{ label_ls }}em;
    color: {{ section.settings.accent_color }};
    margin: 0 0 {{ section.settings.label_spacing }}px 0;
  }

  .mep-text-{{ sec_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: {{ section.settings.text_size }}px;
    line-height: {{ lh }};
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  /* ── Pairs Well With — centered ── */
  .mep-pairing-{{ sec_id }} {
    padding: {{ section.settings.pairing_padding_vertical }}px {{ section.settings.block_padding_horizontal }}px {{ section.settings.pairing_padding_bottom }}px;
  }

  .mep-pairing-title-{{ sec_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: {{ section.settings.label_size }}px;
    text-transform: uppercase;
    letter-spacing: {{ label_ls }}em;
    color: {{ section.settings.accent_color }};
    text-align: center;
    margin: 0 0 {{ section.settings.pairing_title_spacing }}px 0;
  }

  /* Centered flex — wraps and centers any number of cards */
  .mep-pairing-cards-{{ sec_id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: {{ section.settings.card_gap }}px;
  }

  .mep-pairing-card-{{ sec_id }} {
    flex-shrink: 0;
    min-width: {{ section.settings.card_min_width }}px;
    padding: {{ section.settings.card_padding_vertical }}px {{ section.settings.card_padding_horizontal }}px;
    background-color: {{ section.settings.card_background }};
    border: {{ section.settings.card_border_thickness }}px solid {{ section.settings.accent_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .mep-pairing-card-{{ sec_id }}:hover {
    transform: translateY(-{{ section.settings.card_hover_lift }}px);
    box-shadow: 0 {{ section.settings.card_hover_lift }}px {{ section.settings.card_hover_lift | times: 3 }}px {{ section.settings.card_shadow_color }};
  }

  .mep-pairing-card-label-{{ sec_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: {{ section.settings.card_text_size }}px;
    color: {{ section.settings.accent_color }};
    margin: 0;
    text-align: center;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .mep-columns-{{ sec_id }} {
      grid-template-columns: 1fr;
    }
    .mep-col-{{ sec_id }}:first-child {
      border-right: none;
      border-bottom: {{ section.settings.divider_thickness }}px solid {{ section.settings.divider_color }};
    }
    .mep-title-{{ sec_id }} {
      font-size: {{ mobile_title_size }}px;
      padding: {{ mobile_title_pt }}px 20px {{ mobile_title_pb }}px;
    }
    .mep-block-{{ sec_id }} {
      padding: {{ mobile_block_pv }}px {{ mobile_block_ph }}px;
    }
    .mep-block-{{ sec_id }}:hover {
      padding-left: {{ mobile_hover_pl }}px;
    }
    .mep-pairing-{{ sec_id }} {
      padding: {{ mobile_pairing_pv }}px {{ mobile_block_ph }}px {{ mobile_pairing_pb }}px;
    }
  }
{% endstyle %}

<mineral-energy-panel-{{ sec_id }}
  class="mep-{{ sec_id }}"
  {{ section.shopify_attributes }}
>
  <div class="mep-container-{{ sec_id }}">

    {% if section.settings.section_title != blank %}
      <h2 class="mep-title-{{ sec_id }}">{{ section.settings.section_title }}</h2>
    {% endif %}

    {%- comment -%}
      2-column layout:
      LEFT  (Physical)  → History, Modern & Scientific Use
      RIGHT (Metaphysical) → Energy Properties, Grid Design & Feng Shui
    {%- endcomment -%}

    <div class="mep-columns-{{ sec_id }}">

      {%- comment -%} ── LEFT COLUMN: Physical ── {%- endcomment -%}
      <div class="mep-col-{{ sec_id }}">
        <h3 class="mep-col-header-{{ sec_id }}">{{ section.settings.left_col_label | default: 'Physical' }}</h3>

        {% if has_history %}
          <div class="mep-block-{{ sec_id }}" data-mep-block>
            <div class="mep-label-{{ sec_id }}">History</div>
            <div class="mep-text-{{ sec_id }}">{{ metaobject.history.value }}</div>
          </div>
        {% endif %}

        {% if has_modern %}
          <div class="mep-block-{{ sec_id }}" data-mep-block>
            <div class="mep-label-{{ sec_id }}">Modern &amp; Scientific Use</div>
            <div class="mep-text-{{ sec_id }}">{{ metaobject.modern_or_scientific_use.value }}</div>
          </div>
        {% endif %}

        {% unless has_history or has_modern %}
          <div class="mep-block-{{ sec_id }}" style="opacity:1;transform:none;">
            <div class="mep-text-{{ sec_id }}" style="opacity:0.4;font-style:italic;">No physical data yet.</div>
          </div>
        {% endunless %}
      </div>

      {%- comment -%} ── RIGHT COLUMN: Metaphysical ── {%- endcomment -%}
      <div class="mep-col-{{ sec_id }}">
        <h3 class="mep-col-header-{{ sec_id }}">{{ section.settings.right_col_label | default: 'Metaphysical' }}</h3>

        {% if has_energy %}
          <div class="mep-block-{{ sec_id }}" data-mep-block>
            <div class="mep-label-{{ sec_id }}">Energy Properties</div>
            <div class="mep-text-{{ sec_id }}">{{ metaobject.energy_properties.value }}</div>
          </div>
        {% endif %}

        {% if has_grid %}
          <div class="mep-block-{{ sec_id }}" data-mep-block>
            <div class="mep-label-{{ sec_id }}">Grid Design &amp; Feng Shui</div>
            <div class="mep-text-{{ sec_id }}">{{ metaobject.grid_design_or_feng_shui_setup.value }}</div>
          </div>
        {% endif %}

        {% unless has_energy or has_grid %}
          <div class="mep-block-{{ sec_id }}" style="opacity:1;transform:none;">
            <div class="mep-text-{{ sec_id }}" style="opacity:0.4;font-style:italic;">No metaphysical data yet.</div>
          </div>
        {% endunless %}
      </div>

    </div>{%- comment -%} end .mep-columns {%- endcomment -%}

    {%- comment -%} ── PAIRS WELL WITH — centered ── {%- endcomment -%}
    {% if has_pairing %}
      <div class="mep-pairing-{{ sec_id }}">
        <div class="mep-pairing-title-{{ sec_id }}">{{ section.settings.pairing_label | default: 'Pairs Well With' }}</div>
        <div class="mep-pairing-cards-{{ sec_id }}">
          {% for item in metaobject.best_to_pair_with.value %}
            {% assign item_name = item.display_name.value %}
            {% if item_name == blank %}{% assign item_name = item.display_name %}{% endif %}
            {% if item_name == blank %}{% assign item_name = item.handle %}{% endif %}
            <a
              href="/pages/crystals/{{ item.system.handle }}"
              class="mep-pairing-card-{{ sec_id }}"
            >
              <p class="mep-pairing-card-label-{{ sec_id }}">{{ item_name }}</p>
            </a>
          {% endfor %}
        </div>
      </div>
    {% endif %}

  </div>
</mineral-energy-panel-{{ sec_id }}>

<script>
(function() {
  if (customElements.get('mineral-energy-panel-{{ sec_id }}')) return;
  class MineralEnergyPanel extends HTMLElement {
    connectedCallback() {
      const blocks = this.querySelectorAll('[data-mep-block]');
      if (!blocks.length) return;
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            const idx = Array.from(blocks).indexOf(entry.target);
            setTimeout(() => entry.target.classList.add('visible'), idx * 100);
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      blocks.forEach(b => obs.observe(b));
    }
  }
  customElements.define('mineral-energy-panel-{{ sec_id }}', MineralEnergyPanel);
})();
</script>

