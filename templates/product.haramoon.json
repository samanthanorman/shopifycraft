        "step1_timing": "AM + PM",
        "step1_tip": "Massage for 60 seconds on damp skin. Rinse with lukewarm water.",
        "wait1": "30 sec",
        "step2_emoji": "💧",
        "step2_name": "{{ metaobjects.haramoon_101[\"clean-and-clear-toner\"].product_name_type.value }}",
        "step2_timing": "AM + PM",
        "step2_tip": "Pat gently into skin — don't rub. Apply while skin is still slightly damp.",
