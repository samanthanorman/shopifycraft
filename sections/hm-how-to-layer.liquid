{% doc %}
  HARAMOON — How to Layer Section
  Step-by-step application order with timing tips, glassmorphism design
  Fully editable in theme editor: colors, timing, descriptions, heading
{% enddoc %}

{% style %}
  .hm-layer-section {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    font-family: 'Poppins', sans-serif;
    overflow: hidden;
    position: relative;
  }
  .hm-layer-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 20% 50%, rgba(52,152,255,0.08) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 50%, rgba(168,212,255,0.06) 0%, transparent 60%);
    pointer-events: none;
  }
  .hm-layer-inner {
    max-width: 960px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .hm-layer-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    text-align: center;
    margin: 0 0 10px;
  }
  .hm-layer-title {
    font-size: clamp(22px, 3.5vw, 36px);
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    text-align: center;
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }
  .hm-layer-subtitle {
    font-size: 15px;
    color: {{ section.settings.subtext_color }};
    text-align: center;
    margin: 0 0 48px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Timeline connector */
  .hm-layer-steps {
    display: flex;
    align-items: stretch;
    gap: 0;
    position: relative;
  }
  .hm-layer-connector {
    position: absolute;
    top: 44px;
    left: calc(12.5% + 20px);
    right: calc(12.5% + 20px);
    height: 2px;
    background: linear-gradient(90deg, {{ section.settings.accent_color }}40, {{ section.settings.accent_color }}, {{ section.settings.accent_color }}40);
    z-index: 1;
  }
  @media (max-width: 640px) {
    .hm-layer-steps { flex-direction: column; gap: 16px; }
    .hm-layer-connector { display: none; }
  }

  /* Step card */
  .hm-layer-step {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 12px;
    position: relative;
    z-index: 2;
    cursor: default;
  }
  .hm-layer-step-bubble {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.08);
    border: 2px solid rgba(255,255,255,0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 4px 24px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.15);
    margin-bottom: 16px;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    position: relative;
  }
  .hm-layer-step:hover .hm-layer-step-bubble {
    transform: translateY(-6px) scale(1.06);
    box-shadow: 0 12px 40px rgba(52,152,255,0.3), inset 0 1px 0 rgba(255,255,255,0.2);
    border-color: {{ section.settings.accent_color }};
  }
  .hm-layer-step-bubble::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, transparent 60%);
    pointer-events: none;
  }
  .hm-layer-step-emoji {
    font-size: 28px;
    line-height: 1;
    margin-bottom: 2px;
  }
  .hm-layer-step-num {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: {{ section.settings.accent_color }};
    text-transform: uppercase;
  }
  .hm-layer-step-name {
    font-size: 13px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 4px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .hm-layer-step-timing {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    background: rgba(52,152,255,0.12);
    border: 1px solid rgba(52,152,255,0.25);
    border-radius: 20px;
    padding: 2px 10px;
    margin-bottom: 8px;
  }
  .hm-layer-step-tip {
    font-size: 12px;
    color: {{ section.settings.subtext_color }};
    line-height: 1.5;
    max-width: 160px;
  }

  /* Wait indicator between steps */
  .hm-layer-wait {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    margin-top: 44px;
    flex-shrink: 0;
  }
  .hm-layer-wait-pill {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: {{ section.settings.subtext_color }};
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 3px 8px;
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    .hm-layer-wait { display: none; }
  }

  /* AM/PM toggle */
  .hm-layer-ampm {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 40px;
  }
  .hm-layer-ampm-btn {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 8px 24px;
    border-radius: 30px;
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.06);
    color: {{ section.settings.subtext_color }};
    cursor: pointer;
    transition: all 0.25s ease;
    backdrop-filter: blur(8px);
  }
  .hm-layer-ampm-btn.active,
  .hm-layer-ampm-btn:hover {
    background: {{ section.settings.accent_color }};
    border-color: {{ section.settings.accent_color }};
    color: #fff;
    box-shadow: 0 4px 16px rgba(52,152,255,0.35);
  }

  /* AM/PM tip panels */
  .hm-layer-tip-panel {
    display: none;
    margin-top: 24px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 20px 28px;
    backdrop-filter: blur(12px);
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }
  .hm-layer-tip-panel.active { display: block; }
  .hm-layer-tip-panel p {
    font-size: 13px;
    color: {{ section.settings.subtext_color }};
    line-height: 1.7;
    margin: 0;
  }
  .hm-layer-tip-panel strong {
    color: {{ section.settings.heading_color }};
  }
{% endstyle %}

<section class="hm-layer-section" id="hm-how-to-layer">
  <div class="hm-layer-inner">

    <p class="hm-layer-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="hm-layer-title">{{ section.settings.heading }}</h2>
    <p class="hm-layer-subtitle">{{ section.settings.subheading }}</p>

    <div class="hm-layer-steps" role="list">
      <div class="hm-layer-connector" aria-hidden="true"></div>

      <!-- Step 1: Cleanser -->
      <div class="hm-layer-step" role="listitem">
        <div class="hm-layer-step-bubble" aria-hidden="true">
          <span class="hm-layer-step-emoji">{{ section.settings.step1_emoji }}</span>
          <span class="hm-layer-step-num">Step 1</span>
        </div>
        <p class="hm-layer-step-name">{{ section.settings.step1_name }}</p>
        <span class="hm-layer-step-timing">{{ section.settings.step1_timing }}</span>
        <p class="hm-layer-step-tip">{{ section.settings.step1_tip }}</p>
      </div>

      <div class="hm-layer-wait" aria-hidden="true">
        <span class="hm-layer-wait-pill">{{ section.settings.wait1 }}</span>
      </div>

      <!-- Step 2: Toner -->
      <div class="hm-layer-step" role="listitem">
        <div class="hm-layer-step-bubble">
          <span class="hm-layer-step-emoji">{{ section.settings.step2_emoji }}</span>
          <span class="hm-layer-step-num">Step 2</span>
        </div>
        <p class="hm-layer-step-name">{{ section.settings.step2_name }}</p>
        <span class="hm-layer-step-timing">{{ section.settings.step2_timing }}</span>
        <p class="hm-layer-step-tip">{{ section.settings.step2_tip }}</p>
      </div>

      <div class="hm-layer-wait" aria-hidden="true">
        <span class="hm-layer-wait-pill">{{ section.settings.wait2 }}</span>
      </div>

      <!-- Step 3: Ampoule -->
      <div class="hm-layer-step" role="listitem">
        <div class="hm-layer-step-bubble">
          <span class="hm-layer-step-emoji">{{ section.settings.step3_emoji }}</span>
          <span class="hm-layer-step-num">Step 3</span>
        </div>
        <p class="hm-layer-step-name">{{ section.settings.step3_name }}</p>
        <span class="hm-layer-step-timing">{{ section.settings.step3_timing }}</span>
        <p class="hm-layer-step-tip">{{ section.settings.step3_tip }}</p>
      </div>

      <div class="hm-layer-wait" aria-hidden="true">
        <span class="hm-layer-wait-pill">{{ section.settings.wait3 }}</span>
      </div>

      <!-- Step 4: Cream -->
      <div class="hm-layer-step" role="listitem">
        <div class="hm-layer-step-bubble">
          <span class="hm-layer-step-emoji">{{ section.settings.step4_emoji }}</span>
          <span class="hm-layer-step-num">Step 4</span>
        </div>
        <p class="hm-layer-step-name">{{ section.settings.step4_name }}</p>
        <span class="hm-layer-step-timing">{{ section.settings.step4_timing }}</span>
        <p class="hm-layer-step-tip">{{ section.settings.step4_tip }}</p>
      </div>
    </div>

    <!-- AM / PM Toggle -->
    {% if section.settings.show_ampm %}
    <div class="hm-layer-ampm" role="tablist" aria-label="Routine timing">
      <button class="hm-layer-ampm-btn active" data-panel="am" role="tab" aria-selected="true">☀️ Morning Routine</button>
      <button class="hm-layer-ampm-btn" data-panel="pm" role="tab" aria-selected="false">🌙 Evening Routine</button>
    </div>
    <div class="hm-layer-tip-panel active" id="hm-panel-am" role="tabpanel">
      <p>{{ section.settings.am_tip }}</p>
    </div>
    <div class="hm-layer-tip-panel" id="hm-panel-pm" role="tabpanel">
      <p>{{ section.settings.pm_tip }}</p>
    </div>
    {% endif %}

  </div>
</section>

<script>
(function() {
  var btns = document.querySelectorAll('.hm-layer-ampm-btn');
  btns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      btns.forEach(function(b) {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      var panel = btn.getAttribute('data-panel');
      document.querySelectorAll('.hm-layer-tip-panel').forEach(function(p) {
        p.classList.remove('active');
      });
      var target = document.getElementById('hm-panel-' + panel);
      if (target) target.classList.add('active');
    });
  });
})();
</script>

