          "{{ matched_mineral.one_liner }}"
        </p>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%} ── MINERAL PROFILE (if matched) ── {%- endcomment -%}
  {%- if matched_mineral and section.settings.show_mineral_profile -%}
  <div class="crys-block">
    <div class="crys-section">
      <div class="crys-block-header">
        <p class="crys-block-eyebrow">{{ section.settings.mineral_eyebrow | default: 'Crystal Profile' }}</p>
        <h2 class="crys-block-title">{{ section.settings.mineral_heading | default: 'Know Your Stone' }}</h2>
        <p class="crys-block-subtitle">{{ section.settings.mineral_subtitle | default: 'Every crystal carries its own identity. Here is everything about this one.' }}</p>
      </div>
      <div class="crys-mineral-grid">
        {%- if matched_mineral.origin -%}
