{% doc %}
  @prompt
    Create a custom Liquid block with two columns side by side (Morning and Evening). This is a static content block — no metafields needed.
    
    Layout: Two equal columns on desktop, stacked on mobile. Each column has a small label at the top (Morning / Evening), a subtle divider or icon, and a short paragraph of text below. Compact and elegant — this should not be a large section, think of it as an informational callout card, not a hero.
    
    Content (hardcode this text exactly):
    
    Morning column label: "Morning" Morning text: "Focus on hydration and protection. HARAMOON's lightweight formula layers perfectly under sunscreen and makeup without pilling. Your skin is prepped for the day — barrier strong, moisture locked."
    
    Evening column label: "Evening" Evening text: "This is when your skin repairs itself. The ampoule's peptides and the cream's Centella work while you sleep. No SPF needed at night — let the actives do their job. For best results, apply to slightly damp skin right after cleansing."
    
    Style:
    
    Each column has a small decorative icon or sun/moon emoji before the label (☀️ for Morning, 🌙 for Evening) — make these schema settings (text field) so they can be swapped
    Column labels are small, uppercase, letter-spaced — like a category tag
    Body text is small, muted color, readable
    Columns sit inside a lightly bordered or softly shaded container card — subtle, not heavy
    Overall feel: spa editorial, minimal, premium
    Schema settings: Morning label, morning body text, evening label, evening body text, morning icon emoji, evening icon emoji — all text fields so copy can be edited from the theme sidebar without touching code.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-routine-card-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-routine-card__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
    display: flex;
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-routine-card__column-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-routine-card__divider-{{ ai_gen_id }} {
    width: 1px;
    background-color: {{ block.settings.divider_color }};
    opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
  }

  .ai-routine-card__label-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-routine-card__icon-{{ ai_gen_id }} {
    font-size: {{ block.settings.icon_size }}px;
    line-height: 1;
  }

  .ai-routine-card__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: {{ block.settings.label_color }};
    margin: 0;
  }

  .ai-routine-card__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-routine-card__container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-routine-card__divider-{{ ai_gen_id }} {
      width: 100%;
      height: 1px;
    }
  }
{% endstyle %}

<div class="ai-routine-card-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-routine-card__container-{{ ai_gen_id }}">
    <div class="ai-routine-card__column-{{ ai_gen_id }}">
      <div class="ai-routine-card__label-wrapper-{{ ai_gen_id }}">
        <span class="ai-routine-card__icon-{{ ai_gen_id }}">{{ block.settings.morning_icon }}</span>
        <h3 class="ai-routine-card__label-{{ ai_gen_id }}">{{ block.settings.morning_label }}</h3>
      </div>
      <p class="ai-routine-card__text-{{ ai_gen_id }}">{{ block.settings.morning_text }}</p>
    </div>

    <div class="ai-routine-card__divider-{{ ai_gen_id }}"></div>

    <div class="ai-routine-card__column-{{ ai_gen_id }}">
      <div class="ai-routine-card__label-wrapper-{{ ai_gen_id }}">
        <span class="ai-routine-card__icon-{{ ai_gen_id }}">{{ block.settings.evening_icon }}</span>
        <h3 class="ai-routine-card__label-{{ ai_gen_id }}">{{ block.settings.evening_label }}</h3>
      </div>
      <p class="ai-routine-card__text-{{ ai_gen_id }}">{{ block.settings.evening_text }}</p>
    </div>
  </div>
</div>

