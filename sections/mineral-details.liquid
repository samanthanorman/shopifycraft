{% comment %}
  Mineral metaobject detail section — Premium Holographic Cyber Edition
  Wax | Wane — Gen Z · K-pop · Holographic · Cyber · Hermione Granger
{% endcomment %}
{% assign m = metaobject %}

<div class="mineral-page-wrapper">

  <section class="mineral-hero-bleed">
    {% if m.image %}
      {{ m.image | image_url: width: 2400 | image_tag: alt: m.display_name, class: 'mineral-hero-bleed__img', loading: 'eager' }}
    {% endif %}
    <div class="mineral-hero-bleed__overlay">
      <div class="mineral-hero-bleed__content">
        {% if m.element %}<span class="mineral-element-badge">{{ m.element }}</span>{% endif %}
        <h1 class="mineral-title">{{ m.display_name | default: m.one_liner }}</h1>
        {% if m.one_liner %}<p class="mineral-kicker">{{ m.one_liner }}</p>{% endif %}
        {% if m.chemical_formula %}<span class="mineral-formula">{{ m.chemical_formula }}</span>{% endif %}
      </div>
    </div>
  </section>

  <div class="mineral-wrap">

    {% if m.summary %}
      <div class="mineral-summary-block fade-in-up">
        <p class="mineral-summary">{{ m.summary | newline_to_br }}</p>
      </div>
    {% endif %}

    <section class="mineral-meta-grid fade-in-up">
      <div class="meta-card meta-card--facts">
        <h3 class="meta-card__title">Quick Facts</h3>
        <ul class="meta-list">
          {% if m.chemical_formula %}<li><span class="meta-label">Formula</span><span class="meta-value">{{ m.chemical_formula }}</span></li>{% endif %}
          {% if m.mohs_hardness %}<li><span class="meta-label">Hardness</span><span class="meta-value">Mohs {{ m.mohs_hardness }}</span></li>{% endif %}
          {% if m.color %}<li><span class="meta-label">Color</span><span class="meta-value">{{ m.color }}</span></li>{% endif %}
          {% if m.element %}<li><span class="meta-label">Element</span><span class="meta-value">{{ m.element }}</span></li>{% endif %}
          {% if m.planetary_association %}<li><span class="meta-label">Planet</span><span class="meta-value">{{ m.planetary_association }}</span></li>{% endif %}
          {% if m.numerology_number %}<li><span class="meta-label">Numerology</span><span class="meta-value">{{ m.numerology_number }}</span></li>{% endif %}
        </ul>
      </div>
      <div class="meta-card meta-card--vibe">
        <h3 class="meta-card__title">Vibe Match</h3>
        {% if m.zodiac_sign %}
          {% assign z_list = m.zodiac_sign | replace: ';', ',' | split: ',' %}
          <div class="meta-row">
            <span class="meta-label">Zodiac</span>
            <div class="chips">
              {% for item in z_list %}{% assign label = item | strip %}{% if label != blank %}<span class="chip chip--zodiac">{{ label }}</span>{% endif %}{% endfor %}
            </div>
          </div>
        {% endif %}
        {% if m.body_part_center %}
          {% assign bc_list = m.body_part_center | replace: ';', ',' | split: ',' %}
          <div class="meta-row">
            <span class="meta-label">Body Focus</span>
            <div class="chips">
              {% for item in bc_list %}{% assign label = item | strip %}{% if label != blank %}<span class="chip chip--body">{{ label }}</span>{% endif %}{% endfor %}
            </div>
          </div>
        {% endif %}
        {% if m.best_to_pair_with %}
          {% assign bt_list = m.best_to_pair_with | replace: ';', ',' | split: ',' %}
          <div class="meta-row">
            <span class="meta-label">Pair With</span>
            <div class="chips">
              {% for item in bt_list %}{% assign bt = item | strip %}{% if bt != blank %}<span class="chip chip--pair">{{ bt }}</span>{% endif %}{% endfor %}
            </div>
          </div>
        {% endif %}
      </div>
    </section>

    <section class="mineral-content">
      {% if m.energy_properties %}
        <article class="mineral-article mineral-article--energy fade-in-up">
          <div class="mineral-article__icon">✦</div>
          <h2 class="mineral-article__title">Energy Properties</h2>
          <div class="mineral-article__body">{{ m.energy_properties | newline_to_br }}</div>
        </article>
      {% endif %}
      {% if m.origin_story %}
        <article class="mineral-article fade-in-up">
          <div class="mineral-article__icon">◈</div>
          <h2 class="mineral-article__title">Origin Story</h2>
          <div class="mineral-article__body">{{ m.origin_story | metafield_tag }}</div>
        </article>
      {% endif %}
      {% if m.science %}
        <article class="mineral-article mineral-article--science fade-in-up">
          <div class="mineral-article__icon">⬡</div>
          <h2 class="mineral-article__title">Science & Geology</h2>
          <div class="mineral-article__body">{{ m.science | metafield_tag }}</div>
        </article>
      {% endif %}
      {% if m.modern_uses %}
        <article class="mineral-article fade-in-up">
          <div class="mineral-article__icon">◇</div>
          <h2 class="mineral-article__title">Modern Uses</h2>
          <div class="mineral-article__body">{{ m.modern_uses | metafield_tag }}</div>
        </article>
      {% endif %}
      {% if m.cleanse or m.recharge or m.safety_notes %}
        <article class="mineral-article mineral-article--care fade-in-up">
          <div class="mineral-article__icon">☽</div>
          <h2 class="mineral-article__title">Care & Handling</h2>
          <div class="mineral-article__body">
            {% if m.cleanse %}<div class="care-row"><span class="care-label">Cleanse</span><p>{{ m.cleanse | newline_to_br }}</p></div>{% endif %}
            {% if m.recharge %}<div class="care-row"><span class="care-label">Recharge</span><p>{{ m.recharge | newline_to_br }}</p></div>{% endif %}
            {% if m.safety_notes %}<div class="care-row care-row--warning"><span class="care-label">⚠ Safety</span><p>{{ m.safety_notes | newline_to_br }}</p></div>{% endif %}
          </div>
        </article>
      {% endif %}
      {% if m.best_to_pair_with %}
        <article class="mineral-article fade-in-up">
          <div class="mineral-article__icon">◎</div>
          <h2 class="mineral-article__title">Best To Pair With</h2>
          <div class="mineral-article__body">{{ m.best_to_pair_with | newline_to_br }}</div>
        </article>
      {% endif %}
    </section>

    {% if m.gallery and m.gallery.size > 0 %}
      <section class="mineral-gallery fade-in-up">
        <h2 class="mineral-section-title">Gallery</h2>
        <div class="mineral-gallery__grid">
          {% for img in m.gallery %}
            <figure class="mineral-gallery__item holo-border">
              {{ img | image_url: width: 1200 | image_tag: loading: 'lazy', alt: m.display_name }}
            </figure>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% assign products = blank %}
    {% if m.product %}
      {% if m.product.size %}{% assign products = m.product %}{% else %}{% assign products = m.product | array %}{% endif %}
    {% endif %}
    {% if products and products.size > 0 %}
      <section class="mineral-related fade-in-up">
        <h2 class="mineral-section-title">Shop {{ m.display_name }}</h2>
        <div class="mineral-related__grid">
          {% for p in products %}
            <a class="mineral-product-card holo-border" href="{{ p.url }}">
              <div class="mineral-product-card__image">{{ p | image_url: width: 700 | image_tag: alt: p.title, loading: 'lazy' }}</div>
              <div class="mineral-product-card__meta">
                <h3 class="mineral-product-card__title">{{ p.title }}</h3>
                {% if p.price %}<span class="mineral-product-card__price">{{ p.price | money }}</span>{% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
      </section>
    {% endif %}

  </div>
</div>

<style>
.mineral-page-wrapper{--mineral-accent:#9b59b6;--mineral-glow:rgba(155,89,182,0.4)}
.mineral-hero-bleed{position:relative;width:100vw;left:50%;right:50%;margin-left:-50vw;margin-right:-50vw;overflow:hidden;margin-bottom:0}
.mineral-hero-bleed__img{width:100%;height:52vh;object-fit:cover;display:block;filter:brightness(0.75) saturate(1.1)}
@media(min-width:980px){.mineral-hero-bleed__img{height:62vh}}
.mineral-hero-bleed__overlay{position:absolute;inset:0;display:flex;align-items:flex-end;justify-content:center;padding:0 1rem 6%;background:linear-gradient(to top,rgba(13,27,62,0.85) 0%,rgba(13,27,62,0.3) 50%,transparent 100%)}
.mineral-hero-bleed__content{text-align:center;max-width:700px}
.mineral-element-badge{display:inline-block;padding:4px 14px;border-radius:20px;font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;background:rgba(155,89,182,0.3);border:1px solid rgba(155,89,182,0.5);color:#d1e9fc;margin-bottom:12px;backdrop-filter:blur(8px)}
.mineral-title{color:#fff;font-size:clamp(2rem,4vw,3.2rem);font-weight:800;letter-spacing:-0.02em;line-height:1.1;margin:0 0 8px;text-shadow:0 2px 20px rgba(0,0,0,0.5)}
.mineral-kicker{color:rgba(255,255,255,0.85);font-size:clamp(0.95rem,1.5vw,1.1rem);margin:0 0 10px;line-height:1.5}
.mineral-formula{display:inline-block;font-family:monospace;font-size:0.85rem;color:rgba(209,233,252,0.8);background:rgba(52,152,255,0.15);border:1px solid rgba(52,152,255,0.25);padding:3px 10px;border-radius:6px;letter-spacing:0.05em}
.mineral-wrap{max-width:1200px;margin:0 auto;padding:clamp(24px,3vw,48px) clamp(16px,2vw,24px)}
.mineral-summary-block{max-width:780px;margin:0 auto 40px;text-align:center}
.mineral-summary{font-size:clamp(1rem,1.5vw,1.15rem);line-height:1.85;opacity:0.85}
.mineral-meta-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:40px}
@media(max-width:768px){.mineral-meta-grid{grid-template-columns:1fr}}
.meta-card{background:rgba(27,58,82,0.25);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid rgba(209,233,252,0.15);border-radius:16px;padding:24px;transition:all 0.4s cubic-bezier(0.4,0,0.2,1);position:relative;overflow:hidden}
.meta-card::before{content:'';position:absolute;inset:-2px;background:linear-gradient(45deg,#9b59b6,#3498ff,#d1e9fc,#c9a961,#9b59b6);background-size:300% 300%;border-radius:18px;opacity:0;z-index:-1;animation:holoRotate 5s ease infinite;transition:opacity 0.4s ease}
.meta-card:hover::before{opacity:0.45}
.meta-card:hover{transform:translateY(-4px);border-color:rgba(209,233,252,0.35);box-shadow:0 0 20px rgba(155,89,182,0.25),0 8px 32px rgba(0,0,0,0.15)}
.meta-card__title{font-size:0.7rem!important;letter-spacing:0.15em!important;text-transform:uppercase!important;font-weight:700!important;color:#d1e9fc!important;margin:0 0 16px!important;padding-bottom:10px!important;border-bottom:1px solid rgba(209,233,252,0.15)!important}
.meta-list{list-style:none;margin:0;padding:0}
.meta-list li{display:flex;justify-content:space-between;align-items:baseline;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.05);font-size:0.9rem;gap:12px}
.meta-list li:last-child{border-bottom:none}
.meta-label{font-weight:700;font-size:0.75rem;letter-spacing:0.06em;text-transform:uppercase;color:#ab94a0;flex-shrink:0}
.meta-value{text-align:right;opacity:0.9}
.meta-row{margin-bottom:16px}
.meta-row:last-child{margin-bottom:0}
.meta-row>.meta-label{display:block;margin-bottom:6px}
.chips{display:flex;flex-wrap:wrap;gap:6px}
.chip{display:inline-block;padding:4px 12px;border-radius:20px;font-size:0.75rem;font-weight:600;letter-spacing:0.04em;transition:all 0.2s ease;cursor:default}
.chip--zodiac{background:rgba(155,89,182,0.15);border:1px solid rgba(155,89,182,0.35);color:#d1b3f0}
.chip--zodiac:hover{background:rgba(155,89,182,0.3);box-shadow:0 0 10px rgba(155,89,182,0.4);transform:scale(1.05)}
.chip--body{background:rgba(52,152,255,0.12);border:1px solid rgba(52,152,255,0.3);color:#7ec8ff}
.chip--body:hover{background:rgba(52,152,255,0.25);box-shadow:0 0 10px rgba(52,152,255,0.35);transform:scale(1.05)}
.chip--pair{background:rgba(201,169,97,0.12);border:1px solid rgba(201,169,97,0.3);color:#e8c97a}
.chip--pair:hover{background:rgba(201,169,97,0.25);box-shadow:0 0 10px rgba(201,169,97,0.4);transform:scale(1.05)}
.mineral-content{margin-bottom:48px}
.mineral-article{margin-bottom:28px;padding:28px 32px;border-radius:16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);transition:all 0.4s ease;position:relative}
.mineral-article:hover{background:rgba(255,255,255,0.05);border-color:rgba(209,233,252,0.15)}
.mineral-article--energy{border-left:3px solid rgba(155,89,182,0.5)!important}
.mineral-article--science{border-left:3px solid rgba(52,152,255,0.5)!important}
.mineral-article--care{border-left:3px solid rgba(201,169,97,0.5)!important}
.mineral-article__icon{font-size:1.2rem;color:#c9a961;margin-bottom:8px;opacity:0.7}
.mineral-article__title{font-size:1rem!important;font-weight:700!important;letter-spacing:0.06em!important;text-transform:uppercase!important;margin:0 0 16px!important;color:#d1e9fc!important}
.mineral-article__body{line-height:1.85;font-size:0.95rem;opacity:0.85}
.care-row{margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid rgba(255,255,255,0.06)}
.care-row:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
.care-row .care-label{display:block;font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#ab94a0;margin-bottom:6px}
.care-row--warning{background:rgba(245,166,35,0.08);border-radius:10px;padding:12px 16px;border-left:3px solid rgba(245,166,35,0.5)!important}
.mineral-section-title{font-size:0.75rem!important;font-weight:700!important;letter-spacing:0.15em!important;text-transform:uppercase!important;color:#d1e9fc!important;margin:0 0 20px!important;padding-bottom:12px!important;border-bottom:1px solid rgba(209,233,252,0.15)!important}
.mineral-gallery{margin-bottom:48px}
.mineral-gallery__grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
@media(min-width:768px){.mineral-gallery__grid{grid-template-columns:repeat(3,1fr)}}
.mineral-gallery__item{margin:0;border-radius:14px;overflow:hidden;transition:all 0.4s ease}
.mineral-gallery__item img{width:100%;height:220px;object-fit:cover;display:block;transition:transform 0.5s ease}
.mineral-gallery__item:hover img{transform:scale(1.05)}
.mineral-gallery__item:hover{box-shadow:0 0 20px rgba(155,89,182,0.4),0 8px 32px rgba(0,0,0,0.2)}
.mineral-related{margin-bottom:48px}
.mineral-related__grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
@media(min-width:768px){.mineral-related__grid{grid-template-columns:repeat(4,1fr)}}
.mineral-product-card{display:block;text-decoration:none;color:inherit;border-radius:14px;overflow:hidden;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.03);transition:all 0.4s cubic-bezier(0.4,0,0.2,1);position:relative}
.mineral-product-card:hover{transform:translateY(-6px);box-shadow:0 0 16px rgba(201,169,97,0.35),0 8px 32px rgba(0,0,0,0.2);border-color:rgba(201,169,97,0.3)}
.mineral-product-card__image img{width:100%;aspect-ratio:1;object-fit:cover;display:block;transition:transform 0.5s ease}
.mineral-product-card:hover .mineral-product-card__image img{transform:scale(1.06)}
.mineral-product-card__meta{padding:12px 14px}
.mineral-product-card__title{margin:0 0 6px;font-size:0.9rem;font-weight:600;letter-spacing:-0.01em;line-height:1.3}
.mineral-product-card__price{font-size:0.85rem;font-weight:700;color:#c9a961}
.fade-in-up{animation:fadeInUp 0.6s ease-out backwards}
.mineral-summary-block{animation-delay:0.1s}
.mineral-meta-grid{animation-delay:0.2s}
.mineral-gallery{animation-delay:0.5s}
.mineral-related{animation-delay:0.6s}
@keyframes fadeInUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@keyframes holoRotate{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
</style>

{% schema %}
{
  "name": "Mineral Details",
  "settings": [],
  "presets": [{ "name": "Mineral Details" }]
}
{% endschema %}
