{% doc %}
  @prompt
    	•	Section Background: deep green (#1F5C46)
    	•	Title: “TikTok & Social Highlights” (large serif font, white text)
    	•	Sub-elements:
    	•	Button: “TikTok” with icon (dark green/white contrast)
    	•	Instagram-style mockup frame (right side, placeholder for embedded social post)
    	•	Text CTA: “Find more on TikTok @lnk.nebraska”
    	•	Button: “Follow Us” (coral-red, rounded)
    	•	Layout: 2-column (Left: text/buttons, Right: image/preview)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-social-highlights-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-social-highlights-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-social-highlights-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .ai-social-highlights-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .ai-social-highlights-title-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: {{ settings.type_header_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-social-highlights-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-social-highlights-tiktok-btn-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 28px;
    background-color: {{ block.settings.tiktok_button_bg }};
    color: {{ block.settings.tiktok_button_text }};
    text-decoration: none;
    border-radius: {{ settings.buttons_radius }}px;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: 600;
    font-size: 16px;
    transition: all 0.3s ease;
    align-self: flex-start;
    border: {{ settings.buttons_border_thickness }}px solid {{ block.settings.tiktok_button_bg }};
  }

  .ai-social-highlights-tiktok-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tiktok_button_hover_bg }};
    color: {{ block.settings.tiktok_button_hover_text }};
    border-color: {{ block.settings.tiktok_button_hover_bg }};
    transform: translateY(-2px);
  }

  .ai-social-highlights-tiktok-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-social-highlights-cta-text-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: {{ block.settings.cta_text_size }}px;
    color: {{ block.settings.cta_text_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-social-highlights-follow-btn-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background-color: {{ block.settings.follow_button_bg }};
    color: {{ block.settings.follow_button_text_color }};
    text-decoration: none;
    border-radius: 50px;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: 600;
    font-size: 16px;
    transition: all 0.3s ease;
    align-self: flex-start;
    border: 2px solid {{ block.settings.follow_button_bg }};
  }

  .ai-social-highlights-follow-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.follow_button_hover_bg }};
    color: {{ block.settings.follow_button_hover_text }};
    border-color: {{ block.settings.follow_button_hover_bg }};
    transform: translateY(-2px);
  }

  .ai-social-highlights-mockup-{{ ai_gen_id }} {
    position: relative;
    max-width: 400px;
    margin: 0 auto;
  }

  .ai-social-highlights-frame-{{ ai_gen_id }} {
    background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .ai-social-highlights-inner-frame-{{ ai_gen_id }} {
    background-color: #ffffff;
    border-radius: 12px;
    padding: 16px;
    min-height: 300px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-social-highlights-post-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-social-highlights-avatar-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(45deg, #f09433, #e6683c);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: bold;
    font-size: 14px;
  }

  .ai-social-highlights-username-{{ ai_gen_id }} {
    font-weight: 600;
    color: #262626;
    font-size: 14px;
  }

  .ai-social-highlights-post-image-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    background-color: #f5f5f5;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-social-highlights-post-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-social-highlights-placeholder-{{ ai_gen_id }} {
    color: #999;
    font-size: 14px;
    text-align: center;
  }

  .ai-social-highlights-post-actions-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .ai-social-highlights-action-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    cursor: pointer;
    color: #262626;
  }

  .ai-social-highlights-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    background-color: rgba(255, 255, 255, 0.9);
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 768px) {
    .ai-social-highlights-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
      text-align: center;
    }

    .ai-social-highlights-content-{{ ai_gen_id }} {
      order: 2;
    }

    .ai-social-highlights-mockup-{{ ai_gen_id }} {
      order: 1;
      max-width: 300px;
    }

    .ai-social-highlights-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-social-highlights-buttons-{{ ai_gen_id }} {
      align-items: center;
    }

    .ai-social-highlights-tiktok-btn-{{ ai_gen_id }},
    .ai-social-highlights-follow-btn-{{ ai_gen_id }} {
      align-self: center;
    }
  }
{% endstyle %}

<div class="ai-social-highlights-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-social-highlights-container-{{ ai_gen_id }}">
    <div class="ai-social-highlights-grid-{{ ai_gen_id }}">
      <div class="ai-social-highlights-content-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-social-highlights-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}

        <div class="ai-social-highlights-buttons-{{ ai_gen_id }}">
          {% if block.settings.tiktok_link != blank %}
            <a href="{{ block.settings.tiktok_link }}" class="ai-social-highlights-tiktok-btn-{{ ai_gen_id }}" target="_blank" rel="noopener">
              <svg class="ai-social-highlights-tiktok-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
              </svg>
              {{ block.settings.tiktok_btn_text }}
            </a>
          {% endif %}

          {% if block.settings.cta_text != blank %}
            <p class="ai-social-highlights-cta-text-{{ ai_gen_id }}">{{ block.settings.cta_text }}</p>
          {% endif %}

          {% if block.settings.follow_link != blank %}
            <a href="{{ block.settings.follow_link }}" class="ai-social-highlights-follow-btn-{{ ai_gen_id }}" target="_blank" rel="noopener">
              {{ block.settings.follow_btn_text }}
            </a>
          {% endif %}
        </div>
      </div>

      <div class="ai-social-highlights-mockup-{{ ai_gen_id }}">
        <div class="ai-social-highlights-frame-{{ ai_gen_id }}">
          <div class="ai-social-highlights-inner-frame-{{ ai_gen_id }}">
            <div class="ai-social-highlights-post-header-{{ ai_gen_id }}">
              <div class="ai-social-highlights-avatar-{{ ai_gen_id }}">
                {% if block.settings.username != blank %}
                  {{ block.settings.username | slice: 0, 1 | upcase }}
                {% else %}
                  @
                {% endif %}
              </div>
              <div class="ai-social-highlights-username-{{ ai_gen_id }}">
                {% if block.settings.username != blank %}
                  {{ block.settings.username }}
                {% else %}
                  @your_username
                {% endif %}
              </div>
            </div>

            <div class="ai-social-highlights-post-image-{{ ai_gen_id }}">
              {% if block.settings.post_image %}
                <img
                  src="{{ block.settings.post_image | image_url: width: 400 }}"
                  alt="{{ block.settings.post_image.alt | escape }}"
                  loading="lazy"
                  width="400"
                  height="200"
                >
              {% else %}
                <div class="ai-social-highlights-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-social-highlights-post-actions-{{ ai_gen_id }}">
              <svg class="ai-social-highlights-action-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
              <svg class="ai-social-highlights-action-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
              </svg>
              <svg class="ai-social-highlights-action-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="18" cy="5" r="3"/>
                <circle cx="6" cy="12" r="3"/>
                <circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
            </div>
          </div>
        </div>
        {% unless block.settings.post_image %}
          <div class="ai-social-highlights-empty-state-{{ ai_gen_id }}">
            Add a social post image
          </div>
        {% endunless %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Social highlights",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "TikTok & Social Highlights"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 48
    },
    {
      "type": "text",
      "id": "tiktok_btn_text",
      "label": "TikTok button text",
      "default": "TikTok"
    },
    {
      "type": "url",
      "id": "tiktok_link",
      "label": "TikTok link"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Find more on TikTok @ink.nebraska"
    },
    {
      "type": "range",
      "id": "cta_text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "CTA text size",
      "default": 16
    },
    {
      "type": "text",
      "id": "follow_btn_text",
      "label": "Follow button text",
      "default": "Follow Us"
    },
    {
      "type": "url",
      "id": "follow_link",
      "label": "Follow button link"
    },
    {
      "type": "header",
      "content": "Social mockup"
    },
    {
      "type": "text",
