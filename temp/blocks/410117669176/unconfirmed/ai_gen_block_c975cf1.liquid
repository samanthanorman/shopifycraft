      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "question_size",
      "label": "Question size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "range",
      "id": "answer_size",
      "label": "Answer size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fdfaf0"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#0d1b3e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#0d1b3e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#e2c84b"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider",
      "default": "#e8dcc8"
    },
    {
      "type": "color",
      "id": "hover_background",
      "label": "Hover background",
      "default": "#faf6eb"
    }
  ],
  "presets": [
    {
      "name": "FAQ accordion"
    }
  ]
}
{% endschema %}