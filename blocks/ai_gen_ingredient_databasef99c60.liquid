{% doc %}
  @prompt
    Create a structured ingredient database section that displays K-beauty skincare ingredients with their categories, origins, functions, and descriptions. Each ingredient should be clearly organized with the ingredient name as a heading, followed by category classification (Level1 and Level2), origin type, primary functions, and detailed description. The layout should be clean, scannable, and mobile-friendly with proper spacing and typography hierarchy.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ingredient-database-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-ingredient-database-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-ingredient-database-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-ingredient-database-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-ingredient-database-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-ingredient-database-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax({{ block.settings.card_min_width }}px, 1fr));
    gap: {{ block.settings.card_spacing }}px;
    margin-top: {{ block.settings.grid_spacing }}px;
  }

  .ai-ingredient-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ai-ingredient-card-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
  }

  .ai-ingredient-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.ingredient_name_size }}px;
    color: {{ block.settings.ingredient_name_color }};
    margin: 0 0 16px;
    font-weight: 600;
    line-height: 1.3;
    border-bottom: 2px solid {{ block.settings.accent_color }};
    padding-bottom: 8px;
  }

  .ai-ingredient-meta-{{ ai_gen_id }} {
    margin-bottom: 20px;
  }

  .ai-ingredient-category-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .ai-category-tag-{{ ai_gen_id }} {
    background-color: {{ block.settings.tag_background }};
    color: {{ block.settings.tag_text_color }};
    padding: 4px 12px;
    border-radius: {{ block.settings.tag_border_radius }}px;
    font-size: {{ block.settings.tag_font_size }}px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-category-tag-level1-{{ ai_gen_id }} {
    background-color: {{ block.settings.level1_color }};
  }

  .ai-category-tag-level2-{{ ai_gen_id }} {
    background-color: {{ block.settings.level2_color }};
  }

  .ai-ingredient-origin-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .ai-origin-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    color: {{ block.settings.label_color }};
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-origin-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.value_font_size }}px;
    color: {{ block.settings.value_color }};
    background-color: {{ block.settings.origin_background }};
    padding: 4px 10px;
    border-radius: {{ block.settings.value_border_radius }}px;
  }

  .ai-ingredient-functions-{{ ai_gen_id }} {
    margin-bottom: 16px;
  }

  .ai-functions-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    color: {{ block.settings.label_color }};
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
    display: block;
  }

  .ai-functions-list-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .ai-function-item-{{ ai_gen_id }} {
    background-color: {{ block.settings.function_background }};
    color: {{ block.settings.function_text_color }};
    padding: 3px 8px;
    border-radius: {{ block.settings.function_border_radius }}px;
    font-size: {{ block.settings.function_font_size }}px;
    font-weight: 400;
  }

  .ai-ingredient-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-ingredient-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.subtitle_color }};
    font-style: italic;
  }

  @media screen and (max-width: 768px) {
    .ai-ingredient-database-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_spacing | times: 0.75 }}px;
    }

    .ai-ingredient-database-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-ingredient-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }

    .ai-ingredient-category-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-ingredient-database-container-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .ai-ingredient-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.ingredient_name_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-ingredient-database-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ingredient-database-container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-ingredient-database-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-ingredient-database-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <div class="ai-ingredient-database-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-ingredient-database-grid-{{ ai_gen_id }}">
      {% assign has_ingredients = false %}
      
      {% for i in (1..10) %}
        {% liquid
          assign ingredient_name_key = 'ingredient_' | append: i | append: '_name'
          assign level1_key = 'ingredient_' | append: i | append: '_level1'
          assign level2_key = 'ingredient_' | append: i | append: '_level2'
          assign origin_key = 'ingredient_' | append: i | append: '_origin'
          assign functions_key = 'ingredient_' | append: i | append: '_functions'
          assign description_key = 'ingredient_' | append: i | append: '_description'

          assign ingredient_name = block.settings[ingredient_name_key]
          assign level1 = block.settings[level1_key]
          assign level2 = block.settings[level2_key]
          assign origin = block.settings[origin_key]
          assign functions = block.settings[functions_key]
          assign description = block.settings[description_key]
        %}

        {% if ingredient_name != blank %}
          {% assign has_ingredients = true %}
          <div class="ai-ingredient-card-{{ ai_gen_id }}">
            <h3 class="ai-ingredient-name-{{ ai_gen_id }}">{{ ingredient_name }}</h3>
            
            <div class="ai-ingredient-meta-{{ ai_gen_id }}">
              {% if level1 != blank or level2 != blank %}
                <div class="ai-ingredient-category-{{ ai_gen_id }}">
                  {% if level1 != blank %}
                    <span class="ai-category-tag-{{ ai_gen_id }} ai-category-tag-level1-{{ ai_gen_id }}">{{ level1 }}</span>
                  {% endif %}
                  {% if level2 != blank %}
                    <span class="ai-category-tag-{{ ai_gen_id }} ai-category-tag-level2-{{ ai_gen_id }}">{{ level2 }}</span>
                  {% endif %}
                </div>
              {% endif %}

              {% if origin != blank %}
                <div class="ai-ingredient-origin-{{ ai_gen_id }}">
                  <span class="ai-origin-label-{{ ai_gen_id }}">Origin:</span>
                  <span class="ai-origin-value-{{ ai_gen_id }}">{{ origin }}</span>
                </div>
              {% endif %}

              {% if functions != blank %}
                <div class="ai-ingredient-functions-{{ ai_gen_id }}">
                  <span class="ai-functions-label-{{ ai_gen_id }}">Functions:</span>
                  <div class="ai-functions-list-{{ ai_gen_id }}">
                    {% assign function_list = functions | split: ',' %}
                    {% for function in function_list %}
                      <span class="ai-function-item-{{ ai_gen_id }}">{{ function | strip }}</span>
                    {% endfor %}
                  </div>
                </div>
              {% endif %}
            </div>

            {% if description != blank %}
              <div class="ai-ingredient-description-{{ ai_gen_id }}">{{ description }}</div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

      {% unless has_ingredients %}
        <div class="ai-ingredient-empty-state-{{ ai_gen_id }}">
          Add your first K-beauty ingredient to get started
        </div>
      {% endunless %}
    </div>
  </div>
</div>

