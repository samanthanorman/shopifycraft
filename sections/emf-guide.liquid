      "label": "Card Background",
      "default": "#f8fafc"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card Border",
      "default": "#e2e8f0"
    },
    {
      "type": "header",
      "content": "Intro Section"
    },
    {
