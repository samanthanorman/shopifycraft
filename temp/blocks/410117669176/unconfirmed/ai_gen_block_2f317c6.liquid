{% doc %}
  @prompt
    HARAMOON_101 metaobject is incredibly rich and each is linked as a product metafield to this product template page so ensure that everything on the back end is looped accurately since im an amateur and need help with technical prompting  — pH, absorption time, clinical results, 18 ingredient profiles, layering tips, skin type refs, routine step number — are all fields within the metaobject definition (5 total for the 5 products you must link accurately so data populates according to each. this section is intended for an INGREDIENT SPOTLIGHT — built around your actual active_ingredients + ingredient_profile metaobject data:
    
    --- Create a premium ingredient spotlight section for a K-beauty skincare product page. Display 5-6 key active ingredients as large editorial cards in a 2-column grid on desktop, single column on mobile. Each card contains: an oversized ingredient name in a thin elegant serif display font (e.g. "Niacinamide", "Hyaluronic Acid", "Madecassoside", "Sea Buckthorn Oil", "Ceramides", "Palmitoyl Tripeptide-5"), a one-line benefit subtitle in small caps accent color (e.g. "Brightening + Pore Refining"), and a 2-3 sentence description of what the ingredient does for skin. Add an optional small uploadable image or botanical icon per card. Cards should have a soft hover lift with a very subtle shadow. Use a warm cream or soft sage green background. Include an editable bold editorial section title (e.g. "What's Inside") and a short subtitle. All ingredient names, subtitles, descriptions, and images must be editable in theme settings as repeatable blocks — minimum 6 blocks. Add ChemicalSubstance schema JSON-LD in a script tag for each ingredient with "name" and "description" properties, nested inside the parent Product schema context. Animate cards in on scroll with a gentle staggered fade-up. Premium Mamonde-level aesthetic — generous whitespace, no clutter.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% assign haramoon_data = product.metafields.custom.haramoon_101 %}

{% style %}
  .ai-ingredient-spotlight-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-ingredient-spotlight-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-ingredient-spotlight-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-ingredient-spotlight-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.2;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    letter-spacing: -0.02em;
  }

  .ai-ingredient-spotlight-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-ingredient-spotlight-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.card_gap }}px;
    margin-top: {{ block.settings.grid_top_margin }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-ingredient-spotlight-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }

  .ai-ingredient-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-ingredient-card-{{ ai_gen_id }}.ai-ingredient-card-visible-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-ingredient-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
  }

  .ai-ingredient-card-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: 20px;
    border-radius: 50%;
    overflow: hidden;
    background-color: {{ block.settings.icon_background }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-ingredient-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-ingredient-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-ingredient-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-ingredient-card-name-{{ ai_gen_id }} {
    font-family: {{ block.settings.ingredient_font.family }}, {{ block.settings.ingredient_font.fallback_families }};
    font-weight: {{ block.settings.ingredient_font.weight }};
    font-size: {{ block.settings.ingredient_name_size }}px;
    line-height: 1.2;
    color: {{ block.settings.ingredient_name_color }};
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }

  .ai-ingredient-card-benefit-{{ ai_gen_id }} {
    font-size: {{ block.settings.benefit_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: {{ block.settings.accent_color }};
    margin: 0 0 16px 0;
    font-weight: 500;
  }

  .ai-ingredient-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    color: {{ block.settings.description_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-ingredient-spotlight-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-ingredient-card-name-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.ingredient_name_size }}px * 0.85);
    }
  }
{% endstyle %}

<ingredient-spotlight-{{ ai_gen_id }}
  class="ai-ingredient-spotlight-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-ingredient-spotlight-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_subtitle != blank %}
      <div class="ai-ingredient-spotlight-header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-ingredient-spotlight-title-{{ ai_gen_id }}">
            {{ block.settings.section_title }}
          </h2>
        {% endif %}
        {% if block.settings.section_subtitle != blank %}
          <p class="ai-ingredient-spotlight-subtitle-{{ ai_gen_id }}">
            {{ block.settings.section_subtitle }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-ingredient-spotlight-grid-{{ ai_gen_id }}">
      {% if haramoon_data and haramoon_data.ingredient_profile %}
        {% for ingredient_entry in haramoon_data.ingredient_profile.value %}
          {% assign ingredient = ingredient_entry %}
          <div
            class="ai-ingredient-card-{{ ai_gen_id }}"
            data-index="{{ forloop.index }}"
          >
            {% if ingredient.ingredient_image %}
              <div class="ai-ingredient-card-image-wrapper-{{ ai_gen_id }}">
                <img
                  src="{{ ingredient.ingredient_image | image_url: width: 200 }}"
                  alt="{{ ingredient.ingredient_name }}"
                  class="ai-ingredient-card-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              </div>
            {% endif %}

            {% if ingredient.ingredient_name %}
              <h3 class="ai-ingredient-card-name-{{ ai_gen_id }}">
                {{ ingredient.ingredient_name }}
              </h3>
            {% endif %}

            {% if ingredient.benefit_category %}
              <div class="ai-ingredient-card-benefit-{{ ai_gen_id }}">
                {{ ingredient.benefit_category }}
              </div>
            {% endif %}

            {% if ingredient.description %}
              <div class="ai-ingredient-card-description-{{ ai_gen_id }}">
                {{ ingredient.description }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</ingredient-spotlight-{{ ai_gen_id }}>

{% if haramoon_data and haramoon_data.ingredient_profile %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": [
      {% for ingredient_entry in haramoon_data.ingredient_profile.value %}
        {% assign ingredient = ingredient_entry %}
        {
          "@type": "ListItem",
          "position": {{ forloop.index }},
          "item": {
            "@type": "ChemicalSubstance",
            "name": "{{ ingredient.ingredient_name | escape }}",
            "description": "{{ ingredient.description | strip_html | escape }}"
          }
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  }
  </script>
{% endif %}

<script>
  (function() {
    class IngredientSpotlight{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.animationDelay = {{ block.settings.animation_delay }};
      }

      connectedCallback() {
        this.setupScrollAnimation();
      }

      setupScrollAnimation() {
        const cards = this.querySelectorAll('.ai-ingredient-card-{{ ai_gen_id }}');
        
        if (!cards.length) return;

        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const card = entry.target;
              const index = parseInt(card.dataset.index) - 1;
              const delay = index * this.animationDelay;
              
              setTimeout(() => {
                card.classList.add('ai-ingredient-card-visible-{{ ai_gen_id }}');
              }, delay);
              
              observer.unobserve(card);
            }
          });
        }, observerOptions);

        cards.forEach((card) => {
          observer.observe(card);
        });
      }
    }

    customElements.define('ingredient-spotlight-{{ ai_gen_id }}', IngredientSpotlight{{ ai_gen_id }});
  })();
</script>

