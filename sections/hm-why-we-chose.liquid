{% doc %}
  About HARAMOON — "Why We Chose HARAMOON" Section
  First-person voice from Wax | Wane explaining the vetting process
  Google Merchant Center authenticity signal
  Glassmorphism quote card design, fully editable in theme editor
  ⚠️  SAMANTHA: Replace placeholder text in theme editor with your own words!
     Go to: Shopify Admin → Online Store → Customize → About HARAMOON page
     → "Why We Chose HARAMOON" section → edit all text fields
{% enddoc %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

  .hm-why-section {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    font-family: 'Poppins', sans-serif;
    position: relative;
    overflow: hidden;
  }
  .hm-why-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 20%, rgba(52,152,255,0.07) 0%, transparent 55%),
                radial-gradient(ellipse at 20% 80%, rgba(168,212,255,0.04) 0%, transparent 55%);
    pointer-events: none;
  }
  .hm-why-inner {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .hm-why-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    text-align: center;
    margin: 0 0 10px;
  }
  .hm-why-title {
    font-size: clamp(22px, 3.5vw, 38px);
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    text-align: center;
    margin: 0 0 48px;
    letter-spacing: -0.02em;
  }

  /* Two-column layout: quote card + criteria list */
  .hm-why-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }
  @media (max-width: 680px) {
    .hm-why-layout { grid-template-columns: 1fr; }
  }

  /* Quote card */
  .hm-why-quote-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 32px 28px;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.3s ease;
  }
  .hm-why-quote-card:hover {
    box-shadow: 0 16px 48px rgba(0,0,0,0.25);
  }
  .hm-why-quote-card::before {
    content: '"';
    position: absolute;
    top: -10px; left: 20px;
    font-size: 120px;
    font-weight: 900;
    color: {{ section.settings.accent_color }};
    opacity: 0.08;
    line-height: 1;
    font-family: Georgia, serif;
    pointer-events: none;
  }
  .hm-why-quote-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, {{ section.settings.accent_color }}60, {{ section.settings.accent_color }});
    border-radius: 20px 20px 0 0;
  }
  .hm-why-quote-text {
    font-size: 15px;
    color: {{ section.settings.body_color }};
    line-height: 1.8;
    margin: 0 0 24px;
    position: relative;
    z-index: 1;
    font-style: italic;
  }
  .hm-why-quote-text-2 {
    font-size: 14px;
    color: {{ section.settings.subtext_color }};
    line-height: 1.7;
    margin: 0 0 24px;
    position: relative;
    z-index: 1;
  }
  .hm-why-signature {
    display: flex;
    align-items: center;
    gap: 12px;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 20px;
  }
  .hm-why-sig-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, {{ section.settings.accent_color }}40, {{ section.settings.accent_color }}20);
    border: 2px solid {{ section.settings.accent_color }}40;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
    overflow: hidden;
  }
  .hm-why-sig-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  .hm-why-sig-name {
    font-size: 14px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    line-height: 1.2;
  }
  .hm-why-sig-title {
    font-size: 11px;
    color: {{ section.settings.subtext_color }};
    letter-spacing: 0.05em;
  }

  /* Criteria list */
  .hm-why-criteria {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .hm-why-criteria-item {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 18px 20px;
    backdrop-filter: blur(8px);
    display: flex;
    align-items: flex-start;
    gap: 14px;
    transition: transform 0.22s ease, border-color 0.22s ease;
  }
  .hm-why-criteria-item:hover {
    transform: translateX(4px);
    border-color: {{ section.settings.accent_color }}40;
  }
  .hm-why-criteria-icon {
    font-size: 22px;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .hm-why-criteria-text {
    flex: 1;
  }
  .hm-why-criteria-name {
    font-size: 13px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 3px;
  }
  .hm-why-criteria-desc {
    font-size: 12px;
    color: {{ section.settings.subtext_color }};
    line-height: 1.5;
    margin: 0;
  }
{% endstyle %}

<section class="hm-why-section" id="why-we-chose-haramoon">
  <div class="hm-why-inner">

    <p class="hm-why-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="hm-why-title">{{ section.settings.heading }}</h2>

    <div class="hm-why-layout">

      <!-- Quote Card (Samantha's voice) -->
      <div class="hm-why-quote-card">
        <p class="hm-why-quote-text">{{ section.settings.quote_text }}</p>
        <p class="hm-why-quote-text-2">{{ section.settings.body_text }}</p>
        <div class="hm-why-signature">
          <div class="hm-why-sig-avatar">
            {%- if section.settings.sig_photo != blank -%}
              <img src="{{ section.settings.sig_photo | image_url: width: 88 }}" alt="{{ section.settings.sig_name }}" loading="lazy">
            {%- else -%}
              🌙
            {%- endif -%}
          </div>
          <div>
            <p class="hm-why-sig-name">{{ section.settings.sig_name }}</p>
            <p class="hm-why-sig-title">{{ section.settings.sig_title }}</p>
          </div>
        </div>
      </div>

      <!-- Vetting Criteria -->
      <div class="hm-why-criteria" role="list" aria-label="Our vetting criteria">

        {% for i in (1..5) %}
          {% assign icon_key = 'criteria' | append: i | append: '_icon' %}
          {% assign name_key = 'criteria' | append: i | append: '_name' %}
          {% assign desc_key = 'criteria' | append: i | append: '_desc' %}
          {% assign show_key = 'criteria' | append: i | append: '_show' %}
          {% if section.settings[show_key] %}
          <div class="hm-why-criteria-item" role="listitem">
            <span class="hm-why-criteria-icon" aria-hidden="true">{{ section.settings[icon_key] }}</span>
            <div class="hm-why-criteria-text">
              <p class="hm-why-criteria-name">{{ section.settings[name_key] }}</p>
              <p class="hm-why-criteria-desc">{{ section.settings[desc_key] }}</p>
            </div>
          </div>
          {% endif %}
        {% endfor %}

      </div>
    </div>
  </div>
</section>

