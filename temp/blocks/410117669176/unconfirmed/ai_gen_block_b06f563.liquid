<script>
  (function() {
    class StickyAnchorNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.tabs = [];
        this.sections = [];
        this.scrollTimeout = null;
        this.isScrolling = false;
      }

      connectedCallback() {
        this.tabs = Array.from(this.querySelectorAll('.ai-sticky-nav-tab-{{ ai_gen_id }}'));
        this.setupScrollSpy();
        this.setupSmoothScroll();
      }

      setupScrollSpy() {
        this.tabs.forEach(tab => {
          const anchor = tab.getAttribute('data-anchor');
          if (anchor) {
            const section = document.getElementById(anchor);
            if (section) {
              this.sections.push({ tab, section, anchor });
            }
          }
        });

        if (this.sections.length > 0) {
          window.addEventListener('scroll', () => this.handleScroll(), { passive: true });
          this.handleScroll();
        }
      }

      handleScroll() {
        if (this.isScrolling) return;

        clearTimeout(this.scrollTimeout);
        this.scrollTimeout = setTimeout(() => {
          const scrollPosition = window.scrollY + 150;

          let activeSection = null;

          for (let i = this.sections.length - 1; i >= 0; i--) {
            const { section } = this.sections[i];
            if (section.offsetTop <= scrollPosition) {
              activeSection = this.sections[i];
              break;
            }
          }

          this.tabs.forEach(tab => tab.classList.remove('active'));

          if (activeSection) {
            activeSection.tab.classList.add('active');
          }
        }, 50);
      }

      setupSmoothScroll() {
        this.tabs.forEach(tab => {
          tab.addEventListener('click', (e) => {
            e.preventDefault();
            const anchor = tab.getAttribute('data-anchor');
            const targetSection = document.getElementById(anchor);

            if (targetSection) {
              this.isScrolling = true;

              const navHeight = this.offsetHeight;
              const targetPosition = targetSection.offsetTop - navHeight - 20;

              window.scrollTo({
                top: targetPosition,
                behavior: 'smooth'
              });

              this.tabs.forEach(t => t.classList.remove('active'));
              tab.classList.add('active');

              setTimeout(() => {
                this.isScrolling = false;
              }, 1000);
            }
          });
        });
      }
    }

    customElements.define('sticky-anchor-nav-{{ ai_gen_id }}', StickyAnchorNav{{ ai_gen_id }});
  })();
</script>

