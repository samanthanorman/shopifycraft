          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6,9 12,15 18,9"></polyline>
          </svg>
        </div>

        <p class="ai-skincare-guide__description-{{ ai_gen_id }}">
          A powerful humectant that can hold up to 1,000 times its weight in water, providing intense hydration.
        </p>

        <div class="ai-skincare-guide__expandable-content-{{ ai_gen_id }}">
          <div class="ai-skincare-guide__benefits-{{ ai_gen_id }}">
            <h4 class="ai-skincare-guide__benefits-title-{{ ai_gen_id }}">Key Benefits</h4>
