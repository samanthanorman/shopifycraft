        "step4_emoji": "🌙",
        "step4_name": "{{ metaobjects.haramoon_101[\"centella-moisture-cream\"].product_name_type.value }}",
        "step4_timing": "AM + PM",
        "step4_tip": "Seal everything in. Use upward strokes. SPF on top in the morning.",
