          <p class="crys-mineral-card__label">🌍 Origin</p>
          <p class="crys-mineral-card__value">{{ matched_mineral.origin }}</p>
        </div>
        {%- endif -%}
        {%- if matched_mineral.planets -%}
        <div class="crys-mineral-card">
          <p class="crys-mineral-card__label">🪐 Ruling Planet</p>
          <p class="crys-mineral-card__value">{{ matched_mineral.planets }}</p>
