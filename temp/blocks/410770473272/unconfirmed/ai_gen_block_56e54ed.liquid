{% doc %}
  @prompt
    Create a custom Liquid block for a metaobject page template. It displays a horizontal carousel of ingredient cards.
    
    Data: Loop through metaobject.fields.ingredient_profile.value. For each entry, show:
    
    A small centered icon image (from a block-level image picker schema setting, matched by loop index order)
    The ingredient name: entry.field('name').value
    Short description: entry.field('description').value (3 line clamp)
    The entire card links to entry.url
    Layout: 4 cards visible on desktop, 2 tablet, 1 mobile. Left/right arrow buttons to scroll. Light border, rounded corners, minimal white card style.
    
    Schema settings: heading text (default "Hero Ingredients Inside"), subheading text (default "Click Each Card To Learn More"), emoji appended to heading (default 👁️). Block type "icon" with one image picker — limit 20 blocks.
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ingredient-carousel-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 0;
  }

  .ai-ingredient-carousel__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .ai-ingredient-carousel__heading-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 600;
    margin: 0 0 8px;
    color: #0d1b3e;
  }

  .ai-ingredient-carousel__subheading-{{ ai_gen_id }} {
    font-size: 16px;
    color: #666;
    margin: 0;
  }

  .ai-ingredient-carousel__wrapper-{{ ai_gen_id }} {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
  }

  .ai-ingredient-carousel__track-container-{{ ai_gen_id }} {
    overflow: hidden;
    position: relative;
  }

  .ai-ingredient-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
    transition: transform 0.4s ease;
  }

  .ai-ingredient-carousel__card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - 60px) / 4);
    background: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    padding: 24px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-ingredient-carousel__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-ingredient-carousel__icon-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .ai-ingredient-carousel__icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-ingredient-carousel__icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-ingredient-carousel__icon-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-ingredient-carousel__name-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 12px;
    color: #0d1b3e;
  }

  .ai-ingredient-carousel__description-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.5;
    color: #666;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-ingredient-carousel__button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #ffffff;
    border: 1px solid #e0e0e0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .ai-ingredient-carousel__button-{{ ai_gen_id }}:hover {
    background-color: #f4f4f4;
    border-color: #ccc;
  }

  .ai-ingredient-carousel__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-ingredient-carousel__button-{{ ai_gen_id }}:disabled:hover {
    background-color: #ffffff;
    border-color: #e0e0e0;
  }

  .ai-ingredient-carousel__button--prev-{{ ai_gen_id }} {
    left: 0;
  }

  .ai-ingredient-carousel__button--next-{{ ai_gen_id }} {
    right: 0;
  }

  .ai-ingredient-carousel__button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 989px) {
    .ai-ingredient-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - 20px) / 2);
    }

    .ai-ingredient-carousel__wrapper-{{ ai_gen_id }} {
      padding: 0 50px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-ingredient-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-ingredient-carousel__wrapper-{{ ai_gen_id }} {
      padding: 0 50px;
    }

    .ai-ingredient-carousel__heading-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-ingredient-carousel__subheading-{{ ai_gen_id }} {
      font-size: 14px;
    }
  }
{% endstyle %}

<ingredient-carousel-{{ ai_gen_id }} class="ai-ingredient-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ingredient-carousel__header-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-ingredient-carousel__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}{% if block.settings.heading_emoji != blank %} {{ block.settings.heading_emoji }}{% endif %}
      </h2>
    {% endif %}
    {% if block.settings.subheading != blank %}
      <p class="ai-ingredient-carousel__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="ai-ingredient-carousel__wrapper-{{ ai_gen_id }}">
    <button
      class="ai-ingredient-carousel__button-{{ ai_gen_id }} ai-ingredient-carousel__button--prev-{{ ai_gen_id }}"
      aria-label="Previous"
      data-carousel-prev
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <div class="ai-ingredient-carousel__track-container-{{ ai_gen_id }}">
      <div class="ai-ingredient-carousel__track-{{ ai_gen_id }}" data-carousel-track>
        {% if metaobject.fields.ingredient_profile.value %}
          {% for entry in metaobject.fields.ingredient_profile.value %}
            {% assign ingredient_name = entry.name %}
            {% assign ingredient_description = entry.description %}
            {% assign icon_setting_key = 'icon_' | append: forloop.index %}
            {% assign icon_image = block.settings[icon_setting_key] %}
            <a
              href="{{ entry.url }}"
              class="ai-ingredient-carousel__card-{{ ai_gen_id }}"
              data-carousel-card
            >
              <div class="ai-ingredient-carousel__icon-{{ ai_gen_id }}">
                {% if icon_image %}
                  <img
                    src="{{ icon_image | image_url: width: 160 }}"
                    alt="{{ ingredient_name | escape }}"
                    loading="lazy"
                    width="80"
                    height="80"
                  >
                {% else %}
                  <div class="ai-ingredient-carousel__icon-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <h3 class="ai-ingredient-carousel__name-{{ ai_gen_id }}">
                {{ ingredient_name }}
              </h3>
              <p class="ai-ingredient-carousel__description-{{ ai_gen_id }}">
                {{ ingredient_description }}
              </p>
            </a>
          {% endfor %}
        {% else %}
          {% for i in (1..4) %}
            <div class="ai-ingredient-carousel__card-{{ ai_gen_id }}" data-carousel-card>
              <div class="ai-ingredient-carousel__icon-{{ ai_gen_id }}">
                <div class="ai-ingredient-carousel__icon-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              </div>
              <h3 class="ai-ingredient-carousel__name-{{ ai_gen_id }}">Ingredient Name</h3>
              <p class="ai-ingredient-carousel__description-{{ ai_gen_id }}">
                Add ingredient profile metaobject list to display ingredient cards here.
              </p>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <button
      class="ai-ingredient-carousel__button-{{ ai_gen_id }} ai-ingredient-carousel__button--next-{{ ai_gen_id }}"
      aria-label="Next"
      data-carousel-next
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</ingredient-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class IngredientCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.cardsPerView = 4;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-carousel-track]');
        this.cards = this.querySelectorAll('[data-carousel-card]');
        this.prevButton = this.querySelector('[data-carousel-prev]');
        this.nextButton = this.querySelector('[data-carousel-next]');

        if (!this.track || !this.cards.length) return;

        this.updateCardsPerView();
        this.updateButtons();

        this.prevButton.addEventListener('click', () => this.prev());
        this.nextButton.addEventListener('click', () => this.next());

        window.addEventListener('resize', () => {
          this.updateCardsPerView();
          this.updatePosition();
          this.updateButtons();
        });
      }

      updateCardsPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.cardsPerView = 1;
        } else if (width <= 989) {
          this.cardsPerView = 2;
        } else {
          this.cardsPerView = 4;
        }
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updatePosition();
          this.updateButtons();
        }
      }

      next() {
        const maxIndex = Math.max(0, this.cards.length - this.cardsPerView);
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.updatePosition();
          this.updateButtons();
        }
      }

      updatePosition() {
        const cardWidth = this.cards[0].offsetWidth;
        const gap = 20;
        const offset = -(this.currentIndex * (cardWidth + gap));
        this.track.style.transform = `translateX(${offset}px)`;
      }

      updateButtons() {
        const maxIndex = Math.max(0, this.cards.length - this.cardsPerView);
        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= maxIndex;
      }
    }

    customElements.define('ingredient-carousel-{{ ai_gen_id }}', IngredientCarousel{{ ai_gen_id }});
  })();
</script>

