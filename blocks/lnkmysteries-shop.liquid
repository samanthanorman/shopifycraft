{% doc %}
  @prompt
    Dual Text Section (Unlock Mysteries / Shop Good Life)
    
    Prompt Spec:
    	•	Section Layout: Two equal-width text blocks side by side (stack on mobile).
    	•	Background: Light beige (same as hero section for consistency).
    	•	Typography: Serif for headings, Sans-serif for body text.
    	•	Block 1:
    	•	Heading: “Unlock the mysteries of the…” (continue hidden legends theme)
    	•	Description: Short 2–3 lines expanding on curiosity/mythology angle.
    	•	Block 2:
    	•	Heading: “Shop Good Life…”
    	•	Description: 2–3 lines tying Nebraska’s brand to lifestyle, souvenirs, or online shop.
    	•	Style: Minimal, no images — just clean text with breathing room.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dual-text-section-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-dual-text-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-dual-text-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: start;
  }

  .ai-dual-text-block-{{ ai_gen_id }} {
    padding: {{ block.settings.block_padding }}px;
  }

  .ai-dual-text-heading-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: {{ settings.type_header_font.weight }};
    font-style: {{ settings.type_header_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.3;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
  }

  .ai-dual-text-description-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: {{ settings.type_body_font.weight }};
    font-style: {{ settings.type_body_font.style }};
    font-size: {{ block.settings.body_size }}px;
    line-height: 1.6;
    color: {{ block.settings.body_color }};
    margin: 0;
  }

  .ai-dual-text-description-{{ ai_gen_id }} p {
    margin: 0 0 1em;
  }

  .ai-dual-text-description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-dual-text-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-dual-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.85 }}px;
    }

    .ai-dual-text-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.95 }}px;
    }

    .ai-dual-text-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 0 {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-dual-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-dual-text-container-{{ ai_gen_id }}">
    <div class="ai-dual-text-grid-{{ ai_gen_id }}">
      <div class="ai-dual-text-block-{{ ai_gen_id }}">
        {% if block.settings.block_1_heading != blank %}
          <h2 class="ai-dual-text-heading-{{ ai_gen_id }}">{{ block.settings.block_1_heading }}</h2>
        {% endif %}
        {% if block.settings.block_1_description != blank %}
          <div class="ai-dual-text-description-{{ ai_gen_id }}">{{ block.settings.block_1_description }}</div>
        {% endif %}
      </div>

      <div class="ai-dual-text-block-{{ ai_gen_id }}">
        {% if block.settings.block_2_heading != blank %}
          <h2 class="ai-dual-text-heading-{{ ai_gen_id }}">{{ block.settings.block_2_heading }}</h2>
        {% endif %}
        {% if block.settings.block_2_description != blank %}
          <div class="ai-dual-text-description-{{ ai_gen_id }}">{{ block.settings.block_2_description }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Dual text section",
  "settings": [
    {
      "type": "header",
      "content": "Block 1 content"
    },
    {
      "type": "text",
      "id": "block_1_heading",
      "label": "Heading",
      "default": "Unlock the mysteries of the ancient world"
    },
    {
      "type": "richtext",
      "id": "block_1_description",
      "label": "Description",
      "default": "<p>Discover hidden legends and forgotten tales that have shaped civilizations. Journey through time and explore the curiosities that connect us to our mysterious past.</p>"
    },
    {
      "type": "header",
      "content": "Block 2 content"
    },
    {
      "type": "text",
      "id": "block_2_heading",
      "label": "Heading",
      "default": "Shop the good life"
    },
    {
      "type": "richtext",
      "id": "block_2_description",
      "label": "Description",
      "default": "<p>Embrace Nebraska's authentic lifestyle with carefully curated souvenirs and treasures. Find unique pieces that celebrate the heartland spirit and bring good vibes to your everyday.</p>"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#efeeec"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#002c60"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
      "default": "#002c60"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Body text size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Section top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Section bottom padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Column gap",
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "min": 20,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Mobile gap",
      "default": 40
    },
    {
      "type": "range",
      "id": "block_padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Block padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading bottom margin",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Dual text section"
    }
  ]
}
{% endschema %}