                  <polyline points="20,6 9,17 4,12"></polyline>
                </svg>
                Deep hydration and moisture retention
              </li>
              <li class="ai-skincare-guide__benefit-item-{{ ai_gen_id }}">
                <svg class="ai-skincare-guide__benefit-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20,6 9,17 4,12"></polyline>
                </svg>
                Plumps skin and reduces fine lines
              </li>
              <li class="ai-skincare-guide__benefit-item-{{ ai_gen_id }}">
                <svg class="ai-skincare-guide__benefit-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20,6 9,17 4,12"></polyline>
                </svg>
                Suitable for all skin types
              </li>
            </ul>
          </div>

          <div class="ai-skincare-guide__usage-{{ ai_gen_id }}">
            <h5 class="ai-skincare-guide__usage-title-{{ ai_gen_id }}">How to Use</h5>
            <p class="ai-skincare-guide__usage-text-{{ ai_gen_id }}">
              Apply to damp skin after cleansing. Follow with moisturizer to seal in hydration. Use morning and evening.
            </p>
          </div>
        </div>
      </div>

