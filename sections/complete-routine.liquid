{% comment %}
  HARAMOON Complete 4-Step Glass Skin Routine Page
  Structure: Problem → Agitate → Solution (PAS) + 4 routine steps + ingredients + bundle CTA
  Uses: haramoon_101 metaobject entries (one per step), ingredient_profile metaobject references
{% endcomment %}

{%- assign hm_steps = shop.metaobjects.haramoon_101.values -%}
{%- assign sorted_steps = hm_steps | sort: 'routine_step_number' -%}

<div class="hm-routine-page" id="haramoon-routine">

  {%- comment -%} ── HERO / PAS PROBLEM ── {%- endcomment -%}
  <section class="hm-routine-hero">
    <div class="hm-routine-hero__inner">
      <p class="hm-routine-eyebrow">{{ section.settings.eyebrow | default: 'HARAMOON × Korean Glass Skin' }}</p>
      <h1 class="hm-routine-hero__title">{{ section.settings.hero_title | default: 'Your Skin Has Been Trying to Tell You Something.' }}</h1>
      <p class="hm-routine-hero__problem">{{ section.settings.problem_text | default: 'Dullness. Uneven texture. Products that promise everything and deliver nothing. You've tried the 10-step routines, the trending serums, the overnight miracles. And your skin is still not where you want it to be.' }}</p>
    </div>
  </section>

  {%- comment -%} ── AGITATE ── {%- endcomment -%}
  <section class="hm-routine-agitate">
    <div class="hm-routine-agitate__inner">
      <h2 class="hm-routine-agitate__title">{{ section.settings.agitate_title | default: 'The Problem Isn\'t Your Skin. It\'s Your Routine.' }}</h2>
      <p class="hm-routine-agitate__body">{{ section.settings.agitate_text | default: 'Most Western skincare is formulated to mask — not transform. Korean skincare is different. It\'s built on the principle that skin health is earned through consistency, layering, and ingredients that actually work with your biology. HARAMOON distills 4 decades of K-beauty science into 4 precise steps. No filler. No fluff. Just glass skin.' }}</p>
      <div class="hm-routine-agitate__stats">
        <div class="hm-routine-stat">
          <span class="hm-routine-stat__number">4</span>
          <span class="hm-routine-stat__label">Steps</span>
        </div>
        <div class="hm-routine-stat">
          <span class="hm-routine-stat__number">~5</span>
          <span class="hm-routine-stat__label">Minutes</span>
        </div>
        <div class="hm-routine-stat">
          <span class="hm-routine-stat__number">AM + PM</span>
          <span class="hm-routine-stat__label">Daily</span>
        </div>
        <div class="hm-routine-stat">
          <span class="hm-routine-stat__number">14</span>
          <span class="hm-routine-stat__label">Days to Visible Results</span>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ── SOLUTION: THE 4 STEPS ── {%- endcomment -%}
  <section class="hm-routine-steps-section">
    <div class="hm-routine-steps-section__inner">
      <p class="hm-routine-eyebrow">The Solution</p>
      <h2 class="hm-routine-steps-section__title">{{ section.settings.steps_title | default: 'The HARAMOON 4-Step Glass Skin System' }}</h2>
      <p class="hm-routine-steps-section__subtitle">{{ section.settings.steps_subtitle | default: 'Each step is engineered to work with the next. Skip one and you break the chain.' }}</p>

      {%- comment -%} Step progress indicator {%- endcomment -%}
      <div class="hm-routine-progress" aria-label="Routine steps">
        {%- for i in (1..4) -%}
          <div class="hm-routine-progress__item">
            <div class="hm-routine-progress__circle">{{ i }}</div>
            {%- if i < 4 -%}<div class="hm-routine-progress__line"></div>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} Step cards — pulled from haramoon_101 metaobject {%- endcomment -%}
      <div class="hm-routine-steps-grid">
        {%- if sorted_steps.size > 0 -%}
          {%- for step in sorted_steps -%}
            {%- assign step_num = step.routine_step_number | default: forloop.index -%}
            {%- assign step_name = step.routine_step_name | default: step.product_name_type -%}
            {%- assign step_claims = step.key_claims -%}
            {%- assign step_story = step.product_story -%}
            {%- assign step_benefits = step.skin_care_benefits -%}
            {%- assign step_clinical = step.clinical_results -%}
            {%- assign step_ingredients = step.ingredient_profile -%}
            <div class="hm-routine-step-card" data-step="{{ step_num }}">
              <div class="hm-routine-step-card__header">
                <span class="hm-routine-step-card__number">Step {{ step_num }}</span>
                <h3 class="hm-routine-step-card__name">{{ step_name }}</h3>
                {%- if step.product_highlight != blank -%}
                  <p class="hm-routine-step-card__highlight">{{ step.product_highlight }}</p>
                {%- endif -%}
              </div>

              {%- comment -%} Product image if available {%- endcomment -%}
              {%- if step.images and step.images.size > 0 -%}
                <div class="hm-routine-step-card__image">
                  {{ step.images.first | image_url: width: 600 | image_tag: alt: step_name, loading: 'lazy' }}
                </div>
              {%- endif -%}

              <div class="hm-routine-step-card__body">
                {%- if step_story != blank -%}
                  <p class="hm-routine-step-card__story">{{ step_story }}</p>
                {%- endif -%}

                {%- if step_claims and step_claims.size > 0 -%}
                  <ul class="hm-routine-step-card__claims">
                    {%- for claim in step_claims -%}
                      <li>{{ claim }}</li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

                {%- if step_benefits != blank -%}
                  <div class="hm-routine-step-card__benefits">
                    <span class="hm-routine-step-card__label">Skin Benefits</span>
                    <p>{{ step_benefits }}</p>
                  </div>
                {%- endif -%}

                {%- if step_clinical != blank -%}
                  <div class="hm-routine-step-card__clinical">
                    <span class="hm-routine-step-card__label">Clinical Results</span>
                    <p>{{ step_clinical }}</p>
                  </div>
                {%- endif -%}

                {%- comment -%} Linked ingredient profiles {%- endcomment -%}
                {%- if step_ingredients and step_ingredients.size > 0 -%}
                  <div class="hm-routine-step-card__ingredients">
                    <span class="hm-routine-step-card__label">Key Ingredients</span>
                    <div class="hm-routine-ingredient-chips">
                      {%- for ing in step_ingredients -%}
                        {%- assign ing_obj = ing.value -%}
                        {%- assign ing_name = ing_obj.ingredient_name | default: ing_obj.name -%}
                        {%- if ing_obj.system.url != blank -%}
                          <a href="{{ ing_obj.system.url }}" class="hm-routine-ingredient-chip hm-routine-ingredient-chip--link">{{ ing_name }}</a>
                        {%- else -%}
                          <span class="hm-routine-ingredient-chip">{{ ing_name }}</span>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endif -%}

                {%- comment -%} Usage timing {%- endcomment -%}
                <div class="hm-routine-step-card__meta">
                  {%- if step.best_for_time_of_day != blank -%}
                    <span class="hm-routine-step-card__meta-item">🕐 {{ step.best_for_time_of_day }}</span>
                  {%- endif -%}
                  {%- if step.absorption_time != blank -%}
                    <span class="hm-routine-step-card__meta-item">⏱ Absorbs in {{ step.absorption_time }}</span>
                  {%- endif -%}
                  {%- if step.texture_type != blank -%}
                    <span class="hm-routine-step-card__meta-item">✦ {{ step.texture_type }}</span>
                  {%- endif -%}
                </div>
              </div>

              {%- comment -%} Shop this step CTA {%- endcomment -%}
              {%- assign step_products = step.active_ingredients -%}
              {%- if step_products and step_products.size > 0 -%}
                <div class="hm-routine-step-card__cta">
                  {%- for prod_ref in step_products limit: 1 -%}
                    {%- assign prod = prod_ref.value -%}
                    {%- if prod.url != blank -%}
                      <a href="{{ prod.url }}" class="hm-routine-step-card__btn">Shop Step {{ step_num }} →</a>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Fallback if no metaobject entries exist yet {%- endcomment -%}
          {%- assign step_names = 'Prep & Cleanse,Treat & Target,Hydrate & Plump,Seal & Protect' | split: ',' -%}
          {%- assign step_desc = 'Double cleanse to remove impurities and prep skin for actives.,Apply targeted serums with active ingredients for your skin concern.,Layer hydrating essences and toners to plump and balance.,Lock in moisture and protect the skin barrier.' | split: ',' -%}
          {%- for i in (1..4) -%}
            <div class="hm-routine-step-card" data-step="{{ i }}">
              <div class="hm-routine-step-card__header">
                <span class="hm-routine-step-card__number">Step {{ i }}</span>
                <h3 class="hm-routine-step-card__name">{{ step_names[forloop.index0] }}</h3>
              </div>
              <div class="hm-routine-step-card__body">
                <p class="hm-routine-step-card__story">{{ step_desc[forloop.index0] }}</p>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>

  {%- comment -%} ── BUNDLE CTA ── {%- endcomment -%}
  {%- if section.settings.bundle_product != blank -%}
    {%- assign bundle = section.settings.bundle_product -%}
    <section class="hm-routine-bundle">
      <div class="hm-routine-bundle__inner">
        <p class="hm-routine-eyebrow">Get The Full System</p>
        <h2 class="hm-routine-bundle__title">{{ section.settings.bundle_heading | default: 'The HARAMOON Glass Skin Bundle' }}</h2>
        <p class="hm-routine-bundle__text">{{ section.settings.bundle_text | default: 'All 4 steps. One box. Free shipping. Start your glass skin journey today.' }}</p>
        <a href="{{ bundle.url }}" class="hm-routine-bundle__btn">
          Shop the Bundle
          {%- if bundle.price -%}
            <span class="hm-routine-bundle__price"> — {{ bundle.price | money }}</span>
          {%- endif -%}
        </a>
      </div>
    </section>
  {%- else -%}
    <section class="hm-routine-bundle">
      <div class="hm-routine-bundle__inner">
        <p class="hm-routine-eyebrow">Get The Full System</p>
        <h2 class="hm-routine-bundle__title">{{ section.settings.bundle_heading | default: 'The HARAMOON Glass Skin Bundle' }}</h2>
        <p class="hm-routine-bundle__text">{{ section.settings.bundle_text | default: 'All 4 steps. One box. Free shipping. Start your glass skin journey today.' }}</p>
        <a href="{{ section.settings.bundle_url | default: '/collections/haramoon-korean-skincare' }}" class="hm-routine-bundle__btn">Shop the Bundle →</a>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ── HARAMOON BLOG ── {%- endcomment -%}
  {%- assign hm_blog = blogs['why-korean-skincare'] -%}
  {%- if hm_blog and hm_blog.articles.size > 0 -%}
    <section class="hm-routine-blog">
      <div class="hm-routine-blog__inner">
        <p class="hm-routine-eyebrow">The Science Behind It</p>
        <h2 class="hm-routine-blog__title">From The HARAMOON Blog</h2>
        <div class="hm-routine-blog__grid">
          {%- for article in hm_blog.articles limit: 3 -%}
            <a href="{{ article.url }}" class="hm-routine-blog-card">
              {%- if article.image -%}
                <div class="hm-routine-blog-card__image">
                  {{ article.image | image_url: width: 600 | image_tag: alt: article.title, loading: 'lazy' }}
                </div>
              {%- endif -%}
              <div class="hm-routine-blog-card__body">
                <p class="hm-routine-blog-card__date">{{ article.published_at | date: '%b %d, %Y' }}</p>
                <h3 class="hm-routine-blog-card__title">{{ article.title }}</h3>
                {%- if article.excerpt != blank -%}
                  <p class="hm-routine-blog-card__excerpt">{{ article.excerpt | strip_html | truncate: 90 }}</p>
                {%- endif -%}
                <span class="hm-routine-blog-card__read">Read More →</span>
              </div>
            </a>
          {%- endfor -%}
        </div>
        <div style="text-align:center;margin-top:32px;">
          <a href="{{ hm_blog.url }}" class="hm-routine-blog__all">View All HARAMOON Posts →</a>
        </div>
      </div>
    </section>
  {%- endif -%}

</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');

  .hm-routine-page {
    font-family: 'Poppins', sans-serif;
    background: #fff;
    color: #141615;
  }

  /* ── EYEBROW ── */
  .hm-routine-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #3498ff;
    margin: 0 0 14px;
  }

  /* ── HERO / PAS PROBLEM ── */
  .hm-routine-hero {
    background: linear-gradient(135deg, #0d1b3e 0%, #1a2a5e 50%, #0d1b3e 100%);
    padding: 100px 20px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hm-routine-hero::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(52,152,255,0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .hm-routine-hero__inner {
    max-width: 760px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .hm-routine-hero .hm-routine-eyebrow { color: #7ec8ff; }
  .hm-routine-hero__title {
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 800;
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 24px;
  }
  .hm-routine-hero__problem {
    font-size: clamp(15px, 1.5vw, 17px);
    color: rgba(255,255,255,0.75);
    line-height: 1.8;
    margin: 0;
  }

  /* ── AGITATE ── */
  .hm-routine-agitate {
    background: #f8f4f0;
    padding: 80px 20px;
    text-align: center;
  }
  .hm-routine-agitate__inner { max-width: 820px; margin: 0 auto; }
  .hm-routine-agitate__title {
    font-size: clamp(22px, 3vw, 36px);
    font-weight: 700;
    color: #141615;
    margin: 0 0 20px;
    line-height: 1.2;
  }
  .hm-routine-agitate__body {
    font-size: 16px;
    line-height: 1.8;
    color: #53585a;
    margin: 0 0 48px;
  }
  .hm-routine-agitate__stats {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }
  .hm-routine-stat { text-align: center; }
  .hm-routine-stat__number {
    display: block;
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 800;
    color: #3498ff;
    line-height: 1;
    margin-bottom: 6px;
  }
  .hm-routine-stat__label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #53585a;
  }

  /* ── STEPS SECTION ── */
  .hm-routine-steps-section {
    padding: 80px 20px;
    background: #fff;
  }
  .hm-routine-steps-section__inner { max-width: 1200px; margin: 0 auto; }
  .hm-routine-steps-section__title {
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 700;
    color: #141615;
    margin: 0 0 12px;
    text-align: center;
  }
  .hm-routine-steps-section__subtitle {
    font-size: 15px;
    color: #53585a;
    text-align: center;
    margin: 0 0 48px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  /* Progress indicator */
  .hm-routine-progress {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 56px;
    gap: 0;
  }
  .hm-routine-progress__item {
    display: flex;
    align-items: center;
  }
  .hm-routine-progress__circle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #3498ff, #0d6efd);
    color: #fff;
    font-size: 16px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(52,152,255,0.35);
    flex-shrink: 0;
  }
  .hm-routine-progress__line {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, #3498ff, rgba(52,152,255,0.2));
  }
  @media(max-width: 480px) { .hm-routine-progress__line { width: 30px; } }

  /* Step cards grid */
  .hm-routine-steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  @media(min-width: 768px) {
    .hm-routine-steps-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .hm-routine-step-card {
    border: 1px solid rgba(52,152,255,0.15);
    border-radius: 20px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
  }
  .hm-routine-step-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #3498ff, #a855f7, #3498ff);
    background-size: 200% 100%;
    animation: shimmer 3s ease infinite;
  }
  @keyframes shimmer {
    0% { background-position: 0% 0%; }
    100% { background-position: 200% 0%; }
  }
  .hm-routine-step-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(52,152,255,0.18);
  }
  .hm-routine-step-card__header {
    padding: 28px 28px 0;
  }
  .hm-routine-step-card__number {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #3498ff;
    display: block;
    margin-bottom: 6px;
  }
  .hm-routine-step-card__name {
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 700;
    color: #141615;
    margin: 0 0 8px;
    line-height: 1.2;
  }
  .hm-routine-step-card__highlight {
    font-size: 13px;
    color: #53585a;
    margin: 0 0 16px;
    line-height: 1.5;
  }
  .hm-routine-step-card__image {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .hm-routine-step-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .hm-routine-step-card:hover .hm-routine-step-card__image img {
    transform: scale(1.04);
  }
  .hm-routine-step-card__body {
    padding: 20px 28px;
  }
  .hm-routine-step-card__story {
    font-size: 14px;
    line-height: 1.75;
    color: #53585a;
    margin: 0 0 16px;
  }
  .hm-routine-step-card__label {
    display: block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #3498ff;
    margin-bottom: 6px;
  }
  .hm-routine-step-card__claims {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
  }
  .hm-routine-step-card__claims li {
    font-size: 13px;
    color: #141615;
    padding: 4px 0 4px 18px;
    position: relative;
    line-height: 1.5;
  }
  .hm-routine-step-card__claims li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #3498ff;
    font-weight: 700;
  }
  .hm-routine-step-card__benefits,
  .hm-routine-step-card__clinical {
    margin-bottom: 16px;
    font-size: 13px;
    color: #53585a;
    line-height: 1.6;
  }
  .hm-routine-ingredient-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 6px;
  }
  .hm-routine-ingredient-chip {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    background: rgba(52,152,255,0.08);
    border: 1px solid rgba(52,152,255,0.2);
    color: #0d6efd;
  }
  .hm-routine-ingredient-chip--link {
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .hm-routine-ingredient-chip--link:hover {
    background: rgba(52,152,255,0.18);
    border-color: rgba(52,152,255,0.5);
    transform: scale(1.04);
  }
  .hm-routine-step-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .hm-routine-step-card__meta-item {
    font-size: 11px;
    color: #53585a;
    font-weight: 500;
  }
  .hm-routine-step-card__cta {
    padding: 0 28px 24px;
  }
  .hm-routine-step-card__btn {
    display: inline-block;
    padding: 10px 24px;
    background: #141615;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .hm-routine-step-card__btn:hover {
    background: #3498ff;
    transform: translateY(-2px);
  }

  /* ── BUNDLE CTA ── */
  .hm-routine-bundle {
    background: linear-gradient(135deg, #0d1b3e 0%, #1a2a5e 100%);
    padding: 80px 20px;
    text-align: center;
  }
  .hm-routine-bundle__inner { max-width: 640px; margin: 0 auto; }
  .hm-routine-bundle .hm-routine-eyebrow { color: #7ec8ff; }
  .hm-routine-bundle__title {
    font-size: clamp(24px, 3vw, 38px);
    font-weight: 700;
    color: #fff;
    margin: 0 0 16px;
    line-height: 1.2;
  }
  .hm-routine-bundle__text {
    font-size: 15px;
    color: rgba(255,255,255,0.75);
    margin: 0 0 32px;
    line-height: 1.7;
  }
  .hm-routine-bundle__btn {
    display: inline-block;
    padding: 16px 40px;
    background: #f5e642;
    color: #141615;
