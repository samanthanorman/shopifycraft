{% doc %}
  @prompt
    --- Create a premium ingredient spotlight section for a K-beauty skincare product page. Display 5-6 key active ingredients as large editorial cards in a 2-column grid on desktop, single column on mobile. Each card contains: an oversized ingredient name in a thin elegant serif display font (e.g. "Niacinamide", "Hyaluronic Acid", "Madecassoside", "Sea Buckthorn Oil", "Ceramides", "Palmitoyl Tripeptide-5"), a one-line benefit subtitle in small caps accent color (e.g. "Brightening + Pore Refining"), and a 2-3 sentence description of what the ingredient does for skin. Add an optional small uploadable image or botanical icon per card. Cards should have a soft hover lift with a very subtle shadow. Use a warm cream or soft sage green background. Include an editable bold editorial section title (e.g. "What's Inside") and a short subtitle. All ingredient names, subtitles, descriptions, and images must be editable in theme settings as repeatable blocks — minimum 6 blocks. Add ChemicalSubstance schema JSON-LD in a script tag for each ingredient with "name" and "description" properties, nested inside the parent Product schema context. Animate cards in on scroll with a gentle staggered fade-up. Premium Mamonde-level aesthetic — generous whitespace, no clutter.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ingredient-spotlight-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-ingredient-spotlight-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-ingredient-spotlight-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-ingredient-spotlight-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.2;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    letter-spacing: -0.02em;
  }

  .ai-ingredient-spotlight-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    line-height: 1.6;
    color: {{ block.settings.subtitle_color }};
    max-width: 700px;
    margin: 0 auto;
  }

  .ai-ingredient-spotlight-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.card_gap }}px;
    margin-top: {{ block.settings.grid_top_spacing }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-ingredient-spotlight-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .ai-ingredient-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    opacity: 0;
    transform: translateY(30px);
  }

  .ai-ingredient-card-{{ ai_gen_id }}.ai-ingredient-card-visible-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-ingredient-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .ai-ingredient-card-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    margin: 0 auto {{ block.settings.image_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-ingredient-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-ingredient-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.3;
  }

  .ai-ingredient-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-ingredient-card-name-{{ ai_gen_id }} {
    font-family: {{ block.settings.ingredient_font.family }}, {{ block.settings.ingredient_font.fallback_families }};
    font-weight: {{ block.settings.ingredient_font.weight }};
    font-size: {{ block.settings.ingredient_name_size }}px;
    line-height: 1.2;
    color: {{ block.settings.ingredient_name_color }};
    margin: 0 0 {{ block.settings.name_spacing }}px;
    text-align: center;
    letter-spacing: -0.01em;
  }

  .ai-ingredient-card-benefit-{{ ai_gen_id }} {
    font-size: {{ block.settings.benefit_size }}px;
    line-height: 1.4;
    color: {{ block.settings.accent_color }};
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
    margin: 0 0 {{ block.settings.benefit_spacing }}px;
    text-align: center;
  }

  .ai-ingredient-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.7;
    color: {{ block.settings.description_color }};
    text-align: center;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-ingredient-spotlight-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }

    .ai-ingredient-card-name-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.ingredient_name_size }}px * 0.75);
    }

    .ai-ingredient-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<ingredient-spotlight-{{ ai_gen_id }}
  class="ai-ingredient-spotlight-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-ingredient-spotlight-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_subtitle != blank %}
      <div class="ai-ingredient-spotlight-header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-ingredient-spotlight-title-{{ ai_gen_id }}">
            {{ block.settings.section_title }}
          </h2>
        {% endif %}
        {% if block.settings.section_subtitle != blank %}
          <div class="ai-ingredient-spotlight-subtitle-{{ ai_gen_id }}">
            {{ block.settings.section_subtitle }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-ingredient-spotlight-grid-{{ ai_gen_id }}">
      {% liquid
        assign ingredient_1_name = block.settings.ingredient_1_name
        assign ingredient_1_benefit = block.settings.ingredient_1_benefit
        assign ingredient_1_description = block.settings.ingredient_1_description
        assign ingredient_1_image = block.settings.ingredient_1_image

        assign ingredient_2_name = block.settings.ingredient_2_name
        assign ingredient_2_benefit = block.settings.ingredient_2_benefit
        assign ingredient_2_description = block.settings.ingredient_2_description
        assign ingredient_2_image = block.settings.ingredient_2_image

        assign ingredient_3_name = block.settings.ingredient_3_name
        assign ingredient_3_benefit = block.settings.ingredient_3_benefit
        assign ingredient_3_description = block.settings.ingredient_3_description
        assign ingredient_3_image = block.settings.ingredient_3_image

        assign ingredient_4_name = block.settings.ingredient_4_name
        assign ingredient_4_benefit = block.settings.ingredient_4_benefit
        assign ingredient_4_description = block.settings.ingredient_4_description
        assign ingredient_4_image = block.settings.ingredient_4_image

        assign ingredient_5_name = block.settings.ingredient_5_name
        assign ingredient_5_benefit = block.settings.ingredient_5_benefit
        assign ingredient_5_description = block.settings.ingredient_5_description
        assign ingredient_5_image = block.settings.ingredient_5_image

        assign ingredient_6_name = block.settings.ingredient_6_name
        assign ingredient_6_benefit = block.settings.ingredient_6_benefit
        assign ingredient_6_description = block.settings.ingredient_6_description
        assign ingredient_6_image = block.settings.ingredient_6_image
      %}

      {% for i in (1..6) %}
        {% liquid
          case i
            when 1
              assign name = ingredient_1_name
              assign benefit = ingredient_1_benefit
              assign description = ingredient_1_description
              assign image = ingredient_1_image
            when 2
              assign name = ingredient_2_name
              assign benefit = ingredient_2_benefit
              assign description = ingredient_2_description
              assign image = ingredient_2_image
            when 3
              assign name = ingredient_3_name
              assign benefit = ingredient_3_benefit
              assign description = ingredient_3_description
              assign image = ingredient_3_image
            when 4
              assign name = ingredient_4_name
              assign benefit = ingredient_4_benefit
              assign description = ingredient_4_description
              assign image = ingredient_4_image
            when 5
              assign name = ingredient_5_name
              assign benefit = ingredient_5_benefit
              assign description = ingredient_5_description
              assign image = ingredient_5_image
            when 6
              assign name = ingredient_6_name
              assign benefit = ingredient_6_benefit
              assign description = ingredient_6_description
              assign image = ingredient_6_image
          endcase
        %}

        {% if name != blank %}
          <div
            class="ai-ingredient-card-{{ ai_gen_id }}"
            data-ingredient-card
            data-ingredient-name="{{ name | escape }}"
            data-ingredient-description="{{ description | escape }}"
            style="transition-delay: {{ forloop.index | times: 0.1 }}s;"
          >
            {% if image != blank %}
              <div class="ai-ingredient-card-image-wrapper-{{ ai_gen_id }}">
                <img
                  src="{{ image | image_url: width: 200 }}"
                  alt="{{ name | escape }}"
                  class="ai-ingredient-card-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              </div>
            {% elsif block.settings.show_placeholder_icon %}
              <div class="ai-ingredient-card-image-wrapper-{{ ai_gen_id }}">
                <div class="ai-ingredient-card-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              </div>
            {% endif %}

            <h3 class="ai-ingredient-card-name-{{ ai_gen_id }}">
              {{ name }}
            </h3>

            {% if benefit != blank %}
              <div class="ai-ingredient-card-benefit-{{ ai_gen_id }}">
                {{ benefit }}
              </div>
            {% endif %}

            {% if description != blank %}
              <div class="ai-ingredient-card-description-{{ ai_gen_id }}">
                {{ description }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</ingredient-spotlight-{{ ai_gen_id }}>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": [
    {% assign ingredient_count = 0 %}
    {% for i in (1..6) %}
      {% liquid
        case i
          when 1
            assign name = block.settings.ingredient_1_name
            assign description = block.settings.ingredient_1_description
          when 2
            assign name = block.settings.ingredient_2_name
            assign description = block.settings.ingredient_2_description
          when 3
            assign name = block.settings.ingredient_3_name
            assign description = block.settings.ingredient_3_description
          when 4
            assign name = block.settings.ingredient_4_name
            assign description = block.settings.ingredient_4_description
          when 5
            assign name = block.settings.ingredient_5_name
            assign description = block.settings.ingredient_5_description
          when 6
            assign name = block.settings.ingredient_6_name
            assign description = block.settings.ingredient_6_description
        endcase
      %}
      {% if name != blank %}
        {% if ingredient_count > 0 %},{% endif %}
        {
          "@type": "ChemicalSubstance",
          "name": {{ name | json }},
          "description": {{ description | json }}
        }
        {% assign ingredient_count = ingredient_count | plus: 1 %}
      {% endif %}
    {% endfor %}
  ]
}
</script>

<script>
  (function() {
    class IngredientSpotlight{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.cards = this.querySelectorAll('[data-ingredient-card]');
        this.observer = null;
      }

      connectedCallback() {
        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px 0px -100px 0px',
          threshold: 0.1
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('ai-ingredient-card-visible-{{ ai_gen_id }}');
              this.observer.unobserve(entry.target);
            }
          });
        }, options);

        this.cards.forEach((card) => {
          this.observer.observe(card);
        });
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('ingredient-spotlight-{{ ai_gen_id }}', IngredientSpotlight{{ ai_gen_id }});
  })();
</script>

