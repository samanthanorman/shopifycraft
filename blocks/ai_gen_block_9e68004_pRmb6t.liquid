  class IngredientTaxonomy {
    constructor(containerId, data) {
      this.containerId = containerId;
      this.data = data;
      this.width = 0;
      this.height = 0;
      this.svg = null;
      this.g = null;
      this.tree = null;
      this.root = null;
      this.tooltip = d3.select(`#tooltip-${containerId.split('-')[2]}`);
      
      this.init();
    }

    init() {
      this.setupDimensions();
      this.setupSVG();
      this.setupTree();
      this.setupControls();
      this.render();
      this.setupResize();
    }

    setupDimensions() {
      const container = document.getElementById(this.containerId);
      this.width = container.clientWidth;
      this.height = container.clientHeight;
    }

    setupSVG() {
      const svgId = this.containerId.replace('container', 'svg');
      this.svg = d3.select(`#${svgId}`)
        .attr('width', this.width)
        .attr('height', this.height);

      this.g = this.svg.append('g')
        .attr('transform', `translate(${this.width / 2}, 50)`);

      const zoom = d3.zoom()
        .scaleExtent([0.1, 3])
        .on('zoom', (event) => {
          this.g.attr('transform', event.transform);
        });

      this.svg.call(zoom);
    }

    setupTree() {
      this.tree = d3.tree().size([this.width - 100, this.height - 100]);
      this.root = d3.hierarchy(this.data);
      this.root.x0 = 0;
      this.root.y0 = 0;

      if (this.root.children) {
        this.root.children.forEach(this.collapse.bind(this));
      }
    }

    setupControls() {
      const idSuffix = this.containerId.split('-')[2];
      
      d3.select(`#expand-all-${idSuffix}`)
        .on('click', () => this.expandAll());
      
      d3.select(`#collapse-all-${idSuffix}`)
        .on('click', () => this.collapseAll());
      
      d3.select(`#reset-${idSuffix}`)
        .on('click', () => this.reset());
    }

    getNodeColor(d) {
      const colors = {
        0: '{{ block.settings.primary_color }}',
        1: '{{ block.settings.dark_color }}',
        2: '#000000',
        3: '#ffffff'
      };
      return colors[d.data.level] || '#cccccc';
    }

    getTextColor(d) {
      return d.data.level === 3 ? '#000000' : '#ffffff';
    }

    collapse(d) {
      if (d.children) {
        d._children = d.children;
        d._children.forEach(this.collapse.bind(this));
        d.children = null;
      }
    }

    expand(d) {
      if (d._children) {
        d.children = d._children;
        d._children = null;
      }
    }

    expandAll() {
      this.root.descendants().forEach(this.expand.bind(this));
      this.update(this.root);
    }

    collapseAll() {
      this.root.descendants().forEach(this.collapse.bind(this));
      this.update(this.root);
    }

    reset() {
      this.root.descendants().forEach(this.collapse.bind(this));
      if (this.root.children) {
        this.root.children.forEach(d => {
          if (d._children) {
            d.children = d._children;
            d._children = null;
          }
        });
      }
      this.update(this.root);
    }

    click(event, d) {
      if (d.children) {
        d._children = d.children;
        d.children = null;
      } else {
        d.children = d._children;
        d._children = null;
      }
      this.update(d);
    }

    showTooltip(event, d) {
      const tooltipTitle = this.tooltip.select('.ai-ingredient-taxonomy__tooltip-title-{{ ai_gen_id }}');
      const tooltipContent = this.tooltip.select('.ai-ingredient-taxonomy__tooltip-content-{{ ai_gen_id }}');
      
      tooltipTitle.text(d.data.name);
      tooltipContent.html(`
        <strong>Function:</strong> ${d.data.function}<br>
        <strong>Origin:</strong> ${d.data.origin}<br>
        <strong>Description:</strong> ${d.data.description}<br>
        <strong>Derivatives:</strong> ${d.data.derivatives}
      `);

      this.tooltip
        .style('opacity', 1)
        .style('left', (event.pageX + 10) + 'px')
        .style('top', (event.pageY - 10) + 'px');
    }

    hideTooltip() {
      this.tooltip.style('opacity', 0);
    }

    handleIngredientClick(event, d) {
      if (d.data.level === 3) {
        const ingredientName = d.data.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
        const url = `/pages/ingredients/${ingredientName}`;
        window.open(url, '_blank');
      }
    }

    update(source) {
      const treeData = this.tree(this.root);
      const nodes = treeData.descendants();
      const links = treeData.descendants().slice(1);

      let i = 0;
      nodes.forEach(d => {
        d.y = d.depth * 180;
        d.id = d.id || ++i;
      });

      const node = this.g.selectAll('g.node')
        .data(nodes, d => d.id);

      const nodeEnter = node.enter().append('g')
        .attr('class', 'node')
        .attr('transform', d => `translate(${source.x0},${source.y0})`)
        .on('click', (event, d) => this.click(event, d))
        .on('mouseover', (event, d) => this.showTooltip(event, d))
        .on('mouseout', () => this.hideTooltip());

      nodeEnter.append('circle')
        .attr('r', 1e-6)
        .style('fill', d => d._children ? this.getNodeColor(d) : '#fff')
        .style('stroke', d => this.getNodeColor(d));

      nodeEnter.append('text')
        .attr('dy', '.35em')
        .attr('x', d => d.children || d._children ? -13 : 13)
        .attr('text-anchor', d => d.children || d._children ? 'end' : 'start')
        .text(d => d.data.name)
        .style('fill', d => this.getTextColor(d))
        .style('fill-opacity', 1e-6)
        .classed('clickable', d => d.data.level === 3)
        .on('click', (event, d) => {
          event.stopPropagation();
          if (d.data.level === 3) {
            this.handleIngredientClick(event, d);
          } else {
            this.click(event, d);
          }
        });

      const nodeUpdate = nodeEnter.merge(node);

      nodeUpdate.transition()
        .duration(750)
        .attr('transform', d => `translate(${d.x},${d.y})`);

      nodeUpdate.select('circle')
        .transition()
        .duration(750)
        .attr('r', 8)
        .style('fill', d => d._children ? this.getNodeColor(d) : '#fff')
        .style('stroke', d => this.getNodeColor(d));

      nodeUpdate.select('text')
        .transition()
        .duration(750)
        .style('fill-opacity', 1)
        .style('fill', d => d._children ? '#fff' : this.getTextColor(d));

      const nodeExit = node.exit().transition()
        .duration(750)
        .attr('transform', d => `translate(${source.x},${source.y})`)
        .remove();

      nodeExit.select('circle')
        .attr('r', 1e-6);

      nodeExit.select('text')
        .style('fill-opacity', 1e-6);

      const link = this.g.selectAll('path.link')
        .data(links, d => d.id);

      const linkEnter = link.enter().insert('path', 'g')
        .attr('class', 'link')
        .attr('d', d => {
          const o = {x: source.x0, y: source.y0};
          return this.diagonal(o, o);
        });

      const linkUpdate = linkEnter.merge(link);

      linkUpdate.transition()
        .duration(750)
        .attr('d', d => this.diagonal(d, d.parent));

      link.exit().transition()
        .duration(750)
        .attr('d', d => {
          const o = {x: source.x, y: source.y};
          return this.diagonal(o, o);
        })
        .remove();

      nodes.forEach(d => {
        d.x0 = d.x;
        d.y0 = d.y;
      });
    }

    diagonal(s, d) {
      return `M ${s.x} ${s.y}
              C ${(s.x + d.x) / 2} ${s.y},
                ${(s.x + d.x) / 2} ${d.y},
                ${d.x} ${d.y}`;
    }

    render() {
      this.update(this.root);
    }

    setupResize() {
      window.addEventListener('resize', () => {
        this.setupDimensions();
        this.svg.attr('width', this.width).attr('height', this.height);
        this.tree.size([this.width - 100, this.height - 100]);
        this.update(this.root);
      });
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    new IngredientTaxonomy('tree-container-{{ ai_gen_id }}', taxonomyData);
  });
})();
</script>

