{% comment %}
  HARAMOON 101 — Elite Metaobject Page
  Template: metaobject/haramoon_101.json
  URL pattern: /metaobjects/haramoon_101/[handle]
  Uses: metaobject variable (haramoon_101 type)
{% endcomment %}

{%- assign m = metaobject -%}
{%- assign step = m.routine_step_number.value | plus: 0 -%}
{%- assign step_labels = "Cleanse,Tone,Treat,Moisturize" | split: "," -%}
{%- assign step_emojis = "🌊,💧,✨,🌙" | split: "," -%}
{%- assign step_name = step_labels[step | minus: 1] | default: "Routine" -%}
{%- assign step_emoji = step_emojis[step | minus: 1] | default: "✨" -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ m.product_name_type.value | json }},
  "description": {{ m.product_highlight.value | json }},
  "brand": { "@type": "Brand", "name": "HARAMOON" },
  "url": "{{ request.origin }}{{ metaobject.system.url }}",
  {% if m.images.value.first %}"image": "{{ m.images.value.first | image_url: width: 800 }}",{% endif %}
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "url": "{{ request.origin }}{{ m.product.value.url }}"
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ request.origin }}/" },
    { "@type": "ListItem", "position": 2, "name": "HARAMOON Glass Skin Routine", "item": "{{ request.origin }}/pages/complete-routine" },
    { "@type": "ListItem", "position": 3, "name": {{ m.product_name_type.value | json }}, "item": "{{ request.origin }}{{ metaobject.system.url }}" }
  ]
}
</script>

<style>
  .hm-page { background: #050d1a; color: #fafafa; font-family: 'Poppins', sans-serif; overflow-x: hidden; }
  .hm-hero {
    position: relative; min-height: 85vh;
    display: grid; grid-template-columns: 1fr 1fr;
    align-items: center; gap: 4rem; padding: 5rem 5rem 3rem;
    overflow: hidden;
  }
  .hm-hero::before {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse at 25% 50%, rgba(0,212,255,0.1) 0%, transparent 55%),
                radial-gradient(ellipse at 75% 20%, rgba(212,175,55,0.07) 0%, transparent 45%);
  }
  .hm-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: linear-gradient(135deg, #00d4ff, #0a2463);
    color: #fff; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.15em;
    text-transform: uppercase; padding: 6px 18px; border-radius: 100px;
    margin-bottom: 1.25rem; animation: badge-pulse 2.5s ease-in-out infinite;
  }
  @keyframes badge-pulse { 0%,100%{box-shadow:0 0 0 0 rgba(0,212,255,0.35)} 50%{box-shadow:0 0 0 10px rgba(0,212,255,0)} }
  .hm-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem); font-weight: 800; line-height: 1.1; margin: 0 0 1rem;
    background: linear-gradient(135deg, #fff 0%, #00d4ff 45%, #d4af37 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .hm-caption { font-size: 1rem; color: rgba(255,255,255,0.55); font-style: italic; margin: 0 0 1rem; line-height: 1.6; }
  .hm-highlight { font-size: 1.05rem; color: rgba(255,255,255,0.8); line-height: 1.75; margin: 0 0 2rem; }
  .hm-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hm-btn { display: inline-block; padding: 13px 28px; border-radius: 50px; font-weight: 700; font-size: 0.88rem; text-decoration: none; transition: all 0.3s ease; }
  .hm-btn-primary { background: linear-gradient(135deg, #00d4ff, #0070f3); color: #fff; box-shadow: 0 4px 20px rgba(0,212,255,0.3); }
  .hm-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,212,255,0.5); }
  .hm-btn-ghost { background: transparent; color: #00d4ff; border: 1.5px solid rgba(0,212,255,0.35); }
  .hm-btn-ghost:hover { background: rgba(0,212,255,0.08); border-color: #00d4ff; }

  .hm-visual { position: relative; display: flex; justify-content: center; align-items: center; }
  .hm-img-orb {
    position: relative; width: 360px; height: 360px; border-radius: 50%; overflow: hidden;
    box-shadow: 0 0 60px rgba(0,212,255,0.2), 0 0 120px rgba(212,175,55,0.08);
    animation: float 7s ease-in-out infinite;
  }
  @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-14px)} }
  .hm-img-orb img { width: 100%; height: 100%; object-fit: cover; }
  .hm-ring { position: absolute; inset: -18px; border-radius: 50%; border: 1px solid rgba(0,212,255,0.18); animation: spin 22s linear infinite; }
  .hm-ring-2 { position: absolute; inset: -36px; border-radius: 50%; border: 1px dashed rgba(212,175,55,0.12); animation: spin 38s linear infinite reverse; }
  @keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

  .hm-steps-bar {
    background: rgba(10,36,99,0.7); border-top: 1px solid rgba(0,212,255,0.12);
    border-bottom: 1px solid rgba(0,212,255,0.12); padding: 1.75rem 5rem;
  }
  .hm-steps-label { text-align: center; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 1.25rem; }
  .hm-steps-row { display: flex; justify-content: center; align-items: center; }
  .hm-step-item { display: flex; flex-direction: column; align-items: center; gap: 7px; flex: 1; max-width: 130px; position: relative; text-decoration: none; }
  .hm-step-item:not(:last-child)::after { content: ''; position: absolute; top: 20px; left: 58%; width: 84%; height: 1px; background: linear-gradient(90deg, rgba(0,212,255,0.25), transparent); }
  .hm-step-dot { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; background: rgba(255,255,255,0.04); border: 1.5px solid rgba(255,255,255,0.08); transition: all 0.3s; }
  .hm-step-item.active .hm-step-dot { background: linear-gradient(135deg, #00d4ff, #0070f3); border-color: #00d4ff; box-shadow: 0 0 20px rgba(0,212,255,0.5); animation: badge-pulse 2s ease-in-out infinite; }
  .hm-step-text { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.3); text-align: center; }
  .hm-step-item.active .hm-step-text { color: #00d4ff; }

  .hm-sec { padding: 4rem 5rem; }
  .hm-sec-eyebrow { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #00d4ff; margin-bottom: 0.5rem; }
  .hm-sec-heading { font-size: clamp(1.4rem, 2.5vw, 2rem); font-weight: 800; margin: 0 0 1.75rem; background: linear-gradient(135deg, #fff 55%, #00d4ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

  .hm-claims-box { background: linear-gradient(135deg, rgba(10,36,99,0.45), rgba(0,212,255,0.04)); border-radius: 18px; padding: 2.5rem; }
  .hm-claims-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 1rem; margin-top: 1.5rem; }
  .hm-claim { display: flex; align-items: center; gap: 10px; background: rgba(0,212,255,0.07); border: 1px solid rgba(0,212,255,0.18); border-radius: 10px; padding: 12px 16px; font-size: 0.83rem; font-weight: 600; color: rgba(255,255,255,0.88); transition: all 0.25s; }
  .hm-claim:hover { background: rgba(0,212,255,0.14); transform: translateY(-2px); }
  .hm-claim::before { content: '✓'; color: #00d4ff; font-weight: 800; }

  .hm-body-text { font-size: 1rem; line-height: 1.8; color: rgba(255,255,255,0.78); white-space: pre-line; }
  .hm-clinical-box { background: linear-gradient(135deg, rgba(212,175,55,0.05), rgba(10,36,99,0.35)); border: 1px solid rgba(212,175,55,0.18); border-radius: 18px; padding: 2.5rem; }
  .hm-clinical-box .rte { color: rgba(255,255,255,0.82); line-height: 1.8; }
  .hm-clinical-box .rte h3 { color: #d4af37; }

  .hm-howto-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
  .hm-meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.85rem; }
  .hm-meta-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 10px; padding: 0.9rem 1.1rem; }
  .hm-meta-lbl { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 3px; }
  .hm-meta-val { font-size: 0.88rem; font-weight: 600; color: rgba(255,255,255,0.88); }

  .hm-layering-box { background: linear-gradient(135deg, rgba(255,107,157,0.05), rgba(10,36,99,0.35)); border: 1px solid rgba(255,107,157,0.12); border-radius: 18px; padding: 2.5rem; }
  .hm-layering-box .rte { color: rgba(255,255,255,0.82); line-height: 1.8; }

  .hm-chips { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 1.25rem; }
  .hm-chip { display: inline-flex; align-items: center; gap: 6px; background: rgba(0,212,255,0.06); border: 1px solid rgba(0,212,255,0.18); border-radius: 100px; padding: 7px 15px; font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.82); text-decoration: none; transition: all 0.22s; }
  .hm-chip:hover { background: rgba(0,212,255,0.16); border-color: #00d4ff; color: #fff; transform: translateY(-2px); box-shadow: 0 4px 14px rgba(0,212,255,0.22); }
  .hm-chip-dot { width: 5px; height: 5px; border-radius: 50%; background: #00d4ff; }

  .hm-inci { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 10px; padding: 1.25rem 1.75rem; margin-top: 1.5rem; }
  .hm-inci details summary { font-size: 0.82rem; font-weight: 600; color: rgba(255,255,255,0.4); cursor: pointer; list-style: none; display: flex; align-items: center; gap: 8px; }
  .hm-inci details summary::before { content: '+'; font-size: 1.1rem; color: #00d4ff; }
  .hm-inci details[open] summary::before { content: '−'; }
  .hm-inci .inci-body { font-size: 0.75rem; line-height: 1.8; color: rgba(255,255,255,0.4); margin-top: 0.75rem; white-space: pre-line; }

  .hm-caution { background: rgba(255,107,157,0.04); border: 1px solid rgba(255,107,157,0.18); border-radius: 10px; padding: 1.25rem 1.75rem; font-size: 0.83rem; line-height: 1.7; color: rgba(255,255,255,0.6); }
  .hm-caution-lbl { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,107,157,0.75); margin-bottom: 6px; }

  .hm-blog-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; margin-top: 1.75rem; }
  .hm-blog-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; overflow: hidden; text-decoration: none; transition: all 0.3s; display: flex; flex-direction: column; }
  .hm-blog-card:hover { transform: translateY(-4px); border-color: rgba(0,212,255,0.28); box-shadow: 0 8px 28px rgba(0,212,255,0.09); }
  .hm-blog-card img { width: 100%; height: 150px; object-fit: cover; }
  .hm-blog-card-body { padding: 1.1rem; flex: 1; }
  .hm-blog-card-tag { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #00d4ff; margin-bottom: 5px; }
  .hm-blog-card-title { font-size: 0.9rem; font-weight: 700; color: rgba(255,255,255,0.88); line-height: 1.4; margin: 0; }

  .hm-cta-section { text-align: center; padding: 5rem 4rem; background: linear-gradient(135deg, rgba(10,36,99,0.55), rgba(0,212,255,0.04)); border-top: 1px solid rgba(0,212,255,0.1); }
  .hm-cta-title { font-size: clamp(1.4rem, 2.5vw, 2.2rem); font-weight: 800; margin-bottom: 0.75rem; }
  .hm-cta-sub { color: rgba(255,255,255,0.55); margin-bottom: 2.25rem; font-size: 1rem; }
  .hm-cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  .hm-breadcrumb { padding: 1.5rem 5rem 0; font-size: 0.75rem; color: rgba(255,255,255,0.3); display: flex; align-items: center; gap: 7px; flex-wrap: wrap; }
  .hm-breadcrumb a { color: rgba(0,212,255,0.55); text-decoration: none; }
  .hm-breadcrumb a:hover { color: #00d4ff; }

  @media (max-width: 768px) {
    .hm-hero { grid-template-columns: 1fr; padding: 3.5rem 1.5rem 2rem; min-height: auto; gap: 2rem; }
    .hm-visual { order: -1; }
    .hm-img-orb { width: 240px; height: 240px; }
    .hm-sec { padding: 3rem 1.5rem; }
    .hm-steps-bar { padding: 1.5rem; }
    .hm-howto-grid { grid-template-columns: 1fr; }
    .hm-breadcrumb { padding: 1rem 1.5rem 0; }
    .hm-cta-section { padding: 3.5rem 1.5rem; }
    .hm-claims-box, .hm-clinical-box, .hm-layering-box { padding: 1.75rem; }
  }
</style>

<div class="hm-page">

  <nav class="hm-breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> <span>›</span>
    <a href="/pages/complete-routine">HARAMOON Routine</a> <span>›</span>
    <span>{{ m.product_name_type.value }}</span>
  </nav>

  <section class="hm-hero">
    <div>
      <div class="hm-badge">{{ step_emoji }} Step {{ step }} · {{ step_name }}</div>
      <h1 class="hm-title">{{ m.product_name_type.value }}</h1>
      {%- if m.product_caption.value != blank -%}<p class="hm-caption">{{ m.product_caption.value }}</p>{%- endif -%}
      {%- if m.product_highlight.value != blank -%}<p class="hm-highlight">{{ m.product_highlight.value }}</p>{%- endif -%}
      <div class="hm-ctas">
        {%- if m.product.value != blank -%}<a href="{{ m.product.value.url }}" class="hm-btn hm-btn-primary">Shop Now →</a>{%- endif -%}
        <a href="/pages/complete-routine" class="hm-btn hm-btn-ghost">Full Routine</a>
      </div>
    </div>
    <div class="hm-visual">
      <div class="hm-img-orb">
        {%- if m.images.value.first -%}
          <img src="{{ m.images.value.first | image_url: width: 600 }}" alt="{{ m.product_name_type.value }}" loading="eager">
        {%- elsif m.product.value.featured_image -%}
          <img src="{{ m.product.value.featured_image | image_url: width: 600 }}" alt="{{ m.product_name_type.value }}" loading="eager">
        {%- endif -%}
      </div>
      <div class="hm-ring"></div>
      <div class="hm-ring-2"></div>
    </div>
  </section>

  <div class="hm-steps-bar">
    <p class="hm-steps-label">The HARAMOON 4-Step Glass Skin Routine</p>
    <div class="hm-steps-row">
      {%- assign s_labels = "Cleanse,Tone,Treat,Moisturize" | split: "," -%}
      {%- assign s_emojis = "🌊,💧,✨,🌙" | split: "," -%}
      {%- for i in (1..4) -%}
        {%- assign is_active = "" -%}
        {%- if i == step -%}{%- assign is_active = "active" -%}{%- endif -%}
        <a href="/pages/complete-routine#step-{{ i }}" class="hm-step-item {{ is_active }}">
          <div class="hm-step-dot">{{ s_emojis[forloop.index0] }}</div>
          <span class="hm-step-text">{{ s_labels[forloop.index0] }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>

  {%- if m.key_claims.value != blank -%}
  <section class="hm-sec">
    <div class="hm-claims-box">
      <p class="hm-sec-eyebrow">What It Delivers</p>
      <h2 class="hm-sec-heading">Key Claims</h2>
      <div class="hm-claims-grid">
        {%- for claim in m.key_claims.value -%}<div class="hm-claim">{{ claim }}</div>{%- endfor -%}
      </div>
    </div>
  </section>
  {%- endif -%}

  {%- if m.skin_care_benefits.value != blank -%}
  <section class="hm-sec" style="padding-top:0">
    <p class="hm-sec-eyebrow">Why Your Skin Loves It</p>
    <h2 class="hm-sec-heading">Skin Benefits</h2>
    <p class="hm-body-text">{{ m.skin_care_benefits.value }}</p>
  </section>
  {%- endif -%}

  {%- if m.clinical_results.value != blank -%}
  <section class="hm-sec" style="padding-top:0">
    <p class="hm-sec-eyebrow">Backed by Science</p>
    <h2 class="hm-sec-heading">Clinical Results</h2>
    <div class="hm-clinical-box"><div class="rte">{{ m.clinical_results.value }}</div></div>
  </section>
  {%- endif -%}

  <section class="hm-sec" style="background:rgba(255,255,255,0.02);border-top:1px solid rgba(255,255,255,0.05);border-bottom:1px solid rgba(255,255,255,0.05)">
    <p class="hm-sec-eyebrow">Application Guide</p>
    <h2 class="hm-sec-heading">How to Use</h2>
    <div class="hm-howto-grid">
      <div>
        {%- if m.how_to_use.value != blank -%}<p class="hm-body-text">{{ m.how_to_use.value }}</p>{%- endif -%}
      </div>
      <div class="hm-meta-grid">
        {%- if m.texture_type.value != blank -%}<div class="hm-meta-card"><div class="hm-meta-lbl">Texture</div><div class="hm-meta-val">{{ m.texture_type.value }}</div></div>{%- endif -%}
        {%- if m.finish_type.value != blank -%}<div class="hm-meta-card"><div class="hm-meta-lbl">Finish</div><div class="hm-meta-val">{{ m.finish_type.value }}</div></div>{%- endif -%}
        {%- if m.absorption_time.value != blank -%}<div class="hm-meta-card"><div class="hm-meta-lbl">Absorbs In</div><div class="hm-meta-val">{{ m.absorption_time.value }}</div></div>{%- endif -%}
        {%- if m.ph.value != blank -%}<div class="hm-meta-card"><div class="hm-meta-lbl">pH</div><div class="hm-meta-val">{{ m.ph.value }}</div></div>{%- endif -%}
        {%- if m.application_method.value != blank -%}<div class="hm-meta-card"><div class="hm-meta-lbl">Application</div><div class="hm-meta-val">{{ m.application_method.value }}</div></div>{%- endif -%}
        {%- if m.best_for_time_of_day.value != blank -%}<div class="hm-meta-card"><div class="hm-meta-lbl">Best Time</div><div class="hm-meta-val">{{ m.best_for_time_of_day.value | join: " · " }}</div></div>{%- endif -%}
      </div>
    </div>
  </section>

  {%- if m.layering_tips.value != blank -%}
  <section class="hm-sec">
    <p class="hm-sec-eyebrow">Layer Like a Pro</p>
    <h2 class="hm-sec-heading">Layering Tips</h2>
    <div class="hm-layering-box"><div class="rte">{{ m.layering_tips.value }}</div></div>
  </section>
  {%- endif -%}

  {%- if m.ingredient_profile.value != blank -%}
  <section class="hm-sec" style="padding-top:0">
    <p class="hm-sec-eyebrow">Inside the Formula</p>
    <h2 class="hm-sec-heading">Active Ingredients</h2>
    <div class="hm-chips">
      {%- for ing in m.ingredient_profile.value -%}
        <a href="{{ ing.system.url }}" class="hm-chip">
          <span class="hm-chip-dot"></span>
          {{ ing.name.value | default: ing.display_name }}
        </a>
      {%- endfor -%}
    </div>
    {%- if m.full_ingredient_list.value != blank -%}
    <div class="hm-inci">
      <details>
        <summary>Full Ingredient List (INCI)</summary>
        <p class="inci-body">{{ m.full_ingredient_list.value }}</p>
      </details>
    </div>
    {%- endif -%}
  </section>
  {%- endif -%}

  {%- if m.stop_use_indications.value != blank -%}
  <section class="hm-sec" style="padding-top:0">
    <div class="hm-caution">
      <div class="hm-caution-lbl">⚠ Cautions & Stop Use</div>
      {{ m.stop_use_indications.value }}
    </div>
  </section>
  {%- endif -%}

  {%- if m.blog_posts.value != blank -%}
  <section class="hm-sec" style="border-top:1px solid rgba(255,255,255,0.05)">
    <p class="hm-sec-eyebrow">From The Blog</p>
    <h2 class="hm-sec-heading">Read More</h2>
    <div class="hm-blog-grid">
      {%- for article in m.blog_posts.value -%}
        <a href="{{ article.url }}" class="hm-blog-card">
          {%- if article.image -%}<img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title }}" loading="lazy">{%- endif -%}
          <div class="hm-blog-card-body">
            <div class="hm-blog-card-tag">HARAMOON Journal</div>
            <p class="hm-blog-card-title">{{ article.title }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </section>
  {%- endif -%}

  <div class="hm-cta-section">
    <h2 class="hm-cta-title">Ready for Step {{ step }}?</h2>
    <p class="hm-cta-sub">{{ m.product_name_type.value }} — your skin's new ritual.</p>
    <div class="hm-cta-btns">
      {%- if m.product.value != blank -%}<a href="{{ m.product.value.url }}" class="hm-btn hm-btn-primary">Add to Routine →</a>{%- endif -%}
      <a href="/pages/complete-routine" class="hm-btn hm-btn-ghost">See Full 4-Step Routine</a>
    </div>
  </div>

</div>

{% schema %}
{
  "name": "HARAMOON 101 Page",
  "target": "section"
}
{% endschema %}
