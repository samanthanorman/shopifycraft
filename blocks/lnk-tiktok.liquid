    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "CTA text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tiktok_button_bg",
      "label": "TikTok button background",
      "default": "#0e5349"
    },
    {
      "type": "color",
      "id": "tiktok_button_text",
      "label": "TikTok button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tiktok_button_hover_bg",
      "label": "TikTok button hover background",
      "default": "#0a4139"
    },
    {
      "type": "color",
      "id": "tiktok_button_hover_text",
      "label": "TikTok button hover text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "follow_button_bg",
      "label": "Follow button background",
      "default": "#e6683c"
    },
    {
      "type": "color",
      "id": "follow_button_text_color",
      "label": "Follow button text",
