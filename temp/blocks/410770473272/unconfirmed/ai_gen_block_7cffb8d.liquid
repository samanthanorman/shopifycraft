{% doc %}
  @prompt
    Create a custom Liquid block for a metaobject page template. It displays a horizontal carousel of ingredient cards.
    
    Data: Loop through metaobject.fields.ingredient_profile.value. For each entry, show:
    
    A small centered icon image (from a block-level image picker schema setting, matched by loop index order)
    The ingredient name: entry.field('name').value
    Short description: entry.field('description').value (3 line clamp)
    The entire card links to entry.url
    Layout: 4 cards visible on desktop, 2 tablet, 1 mobile. Left/right arrow buttons to scroll. Light border, rounded corners, minimal white card style.
    
    Schema settings: heading text (default "Hero Ingredients Inside"), subheading text (default "Click Each Card To Learn More"), emoji appended to heading (default 👁️). Block type "icon" with one image picker — limit 20 blocks.
    
    , perfect! keep everything the same just allow me to customize the colors/glow effects/size of cards spacing, all that good stuff please!, thank you! last please just allow me to toggle on and off the cards if i dont use them, or let me choose a number of cards to show please!
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ingredient-carousel-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-ingredient-carousel__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .ai-ingredient-carousel__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
    color: {{ block.settings.heading_color }};
  }

  .ai-ingredient-carousel__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-ingredient-carousel__wrapper-{{ ai_gen_id }} {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
  }

  .ai-ingredient-carousel__track-container-{{ ai_gen_id }} {
    overflow: hidden;
    position: relative;
  }

  .ai-ingredient-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.4s ease;
  }

  .ai-ingredient-carousel__card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.card_gap | times: 3 }}px) / 4);
    background: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    {% if block.settings.card_shadow_opacity > 0 %}
      box-shadow: 0 {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 }});
    {% endif %}
  }

  .ai-ingredient-carousel__card-{{ ai_gen_id }}:hover {
    transform: translateY({{ block.settings.card_hover_lift }}px);
    {% if block.settings.card_hover_glow_opacity > 0 %}
      box-shadow: 0 {{ block.settings.card_hover_glow_spread }}px {{ block.settings.card_hover_glow_blur }}px rgba({{ block.settings.card_hover_glow_color | color_extract: 'red' }}, {{ block.settings.card_hover_glow_color | color_extract: 'green' }}, {{ block.settings.card_hover_glow_color | color_extract: 'blue' }}, {{ block.settings.card_hover_glow_opacity | divided_by: 100.0 }});
    {% endif %}
  }

  .ai-ingredient-carousel__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .ai-ingredient-carousel__icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-ingredient-carousel__icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-ingredient-carousel__icon-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-ingredient-carousel__name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_size }}px;
    font-weight: 600;
    margin: 0 0 12px;
    color: {{ block.settings.name_color }};
  }

  .ai-ingredient-carousel__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.5;
    color: {{ block.settings.description_color }};
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-ingredient-carousel__button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: 50%;
    background: {{ block.settings.arrow_background }};
    border: 1px solid {{ block.settings.arrow_border_color }};
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background-color 0.3s ease, border-color 0.3s ease;
    color: {{ block.settings.arrow_color }};
  }

  .ai-ingredient-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
    border-color: {{ block.settings.arrow_hover_border }};
  }

  .ai-ingredient-carousel__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-ingredient-carousel__button-{{ ai_gen_id }}:disabled:hover {
    background-color: {{ block.settings.arrow_background }};
    border-color: {{ block.settings.arrow_border_color }};
  }

  .ai-ingredient-carousel__button--prev-{{ ai_gen_id }} {
    left: 0;
  }

  .ai-ingredient-carousel__button--next-{{ ai_gen_id }} {
    right: 0;
  }

  .ai-ingredient-carousel__button-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.arrow_size }}px * 0.5);
    height: calc({{ block.settings.arrow_size }}px * 0.5);
  }

  @media screen and (max-width: 989px) {
    .ai-ingredient-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px) / 2);
    }

    .ai-ingredient-carousel__wrapper-{{ ai_gen_id }} {
      padding: 0 50px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-ingredient-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-ingredient-carousel__wrapper-{{ ai_gen_id }} {
      padding: 0 50px;
    }

    .ai-ingredient-carousel__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.75);
    }

    .ai-ingredient-carousel__subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.875);
    }
  }
{% endstyle %}

<ingredient-carousel-{{ ai_gen_id }} class="ai-ingredient-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ingredient-carousel__header-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-ingredient-carousel__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}{% if block.settings.heading_emoji != blank %} {{ block.settings.heading_emoji }}{% endif %}
      </h2>
    {% endif %}
    {% if block.settings.subheading != blank %}
      <p class="ai-ingredient-carousel__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="ai-ingredient-carousel__wrapper-{{ ai_gen_id }}">
    <button
      class="ai-ingredient-carousel__button-{{ ai_gen_id }} ai-ingredient-carousel__button--prev-{{ ai_gen_id }}"
      aria-label="Previous"
      data-carousel-prev
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <div class="ai-ingredient-carousel__track-container-{{ ai_gen_id }}">
      <div class="ai-ingredient-carousel__track-{{ ai_gen_id }}" data-carousel-track>
        {% if metaobject.fields.ingredient_profile.value %}
          {% assign card_count = 0 %}
          {% for entry in metaobject.fields.ingredient_profile.value %}
            {% if card_count < block.settings.max_cards %}
              {% assign show_card_key = 'show_card_' | append: forloop.index %}
              {% assign show_card = block.settings[show_card_key] %}
              {% if show_card %}
                {% assign ingredient_name = entry.name %}
                {% assign ingredient_description = entry.description %}
                {% assign icon_setting_key = 'icon_' | append: forloop.index %}
                {% assign icon_image = block.settings[icon_setting_key] %}
                <a
                  href="{{ entry.url }}"
                  class="ai-ingredient-carousel__card-{{ ai_gen_id }}"
                  data-carousel-card
                >
                  <div class="ai-ingredient-carousel__icon-{{ ai_gen_id }}">
                    {% if icon_image %}
                      <img
                        src="{{ icon_image | image_url: width: 160 }}"
                        alt="{{ ingredient_name | escape }}"
                        loading="lazy"
                        width="{{ block.settings.icon_size }}"
                        height="{{ block.settings.icon_size }}"
                      >
                    {% else %}
                      <div class="ai-ingredient-carousel__icon-placeholder-{{ ai_gen_id }}">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>
                  <h3 class="ai-ingredient-carousel__name-{{ ai_gen_id }}">
                    {{ ingredient_name }}
                  </h3>
                  <p class="ai-ingredient-carousel__description-{{ ai_gen_id }}">
                    {{ ingredient_description }}
                  </p>
                </a>
                {% assign card_count = card_count | plus: 1 %}
              {% endif %}
            {% endif %}
          {% endfor %}
        {% else %}
          {% for i in (1..4) %}
            <div class="ai-ingredient-carousel__card-{{ ai_gen_id }}" data-carousel-card>
              <div class="ai-ingredient-carousel__icon-{{ ai_gen_id }}">
                <div class="ai-ingredient-carousel__icon-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              </div>
              <h3 class="ai-ingredient-carousel__name-{{ ai_gen_id }}">Ingredient Name</h3>
              <p class="ai-ingredient-carousel__description-{{ ai_gen_id }}">
                Add ingredient profile metaobject list to display ingredient cards here.
              </p>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <button
      class="ai-ingredient-carousel__button-{{ ai_gen_id }} ai-ingredient-carousel__button--next-{{ ai_gen_id }}"
      aria-label="Next"
      data-carousel-next
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</ingredient-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class IngredientCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.cardsPerView = 4;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-carousel-track]');
        this.cards = this.querySelectorAll('[data-carousel-card]');
        this.prevButton = this.querySelector('[data-carousel-prev]');
        this.nextButton = this.querySelector('[data-carousel-next]');

        if (!this.track || !this.cards.length) return;

        this.updateCardsPerView();
        this.updateButtons();

        this.prevButton.addEventListener('click', () => this.prev());
        this.nextButton.addEventListener('click', () => this.next());

        window.addEventListener('resize', () => {
          this.updateCardsPerView();
          this.updatePosition();
          this.updateButtons();
        });
      }

      updateCardsPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.cardsPerView = 1;
        } else if (width <= 989) {
          this.cardsPerView = 2;
        } else {
          this.cardsPerView = 4;
        }
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updatePosition();
          this.updateButtons();
        }
      }

      next() {
        const maxIndex = Math.max(0, this.cards.length - this.cardsPerView);
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.updatePosition();
          this.updateButtons();
        }
      }

      updatePosition() {
        const cardWidth = this.cards[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.track).gap) || 20;
        const offset = -(this.currentIndex * (cardWidth + gap));
        this.track.style.transform = `translateX(${offset}px)`;
      }

      updateButtons() {
        const maxIndex = Math.max(0, this.cards.length - this.cardsPerView);
        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= maxIndex;
      }
    }

    customElements.define('ingredient-carousel-{{ ai_gen_id }}', IngredientCarousel{{ ai_gen_id }});
  })();
</script>

