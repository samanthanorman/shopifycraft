{% doc %}
  @prompt
     Crystal Identity Card (Hero data block: chakra, zodiac, element, hardness, origin, chemical formula)
    Create a custom Liquid section called crystal_identity_card for a Shopify product page. Pull the linked mineral metaobject using product.metafields.custom.crystal.value. Display the following fields from that metaobject entry: display_name as the section heading, one_liner (Caption) as a subtitle, chakra, zodiac, element, origin, chemical_formula, and mohs_hardness as a clean data grid. Style: crisp white background, medical blue (#0066FF) accent, Poppins medium for labels (dark charcoal #1A1A1A), Raleway light for values (soft grey #666666), thin medical blue top border across full section width, no rounded corners, no gradients. Each data point displayed as a label/value pair in a responsive CSS grid (2 columns on mobile, 3–4 on desktop). Add staggered fade-up scroll entrance animation. Include ItemPage + Product JSON-LD schema in a script tag using the metaobject field values. Section must be dynamic — it reads whatever mineral metaobject is linked to the current product via product.metafields.custom.crystal.value. Include an editable section title setting in schema., the information is pulled exactly right! now simply enhance the design to match a premium gen Z aesthetic, including custom font size, color schemas, spacing, padding, etc. this section is supplemental information that needs to be condensed to the middle of the screen and mobile optimized. include a button at the bottom directing users to explore the crystal more if they visist the link to its own entry page for example amethyst's page url is https://waxandwane.store/pages/crystals/mineral-amethyst
    -add a fun hover/glow or animation to engage distracted audiences on button hover/click please
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign mineral = product.metafields.custom.crystal.value %}

{% style %}
  .ai-crystal-identity-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 50%, #0f1429 100%);
    padding: 60px 24px;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
    position: relative;
    overflow: hidden;
  }

  .ai-crystal-identity-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #00d4ff 0%, #7b2ff7 50%, #ff006e 100%);
  }

  .ai-crystal-identity-{{ ai_gen_id }}.ai-crystal-identity-visible-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-crystal-identity-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-crystal-identity-header-{{ ai_gen_id }} {
    margin-bottom: 40px;
    text-align: center;
  }

  .ai-crystal-identity-section-title-{{ ai_gen_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: #00d4ff;
    margin: 0 0 16px 0;
  }

  .ai-crystal-identity-name-{{ ai_gen_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 36px;
    color: #ffffff;
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  @media screen and (min-width: 750px) {
    .ai-crystal-identity-name-{{ ai_gen_id }} {
      font-size: 42px;
    }
  }

  .ai-crystal-identity-caption-{{ ai_gen_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 15px;
    color: #b8c5d6;
    margin: 0;
    line-height: 1.6;
  }

  .ai-crystal-identity-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }

  @media screen and (min-width: 750px) {
    .ai-crystal-identity-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }

  .ai-crystal-identity-item-{{ ai_gen_id }} {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 20px 16px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease, background 0.3s ease, border-color 0.3s ease;
  }

  .ai-crystal-identity-item-{{ ai_gen_id }}:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(0, 212, 255, 0.3);
  }

  .ai-crystal-identity-visible-{{ ai_gen_id }} .ai-crystal-identity-item-{{ ai_gen_id }}:nth-child(1) {
    transition-delay: 0.1s;
  }

  .ai-crystal-identity-visible-{{ ai_gen_id }} .ai-crystal-identity-item-{{ ai_gen_id }}:nth-child(2) {
    transition-delay: 0.15s;
  }

  .ai-crystal-identity-visible-{{ ai_gen_id }} .ai-crystal-identity-item-{{ ai_gen_id }}:nth-child(3) {
    transition-delay: 0.2s;
  }

  .ai-crystal-identity-visible-{{ ai_gen_id }} .ai-crystal-identity-item-{{ ai_gen_id }}:nth-child(4) {
    transition-delay: 0.25s;
  }

  .ai-crystal-identity-visible-{{ ai_gen_id }} .ai-crystal-identity-item-{{ ai_gen_id }}:nth-child(5) {
    transition-delay: 0.3s;
  }

  .ai-crystal-identity-visible-{{ ai_gen_id }} .ai-crystal-identity-item-{{ ai_gen_id }}:nth-child(6) {
    transition-delay: 0.35s;
  }

  .ai-crystal-identity-visible-{{ ai_gen_id }} .ai-crystal-identity-item-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-crystal-identity-label-{{ ai_gen_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: #7b8a9e;
    margin: 0 0 8px 0;
  }

  .ai-crystal-identity-value-{{ ai_gen_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: 16px;
    color: #e8f0ff;
    margin: 0;
    line-height: 1.4;
  }

  .ai-crystal-identity-cta-wrapper-{{ ai_gen_id }} {
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    transition-delay: 0.4s;
  }

  .ai-crystal-identity-visible-{{ ai_gen_id }} .ai-crystal-identity-cta-wrapper-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-crystal-identity-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: linear-gradient(135deg, #00d4ff 0%, #7b2ff7 100%);
    color: #ffffff;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 14px;
    text-decoration: none;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-crystal-identity-cta-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s ease, height 0.6s ease;
  }

  .ai-crystal-identity-cta-{{ ai_gen_id }}:hover::before {
    width: 300px;
    height: 300px;
  }

  .ai-crystal-identity-cta-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(0, 212, 255, 0.6), 0 0 60px rgba(123, 47, 247, 0.4);
  }

  .ai-crystal-identity-cta-{{ ai_gen_id }}:active {
    transform: translateY(0);
  }

  .ai-crystal-identity-cta-text-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
  }

  .ai-crystal-identity-cta-icon-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-crystal-identity-cta-{{ ai_gen_id }}:hover .ai-crystal-identity-cta-icon-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-crystal-identity-empty-{{ ai_gen_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 14px;
    color: #7b8a9e;
    font-style: italic;
    text-align: center;
    padding: 40px 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-crystal-identity-{{ ai_gen_id }} {
      padding: 40px 20px;
    }

    .ai-crystal-identity-header-{{ ai_gen_id }} {
      margin-bottom: 32px;
    }

    .ai-crystal-identity-grid-{{ ai_gen_id }} {
      margin-bottom: 32px;
    }

    .ai-crystal-identity-item-{{ ai_gen_id }} {
      padding: 16px 12px;
    }

    .ai-crystal-identity-cta-{{ ai_gen_id }} {
      padding: 12px 28px;
      font-size: 13px;
    }
  }
{% endstyle %}

<crystal-identity-card-{{ ai_gen_id }}
  class="ai-crystal-identity-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if mineral %}
    <div class="ai-crystal-identity-container-{{ ai_gen_id }}">
      <div class="ai-crystal-identity-header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-crystal-identity-section-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% endif %}
        {% if mineral.display_name %}
          <h3 class="ai-crystal-identity-name-{{ ai_gen_id }}">{{ mineral.display_name }}</h3>
        {% endif %}
        {% if mineral.one_liner %}
          <p class="ai-crystal-identity-caption-{{ ai_gen_id }}">{{ mineral.one_liner }}</p>
        {% endif %}
      </div>

      <div class="ai-crystal-identity-grid-{{ ai_gen_id }}">
        {% if mineral.chakra %}
          <div class="ai-crystal-identity-item-{{ ai_gen_id }}">
            <div class="ai-crystal-identity-label-{{ ai_gen_id }}">Chakra</div>
            <div class="ai-crystal-identity-value-{{ ai_gen_id }}">{{ mineral.chakra }}</div>
          </div>
        {% endif %}

        {% if mineral.zodiac %}
          <div class="ai-crystal-identity-item-{{ ai_gen_id }}">
            <div class="ai-crystal-identity-label-{{ ai_gen_id }}">Zodiac</div>
            <div class="ai-crystal-identity-value-{{ ai_gen_id }}">{{ mineral.zodiac }}</div>
          </div>
        {% endif %}

        {% if mineral.element %}
          <div class="ai-crystal-identity-item-{{ ai_gen_id }}">
            <div class="ai-crystal-identity-label-{{ ai_gen_id }}">Element</div>
            <div class="ai-crystal-identity-value-{{ ai_gen_id }}">{{ mineral.element }}</div>
          </div>
        {% endif %}

        {% if mineral.origin %}
          <div class="ai-crystal-identity-item-{{ ai_gen_id }}">
            <div class="ai-crystal-identity-label-{{ ai_gen_id }}">Origin</div>
            <div class="ai-crystal-identity-value-{{ ai_gen_id }}">{{ mineral.origin }}</div>
          </div>
        {% endif %}

        {% if mineral.chemical_formula %}
          <div class="ai-crystal-identity-item-{{ ai_gen_id }}">
            <div class="ai-crystal-identity-label-{{ ai_gen_id }}">Chemical Formula</div>
            <div class="ai-crystal-identity-value-{{ ai_gen_id }}">{{ mineral.chemical_formula }}</div>
          </div>
        {% endif %}

        {% if mineral.mohs_hardness %}
          <div class="ai-crystal-identity-item-{{ ai_gen_id }}">
            <div class="ai-crystal-identity-label-{{ ai_gen_id }}">Mohs Hardness</div>
            <div class="ai-crystal-identity-value-{{ ai_gen_id }}">{{ mineral.mohs_hardness }}</div>
          </div>
        {% endif %}
      </div>

      {% if mineral.url %}
        <div class="ai-crystal-identity-cta-wrapper-{{ ai_gen_id }}">
          <a href="{{ mineral.url }}" class="ai-crystal-identity-cta-{{ ai_gen_id }}">
            <span class="ai-crystal-identity-cta-text-{{ ai_gen_id }}">{{ block.settings.button_text }}</span>
            <svg class="ai-crystal-identity-cta-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      {% endif %}
    </div>
  {% else %}
    <div class="ai-crystal-identity-container-{{ ai_gen_id }}">
      <div class="ai-crystal-identity-empty-{{ ai_gen_id }}">
        Next, link a mineral metaobject to this product via product.metafields.custom.crystal
      </div>
    </div>
  {% endif %}
</crystal-identity-card-{{ ai_gen_id }}>

{% if mineral %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemPage",
    "mainEntity": {
      "@type": "Product",
      "name": "{{ product.title | escape }}",
      "description": "{{ product.description | strip_html | escape }}",
      {% if product.featured_image %}
      "image": "{{ product.featured_image | image_url: width: 1200 }}",
      {% endif %}
      "brand": {
        "@type": "Brand",
        "name": "{{ shop.name | escape }}"
      },
      {% if mineral.display_name %}
      "material": "{{ mineral.display_name | escape }}",
      {% endif %}
      "additionalProperty": [
        {% if mineral.chakra %}
        {
          "@type": "PropertyValue",
          "name": "Chakra",
          "value": "{{ mineral.chakra | escape }}"
        }{% if mineral.zodiac or mineral.element or mineral.origin or mineral.chemical_formula or mineral.mohs_hardness %},{% endif %}
        {% endif %}
        {% if mineral.zodiac %}
        {
          "@type": "PropertyValue",
          "name": "Zodiac",
          "value": "{{ mineral.zodiac | escape }}"
        }{% if mineral.element or mineral.origin or mineral.chemical_formula or mineral.mohs_hardness %},{% endif %}
        {% endif %}
        {% if mineral.element %}
        {
          "@type": "PropertyValue",
          "name": "Element",
          "value": "{{ mineral.element | escape }}"
        }{% if mineral.origin or mineral.chemical_formula or mineral.mohs_hardness %},{% endif %}
        {% endif %}
        {% if mineral.origin %}
        {
          "@type": "PropertyValue",
          "name": "Origin",
          "value": "{{ mineral.origin | escape }}"
        }{% if mineral.chemical_formula or mineral.mohs_hardness %},{% endif %}
        {% endif %}
        {% if mineral.chemical_formula %}
        {
          "@type": "PropertyValue",
          "name": "Chemical Formula",
          "value": "{{ mineral.chemical_formula | escape }}"
        }{% if mineral.mohs_hardness %},{% endif %}
        {% endif %}
        {% if mineral.mohs_hardness %}
        {
          "@type": "PropertyValue",
          "name": "Mohs Hardness",
          "value": "{{ mineral.mohs_hardness | escape }}"
        }
        {% endif %}
      ]
    }
  }
  </script>
{% endif %}

<script>
  (function() {
    class CrystalIdentityCard{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.observer = null;
      }

      connectedCallback() {
        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.2
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('ai-crystal-identity-visible-{{ ai_gen_id }}');
              this.observer.unobserve(entry.target);
            }
          });
        }, options);

        this.observer.observe(this);
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('crystal-identity-card-{{ ai_gen_id }}', CrystalIdentityCard{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Crystal identity card",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Crystal Identity"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Explore this crystal"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 900
    }
  ],
  "presets": [
    {
      "name": "Crystal identity card"
    }
  ]
}
{% endschema %}