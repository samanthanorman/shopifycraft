          <p class="crys-care-card__title">Placement & Feng Shui</p>
          <p class="crys-care-card__text">{{ matched_mineral.grid_design_or_feng_shui_setup | truncate: 200 }}</p>
        </div>
        {%- endif -%}
      </div>
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ── HISTORY ── {%- endcomment -%}
  {%- if matched_mineral and matched_mineral.history and section.settings.show_history -%}
  <div class="crys-block">
    <div class="crys-section">
      <div class="crys-block-header">
        <p class="crys-block-eyebrow">{{ section.settings.history_eyebrow | default: 'Through the Ages' }}</p>
        <h2 class="crys-block-title">{{ section.settings.history_heading | default: 'The History of This Crystal' }}</h2>
      </div>
      <div class="crys-history">
        <p class="crys-history__text">{{ matched_mineral.history }}</p>
      </div>
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ── FAQ ── {%- endcomment -%}
  {%- if section.settings.show_faq -%}
  {%- assign crystal_faqs = shop.metaobjects.faq_group.values | where: "category", "Crystal Courtesan" -%}
  {%- if crystal_faqs.size > 0 -%}
  <div class="crys-block">
    <div class="crys-section">
      <div class="crys-block-header">
        <p class="crys-block-eyebrow">{{ section.settings.faq_eyebrow | default: 'Questions & Answers' }}</p>
        <h2 class="crys-block-title">{{ section.settings.faq_heading | default: 'Crystal Courtesan FAQ' }}</h2>
      </div>
      <div class="crys-faq-list">
        {%- for faq in crystal_faqs limit: 8 -%}
        <details class="crys-faq-item">
          <summary class="crys-faq-q">
            {{ faq.question }}
            <span class="crys-faq-chevron">▶</span>
          </summary>
          <div class="crys-faq-a">{{ faq.answer }}</div>
        </details>
        {%- endfor -%}
      </div>
    </div>
  </div>
  {%- endif -%}
  {%- endif -%}

  {%- comment -%} ── RELATED ── {%- endcomment -%}
  {%- if section.settings.show_related -%}
  {%- assign related_products = related.value -%}
  {%- if related_products.size > 0 -%}
  <div class="crys-block">
    <div class="crys-section">
      <div class="crys-block-header">
        <p class="crys-block-eyebrow">{{ section.settings.related_eyebrow | default: 'Keep Exploring' }}</p>
        <h2 class="crys-block-title">{{ section.settings.related_heading | default: 'You Might Also Love' }}</h2>
      </div>
      <div class="crys-related-grid">
        {%- for rp in related_products limit: 4 -%}
