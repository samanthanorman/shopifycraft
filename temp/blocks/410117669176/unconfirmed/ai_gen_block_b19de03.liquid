{% doc %}
  @prompt
    Crystal Energy, History & Use Panel
    (energy_properties, why_you_need_it, history, modern_or_scientific_use, underlying_emotion_or_body_association, grid_design_or_feng_shui_setup + best_to_pair_with cards)
    
    Create a custom Liquid section called mineral_energy_panel for a Shopify metaobject template page (URL pattern: /pages/crystals/[handle]). The Liquid root object is metaobject — access all fields as metaobject.[key].value.
    
    Display the following as titled content blocks — each with a small all-caps Poppins medium medical blue (#0066FF) label heading and Raleway light soft grey (#666666) body text. Only render a block if the field is not blank:
    
    energy_properties → label: "Energy Properties"
    why_you_need_it → label: "Why You Need It"
    history → label: "History"
    modern_or_scientific_use → label: "Modern & Scientific Use"
    underlying_emotion_or_body_association → label: "Emotional & Body Association"
    grid_design_or_feng_shui_setup → label: "Grid Design & Feng Shui"
    Below those blocks, add a "Best to Pair With" row. Loop through metaobject.best_to_pair_with.value — each item is a mineral metaobject reference. For each, display item.display_name.value as a card label and link to /pages/crystals/{{ item.system.handle }}. Render as a horizontal scrolling pill-free card row with medical blue border.
    
    Style: soft cool-white background (#F9FAFB), thin cool-grey (#E5E7EB) dividers between blocks, open block gets 3px medical blue left border accent, 24px+ padding per block. Thin 2px medical blue top border across full section width. Staggered fade-up scroll entrance. No gradients, no pill shapes. Include editable section title in schema.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .mineral-energy-panel-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: #F9FAFB;
    border-top: 2px solid #0066FF;
    padding: 0;
  }

  .mineral-energy-panel__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0;
  }

  .mineral-energy-panel__title-{{ ai_gen_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 28px;
    color: #0066FF;
    text-align: center;
    padding: 40px 20px 20px;
    margin: 0;
  }

  .mineral-energy-panel__content-block-{{ ai_gen_id }} {
    padding: 24px 32px;
    border-bottom: 1px solid #E5E7EB;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease, border-left 0.3s ease;
  }

  .mineral-energy-panel__content-block-{{ ai_gen_id }}.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .mineral-energy-panel__content-block-{{ ai_gen_id }}:hover {
    border-left: 3px solid #0066FF;
    padding-left: 29px;
  }

  .mineral-energy-panel__label-{{ ai_gen_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #0066FF;
    margin: 0 0 12px 0;
  }

  .mineral-energy-panel__text-{{ ai_gen_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 16px;
    line-height: 1.6;
    color: #666666;
    margin: 0;
  }

  .mineral-energy-panel__pairing-section-{{ ai_gen_id }} {
    padding: 32px 32px 40px;
  }

  .mineral-energy-panel__pairing-title-{{ ai_gen_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #0066FF;
    margin: 0 0 16px 0;
  }

  .mineral-energy-panel__pairing-scroll-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: 8px;
    scrollbar-width: thin;
    scrollbar-color: #E5E7EB #F9FAFB;
  }

  .mineral-energy-panel__pairing-scroll-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 6px;
  }

  .mineral-energy-panel__pairing-scroll-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: #F9FAFB;
  }

  .mineral-energy-panel__pairing-scroll-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background: #E5E7EB;
    border-radius: 3px;
  }

  .mineral-energy-panel__pairing-card-{{ ai_gen_id }} {
    flex-shrink: 0;
    min-width: 200px;
    padding: 16px 20px;
    background-color: #FFFFFF;
    border: 2px solid #0066FF;
    border-radius: 6px;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .mineral-energy-panel__pairing-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 12px rgba(0, 102, 255, 0.15);
  }

  .mineral-energy-panel__pairing-card-label-{{ ai_gen_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: 16px;
    color: #0066FF;
    margin: 0;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .mineral-energy-panel__content-block-{{ ai_gen_id }} {
      padding: 20px 24px;
    }

    .mineral-energy-panel__content-block-{{ ai_gen_id }}:hover {
      padding-left: 21px;
    }

    .mineral-energy-panel__pairing-section-{{ ai_gen_id }} {
      padding: 24px 24px 32px;
    }

    .mineral-energy-panel__title-{{ ai_gen_id }} {
      font-size: 24px;
      padding: 32px 20px 16px;
    }
  }
{% endstyle %}

<mineral-energy-panel-{{ ai_gen_id }}
  class="mineral-energy-panel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="mineral-energy-panel__container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <h2 class="mineral-energy-panel__title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}

    {% if metaobject.energy_properties.value != blank %}
      <div class="mineral-energy-panel__content-block-{{ ai_gen_id }}" data-block-index="0">
        <div class="mineral-energy-panel__label-{{ ai_gen_id }}">Energy Properties</div>
        <div class="mineral-energy-panel__text-{{ ai_gen_id }}">{{ metaobject.energy_properties.value }}</div>
      </div>
    {% endif %}

    {% if metaobject.why_you_need_it.value != blank %}
      <div class="mineral-energy-panel__content-block-{{ ai_gen_id }}" data-block-index="1">
        <div class="mineral-energy-panel__label-{{ ai_gen_id }}">Why You Need It</div>
        <div class="mineral-energy-panel__text-{{ ai_gen_id }}">{{ metaobject.why_you_need_it.value }}</div>
      </div>
    {% endif %}

    {% if metaobject.history.value != blank %}
      <div class="mineral-energy-panel__content-block-{{ ai_gen_id }}" data-block-index="2">
        <div class="mineral-energy-panel__label-{{ ai_gen_id }}">History</div>
        <div class="mineral-energy-panel__text-{{ ai_gen_id }}">{{ metaobject.history.value }}</div>
      </div>
    {% endif %}

    {% if metaobject.modern_or_scientific_use.value != blank %}
      <div class="mineral-energy-panel__content-block-{{ ai_gen_id }}" data-block-index="3">
        <div class="mineral-energy-panel__label-{{ ai_gen_id }}">Modern & Scientific Use</div>
        <div class="mineral-energy-panel__text-{{ ai_gen_id }}">{{ metaobject.modern_or_scientific_use.value }}</div>
      </div>
    {% endif %}

    {% if metaobject.underlying_emotion_or_body_association.value != blank %}
      <div class="mineral-energy-panel__content-block-{{ ai_gen_id }}" data-block-index="4">
        <div class="mineral-energy-panel__label-{{ ai_gen_id }}">Emotional & Body Association</div>
        <div class="mineral-energy-panel__text-{{ ai_gen_id }}">{{ metaobject.underlying_emotion_or_body_association.value }}</div>
      </div>
    {% endif %}

    {% if metaobject.grid_design_or_feng_shui_setup.value != blank %}
      <div class="mineral-energy-panel__content-block-{{ ai_gen_id }}" data-block-index="5">
        <div class="mineral-energy-panel__label-{{ ai_gen_id }}">Grid Design & Feng Shui</div>
        <div class="mineral-energy-panel__text-{{ ai_gen_id }}">{{ metaobject.grid_design_or_feng_shui_setup.value }}</div>
      </div>
    {% endif %}

    {% if metaobject.best_to_pair_with.value != blank and metaobject.best_to_pair_with.value.size > 0 %}
      <div class="mineral-energy-panel__pairing-section-{{ ai_gen_id }}">
        <div class="mineral-energy-panel__pairing-title-{{ ai_gen_id }}">Best to Pair With</div>
        <div class="mineral-energy-panel__pairing-scroll-{{ ai_gen_id }}">
          {% for item in metaobject.best_to_pair_with.value %}
            <a
              href="/pages/crystals/{{ item.system.handle }}"
              class="mineral-energy-panel__pairing-card-{{ ai_gen_id }}"
            >
              <div class="mineral-energy-panel__pairing-card-label-{{ ai_gen_id }}">
                {{ item.display_name.value }}
              </div>
            </a>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</mineral-energy-panel-{{ ai_gen_id }}>

<script>
  (function() {
    class MineralEnergyPanel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.blocks = [];
        this.observer = null;
      }

      connectedCallback() {
        this.blocks = this.querySelectorAll('.mineral-energy-panel__content-block-{{ ai_gen_id }}');
        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const block = entry.target;
              const index = parseInt(block.getAttribute('data-block-index'));
              const delay = index * 100;

              setTimeout(() => {
                block.classList.add('visible');
              }, delay);

              this.observer.unobserve(block);
            }
          });
        }, options);

        this.blocks.forEach((block) => {
          this.observer.observe(block);
        });
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('mineral-energy-panel-{{ ai_gen_id }}', MineralEnergyPanel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Mineral energy panel",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Crystal Energy & Properties"
    }
  ],
  "presets": [
    {
      "name": "Mineral energy panel"
    }
  ]
}
{% endschema %}
