{% doc %}
  @prompt
    Create a modern, sleek Liquid code block that matches the aesthetic of premium Korean skincare products like HARAMOON. The design should be clean, minimalist, and sophisticated with smooth animations, elegant typography, and a color scheme that reflects luxury skincare branding. Include modern CSS styling with gradients, subtle shadows, and responsive design elements that would complement a high-end Korean beauty product presentation., Create a modern, sleek Liquid code block that matches the aesthetic of premium Korean skincare products like HARAMOON. The design should be clean, minimalist, and sophisticated with smooth animations, elegant typography, and a color scheme that reflects luxury skincare branding. Include modern CSS styling with gradients, subtle shadows, and responsive design elements that would complement a high-end Korean beauty product presentation.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-korean-skincare-{{ ai_gen_id }} {
    position: relative;
    padding: {{ block.settings.section_padding }}px 20px;
    background: linear-gradient(135deg, {{ block.settings.primary_gradient_color }} 0%, {{ block.settings.secondary_gradient_color }} 100%);
    overflow: hidden;
    min-height: 500px;
    display: flex;
    align-items: center;
  }

  .ai-korean-skincare-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .ai-korean-skincare-content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .ai-korean-skincare-content-{{ ai_gen_id }}.reverse {
    grid-template-columns: 1fr 1fr;
  }

  .ai-korean-skincare-text-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
  }

  .ai-korean-skincare-badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 8px 20px;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 25px;
    font-size: 12px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
    transition: all 0.3s ease;
  }

  .ai-korean-skincare-badge-{{ ai_gen_id }}:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: translateY(-2px);
  }

  .ai-korean-skincare-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 300;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }

  .ai-korean-skincare-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    font-weight: 500;
    color: {{ block.settings.accent_color }};
    margin: 0 0 24px;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .ai-korean-skincare-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0 0 32px;
    opacity: 0.9;
  }

  .ai-korean-skincare-features-{{ ai_gen_id }} {
    display: flex;
    gap: 24px;
    margin-bottom: 40px;
  }

  .ai-korean-skincare-feature-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1;
  }

  .ai-korean-skincare-feature-icon-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
    transition: all 0.3s ease;
  }

  .ai-korean-skincare-feature-icon-{{ ai_gen_id }}:hover {
    transform: translateY(-3px);
    background: rgba(255, 255, 255, 0.25);
  }

  .ai-korean-skincare-feature-icon-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    color: {{ block.settings.accent_color }};
  }

  .ai-korean-skincare-feature-text-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-korean-skincare-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    background: linear-gradient(135deg, {{ block.settings.button_gradient_start }} 0%, {{ block.settings.button_gradient_end }} 100%);
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: 30px;
    font-weight: 500;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .ai-korean-skincare-button-{{ ai_gen_id }}:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
    background: linear-gradient(135deg, {{ block.settings.button_gradient_end }} 0%, {{ block.settings.button_gradient_start }} 100%);
  }

  .ai-korean-skincare-button-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-korean-skincare-button-{{ ai_gen_id }}:hover svg {
    transform: translateX(4px);
  }

  .ai-korean-skincare-image-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ai-korean-skincare-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: 400px;
    aspect-ratio: 1;
    border-radius: 30px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
    transition: all 0.5s ease;
  }

  .ai-korean-skincare-image-wrapper-{{ ai_gen_id }}:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.15);
  }

  .ai-korean-skincare-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .ai-korean-skincare-image-wrapper-{{ ai_gen_id }}:hover img {
    transform: scale(1.05);
  }

  .ai-korean-skincare-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    position: relative;
  }

  .ai-korean-skincare-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
    color: {{ block.settings.text_color }};
  }

  .ai-korean-skincare-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    text-align: center;
    font-weight: 300;
  }

  .ai-korean-skincare-floating-elements-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .ai-korean-skincare-floating-circle-{{ ai_gen_id }} {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .ai-korean-skincare-floating-circle-{{ ai_gen_id }}:nth-child(1) {
    width: 120px;
    height: 120px;
    top: 10%;
    right: 15%;
    animation: ai-korean-skincare-float-{{ ai_gen_id }} 6s ease-in-out infinite;
  }

  .ai-korean-skincare-floating-circle-{{ ai_gen_id }}:nth-child(2) {
    width: 80px;
    height: 80px;
    bottom: 20%;
    left: 10%;
    animation: ai-korean-skincare-float-{{ ai_gen_id }} 8s ease-in-out infinite reverse;
  }

  .ai-korean-skincare-floating-circle-{{ ai_gen_id }}:nth-child(3) {
    width: 60px;
    height: 60px;
    top: 60%;
    right: 8%;
    animation: ai-korean-skincare-float-{{ ai_gen_id }} 7s ease-in-out infinite;
  }

  @keyframes ai-korean-skincare-float-{{ ai_gen_id }} {
    0%, 100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(180deg);
    }
  }

  @media screen and (max-width: 768px) {
    .ai-korean-skincare-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 16px;
      min-height: 400px;
    }

    .ai-korean-skincare-content-{{ ai_gen_id }},
    .ai-korean-skincare-content-{{ ai_gen_id }}.reverse {
      grid-template-columns: 1fr;
      gap: 40px;
      text-align: center;
    }

    .ai-korean-skincare-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-korean-skincare-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-korean-skincare-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-korean-skincare-features-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 16px;
    }

    .ai-korean-skincare-feature-{{ ai_gen_id }} {
      flex-direction: row;
      text-align: left;
      gap: 16px;
    }

    .ai-korean-skincare-feature-icon-{{ ai_gen_id }} {
      margin-bottom: 0;
      flex-shrink: 0;
    }

    .ai-korean-skincare-image-wrapper-{{ ai_gen_id }} {
      max-width: 300px;
    }

    .ai-korean-skincare-floating-circle-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<korean-skincare-{{ ai_gen_id }}
  class="ai-korean-skincare-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-korean-skincare-floating-elements-{{ ai_gen_id }}">
    <div class="ai-korean-skincare-floating-circle-{{ ai_gen_id }}"></div>
    <div class="ai-korean-skincare-floating-circle-{{ ai_gen_id }}"></div>
    <div class="ai-korean-skincare-floating-circle-{{ ai_gen_id }}"></div>
  </div>

  <div class="ai-korean-skincare-container-{{ ai_gen_id }}">
    <div class="ai-korean-skincare-content-{{ ai_gen_id }} {% if block.settings.layout == 'image_right' %}reverse{% endif %}">
      <div class="ai-korean-skincare-text-{{ ai_gen_id }}">
        {% if block.settings.badge_text != blank %}
          <div class="ai-korean-skincare-badge-{{ ai_gen_id }}">
            {{ block.settings.badge_text }}
          </div>
        {% endif %}

        {% if block.settings.subtitle != blank %}
          <div class="ai-korean-skincare-subtitle-{{ ai_gen_id }}">
            {{ block.settings.subtitle }}
          </div>
        {% endif %}

        {% if block.settings.title != blank %}
          <h2 class="ai-korean-skincare-title-{{ ai_gen_id }}">
            {{ block.settings.title }}
          </h2>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-korean-skincare-description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}

        {% if block.settings.show_features %}
          <div class="ai-korean-skincare-features-{{ ai_gen_id }}">
            <div class="ai-korean-skincare-feature-{{ ai_gen_id }}">
              <div class="ai-korean-skincare-feature-icon-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                  <path d="M2 17l10 5 10-5"/>
                  <path d="M2 12l10 5 10-5"/>
                </svg>
              </div>
              <div class="ai-korean-skincare-feature-text-{{ ai_gen_id }}">
                Premium Quality
              </div>
            </div>
            <div class="ai-korean-skincare-feature-{{ ai_gen_id }}">
              <div class="ai-korean-skincare-feature-icon-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </div>
              <div class="ai-korean-skincare-feature-text-{{ ai_gen_id }}">
                Gentle Care
              </div>
            </div>
            <div class="ai-korean-skincare-feature-{{ ai_gen_id }}">
              <div class="ai-korean-skincare-feature-icon-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 12l2 2 4-4"/>
                  <circle cx="12" cy="12" r="10"/>
                </svg>
              </div>
              <div class="ai-korean-skincare-feature-text-{{ ai_gen_id }}">
                Proven Results
              </div>
            </div>
          </div>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <a
            href="{{ block.settings.button_link }}"
            class="ai-korean-skincare-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14"/>
              <path d="M12 5l7 7-7 7"/>
            </svg>
          </a>
        {% endif %}
      </div>

      <div class="ai-korean-skincare-image-{{ ai_gen_id }}">
        <div class="ai-korean-skincare-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.image %}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {% else %}
            <div class="ai-korean-skincare-placeholder-{{ ai_gen_id }}">
              {{ 'product-apparel-1' | placeholder_svg_tag }}
              <div class="ai-korean-skincare-empty-state-{{ ai_gen_id }}">
                Add a beautiful product image
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</korean-skincare-{{ ai_gen_id }}>

<script>
  (function() {
    class KoreanSkincare{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupScrollAnimation();
      }

      setupScrollAnimation() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.style.opacity = '1';
              entry.target.style.transform = 'translateY(0)';
            }
          });
        }, {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        });

        const elements = this.querySelectorAll('.ai-korean-skincare-text-{{ ai_gen_id }}, .ai-korean-skincare-image-{{ ai_gen_id }}');
        elements.forEach((el, index) => {
          el.style.opacity = '0';
          el.style.transform = 'translateY(30px)';
          el.style.transition = `opacity 0.8s ease ${index * 0.2}s, transform 0.8s ease ${index * 0.2}s`;
          observer.observe(el);
        });
      }
    }

    customElements.define('korean-skincare-{{ ai_gen_id }}', KoreanSkincare{{ ai_gen_id }});
  })();
</script>

