{% doc %}
  @prompt
    Crystal Care & FAQ Accordion (Cleanse, recharge, safety notes + FAQ accordion pulling from faq_group metaobjects filtered by crystal category)
    Create a custom Liquid section called crystal_care_faq for a Shopify product page. It has two parts:
    
    Part 1 — Care Instructions: Pull the linked mineral metaobject using product.metafields.custom.crystal.value. Display cleanse, recharge, and safety_notes fields as three distinct accordion rows with rotating medical blue (#0066FF) chevron icons on the right. Only one row open at a time. Smooth CSS height transition, no layout jumps.
    
    Part 2 — FAQ Accordion: Query all metaobjects of type faq_group where the category field equals "Crystals & Minerals", ordered by sort_order ascending, up to 10 entries. Display question as the accordion label and answer as expanded content.
    
    Both parts share the same accordion styling: crisp white background, medical blue accent, Poppins medium dark charcoal question labels, Raleway light soft grey answer text, 24px+ row padding, cool-grey dividers (#E5E7EB), hover gets subtle cool blue tint (#F0F4FF), open row gets medical blue left border (3–4px). Thin medical blue top border across full section width. Staggered fade-up scroll entrance. Include FAQPage JSON-LD schema in a script tag covering all question/answer pairs from both parts. Sharp, minimal, no gradients, no rounded pills. Include editable section title in schema. allow me to custom all aestheetic elements like padding, spacing, width, font size, colors, glow effects, etc. allow. me to toggle fields to show them or not show them for future flexibility
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign mineral = product.metafields.custom.crystal.value %}

{% style %}
  .ai-crystal-care-faq-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.section_background }};
  }

  .ai-crystal-care-faq__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    text-align: {{ block.settings.title_alignment }};
  }

  .ai-crystal-care-faq__top-border-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.top_border_thickness }}px;
    background-color: {{ block.settings.accent_color }};
    margin-bottom: {{ block.settings.accordion_spacing }}px;
    {% if block.settings.enable_glow %}
      box-shadow: 0 0 {{ block.settings.glow_intensity }}px {{ block.settings.accent_color }};
    {% endif %}
  }

  .ai-crystal-care-faq__accordion-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.row_gap }}px;
  }

  .ai-crystal-care-faq__row-{{ ai_gen_id }} {
    background-color: {{ block.settings.row_background }};
    border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
    transition: background-color 0.3s ease, border-left 0.3s ease;
    {% if block.settings.enable_glow %}
      transition: background-color 0.3s ease, border-left 0.3s ease, box-shadow 0.3s ease;
    {% endif %}
  }

  .ai-crystal-care-faq__row-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.row_hover_background }};
  }

  .ai-crystal-care-faq__row-{{ ai_gen_id }}.active {
    border-left: {{ block.settings.active_border_thickness }}px solid {{ block.settings.accent_color }};
    {% if block.settings.enable_glow %}
      box-shadow: 0 0 {{ block.settings.glow_intensity }}px {{ block.settings.accent_color }};
    {% endif %}
  }

  .ai-crystal-care-faq__question-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.row_padding }}px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: {{ block.settings.question_font.family }}, {{ block.settings.question_font.fallback_families }};
    font-weight: {{ block.settings.question_font.weight }};
    font-size: {{ block.settings.question_size }}px;
    color: {{ block.settings.question_color }};
    transition: color 0.3s ease;
  }

  .ai-crystal-care-faq__question-{{ ai_gen_id }}:hover {
    color: {{ block.settings.question_hover_color }};
  }

  .ai-crystal-care-faq__chevron-{{ ai_gen_id }} {
    width: {{ block.settings.chevron_size }}px;
    height: {{ block.settings.chevron_size }}px;
    flex-shrink: 0;
    margin-left: 16px;
    transition: transform 0.3s ease;
  }

  .ai-crystal-care-faq__chevron-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.accent_color }};
    stroke-width: 2;
  }

  .ai-crystal-care-faq__row-{{ ai_gen_id }}.active .ai-crystal-care-faq__chevron-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-crystal-care-faq__answer-wrapper-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }

  .ai-crystal-care-faq__answer-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.row_padding }}px {{ block.settings.row_padding }}px;
    font-family: {{ block.settings.answer_font.family }}, {{ block.settings.answer_font.fallback_families }};
    font-weight: {{ block.settings.answer_font.weight }};
    font-size: {{ block.settings.answer_size }}px;
    color: {{ block.settings.answer_color }};
    line-height: 1.6;
  }

  .ai-crystal-care-faq__empty-state-{{ ai_gen_id }} {
    padding: {{ block.settings.row_padding }}px;
    text-align: center;
    color: {{ block.settings.answer_color }};
    opacity: 0.6;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-crystal-care-faq-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px {{ block.settings.section_padding_horizontal | times: 0.7 }}px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-crystal-care-faq__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-crystal-care-faq__question-{{ ai_gen_id }} {
      font-size: {{ block.settings.question_size | times: 0.9 }}px;
      padding: {{ block.settings.row_padding | times: 0.8 }}px;
    }

    .ai-crystal-care-faq__answer-{{ ai_gen_id }} {
      font-size: {{ block.settings.answer_size | times: 0.9 }}px;
      padding: 0 {{ block.settings.row_padding | times: 0.8 }}px {{ block.settings.row_padding | times: 0.8 }}px;
    }
  }

  @keyframes ai-crystal-care-faq-fade-up-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-crystal-care-faq__row-{{ ai_gen_id }} {
    opacity: 0;
    animation: ai-crystal-care-faq-fade-up-{{ ai_gen_id }} 0.6s ease forwards;
  }

  .ai-crystal-care-faq__row-{{ ai_gen_id }}:nth-child(1) { animation-delay: 0.1s; }
  .ai-crystal-care-faq__row-{{ ai_gen_id }}:nth-child(2) { animation-delay: 0.2s; }
  .ai-crystal-care-faq__row-{{ ai_gen_id }}:nth-child(3) { animation-delay: 0.3s; }
  .ai-crystal-care-faq__row-{{ ai_gen_id }}:nth-child(4) { animation-delay: 0.4s; }
  .ai-crystal-care-faq__row-{{ ai_gen_id }}:nth-child(5) { animation-delay: 0.5s; }
  .ai-crystal-care-faq__row-{{ ai_gen_id }}:nth-child(6) { animation-delay: 0.6s; }
  .ai-crystal-care-faq__row-{{ ai_gen_id }}:nth-child(7) { animation-delay: 0.7s; }
  .ai-crystal-care-faq__row-{{ ai_gen_id }}:nth-child(8) { animation-delay: 0.8s; }
  .ai-crystal-care-faq__row-{{ ai_gen_id }}:nth-child(9) { animation-delay: 0.9s; }
  .ai-crystal-care-faq__row-{{ ai_gen_id }}:nth-child(10) { animation-delay: 1s; }
  .ai-crystal-care-faq__row-{{ ai_gen_id }}:nth-child(11) { animation-delay: 1.1s; }
  .ai-crystal-care-faq__row-{{ ai_gen_id }}:nth-child(12) { animation-delay: 1.2s; }
  .ai-crystal-care-faq__row-{{ ai_gen_id }}:nth-child(13) { animation-delay: 1.3s; }
{% endstyle %}

<crystal-care-faq-{{ ai_gen_id }} class="ai-crystal-care-faq-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_title and block.settings.section_title != blank %}
    <h2 class="ai-crystal-care-faq__title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
  {% endif %}

  <div class="ai-crystal-care-faq__top-border-{{ ai_gen_id }}"></div>

  <div class="ai-crystal-care-faq__accordion-{{ ai_gen_id }}">
    {% if mineral %}
      {% if block.settings.show_cleanse and mineral.cleanse != blank %}
        <div class="ai-crystal-care-faq__row-{{ ai_gen_id }}" data-row-id="cleanse">
          <button
            class="ai-crystal-care-faq__question-{{ ai_gen_id }}"
            aria-expanded="false"
            aria-controls="answer-cleanse-{{ ai_gen_id }}"
          >
            <span>{{ block.settings.cleanse_label }}</span>
            <span class="ai-crystal-care-faq__chevron-{{ ai_gen_id }}">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 9L12 15L18 9" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>
          <div class="ai-crystal-care-faq__answer-wrapper-{{ ai_gen_id }}" id="answer-cleanse-{{ ai_gen_id }}">
            <div class="ai-crystal-care-faq__answer-{{ ai_gen_id }}">
              {{ mineral.cleanse }}
            </div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_recharge and mineral.recharge != blank %}
        <div class="ai-crystal-care-faq__row-{{ ai_gen_id }}" data-row-id="recharge">
          <button
            class="ai-crystal-care-faq__question-{{ ai_gen_id }}"
            aria-expanded="false"
            aria-controls="answer-recharge-{{ ai_gen_id }}"
          >
            <span>{{ block.settings.recharge_label }}</span>
            <span class="ai-crystal-care-faq__chevron-{{ ai_gen_id }}">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 9L12 15L18 9" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>
          <div class="ai-crystal-care-faq__answer-wrapper-{{ ai_gen_id }}" id="answer-recharge-{{ ai_gen_id }}">
            <div class="ai-crystal-care-faq__answer-{{ ai_gen_id }}">
              {{ mineral.recharge }}
            </div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_safety_notes and mineral.safety_notes != blank %}
        <div class="ai-crystal-care-faq__row-{{ ai_gen_id }}" data-row-id="safety">
          <button
            class="ai-crystal-care-faq__question-{{ ai_gen_id }}"
            aria-expanded="false"
            aria-controls="answer-safety-{{ ai_gen_id }}"
          >
            <span>{{ block.settings.safety_notes_label }}</span>
            <span class="ai-crystal-care-faq__chevron-{{ ai_gen_id }}">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 9L12 15L18 9" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>
          <div class="ai-crystal-care-faq__answer-wrapper-{{ ai_gen_id }}" id="answer-safety-{{ ai_gen_id }}">
            <div class="ai-crystal-care-faq__answer-{{ ai_gen_id }}">
              {{ mineral.safety_notes }}
            </div>
          </div>
        </div>
      {% endif %}
    {% endif %}

    {% if block.settings.show_faq %}
      {% assign faq_entries = shop.metaobjects.faq_group.values | where: 'category', 'Crystals & Minerals' | sort: 'sort_order' %}
      {% for faq in faq_entries limit: 10 %}
        {% if faq.question != blank and faq.answer != blank %}
          <div class="ai-crystal-care-faq__row-{{ ai_gen_id }}" data-row-id="faq-{{ forloop.index }}">
            <button
              class="ai-crystal-care-faq__question-{{ ai_gen_id }}"
              aria-expanded="false"
              aria-controls="answer-faq-{{ forloop.index }}-{{ ai_gen_id }}"
            >
              <span>{{ faq.question }}</span>
              <span class="ai-crystal-care-faq__chevron-{{ ai_gen_id }}">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 9L12 15L18 9" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </button>
            <div class="ai-crystal-care-faq__answer-wrapper-{{ ai_gen_id }}" id="answer-faq-{{ forloop.index }}-{{ ai_gen_id }}">
              <div class="ai-crystal-care-faq__answer-{{ ai_gen_id }}">
                {{ faq.answer }}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    {% endif %}

    {% if mineral == blank and block.settings.show_faq == false %}
      <div class="ai-crystal-care-faq__empty-state-{{ ai_gen_id }}">
        No crystal care information or FAQs available. Link a mineral metaobject to this product or enable FAQ display.
      </div>
    {% endif %}
  </div>
</crystal-care-faq-{{ ai_gen_id }}>

{% if block.settings.enable_schema %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% if mineral %}
        {% if block.settings.show_cleanse and mineral.cleanse != blank %}
          {
            "@type": "Question",
            "name": {{ block.settings.cleanse_label | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ mineral.cleanse | json }}
            }
          }{% if block.settings.show_recharge and mineral.recharge != blank %},{% elsif block.settings.show_safety_notes and mineral.safety_notes != blank %},{% elsif block.settings.show_faq %},{% endif %}
        {% endif %}
        {% if block.settings.show_recharge and mineral.recharge != blank %}
          {
            "@type": "Question",
            "name": {{ block.settings.recharge_label | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ mineral.recharge | json }}
            }
          }{% if block.settings.show_safety_notes and mineral.safety_notes != blank %},{% elsif block.settings.show_faq %},{% endif %}
        {% endif %}
        {% if block.settings.show_safety_notes and mineral.safety_notes != blank %}
          {
            "@type": "Question",
            "name": {{ block.settings.safety_notes_label | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ mineral.safety_notes | json }}
            }
          }{% if block.settings.show_faq %},{% endif %}
        {% endif %}
      {% endif %}
      {% if block.settings.show_faq %}
        {% assign faq_entries = shop.metaobjects.faq_group.values | where: 'category', 'Crystals & Minerals' | sort: 'sort_order' %}
        {% for faq in faq_entries limit: 10 %}
          {% if faq.question != blank and faq.answer != blank %}
            {
              "@type": "Question",
              "name": {{ faq.question | json }},
              "acceptedAnswer": {
                "@type": "Answer",
                "text": {{ faq.answer | json }}
              }
            }{% unless forloop.last %},{% endunless %}
          {% endif %}
        {% endfor %}
      {% endif %}
    ]
  }
  </script>
{% endif %}

<script>
(function() {
  class CrystalCareFaq{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.rows = [];
      this.currentOpenRow = null;
    }

    connectedCallback() {
      this.rows = Array.from(this.querySelectorAll('.ai-crystal-care-faq__row-{{ ai_gen_id }}'));
      this.setupEventListeners();
    }

    setupEventListeners() {
      this.rows.forEach((row) => {
        const button = row.querySelector('.ai-crystal-care-faq__question-{{ ai_gen_id }}');
        const answerWrapper = row.querySelector('.ai-crystal-care-faq__answer-wrapper-{{ ai_gen_id }}');
        const answer = row.querySelector('.ai-crystal-care-faq__answer-{{ ai_gen_id }}');

        if (!button || !answerWrapper || !answer) return;

        button.addEventListener('click', () => {
          const isOpen = row.classList.contains('active');

          if (this.currentOpenRow && this.currentOpenRow !== row) {
            this.closeRow(this.currentOpenRow);
          }

          if (isOpen) {
            this.closeRow(row);
            this.currentOpenRow = null;
          } else {
            this.openRow(row);
            this.currentOpenRow = row;
          }
        });
      });
    }

    openRow(row) {
      const button = row.querySelector('.ai-crystal-care-faq__question-{{ ai_gen_id }}');
      const answerWrapper = row.querySelector('.ai-crystal-care-faq__answer-wrapper-{{ ai_gen_id }}');
      const answer = row.querySelector('.ai-crystal-care-faq__answer-{{ ai_gen_id }}');

      row.classList.add('active');
      button.setAttribute('aria-expanded', 'true');
      answerWrapper.style.maxHeight = answer.scrollHeight + 'px';
    }

    closeRow(row) {
      const button = row.querySelector('.ai-crystal-care-faq__question-{{ ai_gen_id }}');
      const answerWrapper = row.querySelector('.ai-crystal-care-faq__answer-wrapper-{{ ai_gen_id }}');

      row.classList.remove('active');
      button.setAttribute('aria-expanded', 'false');
      answerWrapper.style.maxHeight = '0';
    }
  }

  customElements.define('crystal-care-faq-{{ ai_gen_id }}', CrystalCareFaq{{ ai_gen_id }});
})();
</script>

