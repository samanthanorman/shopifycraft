{% comment %}
  HARAMOON 101 Product Detail Section
  Displays the haramoon_101 metaobject entry linked to this product via
  product.metafields.custom.haramoon (metaobject reference field)

  Shows:
  - Routine step indicator (which of 4 steps this product is)
  - Key claims
  - Skin care benefits
  - Clinical results
  - Linked ingredient profiles (clickable chips → ingredient entry pages)
  - Product metadata (pH, texture, absorption time, finish, best time of day)
{% endcomment %}

{%- assign hm = product.metafields.custom.haramoon.value -%}

{%- if hm != blank -%}
  {%- assign step_num = hm.routine_step_number -%}
  {%- assign step_name = hm.routine_step_name | default: hm.product_name_type -%}

  <div class="hm101-section">
    <div class="hm101-inner">

      {%- comment -%} ── ROUTINE STEP INDICATOR ── {%- endcomment -%}
      <div class="hm101-step-indicator">
        <p class="hm101-eyebrow">HARAMOON 4-Step Routine</p>
        <div class="hm101-steps-row">
          {%- for i in (1..4) -%}
            {%- assign is_active = false -%}
            {%- if i == step_num -%}{%- assign is_active = true -%}{%- endif -%}
            <div class="hm101-step-circle {% if is_active %}hm101-step-circle--active{% endif %}">
              <span class="hm101-step-circle__num">{{ i }}</span>
              {%- if is_active and step_name != blank -%}
                <span class="hm101-step-circle__label">{{ step_name }}</span>
              {%- endif -%}
            </div>
            {%- if i < 4 -%}<div class="hm101-step-line {% if i < step_num %}hm101-step-line--done{% endif %}"></div>{%- endif -%}
          {%- endfor -%}
        </div>
        {%- if step_num != blank -%}
          <p class="hm101-step-caption">This product is <strong>Step {{ step_num }}</strong> of the HARAMOON Glass Skin Routine.
            <a href="/pages/complete-routine" class="hm101-routine-link">See the full routine →</a>
          </p>
        {%- endif -%}
      </div>

      {%- comment -%} ── KEY CLAIMS ── {%- endcomment -%}
      {%- assign claims = hm.key_claims -%}
      {%- if claims and claims.size > 0 -%}
        <div class="hm101-block">
          <h3 class="hm101-block__title">What It Does</h3>
          <ul class="hm101-claims-list">
            {%- for claim in claims -%}
              <li>{{ claim }}</li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      {%- comment -%} ── SKIN CARE BENEFITS ── {%- endcomment -%}
      {%- if hm.skin_care_benefits != blank -%}
        <div class="hm101-block">
          <h3 class="hm101-block__title">Skin Benefits</h3>
          <p class="hm101-block__body">{{ hm.skin_care_benefits }}</p>
        </div>
      {%- endif -%}

      {%- comment -%} ── CLINICAL RESULTS ── {%- endcomment -%}
      {%- if hm.clinical_results != blank -%}
        <div class="hm101-block hm101-block--clinical">
          <h3 class="hm101-block__title">Clinical Results</h3>
          <p class="hm101-block__body">{{ hm.clinical_results }}</p>
        </div>
      {%- endif -%}

      {%- comment -%} ── PRODUCT METADATA ── {%- endcomment -%}
      {%- assign has_meta = false -%}
      {%- if hm.ph != blank or hm.texture_type != blank or hm.absorption_time != blank or hm.finish_type != blank or hm.best_for_time_of_day != blank or hm.volume != blank -%}
        {%- assign has_meta = true -%}
      {%- endif -%}
      {%- if has_meta -%}
        <div class="hm101-block">
          <h3 class="hm101-block__title">Product Details</h3>
          <ul class="hm101-meta-list">
            {%- if hm.ph != blank -%}<li><span class="hm101-meta-label">pH</span><span class="hm101-meta-value">{{ hm.ph }}</span></li>{%- endif -%}
            {%- if hm.texture_type != blank -%}<li><span class="hm101-meta-label">Texture</span><span class="hm101-meta-value">{{ hm.texture_type }}</span></li>{%- endif -%}
            {%- if hm.absorption_time != blank -%}<li><span class="hm101-meta-label">Absorbs In</span><span class="hm101-meta-value">{{ hm.absorption_time }}</span></li>{%- endif -%}
            {%- if hm.finish_type != blank -%}<li><span class="hm101-meta-label">Finish</span><span class="hm101-meta-value">{{ hm.finish_type }}</span></li>{%- endif -%}
            {%- if hm.best_for_time_of_day != blank -%}<li><span class="hm101-meta-label">Best Used</span><span class="hm101-meta-value">{{ hm.best_for_time_of_day }}</span></li>{%- endif -%}
            {%- if hm.volume != blank -%}<li><span class="hm101-meta-label">Size</span><span class="hm101-meta-value">{{ hm.volume }}</span></li>{%- endif -%}
          </ul>
        </div>
      {%- endif -%}

      {%- comment -%} ── INGREDIENT PROFILE CHIPS ── {%- endcomment -%}
      {%- assign ing_profiles = hm.ingredient_profile -%}
      {%- if ing_profiles and ing_profiles.size > 0 -%}
        <div class="hm101-block">
          <h3 class="hm101-block__title">Key Ingredients</h3>
          <p class="hm101-block__subtitle">Tap any ingredient to learn more about what it does for your skin.</p>
          <div class="hm101-ingredient-chips">
            {%- for ing_ref in ing_profiles -%}
              {%- assign ing = ing_ref.value -%}
              {%- assign ing_name = ing.ingredient_name | default: ing.name -%}
              {%- assign ing_function = ing.main_function -%}
              {%- if ing.system.url != blank -%}
                <a href="{{ ing.system.url }}" class="hm101-ing-chip hm101-ing-chip--link">
                  <span class="hm101-ing-chip__name">{{ ing_name }}</span>
                  {%- if ing_function != blank -%}
                    <span class="hm101-ing-chip__fn">{{ ing_function }}</span>
                  {%- endif -%}
                </a>
              {%- else -%}
                <span class="hm101-ing-chip">
                  <span class="hm101-ing-chip__name">{{ ing_name }}</span>
                  {%- if ing_function != blank -%}
                    <span class="hm101-ing-chip__fn">{{ ing_function }}</span>
                  {%- endif -%}
                </span>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <a href="/pages/ultimate-korean-skincare-ingredient-glossary" class="hm101-glossary-link">
            View Full Ingredient Glossary →
          </a>
        </div>
      {%- endif -%}

      {%- comment -%} ── PRODUCT HIGHLIGHT / STORY ── {%- endcomment -%}
      {%- if hm.product_highlight != blank -%}
        <div class="hm101-block hm101-block--highlight">
          <p class="hm101-highlight-text">{{ hm.product_highlight }}</p>
        </div>
      {%- endif -%}

    </div>
  </div>
{%- endif -%}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

  .hm101-section {
    padding: {{ section.settings.padding_top | default: 48 }}px 20px {{ section.settings.padding_bottom | default: 48 }}px;
    background: {{ section.settings.bg_color | default: '#ffffff' }};
    font-family: 'Poppins', sans-serif;
  }
  .hm101-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .hm101-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #3498ff;
    margin: 0 0 16px;
  }

  /* ── STEP INDICATOR ── */
  .hm101-step-indicator {
    margin-bottom: 40px;
    padding: 28px;
    background: #f8f9ff;
    border-radius: 16px;
    border: 1px solid rgba(52,152,255,0.12);
  }
  .hm101-steps-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 16px;
    flex-wrap: nowrap;
    overflow-x: auto;
  }
  .hm101-step-circle {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }
  .hm101-step-circle__num {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #e8edf5;
    color: #9aa0b0;
    font-size: 15px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }
  .hm101-step-circle--active .hm101-step-circle__num {
    background: linear-gradient(135deg, #3498ff, #0d6efd);
    color: #fff;
    width: 52px;
    height: 52px;
    font-size: 18px;
    box-shadow: 0 4px 16px rgba(52,152,255,0.4);
    animation: hm101-pulse 2s ease infinite;
  }
  @keyframes hm101-pulse {
    0%, 100% { box-shadow: 0 4px 16px rgba(52,152,255,0.4); }
    50% { box-shadow: 0 4px 28px rgba(52,152,255,0.65); }
  }
  .hm101-step-circle__label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #3498ff;
    text-align: center;
    max-width: 70px;
    line-height: 1.3;
  }
  .hm101-step-line {
    width: 40px;
    height: 2px;
    background: #e8edf5;
    flex-shrink: 0;
    margin-bottom: 22px;
  }
  .hm101-step-line--done {
    background: linear-gradient(90deg, #3498ff, rgba(52,152,255,0.3));
  }
  @media(max-width: 380px) {
    .hm101-step-circle__num { width: 32px; height: 32px; font-size: 13px; }
    .hm101-step-circle--active .hm101-step-circle__num { width: 40px; height: 40px; font-size: 15px; }
    .hm101-step-line { width: 24px; }
  }
  .hm101-step-caption {
    font-size: 12px;
    color: #53585a;
    text-align: center;
    margin: 0;
    line-height: 1.6;
  }
  .hm101-routine-link {
    color: #3498ff;
    font-weight: 600;
    text-decoration: none;
    margin-left: 4px;
  }
  .hm101-routine-link:hover { text-decoration: underline; }

  /* ── BLOCKS ── */
  .hm101-block {
    margin-bottom: 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .hm101-block:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  .hm101-block__title {
    font-size: 11px !important;
    font-weight: 700 !important;
    letter-spacing: 0.15em !important;
    text-transform: uppercase !important;
    color: #141615 !important;
    margin: 0 0 12px !important;
  }
  .hm101-block__subtitle {
    font-size: 12px;
    color: #53585a;
    margin: -6px 0 14px;
    line-height: 1.5;
  }
  .hm101-block__body {
    font-size: 14px;
    color: #53585a;
    line-height: 1.75;
    margin: 0;
  }
  .hm101-block--clinical {
    background: #f0f7ff;
    border-radius: 12px;
    padding: 20px;
    border: 1px solid rgba(52,152,255,0.12);
    border-bottom: 1px solid rgba(52,152,255,0.12) !important;
  }
  .hm101-block--highlight {
    background: linear-gradient(135deg, #0d1b3e, #1a2a5e);
    border-radius: 14px;
    padding: 24px;
    border-bottom: none !important;
  }
  .hm101-highlight-text {
    font-size: 15px;
    font-weight: 500;
    color: rgba(255,255,255,0.9);
    line-height: 1.7;
    margin: 0;
    font-style: italic;
  }

  /* ── CLAIMS LIST ── */
  .hm101-claims-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }
  @media(min-width: 480px) { .hm101-claims-list { grid-template-columns: repeat(2, 1fr); } }
  .hm101-claims-list li {
    font-size: 13px;
    color: #141615;
    padding: 8px 12px 8px 28px;
    position: relative;
    background: #f8f9ff;
    border-radius: 8px;
    line-height: 1.4;
  }
  .hm101-claims-list li::before {
    content: '✓';
    position: absolute;
    left: 10px;
    color: #3498ff;
    font-weight: 700;
    font-size: 12px;
  }

  /* ── META LIST ── */
  .hm101-meta-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  @media(min-width: 480px) { .hm101-meta-list { grid-template-columns: repeat(3, 1fr); } }
  .hm101-meta-list li {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 10px 14px;
    background: #f8f9ff;
    border-radius: 10px;
    border: 1px solid rgba(52,152,255,0.1);
  }
  .hm101-meta-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #3498ff;
  }
  .hm101-meta-value {
    font-size: 13px;
    font-weight: 600;
    color: #141615;
  }

  /* ── INGREDIENT CHIPS ── */
  .hm101-ingredient-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 14px;
  }
  .hm101-ing-chip {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    padding: 8px 14px;
    border-radius: 10px;
    background: rgba(52,152,255,0.06);
    border: 1px solid rgba(52,152,255,0.15);
  }
  .hm101-ing-chip--link {
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .hm101-ing-chip--link:hover {
    background: rgba(52,152,255,0.14);
    border-color: rgba(52,152,255,0.4);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(52,152,255,0.15);
  }
  .hm101-ing-chip__name {
    font-size: 12px;
    font-weight: 700;
    color: #141615;
  }
  .hm101-ing-chip__fn {
    font-size: 10px;
    color: #3498ff;
    font-weight: 500;
  }
  .hm101-glossary-link {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #3498ff;
    text-decoration: none;
    border-bottom: 1px solid rgba(52,152,255,0.3);
    padding-bottom: 2px;
    transition: color 0.2s;
  }
  .hm101-glossary-link:hover { color: #0d6efd; }
</style>

{% schema %}
{
  "name": "HARAMOON 101 Detail",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 0, "max": 100, "step": 4, "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 0, "max": 100, "step": 4, "default": 48 }
  ],
  "presets": [{ "name": "HARAMOON 101 Detail" }]
}
{% endschema %}
