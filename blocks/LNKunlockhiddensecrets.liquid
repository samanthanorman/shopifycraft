{% doc %}
  @prompt
    	Section Type: Hero Banner
    	•	Background: solid light beige (#F8F2E8 approx)
    	•	Heading: “Unlock Nebraska’s Hidden Secrets” (bold, large font ~48px)
    	•	Subheading: “Uncover curiosities, legends, and the unexpected.”
    	•	CTA: Button “Join the Good Life” (rounded, filled with coral-red #E74C3C)
    	•	Alignment: Centered, stacked layout, generous padding top/bottom (~80px)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    text-align: center;
    width: 100%;
  }

  .ai-hero-banner-content-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-hero-banner-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    color: {{ block.settings.heading_color }};
    margin: 0;
    max-width: 800px;
  }

  .ai-hero-banner-subheading-{{ ai_gen_id }} {
    font-family: {{ block.settings.subheading_font.family }}, {{ block.settings.subheading_font.fallback_families }};
    font-weight: {{ block.settings.subheading_font.weight }};
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.4;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    max-width: 600px;
  }

  .ai-hero-banner-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 768px) {
    .ai-hero-banner-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px 16px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-hero-banner-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-hero-banner-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-hero-banner-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h1 class="ai-hero-banner-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h1>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <p class="ai-hero-banner-subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </p>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a 
        href="{{ block.settings.button_link | default: '#' }}" 
        class="ai-hero-banner-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Unlock Nebraska's Hidden Secrets"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Uncover curiosities, legends, and the unexpected."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Join the Good Life"
