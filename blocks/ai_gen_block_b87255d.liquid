{% doc %}
  @prompt
    Crystal Hero Identity Block
    (display_name, one_liner, color swatch, chakra, zodiac, element, origin, chemical_formula, mohs_hardness, planets, number, archetype, musical_chord)
    
    Create a custom Liquid section called mineral_identity_hero for a Shopify metaobject template page (URL pattern: /pages/crystals/[handle]). The Liquid root object is metaobject — access all fields as metaobject.[key].value.
    
    Display the following fields:
    
    metaobject.display_name.value as the main H1 heading
    metaobject.one_liner.value as a subtitle tagline
    metaobject.color.value as a small filled color swatch circle next to the heading
    A responsive CSS data grid (2 col mobile, 4 col desktop) showing: chakra, zodiac, element, origin, chemical_formula, mohs_hardness, planets, number, archetype, musical_chord — each as a label/value pair. Only render a grid cell if the field value is not blank.
    Style: crisp white background (#FFFFFF), medical blue (#0066FF) accent, Poppins medium (dark charcoal #1A1A1A) for labels, Raleway light (soft grey #666666) for values. Thin 2px medical blue top border across full section width. No gradients, no rounded pill shapes. Generous 24px+ padding. Staggered fade-up scroll entrance animation. Include an editable section title setting in schema. Add ItemPage JSON-LD structured data in a script tag using display_name, seo_description, origin, chemical_formula, and color fields. allow full custom spacing, sizing, padding, width, etc
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mineral-hero-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    border-top: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-mineral-hero__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-mineral-hero__header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.header_gap }}px;
    margin-bottom: {{ block.settings.header_margin_bottom }}px;
    flex-wrap: wrap;
  }

  .ai-mineral-hero__title-{{ ai_gen_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-mineral-hero__color-swatch-{{ ai_gen_id }} {
    width: {{ block.settings.swatch_size }}px;
    height: {{ block.settings.swatch_size }}px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 2px solid {{ block.settings.swatch_border_color }};
  }

  .ai-mineral-hero__tagline-{{ ai_gen_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: {{ block.settings.tagline_size }}px;
    color: {{ block.settings.tagline_color }};
    margin: 0 0 {{ block.settings.tagline_margin_bottom }}px;
    line-height: 1.5;
  }

  .ai-mineral-hero__section-title-{{ ai_gen_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: {{ block.settings.section_title_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.section_title_margin_bottom }}px;
    line-height: 1.3;
  }

  .ai-mineral-hero__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-mineral-hero__grid-item-{{ ai_gen_id }} {
    padding: {{ block.settings.grid_item_padding }}px;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-mineral-hero__grid-item-{{ ai_gen_id }}.ai-mineral-hero__visible-{{ ai_gen_id }} {
    animation: ai-mineral-hero-fade-up-{{ ai_gen_id }} 0.6s ease-out forwards;
  }

  .ai-mineral-hero__grid-item-{{ ai_gen_id }}:nth-child(1) {
    animation-delay: 0.1s;
  }

  .ai-mineral-hero__grid-item-{{ ai_gen_id }}:nth-child(2) {
    animation-delay: 0.15s;
  }

  .ai-mineral-hero__grid-item-{{ ai_gen_id }}:nth-child(3) {
    animation-delay: 0.2s;
  }

  .ai-mineral-hero__grid-item-{{ ai_gen_id }}:nth-child(4) {
    animation-delay: 0.25s;
  }

  .ai-mineral-hero__grid-item-{{ ai_gen_id }}:nth-child(5) {
    animation-delay: 0.3s;
  }

  .ai-mineral-hero__grid-item-{{ ai_gen_id }}:nth-child(6) {
    animation-delay: 0.35s;
  }

  .ai-mineral-hero__grid-item-{{ ai_gen_id }}:nth-child(7) {
    animation-delay: 0.4s;
  }

  .ai-mineral-hero__grid-item-{{ ai_gen_id }}:nth-child(8) {
    animation-delay: 0.45s;
  }

  .ai-mineral-hero__grid-item-{{ ai_gen_id }}:nth-child(9) {
    animation-delay: 0.5s;
  }

  .ai-mineral-hero__grid-item-{{ ai_gen_id }}:nth-child(10) {
    animation-delay: 0.55s;
  }

  .ai-mineral-hero__label-{{ ai_gen_id }} {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    margin: 0 0 {{ block.settings.label_margin_bottom }}px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-mineral-hero__value-{{ ai_gen_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: {{ block.settings.value_size }}px;
    color: {{ block.settings.value_color }};
    margin: 0;
    line-height: 1.5;
  }

  @keyframes ai-mineral-hero-fade-up-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (min-width: 750px) {
    .ai-mineral-hero__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-mineral-hero-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-mineral-hero__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-mineral-hero__tagline-{{ ai_gen_id }} {
      font-size: {{ block.settings.tagline_size | times: 0.8 }}px;
    }

    .ai-mineral-hero__section-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.section_title_size | times: 0.8 }}px;
    }

    .ai-mineral-hero__color-swatch-{{ ai_gen_id }} {
      width: {{ block.settings.swatch_size | times: 0.8 }}px;
      height: {{ block.settings.swatch_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<mineral-identity-hero-{{ ai_gen_id }} class="ai-mineral-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-mineral-hero__container-{{ ai_gen_id }}">
    {% if metaobject.display_name.value != blank %}
      <div class="ai-mineral-hero__header-{{ ai_gen_id }}">
        <h1 class="ai-mineral-hero__title-{{ ai_gen_id }}">{{ metaobject.display_name.value }}</h1>
        {% if metaobject.color.value != blank %}
          <div
            class="ai-mineral-hero__color-swatch-{{ ai_gen_id }}"
            style="background-color: {{ metaobject.color.value }};"
            aria-label="Color: {{ metaobject.color.value }}"
          ></div>
        {% endif %}
      </div>
    {% endif %}

    {% if metaobject.one_liner.value != blank %}
      <p class="ai-mineral-hero__tagline-{{ ai_gen_id }}">{{ metaobject.one_liner.value }}</p>
    {% endif %}

    {% if block.settings.section_title != blank %}
      <h2 class="ai-mineral-hero__section-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}

    <div class="ai-mineral-hero__grid-{{ ai_gen_id }}">
      {% if metaobject.chakra.value != blank %}
        <div class="ai-mineral-hero__grid-item-{{ ai_gen_id }}" data-grid-item>
          <div class="ai-mineral-hero__label-{{ ai_gen_id }}">Chakra</div>
          <div class="ai-mineral-hero__value-{{ ai_gen_id }}">{{ metaobject.chakra.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.zodiac.value != blank %}
        <div class="ai-mineral-hero__grid-item-{{ ai_gen_id }}" data-grid-item>
          <div class="ai-mineral-hero__label-{{ ai_gen_id }}">Zodiac</div>
          <div class="ai-mineral-hero__value-{{ ai_gen_id }}">{{ metaobject.zodiac.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.element.value != blank %}
        <div class="ai-mineral-hero__grid-item-{{ ai_gen_id }}" data-grid-item>
          <div class="ai-mineral-hero__label-{{ ai_gen_id }}">Element</div>
          <div class="ai-mineral-hero__value-{{ ai_gen_id }}">{{ metaobject.element.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.origin.value != blank %}
        <div class="ai-mineral-hero__grid-item-{{ ai_gen_id }}" data-grid-item>
          <div class="ai-mineral-hero__label-{{ ai_gen_id }}">Origin</div>
          <div class="ai-mineral-hero__value-{{ ai_gen_id }}">{{ metaobject.origin.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.chemical_formula.value != blank %}
        <div class="ai-mineral-hero__grid-item-{{ ai_gen_id }}" data-grid-item>
          <div class="ai-mineral-hero__label-{{ ai_gen_id }}">Chemical Formula</div>
          <div class="ai-mineral-hero__value-{{ ai_gen_id }}">{{ metaobject.chemical_formula.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.mohs_hardness.value != blank %}
        <div class="ai-mineral-hero__grid-item-{{ ai_gen_id }}" data-grid-item>
          <div class="ai-mineral-hero__label-{{ ai_gen_id }}">Mohs Hardness</div>
          <div class="ai-mineral-hero__value-{{ ai_gen_id }}">{{ metaobject.mohs_hardness.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.planets.value != blank %}
        <div class="ai-mineral-hero__grid-item-{{ ai_gen_id }}" data-grid-item>
          <div class="ai-mineral-hero__label-{{ ai_gen_id }}">Planets</div>
          <div class="ai-mineral-hero__value-{{ ai_gen_id }}">{{ metaobject.planets.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.number.value != blank %}
        <div class="ai-mineral-hero__grid-item-{{ ai_gen_id }}" data-grid-item>
          <div class="ai-mineral-hero__label-{{ ai_gen_id }}">Number</div>
          <div class="ai-mineral-hero__value-{{ ai_gen_id }}">{{ metaobject.number.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.archetype.value != blank %}
        <div class="ai-mineral-hero__grid-item-{{ ai_gen_id }}" data-grid-item>
          <div class="ai-mineral-hero__label-{{ ai_gen_id }}">Archetype</div>
          <div class="ai-mineral-hero__value-{{ ai_gen_id }}">{{ metaobject.archetype.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.musical_chord.value != blank %}
        <div class="ai-mineral-hero__grid-item-{{ ai_gen_id }}" data-grid-item>
          <div class="ai-mineral-hero__label-{{ ai_gen_id }}">Musical Chord</div>
          <div class="ai-mineral-hero__value-{{ ai_gen_id }}">{{ metaobject.musical_chord.value }}</div>
        </div>
      {% endif %}
    </div>
  </div>
</mineral-identity-hero-{{ ai_gen_id }}>

{% if metaobject.display_name.value != blank %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemPage",
    "name": {{ metaobject.display_name.value | json }},
    {% if metaobject.seo_description.value != blank %}
      "description": {{ metaobject.seo_description.value | json }},
    {% endif %}
    "mainEntity": {
      "@type": "Product",
      "name": {{ metaobject.display_name.value | json }},
      {% if metaobject.seo_description.value != blank %}
        "description": {{ metaobject.seo_description.value | json }},
      {% endif %}
      "additionalProperty": [
        {% if metaobject.origin.value != blank %}
          {
            "@type": "PropertyValue",
            "name": "Origin",
            "value": {{ metaobject.origin.value | json }}
          }{% if metaobject.chemical_formula.value != blank or metaobject.color.value != blank %},{% endif %}
        {% endif %}
        {% if metaobject.chemical_formula.value != blank %}
          {
            "@type": "PropertyValue",
            "name": "Chemical Formula",
            "value": {{ metaobject.chemical_formula.value | json }}
          }{% if metaobject.color.value != blank %},{% endif %}
        {% endif %}
        {% if metaobject.color.value != blank %}
          {
            "@type": "PropertyValue",
            "name": "Color",
            "value": {{ metaobject.color.value | json }}
          }
        {% endif %}
      ]
    }
  }
  </script>
{% endif %}

<script>
  (function() {
    class MineralIdentityHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initScrollAnimation();
      }

      initScrollAnimation() {
        const gridItems = this.querySelectorAll('[data-grid-item]');
        
        if (!gridItems.length) return;

        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('ai-mineral-hero__visible-{{ ai_gen_id }}');
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        gridItems.forEach((item) => {
          observer.observe(item);
        });
      }
    }

    customElements.define('mineral-identity-hero-{{ ai_gen_id }}', MineralIdentityHero{{ ai_gen_id }});
  })();
</script>

