{% doc %}
  @prompt
    animated single line/row carousel uppercase text custom liquid section dynamically linking metafield skin care benefits - skin care effects - resembling a cute mid century outline cartoon movie marquee with glowing lights in between each metafield entry put a little dot between to separate the words. this section should be smaller and tasteful we are just adding pizzazz in a unique fun way so please take a moment and understand this prompt as if i am an amateur website designer looking to you for optimal, elite results for this skin care product template page trying to engage the gen z audience, can you add skin_care_benefits to the same line to fill in the entire banner/bar matching the same text and glowy stuff you have now it looks beautiful but there is too much empty space so please include that other metafield for this product template
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    overflow: hidden;
    background: {{ block.settings.background_color }};
    padding: {{ block.settings.vertical_padding }}px 0;
    border-top: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    position: relative;
  }

  .ai-marquee-wrapper-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.animation_speed }}s linear infinite;
  }

  .ai-marquee-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-marquee-item-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: {{ block.settings.item_spacing }}px;
    font-family: {{ block.settings.font.family }}, {{ block.settings.font.fallback_families }};
    font-weight: {{ block.settings.font.weight }};
    font-size: {{ block.settings.font_size }}px;
    text-transform: uppercase;
    letter-spacing: {{ block.settings.letter_spacing }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-marquee-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background: {{ block.settings.dot_color }};
    flex-shrink: 0;
    {% if block.settings.enable_glow %}
      box-shadow: 
        0 0 {{ block.settings.glow_intensity }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 2 }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 3 }}px {{ block.settings.glow_color }};
      animation: ai-marquee-pulse-{{ ai_gen_id }} {{ block.settings.pulse_speed }}s ease-in-out infinite;
    {% endif %}
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  {% if block.settings.enable_glow %}
    @keyframes ai-marquee-pulse-{{ ai_gen_id }} {
      0%, 100% {
        opacity: 1;
      }
      50% {
        opacity: 0.5;
      }
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-marquee-item-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.8 }}px;
    }
    
    .ai-marquee-dot-{{ ai_gen_id }} {
      width: {{ block.settings.dot_size | times: 0.8 }}px;
      height: {{ block.settings.dot_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<marquee-carousel-{{ ai_gen_id }} class="ai-marquee-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marquee-wrapper-{{ ai_gen_id }}">
    <div class="ai-marquee-content-{{ ai_gen_id }}">
      {% liquid
        assign all_items = ''
        assign has_benefits = false
        assign has_effects = false

        if product.metafields.custom.skin_care_benefits != blank
          assign benefits = product.metafields.custom.skin_care_benefits | split: ','
          assign has_benefits = true
        endif

        if product.metafields.custom.skin_care_effects != blank
          assign effects = product.metafields.custom.skin_care_effects | split: ','
          assign has_effects = true
        endif
      %}

      {% if has_benefits or has_effects %}
        {% if has_benefits %}
          {% for benefit in benefits %}
            <span class="ai-marquee-item-{{ ai_gen_id }}">{{ benefit | strip }}</span>
            <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
          {% endfor %}
        {% endif %}

        {% if has_effects %}
          {% for effect in effects %}
            <span class="ai-marquee-item-{{ ai_gen_id }}">{{ effect | strip }}</span>
            <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
          {% endfor %}
        {% endif %}
      {% else %}
        <span class="ai-marquee-item-{{ ai_gen_id }}">Hydrating</span>
        <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
        <span class="ai-marquee-item-{{ ai_gen_id }}">Anti-Aging</span>
        <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
        <span class="ai-marquee-item-{{ ai_gen_id }}">Brightening</span>
        <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
        <span class="ai-marquee-item-{{ ai_gen_id }}">Soothing</span>
        <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
        <span class="ai-marquee-item-{{ ai_gen_id }}">Firming</span>
        <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
      {% endif %}
    </div>
    <div class="ai-marquee-content-{{ ai_gen_id }}" aria-hidden="true">
      {% if has_benefits or has_effects %}
        {% if has_benefits %}
          {% for benefit in benefits %}
            <span class="ai-marquee-item-{{ ai_gen_id }}">{{ benefit | strip }}</span>
            <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
          {% endfor %}
        {% endif %}

        {% if has_effects %}
          {% for effect in effects %}
            <span class="ai-marquee-item-{{ ai_gen_id }}">{{ effect | strip }}</span>
            <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
          {% endfor %}
        {% endif %}
      {% else %}
        <span class="ai-marquee-item-{{ ai_gen_id }}">Hydrating</span>
        <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
        <span class="ai-marquee-item-{{ ai_gen_id }}">Anti-Aging</span>
        <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
        <span class="ai-marquee-item-{{ ai_gen_id }}">Brightening</span>
        <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
        <span class="ai-marquee-item-{{ ai_gen_id }}">Soothing</span>
        <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
        <span class="ai-marquee-item-{{ ai_gen_id }}">Firming</span>
        <span class="ai-marquee-dot-{{ ai_gen_id }}"></span>
      {% endif %}
    </div>
  </div>
</marquee-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class MarqueeCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-marquee-wrapper-{{ ai_gen_id }}');
        this.pauseOnHover();
      }

      pauseOnHover() {
        if (!this.wrapper) return;
        
        this.addEventListener('mouseenter', () => {
          this.wrapper.style.animationPlayState = 'paused';
        });

        this.addEventListener('mouseleave', () => {
          this.wrapper.style.animationPlayState = 'running';
        });
      }
    }

    customElements.define('marquee-carousel-{{ ai_gen_id }}', MarqueeCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Skincare benefits marquee",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Metafield source"
    },
    {
      "type": "paragraph",
      "content": "This block pulls data from product.metafields.custom.skin_care_benefits AND product.metafields.custom.skin_care_effects. Both will display together on the same line. Add comma-separated values to those metafields."
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "font",
      "label": "Font",
      "default": "poppins_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0d1b3e"
    },
    {
      "type": "header",
      "content": "Marquee lights"
    },
    {
      "type": "range",
      "id": "dot_size",
      "label": "Dot size",
      "min": 4,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot color",
      "default": "#f0d84a"
    },
    {
      "type": "checkbox",
      "id": "enable_glow",
      "label": "Enable glow effect",
      "default": true
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "#f0d84a"
    },
    {
      "type": "range",
      "id": "glow_intensity",
      "label": "Glow intensity",
      "min": 2,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "pulse_speed",
      "label": "Pulse speed",
      "min": 1,
      "max": 5,
      "step": 0.5,
      "unit": "s",
      "default": 2
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Item spacing",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 30
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0d1b3e"
    },
    {
      "type": "range",
      "id": "border_thickness",
      "label": "Border thickness",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#f0d84a"
    }
  ],
  "presets": [
    {
      "name": "Skincare benefits marquee"
    }
  ]
}
{% endschema %}
