# ─────────────────────────────────────────────────────────────────────
# WAX | WANE — Blog Sweep Credentials Template
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# The .env file is gitignored and will never be committed.
#
# SHOPIFY_STORE  = your myshopify.com domain (e.g. 6f97d0.myshopify.com)
# SHOPIFY_TOKEN  = your Admin API access token (starts with shpat_)
# GEMINI_API_KEY = your Google Gemini API key (starts with AIzaSy)
# ─────────────────────────────────────────────────────────────────────

SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_TOKEN=shpat_your_token_here
GEMINI_API_KEY=AIzaSy_your_gemini_key_here
