{% comment %}
  Ingredient Profile metaobject detail section — HARAMOON Premium Edition
  Wax | Wane — Gen Z · K-pop · Holographic · Cyber · Hermione Granger
  
  Renders individual ingredient_profile metaobject pages with:
  - Breadcrumb navigation (Home > HARAMOON Glossary > Ingredient Name)
  - Structured data for Google Search Console
  - Prev/Next navigation
  - HARAMOON brand styling (#3498ff medical blue)
{% endcomment %}

{%- assign m = metaobject -%}
{%- render 'metaobject-breadcrumb', metaobject: metaobject, type: 'ingredient' -%}

<style>
  .ingredient-page-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 80px;
    font-family: inherit;
  }

  /* Hero Section */
  .ingredient-hero {
    background: linear-gradient(135deg, #f0f7ff 0%, #e8f4ff 50%, #f5f0ff 100%);
    border-radius: 20px;
    padding: 48px 40px;
    margin: 32px 0;
    border: 1px solid rgba(52, 152, 255, 0.15);
    position: relative;
    overflow: hidden;
  }
  .ingredient-hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(52, 152, 255, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .ingredient-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }
  .ingredient-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .ingredient-badge--category {
    background: rgba(52, 152, 255, 0.12);
    color: #3498ff;
    border: 1px solid rgba(52, 152, 255, 0.25);
  }
  .ingredient-badge--origin-natural {
    background: rgba(14, 83, 73, 0.1);
    color: #0e5349;
    border: 1px solid rgba(14, 83, 73, 0.2);
  }
  .ingredient-badge--origin-synthetic {
    background: rgba(171, 148, 160, 0.15);
    color: #6b5b6e;
    border: 1px solid rgba(171, 148, 160, 0.3);
  }
  .ingredient-badge--origin-both {
    background: rgba(10, 80, 109, 0.1);
    color: #0a506d;
    border: 1px solid rgba(10, 80, 109, 0.2);
  }
  .ingredient-hero__name {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 800;
    color: #0a506d;
    margin: 0 0 8px;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .ingredient-hero__inci {
    font-size: 14px;
    color: rgba(10, 80, 109, 0.6);
    font-style: italic;
    margin-bottom: 16px;
    letter-spacing: 0.02em;
  }
  .ingredient-hero__function {
    font-size: 16px;
    color: #3498ff;
    font-weight: 600;
    margin-bottom: 0;
  }

  /* Content Grid */
  .ingredient-content-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 32px;
    margin-top: 32px;
  }
  @media (max-width: 768px) {
    .ingredient-content-grid {
      grid-template-columns: 1fr;
    }
    .ingredient-hero {
      padding: 32px 24px;
    }
  }

  /* Description Block */
  .ingredient-description-block {
    background: #fff;
    border-radius: 16px;
    padding: 32px;
    border: 1px solid rgba(52, 152, 255, 0.1);
    box-shadow: 0 2px 20px rgba(10, 80, 109, 0.05);
  }
  .ingredient-description-block h2 {
    font-size: 18px;
    font-weight: 700;
    color: #0a506d;
    margin: 0 0 16px;
    padding-bottom: 12px;
    border-bottom: 2px solid rgba(52, 152, 255, 0.15);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .ingredient-description-block h2::before {
    content: '';
    display: inline-block;
    width: 4px;
    height: 20px;
    background: #3498ff;
    border-radius: 2px;
    flex-shrink: 0;
  }
  .ingredient-description-block p {
    font-size: 15px;
    line-height: 1.75;
    color: #2c2c2c;
    margin: 0;
  }

  /* Sidebar Info Card */
  .ingredient-sidebar {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .ingredient-info-card {
    background: #fff;
    border-radius: 16px;
    padding: 24px;
    border: 1px solid rgba(52, 152, 255, 0.1);
    box-shadow: 0 2px 20px rgba(10, 80, 109, 0.05);
  }
  .ingredient-info-card h3 {
    font-size: 13px;
    font-weight: 700;
    color: #3498ff;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 16px;
  }
  .ingredient-info-row {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .ingredient-info-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .ingredient-info-item__label {
    font-size: 11px;
    font-weight: 600;
    color: rgba(10, 80, 109, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .ingredient-info-item__value {
    font-size: 14px;
    color: #0a506d;
    font-weight: 500;
  }

  /* Cultural Note */
  .ingredient-cultural-note {
    background: linear-gradient(135deg, #efeeec 0%, #e8e4f0 100%);
    border-radius: 16px;
    padding: 24px;
    border-left: 4px solid #ab94a0;
  }
  .ingredient-cultural-note h3 {
    font-size: 13px;
    font-weight: 700;
    color: #6b5b6e;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ingredient-cultural-note p {
    font-size: 14px;
    line-height: 1.65;
    color: #3d2f40;
    margin: 0;
  }

  /* CTA Section */
  .ingredient-cta-section {
    margin-top: 48px;
    padding: 40px;
    background: linear-gradient(135deg, #001f44 0%, #002c60 100%);
    border-radius: 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .ingredient-cta-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 30% 50%, rgba(52, 152, 255, 0.15) 0%, transparent 60%),
                radial-gradient(circle at 70% 50%, rgba(171, 148, 160, 0.1) 0%, transparent 60%);
    pointer-events: none;
  }
  .ingredient-cta-section h2 {
    font-size: 24px;
    font-weight: 700;
    color: #dbe8ff;
    margin: 0 0 12px;
    position: relative;
  }
  .ingredient-cta-section p {
    font-size: 15px;
    color: rgba(219, 232, 255, 0.7);
    margin: 0 0 24px;
    position: relative;
  }
  .ingredient-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: #3498ff;
    color: #fff;
    text-decoration: none;
    border-radius: 30px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: all 0.3s ease;
    position: relative;
    box-shadow: 0 0 20px rgba(52, 152, 255, 0.4);
  }
  .ingredient-cta-btn:hover {
    background: #5aabff;
    box-shadow: 0 0 30px rgba(52, 152, 255, 0.6);
    transform: translateY(-2px);
  }
</style>

<div class="ingredient-page-wrapper">
  {%- comment -%} Hero Section {%- endcomment -%}
  <div class="ingredient-hero">
    <div class="ingredient-hero__meta">
      {%- if m.category != blank -%}
        <span class="ingredient-badge ingredient-badge--category">{{ m.category }}</span>
      {%- endif -%}
      {%- if m.chemical_class != blank -%}
        <span class="ingredient-badge ingredient-badge--category" style="background: rgba(10,80,109,0.08); color: #0a506d; border-color: rgba(10,80,109,0.2);">{{ m.chemical_class }}</span>
      {%- endif -%}
      {%- if m.origin != blank -%}
        {%- assign origin_lower = m.origin | downcase -%}
        {%- if origin_lower contains 'natural' and origin_lower contains 'synthetic' -%}
          <span class="ingredient-badge ingredient-badge--origin-both">{{ m.origin }}</span>
        {%- elsif origin_lower contains 'natural' -%}
          <span class="ingredient-badge ingredient-badge--origin-natural">🌿 {{ m.origin }}</span>
        {%- else -%}
          <span class="ingredient-badge ingredient-badge--origin-synthetic">⚗️ {{ m.origin }}</span>
        {%- endif -%}
      {%- endif -%}
    </div>

    <h1 class="ingredient-hero__name">{{ m.name | default: m.display_name }}</h1>

    {%- if m.inci_name != blank and m.inci_name != m.name -%}
      <p class="ingredient-hero__inci">INCI: {{ m.inci_name }}</p>
    {%- endif -%}

    {%- if m.function != blank -%}
      <p class="ingredient-hero__function">{{ m.function }}</p>
    {%- elsif m.benefits != blank -%}
      <p class="ingredient-hero__function">{{ m.benefits }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} Content Grid {%- endcomment -%}
  <div class="ingredient-content-grid">
    {%- comment -%} Main Description {%- endcomment -%}
    <div>
      {%- if m.description != blank -%}
        <div class="ingredient-description-block">
          <h2>About This Ingredient</h2>
          <p>{{ m.description }}</p>
        </div>
      {%- endif -%}

      {%- if m.cultural_note != blank or m.korean_use != blank -%}
        <div class="ingredient-cultural-note" style="margin-top: 20px;">
          <h3>🌸 K-Beauty Perspective</h3>
          <p>{{ m.cultural_note | default: m.korean_use }}</p>
        </div>
      {%- endif -%}

      {%- comment -%} CTA to shop HARAMOON {%- endcomment -%}
      <div class="ingredient-cta-section">
        <h2>Find This Ingredient in HARAMOON</h2>
        <p>Explore our curated Korean skincare collection featuring this and other powerful ingredients.</p>
        <a href="/collections/haramoon-korean-skincare" class="ingredient-cta-btn">
          Shop HARAMOON →
        </a>
      </div>
    </div>

    {%- comment -%} Sidebar {%- endcomment -%}
    <div class="ingredient-sidebar">
      <div class="ingredient-info-card">
        <h3>Ingredient Details</h3>
        <div class="ingredient-info-row">
          {%- if m.category != blank -%}
            <div class="ingredient-info-item">
              <span class="ingredient-info-item__label">Category</span>
              <span class="ingredient-info-item__value">{{ m.category }}</span>
            </div>
          {%- endif -%}
          {%- if m.chemical_class != blank -%}
            <div class="ingredient-info-item">
              <span class="ingredient-info-item__label">Chemical Class</span>
              <span class="ingredient-info-item__value">{{ m.chemical_class }}</span>
            </div>
          {%- endif -%}
          {%- if m.origin != blank -%}
            <div class="ingredient-info-item">
              <span class="ingredient-info-item__label">Origin</span>
              <span class="ingredient-info-item__value">{{ m.origin }}</span>
            </div>
          {%- endif -%}
          {%- if m.function != blank -%}
            <div class="ingredient-info-item">
              <span class="ingredient-info-item__label">Function</span>
              <span class="ingredient-info-item__value">{{ m.function }}</span>
            </div>
          {%- endif -%}
          {%- if m.skin_type != blank -%}
            <div class="ingredient-info-item">
              <span class="ingredient-info-item__label">Best For</span>
              <span class="ingredient-info-item__value">{{ m.skin_type }}</span>
            </div>
          {%- endif -%}
          {%- if m.concentration != blank -%}
            <div class="ingredient-info-item">
              <span class="ingredient-info-item__label">Typical Concentration</span>
              <span class="ingredient-info-item__value">{{ m.concentration }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Back to glossary card {%- endcomment -%}
      <div class="ingredient-info-card" style="text-align: center; background: linear-gradient(135deg, #f0f7ff, #e8f4ff);">
        <h3>Explore More</h3>
        <p style="font-size: 13px; color: #0a506d; margin: 0 0 16px; line-height: 1.5;">Browse all Korean skincare ingredients in our interactive glossary.</p>
        <a href="/pages/haramoon-ingredient-glossary" style="display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; background: #3498ff; color: #fff; text-decoration: none; border-radius: 20px; font-size: 13px; font-weight: 600; transition: all 0.2s ease;">
          View Full Glossary
        </a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Ingredient Profile Detail",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "Ingredient Profile Detail"
    }
  ]
}
{% endschema %}
