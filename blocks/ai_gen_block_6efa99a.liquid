</mineral-identity-hero-{{ ai_gen_id }}>

{% if block.settings.enable_structured_data %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemPage",
    "name": {{ metaobject.display_name.value | default: '' | json }},
    "description": {{ metaobject.seo_description.value | default: metaobject.one_liner.value | default: '' | json }},
    "about": {
      "@type": "Thing",
      "name": {{ metaobject.display_name.value | default: '' | json }},
      {% if metaobject.origin.value != blank %}
      "location": {{ metaobject.origin.value | json }},
      {% endif %}
      {% if metaobject.chemical_formula.value != blank %}
      "additionalProperty": {
        "@type": "PropertyValue",
        "name": "Chemical Formula",
        "value": {{ metaobject.chemical_formula.value | json }}
      },
      {% endif %}
      {% if metaobject.color.value != blank %}
      "color": {{ metaobject.color.value | json }}
      {% endif %}
    }
  }
  </script>
{% endif %}

<script>
  (function() {
    class MineralIdentityHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.animationDelay = {{ block.settings.animation_delay }};
        this.staggerDelay = {{ block.settings.stagger_delay }};
      }

      connectedCallback() {
        if ({{ block.settings.enable_animation | json }}) {
          this.setupScrollAnimation();
        } else {
          this.showAllItems();
        }
      }

      setupScrollAnimation() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              this.animateItems();
              observer.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.1
        });

        observer.observe(this);
      }

      animateItems() {
        const items = this.querySelectorAll('.mineral-identity-hero__grid-item-{{ ai_gen_id }}');
        items.forEach((item, index) => {
          setTimeout(() => {
            item.classList.add('animate');
          }, this.animationDelay + (index * this.staggerDelay));
        });
      }

      showAllItems() {
        const items = this.querySelectorAll('.mineral-identity-hero__grid-item-{{ ai_gen_id }}');
        items.forEach(item => {
          item.style.opacity = '1';
          item.style.transform = 'translateY(0)';
        });
      }
    }

    customElements.define('mineral-identity-hero-{{ ai_gen_id }}', MineralIdentityHero{{ ai_gen_id }});
  })();
</script>

