{% doc %}
  @prompt
    Create a "Previous / Next Ingredient" navigation section for a metaobject-powered ingredient profile page. This section sits at the bottom of the page and shows two navigation cards side by side — one on the left for the previous ingredient and one on the right for the next ingredient — ordered alphabetically (A–Z) by the metaobject entry's display name.
    
    **Layout:**
    - Two cards side by side (left = previous, right = next)
    - Left card: arrow pointing left (←), label "PREVIOUS INGREDIENT" in small uppercase muted text, and the previous ingredient's name in bold dark navy below it
    - Right card: arrow pointing right (→), label "NEXT INGREDIENT" in small uppercase muted text, and the next ingredient's name in bold dark navy below it
    - Cards have a white/light background, rounded corners, subtle border or shadow, matching the screenshot style
    - If there is no previous or next ingredient (first or last in alphabet), hide that card gracefully
    
    **Data / Logic:**
    - Use Shopify metaobjects: query all entries of the same metaobject type (ingredient profiles), sort them alphabetically by display_name
    - Find the current entry's position in that sorted list
    - The previous card links to the entry that comes before alphabetically, the next card links to the entry that comes after
    - Use metaobject.url or construct the URL from the metaobject handle (e.g. /pages/ingredient-profile/[handle])
    - Pull the ingredient name from metaobject.display_name for each adjacent entry
    
    **Customization settings in theme editor:**
    - Section padding (top/bottom)
    - Card background color picker
    - Label text color picker (for "PREVIOUS INGREDIENT" / "NEXT INGREDIENT" text)
    - Ingredient name text color picker
    - Arrow color picker
    - Border radius slider (for card shape)
    - Toggle to show/hide the entire section
    
    **Style details:**
    - Cards should be equal width, responsive (stack vertically on mobile)
    - Left card content is left-aligned
    - Right card content is right-aligned (arrow and label on right side)
    - Subtle box shadow on cards
    - Hover state: slight shadow lift or background tint
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% if block.settings.show_navigation %}
  {% liquid
    assign current_metaobject = page.metaobject
    assign all_ingredients = shop.metaobjects.ingredient_profile.values
    assign sorted_ingredients = all_ingredients | sort: 'display_name'
    
    assign current_index = -1
    for ingredient in sorted_ingredients
      if ingredient.id == current_metaobject.id
        assign current_index = forloop.index0
        break
      endif
    endfor
    
    assign prev_index = current_index | minus: 1
    assign next_index = current_index | plus: 1
    
    assign prev_ingredient = nil
    assign next_ingredient = nil
    
    if prev_index >= 0
      assign prev_ingredient = sorted_ingredients[prev_index]
    endif
    
    if next_index < sorted_ingredients.size
      assign next_ingredient = sorted_ingredients[next_index]
    endif
  %}

  {% style %}
    .ai-ingredient-nav-{{ ai_gen_id }} {
      display: block;
      width: 100%;
      padding-top: {{ block.settings.padding_top }}px;
      padding-bottom: {{ block.settings.padding_bottom }}px;
    }

    .ai-ingredient-nav__container-{{ ai_gen_id }} {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .ai-ingredient-nav__card-{{ ai_gen_id }} {
      background-color: {{ block.settings.card_background }};
      border-radius: {{ block.settings.border_radius }}px;
      padding: 24px;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 16px;
      transition: all 0.3s ease;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .ai-ingredient-nav__card-{{ ai_gen_id }}:hover {
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
      transform: translateY(-2px);
    }

    .ai-ingredient-nav__card--prev-{{ ai_gen_id }} {
      justify-content: flex-start;
    }

    .ai-ingredient-nav__card--next-{{ ai_gen_id }} {
      justify-content: flex-end;
      flex-direction: row-reverse;
    }

    .ai-ingredient-nav__arrow-{{ ai_gen_id }} {
      flex-shrink: 0;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: {{ block.settings.arrow_color }};
    }

    .ai-ingredient-nav__arrow-{{ ai_gen_id }} svg {
      width: 24px;
      height: 24px;
    }

    .ai-ingredient-nav__content-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .ai-ingredient-nav__content--prev-{{ ai_gen_id }} {
      align-items: flex-start;
      text-align: left;
    }

    .ai-ingredient-nav__content--next-{{ ai_gen_id }} {
      align-items: flex-end;
      text-align: right;
    }

    .ai-ingredient-nav__label-{{ ai_gen_id }} {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: {{ block.settings.label_color }};
      opacity: 0.7;
    }

    .ai-ingredient-nav__name-{{ ai_gen_id }} {
      font-size: 18px;
      font-weight: 700;
      color: {{ block.settings.ingredient_name_color }};
      line-height: 1.3;
    }

    @media screen and (max-width: 749px) {
      .ai-ingredient-nav__container-{{ ai_gen_id }} {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .ai-ingredient-nav__card-{{ ai_gen_id }} {
        padding: 20px;
      }

      .ai-ingredient-nav__name-{{ ai_gen_id }} {
        font-size: 16px;
      }

      .ai-ingredient-nav__arrow-{{ ai_gen_id }} {
        width: 32px;
        height: 32px;
      }

      .ai-ingredient-nav__arrow-{{ ai_gen_id }} svg {
        width: 20px;
        height: 20px;
      }
    }
  {% endstyle %}

  <ingredient-navigation-{{ ai_gen_id }} class="ai-ingredient-nav-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
    <div class="ai-ingredient-nav__container-{{ ai_gen_id }}">
      {% if prev_ingredient %}
        <a 
          href="{{ prev_ingredient.url }}" 
          class="ai-ingredient-nav__card-{{ ai_gen_id }} ai-ingredient-nav__card--prev-{{ ai_gen_id }}"
        >
          <div class="ai-ingredient-nav__arrow-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </div>
          <div class="ai-ingredient-nav__content-{{ ai_gen_id }} ai-ingredient-nav__content--prev-{{ ai_gen_id }}">
            <span class="ai-ingredient-nav__label-{{ ai_gen_id }}">Previous Ingredient</span>
            <span class="ai-ingredient-nav__name-{{ ai_gen_id }}">{{ prev_ingredient.display_name }}</span>
          </div>
        </a>
      {% endif %}

      {% if next_ingredient %}
        <a 
          href="{{ next_ingredient.url }}" 
          class="ai-ingredient-nav__card-{{ ai_gen_id }} ai-ingredient-nav__card--next-{{ ai_gen_id }}"
          {% if prev_ingredient == nil %}style="grid-column: 2;"{% endif %}
        >
          <div class="ai-ingredient-nav__arrow-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </div>
          <div class="ai-ingredient-nav__content-{{ ai_gen_id }} ai-ingredient-nav__content--next-{{ ai_gen_id }}">
            <span class="ai-ingredient-nav__label-{{ ai_gen_id }}">Next Ingredient</span>
            <span class="ai-ingredient-nav__name-{{ ai_gen_id }}">{{ next_ingredient.display_name }}</span>
          </div>
        </a>
      {% endif %}
    </div>
  </ingredient-navigation-{{ ai_gen_id }}>

  <script>
    (function() {
      class IngredientNavigation{{ ai_gen_id }} extends HTMLElement {
        constructor() {
          super();
        }

        connectedCallback() {
          this.setupAccessibility();
        }

        setupAccessibility() {
          const cards = this.querySelectorAll('.ai-ingredient-nav__card-{{ ai_gen_id }}');
          cards.forEach(card => {
            card.setAttribute('role', 'link');
          });
        }
      }

      customElements.define('ingredient-navigation-{{ ai_gen_id }}', IngredientNavigation{{ ai_gen_id }});
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Ingredient navigation",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation",
      "default": true
