{% doc %}
  @prompt
    Create a full-width responsive hero banner section for Harry Norman Music in Shopify Liquid that visually matches a modern musician landing page. The layout should have a left image section and a right text section. The left side should display a background image of a man facing away, with a purple-to-teal gradient overlay using linear-gradient(135deg,#4b3a84 0%,#00797a 100%) at about 70% opacity. The right side should use a dark charcoal background (#121212) with a subtle diagonal divider or gradient fade into teal (#00797a). The section height should be 90vh on desktop, 70vh on tablet, and auto on mobile. The right section should contain the text content centered vertically: first, a small text line in the top right corner with “@harrynormanmusic” followed by small white icons for Instagram, Facebook, YouTube, and Twitter spaced evenly (about 18px each). Below that, add the heading “HARRY NORMAN” in uppercase serif (Playfair Display, Cormorant Garamond, or Georgia) color #e0e0e0, letter-spacing 1px, font-size about 48px on desktop. Below that, add “MUSIC” in bold uppercase sans-serif (Montserrat, Raleway, or Poppins) color #f0f0f0 with a diagonal black stripe cutting across the middle achieved with a pseudo-element or gradient mask. Below that, add a tagline “Songwriter and Performing Artist” in italic, color #cfcfcf, font-size 16px. Beneath the tagline include a gold call-to-action button labeled “Listen on Spotify →” linking to https://open.spotify.com/artist/7siG4IFihXuKXMYMm7LLO7
    . The button should have background #d4af37, text #111, border-radius 6px, padding 12px 28px, uppercase lettering, and invert colors on hover. Use the following CSS inline within the Liquid section to define the layout, <style> .hero-harry{display:flex;flex-wrap:wrap;background:#121212;color:#f0f0f0} .hero-harry .left{flex:1;min-width:50%;background:url('{{ 'harry-banner.jpg' | asset_url }}') center/cover no-repeat;position:relative} .hero-harry .left::after{content:"";position:absolute;inset:0;background:linear-gradient(135deg,#4b3a84cc,#006c6ccc)} .hero-harry .right{flex:1;min-width:40%;display:flex;flex-direction:column;justify-content:center;align-items:flex-start;padding:3rem;background:#121212} .hero-harry h1{font-family:'Playfair Display',serif;font-size:48px;margin:0} .hero-harry h2{font-family:'Montserrat',sans-serif;font-size:64px;font-weight:700;position:relative;display:inline-block;color:#f0f0f0} .hero-harry h2::after{content:"";position:absolute;bottom:15%;left:0;width:100%;height:25%;background:rgba(0,0,0,0.6);transform:skew(-20deg)} .hero-harry p{font-style:italic;color:#cfcfcf;margin-top:.5rem} .hero-harry .cta{background:#d4af37;color:#111;padding:12px 28px;border-radius:6px;text-transform:uppercase;font-weight:600;letter-spacing:1px;margin-top:1.5rem;transition:.3s} .hero-harry .cta:hover{background:#111;color:#d4af37} @media(max-width:768px){.hero-harry{flex-direction:column;text-align:center}.hero-harry .right{align-items:center;padding:2rem}.hero-harry h1{font-size:28px}.hero-harry h2{font-size:36px}.hero-harry p{font-size:14px}} </style>
    
    Then output a schema with editable fields: image_picker id: hero_image; text id: hero_heading; text id: hero_subheading; text id: hero_tagline; url id: hero_cta_link; text id: hero_cta_label; color_picker id: left_gradient_start; color_picker id: left_gradient_end; color_picker id: background_right; checkbox id: show_social_icons. Set default values for the text fields as: hero_heading = “HARRY NORMAN”, hero_subheading = “MUSIC”, hero_tagline = “Songwriter and Performing Artist”, hero_cta_label = “Listen on Spotify”. Ensure fonts load via Google Fonts, all text is editable, and layout is mobile-friendly with stacked structur
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">

{% style %}
  .hero-harry-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    background: {{ block.settings.background_right }};
    color: #f0f0f0;
  }

  .hero-harry-{{ ai_gen_id }} .left {
    flex: 1;
    min-width: 50%;
    {% if block.settings.hero_image %}
      background: url('{{ block.settings.hero_image | image_url: width: 1200 }}') center/cover no-repeat;
    {% else %}
      background: #2a2a2a;
      display: flex;
      align-items: center;
      justify-content: center;
    {% endif %}
    position: relative;
    min-height: 90vh;
  }

  .hero-harry-{{ ai_gen_id }} .left::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, {{ block.settings.left_gradient_start }}cc, {{ block.settings.left_gradient_end }}cc);
  }

  .hero-harry-{{ ai_gen_id }} .left .placeholder-wrapper {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .hero-harry-{{ ai_gen_id }} .left .placeholder-wrapper svg {
    width: 100px;
    height: 100px;
    opacity: 0.3;
  }

  .hero-harry-{{ ai_gen_id }} .left .empty-state {
    color: #888;
    font-size: 14px;
    margin-top: 10px;
  }

  .hero-harry-{{ ai_gen_id }} .right {
    flex: 1;
    min-width: 40%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 3rem;
    background: {{ block.settings.background_right }};
    position: relative;
  }

  .hero-harry-{{ ai_gen_id }} .social-icons {
    position: absolute;
    top: 20px;
    right: 20px;
    display: flex;
    gap: 15px;
  }

  .hero-harry-{{ ai_gen_id }} .social-icons a {
    color: #ffffff;
    transition: color 0.3s ease;
  }

  .hero-harry-{{ ai_gen_id }} .social-icons a:hover {
    color: #d4af37;
  }

  .hero-harry-{{ ai_gen_id }} .social-icons svg {
    width: 18px;
    height: 18px;
  }

  .hero-harry-{{ ai_gen_id }} h1 {
    font-family: 'Playfair Display', serif;
    font-size: 48px;
    margin: 0;
    color: #e0e0e0;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .hero-harry-{{ ai_gen_id }} h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: 64px;
    font-weight: 700;
    position: relative;
    display: inline-block;
    color: #f0f0f0;
    margin: 0;
    text-transform: uppercase;
  }

  .hero-harry-{{ ai_gen_id }} h2::after {
    content: "";
    position: absolute;
    bottom: 15%;
    left: 0;
    width: 100%;
    height: 25%;
    background: rgba(0, 0, 0, 0.6);
    transform: skew(-20deg);
  }

  .hero-harry-{{ ai_gen_id }} p {
    font-style: italic;
    color: #cfcfcf;
    margin-top: 0.5rem;
    margin-bottom: 0;
  }

  .hero-harry-{{ ai_gen_id }} .cta {
    background: #d4af37;
    color: #111;
    padding: 12px 28px;
    border-radius: 6px;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 1px;
    margin-top: 1.5rem;
    transition: 0.3s;
    text-decoration: none;
    display: inline-block;
  }

  .hero-harry-{{ ai_gen_id }} .cta:hover {
    background: #111;
    color: #d4af37;
  }

  @media (max-width: 768px) {
    .hero-harry-{{ ai_gen_id }} {
      flex-direction: column;
      text-align: center;
    }

    .hero-harry-{{ ai_gen_id }} .left {
      min-height: 50vh;
    }

    .hero-harry-{{ ai_gen_id }} .right {
      align-items: center;
      padding: 2rem;
    }

    .hero-harry-{{ ai_gen_id }} .social-icons {
      position: static;
      margin-bottom: 20px;
    }

    .hero-harry-{{ ai_gen_id }} h1 {
      font-size: 28px;
    }

    .hero-harry-{{ ai_gen_id }} h2 {
      font-size: 36px;
    }

    .hero-harry-{{ ai_gen_id }} p {
      font-size: 14px;
    }
  }
{% endstyle %}

<div class="hero-harry-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="left">
    {% unless block.settings.hero_image %}
      <div class="placeholder-wrapper">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="empty-state">Add a hero image</div>
      </div>
    {% endunless %}
  </div>
  
  <div class="right">
    {% if block.settings.show_social_icons %}
      <div class="social-icons">
        <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        <a href="https://facebook.com" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href="https://youtube.com" target="_blank" rel="noopener" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
        <a href="https://twitter.com" target="_blank" rel="noopener" aria-label="Twitter">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
          </svg>
        </a>
      </div>
    {% endif %}
    
    <h1>{{ block.settings.hero_heading }}</h1>
    <h2>{{ block.settings.hero_subheading }}</h2>
    <p>{{ block.settings.hero_tagline }}</p>
    
    {% if block.settings.hero_cta_link != blank %}
      <a href="{{ block.settings.hero_cta_link }}" class="cta" target="_blank" rel="noopener">
        {{ block.settings.hero_cta_label }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Harry Norman Hero Banner",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero heading",
      "default": "HARRY NORMAN"
    },
    {
      "type": "text",
      "id": "hero_subheading",
      "label": "Hero subheading",
      "default": "MUSIC"
    },
    {
      "type": "text",
      "id": "hero_tagline",
      "label": "Hero tagline",
      "default": "Songwriter and Performing Artist"
    },
    {
      "type": "text",
      "id": "hero_cta_label",
      "label": "Call to action label",
      "default": "Listen on Spotify"
    },
    {
      "type": "url",
      "id": "hero_cta_link",
      "label": "Call to action link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "left_gradient_start",
      "label": "Left gradient start color",
      "default": "#4b3a84"
    },
    {
      "type": "color",
      "id": "left_gradient_end",
      "label": "Left gradient end color",
      "default": "#006c6c"
    },
    {
      "type": "color",
      "id": "background_right",
      "label": "Right background color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "checkbox",
      "id": "show_social_icons",
      "label": "Show social icons",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Harry Norman Hero Banner"
    }
  ]
}
{% endschema %}