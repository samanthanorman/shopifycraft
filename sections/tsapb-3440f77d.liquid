<!-- --VERSION-9-- -->

{% style %}
:root {
--vtl-neutral-100: #222;
--vtl-neutral-70: #5e5e5e;
--vtl-neutral-03: #f8f8f8;
--vtl-neutral-01: #fff;
--vtl-size-1: 1px;
--vtl-size-2: 2px;
--vtl-size-8: 8px;
--vtl-size-12: 12px;
--vtl-size-14: 14px;
--vtl-size-16: 16px;
--vtl-size-20: 20px;
--vtl-size-24: 24px;
--vtl-size-32: 32px;
--vtl-size-40: 40px;
--vtl-size-48: 48px;
--vtl-size-80: 80px;
--vtl-size-full: 9999px;
--vtl-font-weight-400: 400;
--vtl-font-weight-600: 600;
--vtl-line-height-140: 1.4;
--vtl-border-radius-full: var(--vtl-size-full);
--vtl-border-width-1: var(--vtl-size-1);
--vtl-color-bg-fill-default-on-light: var(--vtl-neutral-100);
--vtl-color-bg-fill-inverse-on-light: var(--vtl-neutral-01);
--vtl-color-bg-surface-tertiary-on-light: var(--vtl-neutral-03);
--vtl-color-text-disable-on-light: var(--vtl-neutral-70);
--vtl-space-2: var(--vtl-size-2);
--vtl-space-8: var(--vtl-size-8);
--vtl-space-12: var(--vtl-size-12);
--vtl-space-16: var(--vtl-size-16);
--vtl-space-20: var(--vtl-size-20);
--vtl-space-24: var(--vtl-size-24);
--vtl-space-32: var(--vtl-size-32);
--vtl-space-40: var(--vtl-size-40);
--vtl-space-48: var(--vtl-size-48);
--vtl-space-80: var(--vtl-size-80);
--vtl-font-size-14: var(--vtl-size-14);
}


{% endstyle %}

<!-- --UUID-3440f77d-- -->
<script>
	if (typeof window.vtlsBreakpoints === 'undefined') {
		window.vtlsBreakpoints = {
			mobile: {
				minWidth: 0,
				maxWidth: 479,
			},
			tablet: {
				minWidth: 480,
				maxWidth: 991,
			},
			desktop: {
				minWidth: 992,
				maxWidth: 10000,
			},
		};
	}
</script>

{% style %}
	

@media(max-width: 479px){.VtlsResponsiveness--TabletAndDesktop{display:none}}@media(min-width: 992px){.VtlsResponsiveness--MobileAndTablet{display:none}}@media(min-width: 480px){.VtlsResponsiveness--Mobile{display:none}}@media not ((min-width: 480px) and (max-width: 991px)){.VtlsResponsiveness--Tablet{display:none}}@media(max-width: 991px){.VtlsResponsiveness--Desktop{display:none}}

{% endstyle %}


<div
	class="
		Vtls-{{ section.id | handle }}
		VtlsVideoCarousel--backgroundStyle-{{ section.settings.section_background_style }}
		VtlsVideoCarousel {% if section.settings.section_width == 100 %}VtlsVideoCarousel--fullWidth{% endif %}
		{% if section.settings.section_background_style == "gradient" and section.settings.enable_animation == true %}VtlsVideoCarousel--hasAnimation{% endif %}
	"
>
	{%- liquid
		assign video_blocks = section.blocks | where: "type", "video"
		assign video_blocks_size = video_blocks.size
		assign videos_per_row = section.settings.videos_per_row | at_most: video_blocks_size
		assign slider_max_width = videos_per_row | times: 1.0 | divided_by: section.settings.videos_per_row | times: 100
		assign autoplay_option = section.settings.autoplay
		assign loop_option = section.settings.loop
		assign controls_option = null

		
		for block in section.blocks
			if block.type == "heading"
				assign heading_block = block
			endif
		endfor
	-%}
	<div
		class="
			VtlsVideoCarouselContainer VtlsCarouselContainer
			{% if heading_block and heading_block.settings.heading != blank %}VtlsVideoCarouselContainer--hasHeading{% endif %}
		"
	>
		{%- if heading_block.settings.heading != blank or heading_block.settings.description != blank -%}
			<div
				class="
					VtlsVideoCarouselTextWrapper
					VtlsVideoCarouselTextWrapper--alignment-{{ heading_block.settings.text_alignment }}
				"
				{{ heading_block.shopify_attributes }}
			>
				{%- if heading_block.settings.heading != blank -%}
					<h2
						class="
							VtlsVideoCarouselTextWrapper__Heading
							VtlsVideoCarouselTextWrapper__Heading--style-{{ heading_block.settings.heading_style }}
						"
					>
						{{ heading_block.settings.heading }}
					</h2>
				{%- endif -%}
				{%- if heading_block.settings.description != blank -%}
					<div
						class="
							VtlsVideoCarouselTextWrapper__Description
						"
					>
						{{ heading_block.settings.description }}
					</div>
				{%- endif -%}
			</div>
		{%- endif -%}
		<vtls-video-carousel
			class="VtlsCarousel"
			style="--slider-max-width: {{ slider_max_width }}%;"
			data-section-width="{{ section.settings.section_width }}"
			data-videos-per-row="{{ videos_per_row }}"
			data-total-videos="{{ video_blocks_size }}"
			data-controls="{{ section.settings.show_video_controls }}"
			data-aspect-ratio="{{ section.settings.aspect_ratio }}"
		>
			<div class="VtlsCarousel__Content">
				<ul class="VtlsCarouselList">
					{%- liquid
						assign blocks_size = video_blocks_size | minus: 1.0
						assign iterations = videos_per_row | blocks_size | ceil
					 -%}
						{%- for i in (1..iterations) -%}
							{%- for block in video_blocks -%}
								{%- liquid
									assign poster_option = null
									if block.settings.poster_desktop != blank and section.settings.autoplay == false
										assign poster_option = block.settings.poster_desktop | img_url: "master"
									endif
								-%}
								<li
									class="VtlsVideoCarouselBlock"
									{{ block.shopify_attributes }}
								>
									<div class="VtlsVideoCarouselBlock__Wrapper">
										<vtls-video-item
											class="VtlsVideoCarouselBlock__Media"
										>
											{%- if block.settings.video_desktop != blank -%}
												{%- if poster_option != blank -%}
													{{
														block.settings.video_desktop
														| video_tag:
															autoplay: autoplay_option,
															loop: loop_option,
															muted: true,
															playsinline: true,
															preload: "metadata",
															poster: poster_option,
															controls: controls_option,
															class: "VtlsVideoCarouselBlock__Media--desktop VtlsCdnVideo-desktop"
													}}
												{%- else -%}
													{{
														block.settings.video_desktop
														| video_tag:
															autoplay: autoplay_option,
															loop: loop_option,
															muted: true,
															playsinline: true,
															preload: "metadata",
															controls: controls_option,
															image_size: "600x",
															class: "VtlsVideoCarouselBlock__Media--desktop VtlsCdnVideo-desktop"
													}}
												{%- endif -%}
											{% else %}
												<img
													src="data:image/webp;base64,"
													alt="Image with an abstract figure"
													width="1280"
													height="600"
													loading="lazy"
													sizes="100vw"
													fetchpriority="low"
													class="VtlsVideoCarouselBlock__Media--defaultVideo"
												>
											{% endif %}
											{%- if section.settings.show_video_controls == true
												and block.settings.video_desktop != blank
											-%}
												<div class="VtlsVideoCarouselControls">
													<button
														aria-label="Play"
														class="VtlsVideoCarouselControls__PlayButton"
													></button>
													<button
														aria-label="Pause"
														class="VtlsVideoCarouselControls__PauseButton"
													></button>
												</div>
												<div class="VtlsVideoCarouselSoundButtons">
													<button
														aria-label="Sound"
														class="VtlsVideoCarouselSoundButtons__SoundButtonOff"
													>
														<svg
															width="24"
															height="24"
															viewBox="0 0 24 24"
															fill="none"
															xmlns="http://www.w3.org/2000/svg"
														>
															<path d="M13.4952 4.08023C13.5877 4.13382 13.6646 4.21162 13.7181 4.30567C13.7717 4.39973 13.7999 4.50668 13.8 4.6156V19.3845C13.8 19.4934 13.7719 19.6003 13.7184 19.6944C13.665 19.7885 13.5882 19.8663 13.4958 19.92C13.4035 19.9737 13.2989 20.0013 13.1927 20C13.0866 19.9986 12.9827 19.9685 12.8916 19.9125L7.0344 16.3076H4.8C4.32261 16.3076 3.86477 16.1131 3.52721 15.7669C3.18964 15.4207 3 14.9512 3 14.4615V9.53488C3.00032 9.04547 3.1901 8.57622 3.52763 8.23027C3.86516 7.88433 4.32282 7.69 4.8 7.69H7.0344L12.8904 4.08762C12.9815 4.03156 13.0856 4.00134 13.1918 4.00004C13.2981 3.99875 13.4028 4.02642 13.4952 4.08023Z" fill="black"/>
															<path d="M16 16L19.2845 11.3011L19.2436 12.5799L16.0954 8H18.4804L20.4702 10.9888L19.5707 11.0186L21.6286 8H23.891L20.7291 12.5353V11.2862L24 16H21.5877L19.5026 12.8178L20.3884 12.9517L18.3169 16H16Z" fill="black"/>
														</svg>
													</button>
													<button
														aria-label="Sound"
														class="VtlsVideoCarouselSoundButtons__SoundButtonOn"
													>
														<svg
															width="24"
															height="24"
															viewBox="0 0 24 24"
															fill="none"
															xmlns="http://www.w3.org/2000/svg"
														>
															<path d="M13.4952 4.08023C13.5877 4.13382 13.6646 4.21162 13.7181 4.30567C13.7717 4.39973 13.7999 4.50668 13.8 4.6156V19.3845C13.8 19.4934 13.7719 19.6003 13.7184 19.6944C13.665 19.7885 13.5882 19.8663 13.4958 19.92C13.4035 19.9737 13.2989 20.0013 13.1927 20C13.0866 19.9986 12.9827 19.9685 12.8916 19.9125L7.0344 16.3076H4.8C4.32261 16.3076 3.86477 16.1131 3.52721 15.7669C3.18964 15.4207 3 14.9512 3 14.4615V9.53488C3.00032 9.04547 3.1901 8.57622 3.52763 8.23027C3.86516 7.88433 4.32282 7.69 4.8 7.69H7.0344L12.8904 4.08762C12.9815 4.03156 13.0856 4.00134 13.1918 4.00004C13.2981 3.99875 13.4028 4.02642 13.4952 4.08023Z" fill="black"/>
															<path d="M18.3007 6.28524C18.6956 5.89928 19.3287 5.90616 19.7148 6.30087C22.7494 9.40543 22.7748 14.6075 19.7109 17.7032C19.3225 18.0956 18.6894 18.0993 18.2968 17.711C17.9044 17.3226 17.9008 16.6895 18.289 16.297C20.574 13.9885 20.5675 10.0347 18.2851 7.6993C17.8992 7.30444 17.906 6.67131 18.3007 6.28524Z" fill="black"/>
															<path d="M16.3682 8.22473C16.7963 7.87598 17.4266 7.94021 17.7754 8.36828C18.6088 9.39139 18.9988 10.7204 19 12.003C19.0012 13.2856 18.6135 14.6161 17.7715 15.6368C17.42 16.0627 16.7893 16.123 16.3633 15.7716C15.9374 15.4201 15.8772 14.7894 16.2285 14.3634C16.7238 13.7629 17.0008 12.909 17 12.005C16.9992 11.1011 16.7205 10.2408 16.2246 9.63195C15.8759 9.2038 15.9401 8.57355 16.3682 8.22473Z" fill="black"/>
														</svg>
													</button>
												</div>
											{%- endif -%}
										</vtls-video-item>
									</div>
								</li>
							{%- endfor -%}
						{%- endfor -%}
				</ul>
				<div class="VtlsCarousel__Navigation">
					<div class="VtlsNavigationButtons VtlsNavigationButtons--style-{{ section.settings.arrows_style }}">
						<button class="VtlsNavigationButtons__Button VtlsLeftChevron">
							{% if section.settings.arrows_style == "chevron" %}
								<svg
									width="24"
									height="24"
									viewBox="0 0 24 24"
									fill="none"
									xmlns="http://www.w3.org/2000/svg"
								>
									<path d="M20 12H7.75L13 6.75L12.34 6L5.84 12.5L12.34 19L13 18.25L7.75 13H20V12Z" fill="black"/>
								</svg>
							{% else %}
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="24"
									height="24"
									viewBox="0 0 24 24"
									fill="none"
								>
									<path d="M14 18L8 12L14 6" stroke="#222" stroke-linecap="round"></path>
								</svg>
							{% endif %}
						</button>
						<button class="VtlsNavigationButtons__Button VtlsRightChevron">
							{% if section.settings.arrows_style == "chevron" %}
								<svg
									width="24"
									height="24"
									viewBox="0 0 24 24"
									fill="none"
									xmlns="http://www.w3.org/2000/svg"
								>
									<path d="M4 12H16.25L11 6.75L11.66 6L18.16 12.5L11.66 19L11 18.25L16.25 13H4V12Z" fill="black"/>
								</svg>
							{% else %}
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="24"
									height="24"
									viewBox="0 0 24 24"
									fill="none"
								>
									<path d="M9 6L15 12L9 18" stroke="#222" stroke-linecap="round"></path>
								</svg>
							{% endif %}
						</button>
					</div>
				</div>
			</div>
		</vtls-video-carousel>
	</div>
</div>

{% schema %}
{
	"name": "❤️ Video Carousel",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "header",
			"content": "Video"
		},
		{
			"type": "select",
			"id": "aspect_ratio",
			"label": "Aspect ratio",
			"options": [
				{
					"value": "2/3",
					"label": "Vertical (9:16)"
				},
				{
					"value": "4/3",
					"label": "Landscape (4:3)"
				},
				{
					"value": "1/1",
					"label": "Square (1:1)"
				}
			],
			"default": "2/3"
		},
		{
			"type": "range",
			"id": "videos_corner_radius",
			"min": 0,
			"max": 40,
			"step": 2,
			"unit": "px",
			"label": "Videos corner radius",
			"default": 16
		},
		{
			"type": "checkbox",
			"id": "autoplay",
			"label": "Autoplay",
			"info": "Video will be on mute.",
			"default": true
		},
		{
			"type": "checkbox",
			"id": "loop",
			"label": "Play on loop",
			"default": true
		},
		{
			"type": "checkbox",
			"id": "show_video_controls",
			"label": "Show video controls",
			"default": true
		},
		{
			"type": "color",
			"id": "controls_color",
			"label": "Video controls color",
			"visible_if": "{{ section.settings.show_video_controls == true }}",
			"default": "#ffffff"
		},
		{
			"type": "color",
			"id": "controls_background_color",
			"label": "Video controls background color",
			"visible_if": "{{ section.settings.show_video_controls == true }}",
			"default": "#222222"
		},
		{
			"type": "header",
			"content": "Design"
		},
		{
			"type": "select",
			"id": "videos_per_row",
			"label": "Videos per row on desktop",
			"options": [
				{
					"value": "3",
					"label": "3"
				},
				{
					"value": "5",
					"label": "5"
				}
			],
			"default": "5"
		},
		{
			"type": "select",
			"id": "section_background_style",
			"label": "Section background",
			"options": [
				{
					"value": "regular",
					"label": "Color"
				},
				{
					"value": "gradient",
					"label": "Gradient"
				}
			],
			"default": "regular"
		},
		{
			"type": "color",
			"id": "section_background",
			"label": "Color",
			"visible_if": "{{ section.settings.section_background_style == 'regular' }}"
		},
		{
			"type": "color_background",
			"id": "section_gradient",
			"label": "Gradient",
			"default": "linear-gradient(#72ffb3, #fffa63)",
			"visible_if": "{{ section.settings.section_background_style == 'gradient' }}"
		},
		{
			"type": "checkbox",
			"id": "enable_animation",
			"label": "Add gradient animation",
			"default": false,
			"visible_if": "{{ section.settings.section_background_style == 'gradient' }}"
		},
		{
			"type": "select",
			"id": "arrows_style",
			"label": "Arrows style",
			"options": [
				{
					"value": "circle",
					"label": "Circle"
				},
				{
					"value": "square",
					"label": "Square"
				},
				{
					"value": "chevron",
					"label": "Arrows"
				},
				{
					"value": "arrow",
					"label": "Chevron"
				}
			],
			"default": "chevron"
		},
		{
			"type": "color",
			"id": "arrows_color",
			"label": "Arrows color",
			"default": "#222222"
		},
		{
			"type": "range",
			"id": "section_width",
			"min": 70,
			"max": 100,
			"step": 1,
			"unit": "%",
			"label": "Section width",
			"default": 100,
			"info": "Applies only to desktop"
		},
		{
			"type": "text",
			"id": "section_max_width",
			"label": "Custom max width (optional)",
			"info": "Section max width in pixels"
		},
		{
			"type": "range",
			"id": "videos_space_between",
			"min": 10,
			"max": 30,
			"step": 2,
			"unit": "px",
			"label": "Space between videos",
			"default": 20
		},
		{
			"type": "range",
			"id": "vertical_padding",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Top - bottom padding (desktop)",
			"default": 40
		},
		{
			"type": "range",
			"id": "vertical_margin",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Top - bottom margin (desktop)",
			"default": 0
		},
		{
			"type": "range",
			"id": "vertical_padding_mobile",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Top - bottom padding (mobile)",
			"default": 20
		},
		{
			"type": "range",
			"id": "vertical_margin_mobile",
			"min": 0,
			"max": 100,
			"step": 2,
			"unit": "px",
			"label": "Top - bottom margin (mobile)",
			"default": 0
		}
	],
	"blocks": [
		{
			"type": "heading",
			"limit": 1,
			"name": "Heading",
			"settings": [
				{
					"type": "text",
					"id": "heading",
					"label": "Heading",
					"default": "Video Carousel"
				},
				{
					"type": "select",
					"id": "heading_size",
					"label": "Heading size",
					"options": [
						{
							"value": "24",
							"label": "Small"
						},
						{
							"value": "32",
							"label": "Medium"
						},
						{
							"value": "48",
							"label": "Large"
						}
					],
					"default": "32"
				},
				{
					"type": "select",
					"id": "heading_style",
					"label": "Heading style",
					"options": [
						{
							"value": "regular",
							"label": "Regular"
						},
						{
							"value": "bold",
							"label": "Bold"
						}
					],
					"default": "regular"
				},
				{
					"type": "richtext",
					"id": "description",
					"label": "Description"
				},
				{
					"type": "select",
					"id": "description_size",
					"label": "Description size",
					"options": [
						{
							"value": "12",
							"label": "Small"
						},
						{
							"value": "16",
							"label": "Medium"
						},
						{
							"value": "20",
							"label": "Large"
						}
					],
					"default": "16"
				},
				{
					"type": "color",
					"id": "text_color",
					"label": "Text color",
					"default": "#222222"
				},
				{
					"type": "select",
					"id": "text_alignment",
					"label": "Text alignment",
					"options": [
						{
							"value": "left",
							"label": "Left"
						},
						{
							"value": "center",
							"label": "Center"
						},
						{
							"value": "right",
							"label": "Right"
						}
					],
					"default": "center"
				}
			]
		},
		{
			"type": "video",
			"limit": 12,
			"name": "Video",
			"settings": [
				{
					"type": "header",
					"content": "Video"
				},
				{
					"type": "video",
					"id": "video_desktop",
					"label": "Video"
				},
				{
					"type": "image_picker",
					"id": "poster_desktop",
					"label": "Thumbnail (optional)",
					"visible_if": "{{ section.settings.autoplay == false }}"
				}
			]
		}
	],
	"presets": [
		{
			"name": "❤️ Square: Video Carousel",
			"category": "Square sections",
			"blocks": [
				{
					"type": "heading"
