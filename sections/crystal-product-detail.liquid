          <p class="crys-mineral-card__label">🔢 Numerology</p>
          <p class="crys-mineral-card__value">{{ matched_mineral.number }}</p>
        </div>
        {%- endif -%}
        {%- if matched_mineral.archetype -%}
        <div class="crys-mineral-card">
          <p class="crys-mineral-card__label">🎭 Archetype</p>
          <p class="crys-mineral-card__value">{{ matched_mineral.archetype | truncate: 80 }}</p>
        </div>
        {%- endif -%}
        {%- if matched_mineral.musical_chord -%}
        <div class="crys-mineral-card">
          <p class="crys-mineral-card__label">🎵 Musical Chord</p>
          <p class="crys-mineral-card__value">{{ matched_mineral.musical_chord | truncate: 80 }}</p>
        </div>
        {%- endif -%}
        {%- if matched_mineral.underlying_emotion_or_body_association -%}
        <div class="crys-mineral-card">
          <p class="crys-mineral-card__label">💫 Associations</p>
          <p class="crys-mineral-card__value">{{ matched_mineral.underlying_emotion_or_body_association }}</p>
        </div>
        {%- endif -%}
        {%- if matched_mineral.energy_properties -%}
        <div class="crys-mineral-card">
          <p class="crys-mineral-card__label">⚡ Energy Properties</p>
          <p class="crys-mineral-card__value">{{ matched_mineral.energy_properties }}</p>
        </div>
        {%- endif -%}
        {%- if matched_mineral.modern_or_scientific_use -%}
        <div class="crys-mineral-card">
          <p class="crys-mineral-card__label">🔬 Modern Use</p>
          <p class="crys-mineral-card__value">{{ matched_mineral.modern_or_scientific_use | truncate: 100 }}</p>
        </div>
        {%- endif -%}
        {%- if matched_mineral.why_you_need_it -%}
        <div class="crys-mineral-card">
          <p class="crys-mineral-card__label">✨ Why You Need It</p>
          <p class="crys-mineral-card__value">{{ matched_mineral.why_you_need_it | truncate: 120 }}</p>
        </div>
        {%- endif -%}
      </div>

      {%- comment -%} Pair With {%- endcomment -%}
      {%- assign pairs = matched_mineral.best_to_pair_with.value -%}
      {%- if pairs.size > 0 -%}
      <div style="margin-top:40px;">
        <p class="crys-block-eyebrow" style="text-align:center;">Best Paired With</p>
        <div class="crys-pair-grid" style="justify-content:center;">
          {%- for pair in pairs -%}
          <a href="/pages/crystal-compendium/{{ pair.handle }}" class="crys-pair-pill">
            💎 {{ pair.display_name | default: pair.handle | capitalize }}
          </a>
          {%- endfor -%}
        </div>
      </div>
      {%- endif -%}
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ── CARE GUIDE ── {%- endcomment -%}
  {%- if matched_mineral and section.settings.show_care -%}
  <div class="crys-block">
    <div class="crys-section">
      <div class="crys-block-header">
        <p class="crys-block-eyebrow">{{ section.settings.care_eyebrow | default: 'Crystal Care' }}</p>
        <h2 class="crys-block-title">{{ section.settings.care_heading | default: 'How to Care for Your Stone' }}</h2>
      </div>
      <div class="crys-care-grid">
        {%- if matched_mineral.cleanse -%}
        <div class="crys-care-card">
          <div class="crys-care-card__icon">🧼</div>
          <p class="crys-care-card__title">Cleansing</p>
          <p class="crys-care-card__text">{{ matched_mineral.cleanse }}</p>
        </div>
        {%- endif -%}
        {%- if matched_mineral.recharge -%}
        <div class="crys-care-card">
