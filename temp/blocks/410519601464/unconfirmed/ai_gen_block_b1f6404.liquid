{% doc %}
  @prompt
    Build a complete Shopify Liquid section called "SEO Breadcrumb" that displays a breadcrumb navigation trail for Google Search Console structured data recognition. This section should work on any page type: regular pages, blog articles, product pages, collection pages, and metaobject pages.
    
    STRUCTURED DATA (most important requirement):
    - Output a JSON-LD script tag in the section with schema.org BreadcrumbList structured data
    - The JSON-LD must include @context "https://schema.org", @type "BreadcrumbList", and itemListElement array
    - Each breadcrumb item must have @type "ListItem", position (1, 2, 3...), name, and item (full absolute URL)
    - The full URL must use shop.url prepended to the relative path so it is always absolute (e.g. https://waxandwane.store/products/wooden-brush-perfect-size)
    - This is what Google Search Console reads — it must be valid JSON-LD
    
    BREADCRUMB LOGIC — detect page type and build the trail automatically:
    - On ALL pages: first crumb is always "Home" linking to /
    - On a PRODUCT page: Home › [Collection Title if available] › [Product Title] — use product.title and product.url; if product.collections is not empty use product.collections.first.title and product.collections.first.url
    - On a COLLECTION page: Home › [Collection Title]
    - On a PAGE template: Home › [Page Title]
    - On a BLOG ARTICLE page: Home › [Blog Title] › [Article Title]
    - On a METAOBJECT page: Home › [customizable middle label from settings] › [metaobject.display_name]
    - Use Liquid conditionals on request.page_type to handle each case
    
    VISUAL BREADCRUMB DISPLAY:
    - Render a visible HTML breadcrumb trail
    - Links separated by › chevron character
    - Last crumb (current page) is plain text, not a link
    - Small font size (13px default), muted color
    - Left-aligned, transparent background
    
    SECTION SETTINGS (schema):
    - show_breadcrumb — checkbox — label "Show visible breadcrumb" — default true — info "Google structured data always outputs regardless of this toggle"
    - metaobject_parent_label — text — label "Metaobject parent label" — default "Ingredient Glossary"
    - metaobject_parent_url — text — label "Metaobject parent URL" — default "/pages/ingredient-glossary"
    - text_color — color — label "Text color" — default #888888
    - link_color — color — label "Link color" — default #555555
    - font_size — range — min 10 max 18 step 1 — label "Font size (px)" — default 13
    - padding_top — range — min 0 max 60 step 4 — label "Padding top" — default 16
    - padding_bottom — range — min 0 max 60 step 4 — label "Padding bottom" — default 8
    
    Output a complete working .liquid section file with all HTML, the JSON-LD script tag, scoped CSS, and a valid {% schema %} block. Write every line of actual working Liquid code — no placeholder comments.
{% enddoc %}
{% liquid
  assign ai_gen_id = section.id | replace: '_', '' | downcase
%}

{% style %}
  .ai-seo-breadcrumb-{{ ai_gen_id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: transparent;
  }

  .ai-seo-breadcrumb-container-{{ ai_gen_id }} {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-seo-breadcrumb-nav-{{ ai_gen_id }} {
    font-size: {{ section.settings.font_size }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.5;
  }

  .ai-seo-breadcrumb-nav-{{ ai_gen_id }} a {
    color: {{ section.settings.link_color }};
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .ai-seo-breadcrumb-nav-{{ ai_gen_id }} a:hover {
    opacity: 0.7;
  }

  .ai-seo-breadcrumb-separator-{{ ai_gen_id }} {
    margin: 0 8px;
    color: {{ section.settings.text_color }};
    opacity: 0.5;
  }

  .ai-seo-breadcrumb-current-{{ ai_gen_id }} {
    color: {{ section.settings.text_color }};
  }
{% endstyle %}

{% liquid
  assign breadcrumb_items = ''
  assign breadcrumb_json = ''
  assign position_counter = 1
  
  assign home_item = '{"@type":"ListItem","position":' | append: position_counter | append: ',"name":"Home","item":"' | append: shop.url | append: '"}'
  assign breadcrumb_json = home_item
  assign position_counter = position_counter | plus: 1
  
  if section.settings.show_breadcrumb
    assign breadcrumb_items = '<a href="/">Home</a>'
  endif
  
  if request.page_type == 'product' and product
    if product.collections.size > 0
      assign first_collection = product.collections.first
      assign collection_item = '{"@type":"ListItem","position":' | append: position_counter | append: ',"name":"' | append: first_collection.title | json | append: ',"item":"' | append: shop.url | append: first_collection.url | append: '"}'
      assign breadcrumb_json = breadcrumb_json | append: ',' | append: collection_item
      assign position_counter = position_counter | plus: 1
      
      if section.settings.show_breadcrumb
        assign breadcrumb_items = breadcrumb_items | append: '<span class="ai-seo-breadcrumb-separator-' | append: ai_gen_id | append: '">›</span><a href="' | append: first_collection.url | append: '">' | append: first_collection.title | append: '</a>'
      endif
    endif
    
    assign product_item = '{"@type":"ListItem","position":' | append: position_counter | append: ',"name":"' | append: product.title | json | append: ',"item":"' | append: shop.url | append: product.url | append: '"}'
    assign breadcrumb_json = breadcrumb_json | append: ',' | append: product_item
    
    if section.settings.show_breadcrumb
      assign breadcrumb_items = breadcrumb_items | append: '<span class="ai-seo-breadcrumb-separator-' | append: ai_gen_id | append: '">›</span><span class="ai-seo-breadcrumb-current-' | append: ai_gen_id | append: '">' | append: product.title | append: '</span>'
    endif
    
  elsif request.page_type == 'collection' and collection
    assign collection_item = '{"@type":"ListItem","position":' | append: position_counter | append: ',"name":"' | append: collection.title | json | append: ',"item":"' | append: shop.url | append: collection.url | append: '"}'
    assign breadcrumb_json = breadcrumb_json | append: ',' | append: collection_item
    
    if section.settings.show_breadcrumb
      assign breadcrumb_items = breadcrumb_items | append: '<span class="ai-seo-breadcrumb-separator-' | append: ai_gen_id | append: '">›</span><span class="ai-seo-breadcrumb-current-' | append: ai_gen_id | append: '">' | append: collection.title | append: '</span>'
    endif
    
  elsif request.page_type == 'page' and page
    assign page_item = '{"@type":"ListItem","position":' | append: position_counter | append: ',"name":"' | append: page.title | json | append: ',"item":"' | append: shop.url | append: page.url | append: '"}'
    assign breadcrumb_json = breadcrumb_json | append: ',' | append: page_item
    
    if section.settings.show_breadcrumb
      assign breadcrumb_items = breadcrumb_items | append: '<span class="ai-seo-breadcrumb-separator-' | append: ai_gen_id | append: '">›</span><span class="ai-seo-breadcrumb-current-' | append: ai_gen_id | append: '">' | append: page.title | append: '</span>'
    endif
    
  elsif request.page_type == 'article' and article
    assign blog_item = '{"@type":"ListItem","position":' | append: position_counter | append: ',"name":"' | append: article.blog.title | json | append: ',"item":"' | append: shop.url | append: article.blog.url | append: '"}'
    assign breadcrumb_json = breadcrumb_json | append: ',' | append: blog_item
    assign position_counter = position_counter | plus: 1
    
    if section.settings.show_breadcrumb
      assign breadcrumb_items = breadcrumb_items | append: '<span class="ai-seo-breadcrumb-separator-' | append: ai_gen_id | append: '">›</span><a href="' | append: article.blog.url | append: '">' | append: article.blog.title | append: '</a>'
    endif
    
    assign article_item = '{"@type":"ListItem","position":' | append: position_counter | append: ',"name":"' | append: article.title | json | append: ',"item":"' | append: shop.url | append: article.url | append: '"}'
    assign breadcrumb_json = breadcrumb_json | append: ',' | append: article_item
    
    if section.settings.show_breadcrumb
      assign breadcrumb_items = breadcrumb_items | append: '<span class="ai-seo-breadcrumb-separator-' | append: ai_gen_id | append: '">›</span><span class="ai-seo-breadcrumb-current-' | append: ai_gen_id | append: '">' | append: article.title | append: '</span>'
    endif
    
  elsif request.page_type == 'metaobject' and metaobject
    if section.settings.metaobject_parent_label != blank and section.settings.metaobject_parent_url != blank
      assign parent_item = '{"@type":"ListItem","position":' | append: position_counter | append: ',"name":"' | append: section.settings.metaobject_parent_label | json | append: ',"item":"' | append: shop.url | append: section.settings.metaobject_parent_url | append: '"}'
      assign breadcrumb_json = breadcrumb_json | append: ',' | append: parent_item
      assign position_counter = position_counter | plus: 1
      
      if section.settings.show_breadcrumb
        assign breadcrumb_items = breadcrumb_items | append: '<span class="ai-seo-breadcrumb-separator-' | append: ai_gen_id | append: '">›</span><a href="' | append: section.settings.metaobject_parent_url | append: '">' | append: section.settings.metaobject_parent_label | append: '</a>'
      endif
    endif
    
    assign metaobject_name = metaobject.display_name | default: metaobject.handle
    assign metaobject_item = '{"@type":"ListItem","position":' | append: position_counter | append: ',"name":"' | append: metaobject_name | json | append: ',"item":"' | append: shop.url | append: request.path | append: '"}'
    assign breadcrumb_json = breadcrumb_json | append: ',' | append: metaobject_item
    
    if section.settings.show_breadcrumb
      assign breadcrumb_items = breadcrumb_items | append: '<span class="ai-seo-breadcrumb-separator-' | append: ai_gen_id | append: '">›</span><span class="ai-seo-breadcrumb-current-' | append: ai_gen_id | append: '">' | append: metaobject_name | append: '</span>'
    endif
  endif
%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{{ breadcrumb_json }}]
}
</script>

{% if section.settings.show_breadcrumb %}
  <div class="ai-seo-breadcrumb-{{ ai_gen_id }}">
    <div class="ai-seo-breadcrumb-container-{{ ai_gen_id }}">
      <nav class="ai-seo-breadcrumb-nav-{{ ai_gen_id }}" aria-label="Breadcrumb">
        {{ breadcrumb_items }}
      </nav>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "SEO breadcrumb",
  "settings": [
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show visible breadcrumb",
      "default": true,
      "info": "Google structured data always outputs regardless of this toggle"
    },
    {
      "type": "header",
      "content": "Metaobject pages"
    },
    {
      "type": "text",
      "id": "metaobject_parent_label",
      "label": "Metaobject parent label",
      "default": "Ingredient Glossary"
    },
    {
      "type": "text",
      "id": "metaobject_parent_url",
      "label": "Metaobject parent URL",
      "default": "/pages/ingredient-glossary"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#888888"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#555555"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 13
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "SEO breadcrumb"
    }
  ]
}
{% endschema %}
