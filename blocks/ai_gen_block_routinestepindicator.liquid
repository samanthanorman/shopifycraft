{% doc %}
  @prompt
    Create a Korean skincare routine step indicator that displays 5 connected circles in a horizontal progress bar. The current product's routine step number (from product.metafields.custom.haramoon.routine_step_number) should be highlighted and pulsing. Each step should be clickable and show the product name on hover. Steps 1-5 should be labeled as: Step 1 Cleanser, Step 2 Toner, Step 3 Ampoule, Step 4 Serum, Step 5 Cream. Include connecting lines between circles. Style with a clean K-beauty aesthetic using soft colors, smooth animations, and mobile-responsive design. Add a heading above showing 'Step X of 5 in Your Korean Skincare Routine'. Include accessibility features for keyboard navigation and screen readers., 1. Visual Style Upgrades:
    Replace basic circles with:
    
    Glassmorphism effect
    Frosted glass look (very K-beauty, very trendy)
    Gradient fills
    Soft pastels that shift on hover
    Neumorphism
    Subtle 3D depth (soft shadows)
    Animated gradients
    Current step has a moving gradient
    Glow effects
    Subtle neon glow on current step
    Typography:
    
    Modern sans-serif
    Inter, Poppins, or DM Sans
    Mixed case
    Not all caps (feels more approachable)
    Emoji accents
    Subtle use (✨ 💧 🌸)
    Color Palette (K-Beauty Gen Z):
    
    Soft lavender (#E6E6FA)
    Peachy pink (#FFD4D4)
    Mint green (#D4F4DD)
    Creamy white (#FFFEF9)
    Warm gray (#F5F5F5)
    2. Micro-Interactions (The Fun Part):
    On Hover:
    
    ✨ Bounce animation
    Step circle bounces slightly
    🌊 Ripple effect
    Like water droplets
    💫 Sparkle particles
    Tiny stars appear around current step
    🎨 Color shift
    Gradient transitions smoothly
    📝 Tooltip slides up
    Product name + benefit
    On Current Step:
    
    💓 Gentle pulse
    Not just opacity, actual scale change
    🌈 Rotating gradient
    Subtle rainbow effect
    ✨ Shimmer overlay
    Light moves across it
    🎯 Magnetic effect
    Other steps slightly lean toward it
    On Click:
    
    🎪 Confetti burst
    Tiny particles (if they complete routine)
    🔊 Haptic feedback
    Vibration on mobile
    🎬 Smooth scroll
    To related product section
    🎨 YOUR BRAND COLOR PALETTE:
    Primary Blue: #3498ff (vibrant, trustworthy)
    Pure White: #ffffff (clean, minimal)
    Deep Black: #141615 (sophisticated)
    Slate Gray: #53585a (neutral, modern)
    This is a high-contrast, professional palette - perfect for liquid glass!, for the option to edit theall  text labels-  underneath the step number, and the heading to allow flexibility similar to how i can edit the colors now. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign current_step = product.metafields.custom.routine_step_number | default: 1 %}

{% style %}
  .ai-routine-indicator-{{ ai_gen_id }} {
    padding: 60px 20px;
    background: linear-gradient(135deg, {{ block.settings.background_color }} 0%, {{ block.settings.background_gradient_color }} 100%);
    border-radius: {{ block.settings.border_radius }}px;
    position: relative;
    overflow: hidden;
  }

  .ai-routine-indicator-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 20% 50%, {{ block.settings.accent_color_1 | color_modify: 'alpha', 0.1 }} 0%, transparent 50%),
                radial-gradient(circle at 80% 50%, {{ block.settings.accent_color_2 | color_modify: 'alpha', 0.1 }} 0%, transparent 50%);
    pointer-events: none;
  }

  .ai-routine-indicator__container-{{ ai_gen_id }} {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .ai-routine-indicator__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 48px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .ai-routine-indicator__emoji-{{ ai_gen_id }} {
    display: inline-block;
    margin: 0 8px;
    font-size: {{ block.settings.heading_size | times: 1.2 }}px;
  }

  .ai-routine-indicator__progress-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    position: relative;
  }

  .ai-routine-indicator__step-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    max-width: 140px;
  }

  .ai-routine-indicator__step-button-{{ ai_gen_id }} {
    width: {{ block.settings.circle_size }}px;
    height: {{ block.settings.circle_size }}px;
    border-radius: 50%;
    border: none;
    background: {{ block.settings.glass_bg_color }};
    backdrop-filter: blur(10px);
    box-shadow: 
      0 8px 32px 0 {{ block.settings.shadow_color | color_modify: 'alpha', 0.15 }},
      inset 0 1px 0 0 {{ block.settings.glass_highlight | color_modify: 'alpha', 0.5 }},
      inset 0 -1px 0 0 {{ block.settings.shadow_color | color_modify: 'alpha', 0.1 }};
    color: {{ block.settings.inactive_text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 18px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    z-index: 2;
    overflow: hidden;
  }

  .ai-routine-indicator__step-button-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, {{ block.settings.glass_highlight | color_modify: 'alpha', 0.3 }} 0%, transparent 100%);
    border-radius: 50%;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .ai-routine-indicator__step-button-{{ ai_gen_id }}:hover {
    transform: translateY(-8px) scale(1.1);
    box-shadow: 
      0 12px 40px 0 {{ block.settings.shadow_color | color_modify: 'alpha', 0.25 }},
      inset 0 1px 0 0 {{ block.settings.glass_highlight | color_modify: 'alpha', 0.7 }},
      0 0 20px {{ block.settings.accent_color_1 | color_modify: 'alpha', 0.3 }};
  }

  .ai-routine-indicator__step-button-{{ ai_gen_id }}:hover::before {
    opacity: 0.5;
  }

  .ai-routine-indicator__step-button-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.active_color }};
    outline-offset: 4px;
  }

  .ai-routine-indicator__step-{{ ai_gen_id }}.active .ai-routine-indicator__step-button-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.active_color }} 0%, {{ block.settings.active_gradient_color }} 100%);
    background-size: 200% 200%;
    color: {{ block.settings.active_text_color }};
    box-shadow: 
      0 12px 48px 0 {{ block.settings.active_color | color_modify: 'alpha', 0.4 }},
      0 0 30px {{ block.settings.active_color | color_modify: 'alpha', 0.5 }},
      inset 0 1px 0 0 {{ block.settings.glass_highlight }};
    animation: ai-routine-pulse-{{ ai_gen_id }} 2s ease-in-out infinite,
               ai-routine-gradient-{{ ai_gen_id }} 3s ease infinite;
  }

  .ai-routine-indicator__step-{{ ai_gen_id }}.active .ai-routine-indicator__step-button-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: linear-gradient(45deg, {{ block.settings.accent_color_1 }}, {{ block.settings.accent_color_2 }}, {{ block.settings.accent_color_1 }});
    background-size: 300% 300%;
    border-radius: 50%;
    z-index: -1;
    animation: ai-routine-shimmer-{{ ai_gen_id }} 3s linear infinite;
    opacity: 0.6;
  }

  .ai-routine-indicator__step-{{ ai_gen_id }}.completed .ai-routine-indicator__step-button-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.completed_color }} 0%, {{ block.settings.completed_gradient_color }} 100%);
    color: {{ block.settings.active_text_color }};
    box-shadow: 
      0 8px 32px 0 {{ block.settings.completed_color | color_modify: 'alpha', 0.3 }},
      inset 0 1px 0 0 {{ block.settings.glass_highlight | color_modify: 'alpha', 0.5 }};
  }

  @keyframes ai-routine-pulse-{{ ai_gen_id }} {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }

  @keyframes ai-routine-gradient-{{ ai_gen_id }} {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  @keyframes ai-routine-shimmer-{{ ai_gen_id }} {
    0% {
      background-position: 0% 50%;
    }
    100% {
      background-position: 300% 50%;
    }
  }

  .ai-routine-indicator__sparkle-{{ ai_gen_id }} {
    position: absolute;
    width: 4px;
    height: 4px;
    background: {{ block.settings.glass_highlight }};
    border-radius: 50%;
    pointer-events: none;
    opacity: 0;
  }

  .ai-routine-indicator__step-{{ ai_gen_id }}.active .ai-routine-indicator__sparkle-{{ ai_gen_id }} {
    animation: ai-routine-sparkle-{{ ai_gen_id }} 1.5s ease-in-out infinite;
  }

  @keyframes ai-routine-sparkle-{{ ai_gen_id }} {
    0%, 100% {
      opacity: 0;
      transform: translate(0, 0) scale(0);
    }
    50% {
      opacity: 1;
      transform: translate(var(--ai-sparkle-x), var(--ai-sparkle-y)) scale(1);
    }
  }

  .ai-routine-indicator__step-label-{{ ai_gen_id }} {
    margin-top: 16px;
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.text_color }};
    text-align: center;
    opacity: 0.6;
    transition: all 0.3s ease;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .ai-routine-indicator__step-{{ ai_gen_id }}.active .ai-routine-indicator__step-label-{{ ai_gen_id }} {
    opacity: 1;
    font-weight: 600;
    color: {{ block.settings.active_color }};
  }

  .ai-routine-indicator__step-{{ ai_gen_id }}:hover .ai-routine-indicator__step-label-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(-2px);
  }

  .ai-routine-indicator__connector-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.circle_size | divided_by: 2 }}px;
    left: 50%;
    right: -50%;
    height: 3px;
    background: linear-gradient(90deg, {{ block.settings.connector_color | color_modify: 'alpha', 0.2 }} 0%, {{ block.settings.connector_color | color_modify: 'alpha', 0.1 }} 100%);
    z-index: 1;
    transition: all 0.4s ease;
    border-radius: 2px;
  }

  .ai-routine-indicator__step-{{ ai_gen_id }}.completed .ai-routine-indicator__connector-{{ ai_gen_id }} {
    background: linear-gradient(90deg, {{ block.settings.completed_color }} 0%, {{ block.settings.completed_gradient_color }} 100%);
    box-shadow: 0 0 10px {{ block.settings.completed_color | color_modify: 'alpha', 0.3 }};
  }

  .ai-routine-indicator__step-{{ ai_gen_id }}:last-child .ai-routine-indicator__connector-{{ ai_gen_id }} {
    display: none;
  }

  .ai-routine-indicator__tooltip-{{ ai_gen_id }} {
    position: absolute;
    bottom: calc(100% + 16px);
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: {{ block.settings.tooltip_bg_color }};
    backdrop-filter: blur(20px);
    color: {{ block.settings.tooltip_text_color }};
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 13px;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
    z-index: 10;
    box-shadow: 
      0 8px 32px 0 {{ block.settings.shadow_color | color_modify: 'alpha', 0.2 }},
      inset 0 1px 0 0 {{ block.settings.glass_highlight | color_modify: 'alpha', 0.3 }};
    border: 1px solid {{ block.settings.glass_highlight | color_modify: 'alpha', 0.2 }};
    font-weight: 500;
  }

  .ai-routine-indicator__tooltip-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 8px solid transparent;
    border-top-color: {{ block.settings.tooltip_bg_color }};
  }

  .ai-routine-indicator__step-button-{{ ai_gen_id }}:hover + .ai-routine-indicator__tooltip-{{ ai_gen_id }},
  .ai-routine-indicator__step-button-{{ ai_gen_id }}:focus + .ai-routine-indicator__tooltip-{{ ai_gen_id }} {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .ai-routine-indicator__benefit-{{ ai_gen_id }} {
    display: block;
    font-size: 11px;
    opacity: 0.8;
    margin-top: 4px;
    font-weight: 400;
  }

  @media screen and (max-width: 749px) {
    .ai-routine-indicator-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-routine-indicator__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.75 }}px;
      margin-bottom: 32px;
    }

    .ai-routine-indicator__emoji-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.9 }}px;
    }

    .ai-routine-indicator__step-button-{{ ai_gen_id }} {
      width: {{ block.settings.circle_size | times: 0.75 }}px;
      height: {{ block.settings.circle_size | times: 0.75 }}px;
      font-size: 14px;
    }

    .ai-routine-indicator__connector-{{ ai_gen_id }} {
      top: {{ block.settings.circle_size | times: 0.75 | divided_by: 2 }}px;
      height: 2px;
    }

    .ai-routine-indicator__step-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | times: 0.85 }}px;
      margin-top: 12px;
    }

    .ai-routine-indicator__step-{{ ai_gen_id }} {
      max-width: 90px;
    }

    .ai-routine-indicator__tooltip-{{ ai_gen_id }} {
      font-size: 11px;
      padding: 8px 12px;
    }

    .ai-routine-indicator__benefit-{{ ai_gen_id }} {
      font-size: 10px;
    }
  }
{% endstyle %}

<skincare-routine-{{ ai_gen_id }} class="ai-routine-indicator-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-routine-indicator__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      {% assign heading_text = block.settings.heading | replace: '{step}', current_step %}
      <h2 class="ai-routine-indicator__heading-{{ ai_gen_id }}">
        {% if block.settings.emoji_before != blank %}
          <span class="ai-routine-indicator__emoji-{{ ai_gen_id }}">{{ block.settings.emoji_before }}</span>
        {% endif %}
        {{ heading_text }}
        {% if block.settings.emoji_after != blank %}
          <span class="ai-routine-indicator__emoji-{{ ai_gen_id }}">{{ block.settings.emoji_after }}</span>
        {% endif %}
      </h2>
    {% endif %}

    <div class="ai-routine-indicator__progress-{{ ai_gen_id }}" role="group" aria-label="Skincare routine steps">
      {% for i in (1..5) %}
        {% assign step_number = i %}
        {% assign is_active = false %}
        {% assign is_completed = false %}
        
        {% if step_number == current_step %}
          {% assign is_active = true %}
        {% elsif step_number < current_step %}
          {% assign is_completed = true %}
        {% endif %}

        {% liquid
          case i
            when 1
              assign step_label = block.settings.step_1_label
              assign step_benefit = block.settings.step_1_benefit
            when 2
              assign step_label = block.settings.step_2_label
              assign step_benefit = block.settings.step_2_benefit
            when 3
              assign step_label = block.settings.step_3_label
              assign step_benefit = block.settings.step_3_benefit
            when 4
              assign step_label = block.settings.step_4_label
              assign step_benefit = block.settings.step_4_benefit
            when 5
              assign step_label = block.settings.step_5_label
              assign step_benefit = block.settings.step_5_benefit
          endcase
        %}

        <div 
          class="ai-routine-indicator__step-{{ ai_gen_id }} {% if is_active %}active{% endif %} {% if is_completed %}completed{% endif %}"
          data-step="{{ step_number }}"
        >
          <button
            class="ai-routine-indicator__step-button-{{ ai_gen_id }}"
            type="button"
            aria-label="{{ step_label }}"
            aria-current="{% if is_active %}step{% else %}false{% endif %}"
            tabindex="0"
          >
            {{ step_number }}
            {% if is_active %}
              {% for j in (1..4) %}
                {% assign angle = j | times: 90 %}
                {% assign x = angle | cos | times: 30 %}
                {% assign y = angle | sin | times: 30 %}
                <span 
                  class="ai-routine-indicator__sparkle-{{ ai_gen_id }}"
                  style="--ai-sparkle-x: {{ x }}px; --ai-sparkle-y: {{ y }}px; animation-delay: {{ j | times: 0.2 }}s;"
                ></span>
              {% endfor %}
            {% endif %}
          </button>
          
          <div class="ai-routine-indicator__tooltip-{{ ai_gen_id }}" role="tooltip">
            {{ step_label }}
            {% if step_benefit != blank %}
              <span class="ai-routine-indicator__benefit-{{ ai_gen_id }}">{{ step_benefit }}</span>
            {% endif %}
          </div>

          <div class="ai-routine-indicator__connector-{{ ai_gen_id }}" aria-hidden="true"></div>
          
          {% if step_label != blank %}
            <div class="ai-routine-indicator__step-label-{{ ai_gen_id }}">
              {{ step_label }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</skincare-routine-{{ ai_gen_id }}>

<script>
  (function() {
    class SkincareRoutine{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupKeyboardNavigation();
        this.setupClickEffects();
      }

      setupKeyboardNavigation() {
        const buttons = this.querySelectorAll('.ai-routine-indicator__step-button-{{ ai_gen_id }}');
        
        buttons.forEach((button, index) => {
          button.addEventListener('keydown', (e) => {
            let targetIndex = index;

            if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
              e.preventDefault();
              targetIndex = index < buttons.length - 1 ? index + 1 : 0;
            } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
              e.preventDefault();
              targetIndex = index > 0 ? index - 1 : buttons.length - 1;
            } else if (e.key === 'Home') {
              e.preventDefault();
              targetIndex = 0;
            } else if (e.key === 'End') {
              e.preventDefault();
              targetIndex = buttons.length - 1;
            }

            if (targetIndex !== index) {
              buttons[targetIndex].focus();
            }
          });
        });
      }

      setupClickEffects() {
        const buttons = this.querySelectorAll('.ai-routine-indicator__step-button-{{ ai_gen_id }}');
        
        buttons.forEach((button) => {
          button.addEventListener('click', (e) => {
            this.createRipple(e, button);
            
            if (navigator.vibrate) {
              navigator.vibrate(50);
            }
          });
        });
      }

      createRipple(event, button) {
        const rect = button.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height);
        const x = event.clientX - rect.left - size / 2;
        const y = event.clientY - rect.top - size / 2;

        const ripple = document.createElement('span');
        ripple.style.cssText = `
          position: absolute;
          width: ${size}px;
          height: ${size}px;
          border-radius: 50%;
          background: radial-gradient(circle, rgba(255,255,255,0.6) 0%, transparent 70%);
          top: ${y}px;
          left: ${x}px;
          pointer-events: none;
          animation: ai-routine-ripple-{{ ai_gen_id }} 0.6s ease-out;
        `;

        button.appendChild(ripple);

        setTimeout(() => {
          ripple.remove();
        }, 600);
      }
    }

    const style = document.createElement('style');
    style.textContent = `
      @keyframes ai-routine-ripple-{{ ai_gen_id }} {
        0% {
          transform: scale(0);
          opacity: 1;
        }
        100% {
          transform: scale(2);
          opacity: 0;
        }
      }
    `;
    document.head.appendChild(style);

    customElements.define('skincare-routine-{{ ai_gen_id }}', SkincareRoutine{{ ai_gen_id }});
  })();
</script>

