              <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="emf-faq-answer" id="emf-faq-{{ forloop.index }}" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <div class="emf-faq-answer__inner" itemprop="text">{{ faq.answer }}</div>
            </div>
          </div>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Static fallback FAQs if no metaobject data yet {%- endcomment -%}
          {%- assign static_faqs = "What is EMF?|Electromagnetic fields (EMF) are invisible areas of energy, often referred to as radiation, associated with the use of electrical power and various forms of natural and man-made lighting. They include both electric and magnetic fields.;Is EMF from my phone dangerous?|The scientific consensus is that everyday EMF exposure from consumer devices is low-level and not proven to cause harm. However, the IARC classifies radiofrequency EMFs as 'possibly carcinogenic' (Group 2B), which is why many people choose to apply the precautionary principle — reducing exposure where easy and practical.;How does Faraday shielding work?|A Faraday cage (or bag) is an enclosure made from conductive material that blocks electromagnetic fields. When your phone is inside a Faraday bag, it cannot send or receive signals — meaning zero RF emissions. The conductive mesh reflects and absorbs the electromagnetic waves.;What is the difference between ELF and RF EMF?|ELF (Extremely Low Frequency) EMFs come from power lines and electrical wiring. RF (Radio Frequency) EMFs come from wireless devices like cell phones, Wi-Fi routers, and Bluetooth. Both are types of non-ionizing radiation — they do not have enough energy to break chemical bonds or remove electrons." | split: ';' -%}
          {%- for faq_item in static_faqs -%}
            {%- assign parts = faq_item | split: '|' -%}
            <div class="emf-faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
              <button class="emf-faq-btn" aria-expanded="false" aria-controls="emf-faq-static-{{ forloop.index }}">
                <span class="emf-faq-btn__q" itemprop="name">{{ parts[0] }}</span>
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="emf-faq-answer" id="emf-faq-static-{{ forloop.index }}" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                <div class="emf-faq-answer__inner" itemprop="text">{{ parts[1] }}</div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
  {%- endif -%}

</div>{%- comment -%} end .emf-page {%- endcomment -%}

<script>
  (function() {
    // ── Toggle cards (concept expand/collapse) ──────────────────
    document.querySelectorAll('.emf-cyber-card__toggle').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var expanded = this.getAttribute('aria-expanded') === 'true';
        var bodyId   = this.getAttribute('aria-controls');
        var body     = document.getElementById(bodyId);
        this.setAttribute('aria-expanded', !expanded);
        if (body) body.classList.toggle('is-open', !expanded);
      });
    });

    // ── FAQ accordion ───────────────────────────────────────────
    document.querySelectorAll('.emf-faq-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var expanded = this.getAttribute('aria-expanded') === 'true';
        var answerId = this.getAttribute('aria-controls');
        var answer   = document.getElementById(answerId);

        // Close all others
        document.querySelectorAll('.emf-faq-btn').forEach(function(b) {
          b.setAttribute('aria-expanded', 'false');
        });
        document.querySelectorAll('.emf-faq-answer').forEach(function(a) {
          a.classList.remove('is-open');
        });

        if (!expanded) {
          this.setAttribute('aria-expanded', 'true');
          if (answer) answer.classList.add('is-open');
        }
      });
    });

    // ── Animate bars when card enters viewport ──────────────────
    if ('IntersectionObserver' in window) {
      var barObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var fill = entry.target.querySelector('.emf-protect-card__bar-fill');
            if (fill) {
              fill.style.animationPlayState = 'running';
            }
          }
        });
      }, { threshold: 0.3 });

      document.querySelectorAll('.emf-protect-card').forEach(function(card) {
        barObserver.observe(card);
      });
    }
  })();
</script>

