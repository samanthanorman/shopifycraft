{% doc %}
  @prompt
    1. INGREDIENT SPOTLIGHT
    
    --- Create a premium ingredient spotlight section for a K-beauty skincare product page. This section must dynamically pull data from a Shopify metaobject of type haramoon_101 that is linked to the current product via a product metafield. From that haramoon_101 entry, access the ingredient_profile field which is a list of metaobject references. Each referenced metaobject has these fields: name (ingredient name), description (full description), main_function (e.g. "Peptide active"), skin_benefits (e.g. "Brightening, Pore refining"), ingredient_origin (e.g. "Synthetic" or "Natural"), and sub_category. Loop through all entries in ingredient_profile and display each as a large editorial card in a 2-column grid on desktop, single column on mobile. Each card shows: the name in an oversized thin serif display font, main_function in small caps accent color as a subtitle, skin_benefits as a highlighted tag or badge, and description as 2-3 lines of body copy in clean sans-serif. Add a soft hover lift effect on each card. Use a warm cream background. Include an editable section title and subtitle in theme settings. Add ChemicalSubstance schema JSON-LD in a script tag for each ingredient using name and description values. Animate cards in with staggered fade-up on scroll. Premium Mamonde-level aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign haramoon_101_entry = product.metafields.custom.haramoon_101.value
  assign ingredient_list = haramoon_101_entry.ingredient_profile.value
%}

{% style %}
  .ai-ingredient-spotlight-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-ingredient-spotlight-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-ingredient-spotlight-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-ingredient-spotlight-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    letter-spacing: -0.02em;
  }

  .ai-ingredient-spotlight-subtitle-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-ingredient-spotlight-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.card_gap }}px;
    margin-top: {{ block.settings.grid_top_spacing }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-ingredient-spotlight-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .ai-ingredient-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-ingredient-card-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-ingredient-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
  }

  .ai-ingredient-name-{{ ai_gen_id }} {
    font-family: {{ block.settings.name_font.family }}, {{ block.settings.name_font.fallback_families }};
    font-weight: {{ block.settings.name_font.weight }};
    font-size: {{ block.settings.name_size }}px;
    color: {{ block.settings.name_color }};
    margin: 0 0 8px 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .ai-ingredient-function-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: {{ block.settings.function_size }}px;
    color: {{ block.settings.accent_color }};
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 12px 0;
    font-weight: 600;
  }

  .ai-ingredient-benefits-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_radius }}px;
    font-size: {{ block.settings.badge_size }}px;
    font-weight: 500;
    margin-bottom: 16px;
  }

  .ai-ingredient-description-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-ingredient-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.subtitle_color }};
    font-size: 16px;
  }
{% endstyle %}

<ingredient-spotlight-{{ ai_gen_id }}
  class="ai-ingredient-spotlight-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-ingredient-spotlight-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_subtitle != blank %}
      <div class="ai-ingredient-spotlight-header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-ingredient-spotlight-title-{{ ai_gen_id }}">
            {{ block.settings.section_title }}
          </h2>
        {% endif %}
        {% if block.settings.section_subtitle != blank %}
          <p class="ai-ingredient-spotlight-subtitle-{{ ai_gen_id }}">
            {{ block.settings.section_subtitle }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    {% if ingredient_list and ingredient_list.size > 0 %}
      <div class="ai-ingredient-spotlight-grid-{{ ai_gen_id }}">
        {% for ingredient in ingredient_list %}
          <div
            class="ai-ingredient-card-{{ ai_gen_id }}"
            data-index="{{ forloop.index }}"
          >
            {% if ingredient.name %}
              <h3 class="ai-ingredient-name-{{ ai_gen_id }}">
                {{ ingredient.name.value }}
              </h3>
            {% endif %}

            {% if ingredient.main_function %}
              <div class="ai-ingredient-function-{{ ai_gen_id }}">
                {{ ingredient.main_function.value }}
              </div>
            {% endif %}

            {% if ingredient.skin_benefits %}
              <div class="ai-ingredient-benefits-{{ ai_gen_id }}">
                {{ ingredient.skin_benefits.value }}
              </div>
            {% endif %}

            {% if ingredient.description %}
              <p class="ai-ingredient-description-{{ ai_gen_id }}">
                {{ ingredient.description.value }}
              </p>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {% if block.settings.enable_schema %}
        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "ItemList",
          "itemListElement": [
            {% for ingredient in ingredient_list %}
              {
                "@type": "ChemicalSubstance",
                "name": {{ ingredient.name.value | json }},
                "description": {{ ingredient.description.value | json }}
              }{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ]
        }
        </script>
      {% endif %}
    {% else %}
      <div class="ai-ingredient-empty-state-{{ ai_gen_id }}">
        <p>Next, link a haramoon_101 metaobject entry with ingredient data to this product</p>
      </div>
    {% endif %}
  </div>
</ingredient-spotlight-{{ ai_gen_id }}>

<script>
  (function() {
    class IngredientSpotlight{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.animationDelay = {{ block.settings.animation_delay }};
      }

      connectedCallback() {
        this.setupScrollAnimation();
      }

      setupScrollAnimation() {
        const cards = this.querySelectorAll('.ai-ingredient-card-{{ ai_gen_id }}');
        
        if (!cards.length) return;

        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const card = entry.target;
              const index = parseInt(card.dataset.index) - 1;
              const delay = index * this.animationDelay;
              
              setTimeout(() => {
                card.classList.add('ai-visible-{{ ai_gen_id }}');
              }, delay);
              
              observer.unobserve(card);
            }
          });
        }, observerOptions);

        cards.forEach((card) => {
          observer.observe(card);
        });
      }
    }

    customElements.define('ingredient-spotlight-{{ ai_gen_id }}', IngredientSpotlight{{ ai_gen_id }});
  })();
</script>

