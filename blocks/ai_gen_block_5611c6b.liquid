{% doc %}
  @prompt
    Create a premium liquid glass Korean skincare routine step indicator using Poppins font. Display 5 steps as frosted glass circles with these exact colors: primary blue #3498ff for active step with animated glow, white #ffffff for glass effect with 10% opacity backdrop blur, deep black #141615 for text, slate gray #53585a for inactive steps. The current step from product.metafields.custom.haramoon.routine_step_number should have a pulsing blue glow effect and rotating shimmer. Add smooth hover animations with subtle bounce. Include gradient connecting lines between steps using blue to gray gradient. Show progress with emojis: Step 1 Cleanser 💧, Step 2 Toner 🌸, Step 3 Ampoule ✨, Step 4 Serum 💫, Step 5 Cream 🔥. Add heading 'Your Glass Skin Journey - Step X of 5' in Poppins font. Include glassmorphism with backdrop-filter blur, neumorphism shadows, smooth transitions, mobile-responsive swipe gestures, and accessibility features. Use high contrast for readability., change to poppins font, allow for all text labels to be editable similar to the colors being editable - center step number circles , please change font style to poppins or century gothic or similar
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign current_step = product.metafields.custom.routine_step_number | default: 1 %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

  .ai-glass-routine-{{ ai_gen_id }} {
    font-family: 'Poppins', 'Century Gothic', 'AppleGothic', sans-serif;
    padding: {{ block.settings.section_padding }}px 20px;
    background: {{ block.settings.background_color }};
    position: relative;
    overflow: hidden;
  }

  .ai-glass-routine-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-glass-routine-heading-{{ ai_gen_id }} {
    font-family: 'Poppins', 'Century Gothic', 'AppleGothic', sans-serif;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    text-align: center;
    margin: 0 0 {{ block.settings.step_spacing }}px;
    letter-spacing: -0.5px;
  }

  .ai-glass-routine-steps-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .ai-glass-routine-steps-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.step_spacing }}px;
    position: relative;
    padding: 20px 0;
  }

  .ai-glass-routine-step-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    z-index: 2;
  }

  .ai-glass-routine-circle-{{ ai_gen_id }} {
    width: {{ block.settings.circle_size }}px;
    height: {{ block.settings.circle_size }}px;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    backdrop-filter: blur({{ block.settings.blur_amount }}px);
    -webkit-backdrop-filter: blur({{ block.settings.blur_amount }}px);
  }

  .ai-glass-routine-circle-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    padding: 2px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0.1));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.6;
  }

  .ai-glass-routine-circle-inactive-{{ ai_gen_id }} {
    background: rgba({{ block.settings.inactive_color | color_extract: 'red' }}, {{ block.settings.inactive_color | color_extract: 'green' }}, {{ block.settings.inactive_color | color_extract: 'blue' }}, 0.15);
    border: 2px solid rgba({{ block.settings.inactive_color | color_extract: 'red' }}, {{ block.settings.inactive_color | color_extract: 'green' }}, {{ block.settings.inactive_color | color_extract: 'blue' }}, 0.3);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .ai-glass-routine-circle-active-{{ ai_gen_id }} {
    background: rgba({{ block.settings.active_color | color_extract: 'red' }}, {{ block.settings.active_color | color_extract: 'green' }}, {{ block.settings.active_color | color_extract: 'blue' }}, 0.2);
    border: 3px solid {{ block.settings.active_color }};
    box-shadow: 
      0 0 30px rgba({{ block.settings.active_color | color_extract: 'red' }}, {{ block.settings.active_color | color_extract: 'green' }}, {{ block.settings.active_color | color_extract: 'blue' }}, 0.6),
      0 0 60px rgba({{ block.settings.active_color | color_extract: 'red' }}, {{ block.settings.active_color | color_extract: 'green' }}, {{ block.settings.active_color | color_extract: 'blue' }}, 0.4),
      0 8px 32px rgba(0, 0, 0, 0.2);
    animation: ai-glass-routine-pulse-{{ ai_gen_id }} 2s ease-in-out infinite;
  }

  .ai-glass-routine-circle-active-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      {{ block.settings.active_color }} 90deg,
      transparent 180deg,
      {{ block.settings.active_color }} 270deg,
      transparent 360deg
    );
    opacity: 0.4;
    animation: ai-glass-routine-rotate-{{ ai_gen_id }} 3s linear infinite;
    z-index: -1;
    filter: blur(8px);
  }

  @keyframes ai-glass-routine-pulse-{{ ai_gen_id }} {
    0%, 100% {
      box-shadow: 
        0 0 30px rgba({{ block.settings.active_color | color_extract: 'red' }}, {{ block.settings.active_color | color_extract: 'green' }}, {{ block.settings.active_color | color_extract: 'blue' }}, 0.6),
        0 0 60px rgba({{ block.settings.active_color | color_extract: 'red' }}, {{ block.settings.active_color | color_extract: 'green' }}, {{ block.settings.active_color | color_extract: 'blue' }}, 0.4),
        0 8px 32px rgba(0, 0, 0, 0.2);
    }
    50% {
      box-shadow: 
        0 0 40px rgba({{ block.settings.active_color | color_extract: 'red' }}, {{ block.settings.active_color | color_extract: 'green' }}, {{ block.settings.active_color | color_extract: 'blue' }}, 0.8),
        0 0 80px rgba({{ block.settings.active_color | color_extract: 'red' }}, {{ block.settings.active_color | color_extract: 'green' }}, {{ block.settings.active_color | color_extract: 'blue' }}, 0.6),
        0 8px 32px rgba(0, 0, 0, 0.3);
    }
  }

  @keyframes ai-glass-routine-rotate-{{ ai_gen_id }} {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .ai-glass-routine-circle-{{ ai_gen_id }}:hover {
    transform: translateY(-8px) scale(1.05);
  }

  .ai-glass-routine-step-number-{{ ai_gen_id }} {
    font-family: 'Poppins', 'Century Gothic', 'AppleGothic', sans-serif;
    font-size: {{ block.settings.step_number_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    line-height: 1;
    margin-bottom: 4px;
  }

  .ai-glass-routine-emoji-{{ ai_gen_id }} {
    font-size: {{ block.settings.emoji_size }}px;
    line-height: 1;
  }

  .ai-glass-routine-label-{{ ai_gen_id }} {
    font-family: 'Poppins', 'Century Gothic', 'AppleGothic', sans-serif;
    font-size: {{ block.settings.label_size }}px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
    text-align: center;
    max-width: 100px;
    line-height: 1.3;
  }

  .ai-glass-routine-connector-{{ ai_gen_id }} {
    position: absolute;
    height: 3px;
    background: linear-gradient(
      90deg,
      rgba({{ block.settings.active_color | color_extract: 'red' }}, {{ block.settings.active_color | color_extract: 'green' }}, {{ block.settings.active_color | color_extract: 'blue' }}, 0.6),
      rgba({{ block.settings.inactive_color | color_extract: 'red' }}, {{ block.settings.inactive_color | color_extract: 'green' }}, {{ block.settings.inactive_color | color_extract: 'blue' }}, 0.3)
    );
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
    border-radius: 2px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-glass-routine-connector-1-{{ ai_gen_id }} {
    left: calc({{ block.settings.circle_size }}px / 2);
    width: calc({{ block.settings.step_spacing }}px);
  }

  .ai-glass-routine-connector-2-{{ ai_gen_id }} {
    left: calc({{ block.settings.circle_size }}px + {{ block.settings.step_spacing }}px + {{ block.settings.circle_size }}px / 2);
    width: calc({{ block.settings.step_spacing }}px);
  }

  .ai-glass-routine-connector-3-{{ ai_gen_id }} {
    left: calc({{ block.settings.circle_size }}px * 2 + {{ block.settings.step_spacing }}px * 2 + {{ block.settings.circle_size }}px / 2);
    width: calc({{ block.settings.step_spacing }}px);
  }

  .ai-glass-routine-connector-4-{{ ai_gen_id }} {
    left: calc({{ block.settings.circle_size }}px * 3 + {{ block.settings.step_spacing }}px * 3 + {{ block.settings.circle_size }}px / 2);
    width: calc({{ block.settings.step_spacing }}px);
  }

  @media screen and (max-width: 989px) {
    .ai-glass-routine-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-glass-routine-steps-{{ ai_gen_id }} {
      gap: calc({{ block.settings.step_spacing }}px * 0.7);
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      padding: 20px 10px;
      justify-content: flex-start;
    }

    .ai-glass-routine-step-{{ ai_gen_id }} {
      scroll-snap-align: center;
      flex-shrink: 0;
    }

    .ai-glass-routine-circle-{{ ai_gen_id }} {
      width: calc({{ block.settings.circle_size }}px * 0.85);
      height: calc({{ block.settings.circle_size }}px * 0.85);
    }

    .ai-glass-routine-step-number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.step_number_size }}px * 0.85);
    }

    .ai-glass-routine-emoji-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.emoji_size }}px * 0.85);
    }

    .ai-glass-routine-label-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.label_size }}px * 0.85);
    }

    .ai-glass-routine-connector-{{ ai_gen_id }} {
      display: none;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-glass-routine-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-glass-routine-circle-{{ ai_gen_id }} {
      width: calc({{ block.settings.circle_size }}px * 0.75);
      height: calc({{ block.settings.circle_size }}px * 0.75);
    }

    .ai-glass-routine-step-number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.step_number_size }}px * 0.75);
    }

    .ai-glass-routine-emoji-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.emoji_size }}px * 0.75);
    }

    .ai-glass-routine-label-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.label_size }}px * 0.75);
    }
  }
{% endstyle %}

