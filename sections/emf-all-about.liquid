    <div class="emf-section">
      <div class="emf-block__header">
        <p class="emf-block__eyebrow">{{ section.settings.faq_eyebrow | default: 'Common Questions' }}</p>
        <h2 class="emf-block__title">{{ section.settings.faq_heading | default: 'EMF FAQ' }}</h2>
