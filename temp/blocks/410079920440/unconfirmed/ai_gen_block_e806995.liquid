{% doc %}
  @prompt
     . The "HARAMOON's Ingredient Science" Section
    Goal: A section that explains the "Why" behind the products -  Modern Gen Z/Alpha Korean skincare aesthetic
    - Poppins font family
    - Card hover effects: lift up 8px, shadow appears, icon animates
    - Scroll-triggered fade-in animation (toggleable)
    - Mobile-responsive
    
    Prompt: "Create a 'Scientific Breakdown' section. Content: Focus on 'Ceramides' and 'Peptides' and 'Hyaluronic Acid' . Design: A 3-column grid. Column 1: 'The Problem' (Weak Barrier). Column 2: 'The Science' (Lipid Restoration). Column 3: 'The Result' (Glass Skin). Use thin vertical lines to separate columns (medical chart style). Technical Output: Output raw HTML/Liquid code that I can inject into a Shopify 'Custom Liquid' block."
    
    Use the Meta object key:ingredient_profile to  help interlink that metaobject and boost organic seo 
    CRITICAL LINKING REQUIREMENT:
    - Wrap entire card in a link element
    - Construct the URL manually using this pattern: /pages/ingredient-profile/{{ ingredient.handle }}
    - Where ingredient.handle is the metaobject's handle (URL-safe version of the name)
    - Example: if handle is "niacinamide", link becomes /pages/ingredient-profile/niacinamide
    - Each card links to a DIFFERENT ingredient page using this URL pattern - allow me to customize fonts sizes colors spacing and anything else that would allow me flexibility in this custom liquid section. this section should serve to entice educated skincare shoppers to take a deeper look at the products. add hover effects, small animations, and glassmorphism vibes to boost engagement with a gen Z attention span!
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ingredient-science-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.background_color }};
    {% if block.settings.enable_glassmorphism %}
      backdrop-filter: blur({{ block.settings.glass_blur }}px);
      -webkit-backdrop-filter: blur({{ block.settings.glass_blur }}px);
    {% endif %}
  }

  .ai-ingredient-science__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-ingredient-science__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-ingredient-science__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    line-height: 1.2;
  }

  .ai-ingredient-science__subtitle-{{ ai_gen_id }} {
    font-family: {{ block.settings.subtitle_font.family }}, {{ block.settings.subtitle_font.fallback_families }};
    font-weight: {{ block.settings.subtitle_font.weight }};
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-ingredient-science__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-ingredient-science__card-{{ ai_gen_id }} {
    position: relative;
    display: block;
    text-decoration: none;
    background: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    transition: all {{ block.settings.animation_duration }}s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    {% if block.settings.enable_glassmorphism %}
      backdrop-filter: blur({{ block.settings.card_glass_blur }}px);
      -webkit-backdrop-filter: blur({{ block.settings.card_glass_blur }}px);
    {% endif %}
  }

  .ai-ingredient-science__card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: {{ block.settings.card_hover_overlay }};
    opacity: 0;
    transition: opacity {{ block.settings.animation_duration }}s ease;
    pointer-events: none;
  }

  .ai-ingredient-science__card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_shadow_y }}px {{ block.settings.hover_shadow_blur }}px {{ block.settings.hover_shadow_color }};
    border-color: {{ block.settings.card_hover_border_color }};
  }

  .ai-ingredient-science__card-{{ ai_gen_id }}:hover::before {
    opacity: {{ block.settings.hover_overlay_opacity }};
  }

  .ai-ingredient-science__card-inner-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
  }

  .ai-ingredient-science__icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ block.settings.icon_background }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    transition: transform {{ block.settings.animation_duration }}s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .ai-ingredient-science__card-{{ ai_gen_id }}:hover .ai-ingredient-science__icon-wrapper-{{ ai_gen_id }} {
    transform: scale({{ block.settings.icon_hover_scale }}) rotate({{ block.settings.icon_hover_rotate }}deg);
  }

  .ai-ingredient-science__icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-ingredient-science__icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.icon_size | times: 0.5 }}px;
    color: {{ block.settings.icon_placeholder_color }};
  }

  .ai-ingredient-science__card-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.card_title_font.family }}, {{ block.settings.card_title_font.fallback_families }};
    font-weight: {{ block.settings.card_title_font.weight }};
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    text-align: {{ block.settings.card_text_alignment }};
    margin: 0 0 {{ block.settings.card_title_spacing }}px;
    line-height: 1.3;
  }

  .ai-ingredient-science__divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_height }}px;
    background: {{ block.settings.divider_color }};
    margin: 0 auto {{ block.settings.divider_spacing }}px;
    border-radius: {{ block.settings.divider_border_radius }}px;
  }

  .ai-ingredient-science__columns-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    position: relative;
  }

  .ai-ingredient-science__column-{{ ai_gen_id }} {
    padding: {{ block.settings.column_padding }}px;
    position: relative;
  }

  .ai-ingredient-science__column-{{ ai_gen_id }}:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: {{ block.settings.separator_offset }}px;
    bottom: {{ block.settings.separator_offset }}px;
    width: {{ block.settings.separator_width }}px;
    background: {{ block.settings.separator_color }};
  }

  .ai-ingredient-science__column-label-{{ ai_gen_id }} {
    font-family: {{ block.settings.column_label_font.family }}, {{ block.settings.column_label_font.fallback_families }};
    font-weight: {{ block.settings.column_label_font.weight }};
    font-size: {{ block.settings.column_label_size }}px;
    color: {{ block.settings.column_label_color }};
    text-transform: {{ block.settings.column_label_transform }};
    letter-spacing: {{ block.settings.column_label_spacing }}px;
    margin: 0 0 {{ block.settings.column_label_margin }}px;
    text-align: {{ block.settings.card_text_alignment }};
  }

  .ai-ingredient-science__column-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.column_text_font.family }}, {{ block.settings.column_text_font.fallback_families }};
    font-weight: {{ block.settings.column_text_font.weight }};
    font-size: {{ block.settings.column_text_size }}px;
    color: {{ block.settings.column_text_color }};
    line-height: 1.6;
    margin: 0;
    text-align: {{ block.settings.card_text_alignment }};
  }

  {% if block.settings.enable_scroll_animation %}
    .ai-ingredient-science__card-{{ ai_gen_id }} {
      opacity: 0;
      transform: translateY(30px);
    }

    .ai-ingredient-science__card-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} {
      opacity: 1;
      transform: translateY(0);
    }
  {% endif %}

  @media screen and (max-width: 989px) {
    .ai-ingredient-science__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-ingredient-science__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-ingredient-science__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-ingredient-science-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px {{ block.settings.section_padding_horizontal | times: 0.6 }}px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-ingredient-science__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-ingredient-science__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-ingredient-science__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.85 }}px;
    }

    .ai-ingredient-science__card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.9 }}px;
    }

    .ai-ingredient-science__columns-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.column_padding }}px;
    }

    .ai-ingredient-science__column-{{ ai_gen_id }}:not(:last-child)::after {
      display: none;
    }

    .ai-ingredient-science__column-{{ ai_gen_id }} {
      padding: {{ block.settings.column_padding | times: 0.7 }}px 0;
      border-bottom: {{ block.settings.separator_width }}px solid {{ block.settings.separator_color }};
    }

    .ai-ingredient-science__column-{{ ai_gen_id }}:last-child {
      border-bottom: none;
    }
  }
{% endstyle %}

<ingredient-science-{{ ai_gen_id }} class="ai-ingredient-science-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ingredient-science__container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_subtitle != blank %}
      <div class="ai-ingredient-science__header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-ingredient-science__title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% endif %}
        {% if block.settings.section_subtitle != blank %}
          <div class="ai-ingredient-science__subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-ingredient-science__grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign ingredient_key = 'ingredient_' | append: i
          assign ingredient = block.settings[ingredient_key]
          assign icon_key = 'ingredient_' | append: i | append: '_icon'
          assign icon = block.settings[icon_key]
          assign problem_key = 'ingredient_' | append: i | append: '_problem'
          assign problem = block.settings[problem_key]
          assign science_key = 'ingredient_' | append: i | append: '_science'
          assign science = block.settings[science_key]
          assign result_key = 'ingredient_' | append: i | append: '_result'
          assign result = block.settings[result_key]
        %}

        {% if ingredient != blank %}
          <a
            href="/pages/ingredient-profile/{{ ingredient.handle }}"
            class="ai-ingredient-science__card-{{ ai_gen_id }}"
            data-card-index="{{ i }}"
          >
            <div class="ai-ingredient-science__card-inner-{{ ai_gen_id }}">
              <div class="ai-ingredient-science__icon-wrapper-{{ ai_gen_id }}">
                {% if icon != blank %}
                  <img
                    src="{{ icon | image_url: width: 200 }}"
                    alt="{{ ingredient.name }}"
                    class="ai-ingredient-science__icon-{{ ai_gen_id }}"
                    loading="lazy"
                    width="200"
                    height="200"
                  >
                {% else %}
                  <div class="ai-ingredient-science__icon-placeholder-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                      <path d="M2 17l10 5 10-5"/>
                      <path d="M2 12l10 5 10-5"/>
                    </svg>
                  </div>
                {% endif %}
              </div>

              <h3 class="ai-ingredient-science__card-title-{{ ai_gen_id }}">{{ ingredient.name }}</h3>

              {% if block.settings.show_divider %}
                <div class="ai-ingredient-science__divider-{{ ai_gen_id }}"></div>
              {% endif %}

              <div class="ai-ingredient-science__columns-{{ ai_gen_id }}">
                <div class="ai-ingredient-science__column-{{ ai_gen_id }}">
                  <div class="ai-ingredient-science__column-label-{{ ai_gen_id }}">{{ block.settings.problem_label }}</div>
                  <div class="ai-ingredient-science__column-text-{{ ai_gen_id }}">{{ problem }}</div>
                </div>

                <div class="ai-ingredient-science__column-{{ ai_gen_id }}">
                  <div class="ai-ingredient-science__column-label-{{ ai_gen_id }}">{{ block.settings.science_label }}</div>
                  <div class="ai-ingredient-science__column-text-{{ ai_gen_id }}">{{ science }}</div>
                </div>

                <div class="ai-ingredient-science__column-{{ ai_gen_id }}">
                  <div class="ai-ingredient-science__column-label-{{ ai_gen_id }}">{{ block.settings.result_label }}</div>
                  <div class="ai-ingredient-science__column-text-{{ ai_gen_id }}">{{ result }}</div>
                </div>
              </div>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</ingredient-science-{{ ai_gen_id }}>

<script>
  (function() {
    class IngredientScience{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.enableScrollAnimation = {{ block.settings.enable_scroll_animation | json }};
      }

      connectedCallback() {
        if (this.enableScrollAnimation) {
          this.setupScrollAnimation();
        }
      }

      setupScrollAnimation() {
        const cards = this.querySelectorAll('.ai-ingredient-science__card-{{ ai_gen_id }}');
        
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              const cardIndex = entry.target.getAttribute('data-card-index');
              setTimeout(() => {
                entry.target.classList.add('ai-visible-{{ ai_gen_id }}');
              }, cardIndex * {{ block.settings.stagger_delay }});
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        cards.forEach(card => {
          observer.observe(card);
        });
      }
    }

    customElements.define('ingredient-science-{{ ai_gen_id }}', IngredientScience{{ ai_gen_id }});
  })();
</script>

