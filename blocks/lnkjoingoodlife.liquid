{% doc %}
  @prompt
    Closing Call-to-Action / Footer Section
    
    Prompt Spec:
    	•	Background: Warm accent (either coral-red or deep green for strong contrast).
    	•	Centralized text encouraging action, e.g.:
    	•	Heading: “Join the Good Life”
    	•	Subtext: “Discover stories, legends, and inspirations from Nebraska.”
    	•	CTA Button: “Subscribe” or “Learn More” (rounded, beige or white for contrast).
    	•	Alignment: Centered, full width.
    	•	Padding: ~80px top/bottom for emphasis.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-closing-cta-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
  }

  .ai-closing-cta-container-{{ ai_gen_id }} {
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
  }

  .ai-closing-cta-heading-{{ ai_gen_id }} {
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: {{ settings.type_header_font.weight }};
    font-style: {{ settings.type_header_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-closing-cta-subtext-{{ ai_gen_id }} {
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: {{ settings.type_body_font.weight }};
    font-style: {{ settings.type_body_font.style }};
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 32px;
    line-height: 1.5;
    opacity: 0.9;
  }

  .ai-closing-cta-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: 500;
    font-size: {{ block.settings.button_text_size }}px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    min-width: 160px;
  }

  .ai-closing-cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  .ai-closing-cta-button-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_color }};
    outline-offset: 2px;
  }

  @media screen and (max-width: 749px) {
    .ai-closing-cta-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px 16px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-closing-cta-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
      margin-bottom: 12px;
    }

    .ai-closing-cta-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
      margin-bottom: 24px;
    }

    .ai-closing-cta-button-{{ ai_gen_id }} {
      padding: 14px 28px;
      font-size: {{ block.settings.button_text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<section
  class="ai-closing-cta-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-closing-cta-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-closing-cta-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-closing-cta-subtext-{{ ai_gen_id }}">
        {{ block.settings.subtext }}
      </p>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link | default: '#' }}"
        class="ai-closing-cta-button-{{ ai_gen_id }}"
        {% if block.settings.button_link == blank %}
          role="button"
          aria-disabled="true"
        {% endif %}
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Closing call-to-action",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Good Life"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Discover stories, legends, and inspirations from Nebraska."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0e5349"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#fffbf4"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#fffbf4"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#0e5349"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#efecec"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button hover text color",
      "default": "#0e5349"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "range",
      "id": "subtext_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subtext size",
      "default": 18
    },
    {
      "type": "range",
      "id": "button_text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Button text size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Button border radius",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Closing call-to-action"
    }
  ]
}
{% endschema %}