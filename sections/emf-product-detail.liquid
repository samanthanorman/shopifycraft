<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "url": "{{ shop.url }}{{ product.url }}",
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  "brand": {
    "@type": "Brand",
    "name": "Wax | Wane"
  },
  "image": [
    {%- for img in product.images limit: 5 -%}
      "{{ img | image_url: width: 800 }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": "USD",
    "price": "{{ product.price | money_without_currency }}",
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "seller": {
      "@type": "Organization",
      "name": "Wax | Wane"
    }
  }
}
</script>

<script>
  function emfpQty(delta) {
    var inp = document.getElementById('emfp-qty-{{ section.id }}');
    var val = parseInt(inp.value) + delta;
    inp.value = Math.max(1, val);
  }
  function emfpVariantChange(sel) {
    document.getElementById('emfp-variant-id-{{ section.id }}').value = sel.value;
    var opt = sel.options[sel.selectedIndex];
    var btn = document.querySelector('.emfp-atc-btn');
    if (opt.disabled) {
      btn.disabled = true;
      btn.textContent = 'Sold Out';
    } else {
      btn.disabled = false;
      btn.textContent = '⚡ Add to Cart';
    }
  }
</script>

