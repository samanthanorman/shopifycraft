{% doc %}
  @prompt
     Crystal Hero Identity Block
    (display_name, one_liner, color swatch, chakra, zodiac, element, origin, chemical_formula, mohs_hardness, planets, number, archetype, musical_chord)
    
    Create a custom Liquid section called mineral_identity_hero for a Shopify metaobject template page (URL pattern: /pages/crystals/[handle]). The Liquid root object is metaobject — access all fields as metaobject.[key].value.
    
    Display the following fields:
    
    metaobject.display_name.value as the main H1 heading
    metaobject.one_liner.value as a subtitle tagline
    metaobject.color.value as a small filled color swatch circle next to the heading
    A responsive CSS data grid (2 col mobile, 4 col desktop) showing: chakra, zodiac, element, origin, chemical_formula, mohs_hardness, planets, number, archetype, musical_chord — each as a label/value pair. Only render a grid cell if the field value is not blank.
    Style: crisp white background (#FFFFFF), medical blue (#0066FF) accent, Poppins medium (dark charcoal #1A1A1A) for labels, Raleway light (soft grey #666666) for values. Thin 2px medical blue top border across full section width. No gradients, no rounded pill shapes. Generous 24px+ padding. Staggered fade-up scroll entrance animation. Include an editable section title setting in schema. Add ItemPage JSON-LD structured data in a script tag using display_name, seo_description, origin, chemical_formula, and color fields. allow full customization of things like spacing padding font size width on screen, colors etc. thank you
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .mineral-identity-hero-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    border-top: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .mineral-identity-hero__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .mineral-identity-hero__section-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.section_title_font.family }}, {{ block.settings.section_title_font.fallback_families }};
    font-weight: {{ block.settings.section_title_font.weight }};
    font-size: {{ block.settings.section_title_size }}px;
    color: {{ block.settings.section_title_color }};
    text-align: {{ block.settings.text_alignment }};
    margin: 0 0 {{ block.settings.section_title_margin }}px;
  }

  .mineral-identity-hero__header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.text_alignment }};
    gap: {{ block.settings.header_gap }}px;
    margin-bottom: {{ block.settings.header_margin }}px;
    flex-wrap: wrap;
  }

  .mineral-identity-hero__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
  }

  .mineral-identity-hero__color-swatch-{{ ai_gen_id }} {
    width: {{ block.settings.swatch_size }}px;
    height: {{ block.settings.swatch_size }}px;
    border-radius: 50%;
    flex-shrink: 0;
    border: {{ block.settings.swatch_border_thickness }}px solid {{ block.settings.swatch_border_color }};
  }

  .mineral-identity-hero__tagline-{{ ai_gen_id }} {
    font-family: {{ block.settings.tagline_font.family }}, {{ block.settings.tagline_font.fallback_families }};
    font-weight: {{ block.settings.tagline_font.weight }};
    font-size: {{ block.settings.tagline_size }}px;
    color: {{ block.settings.tagline_color }};
    text-align: {{ block.settings.text_alignment }};
    margin: 0 0 {{ block.settings.tagline_margin }}px;
    line-height: 1.5;
  }

  .mineral-identity-hero__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    gap: {{ block.settings.grid_gap_mobile }}px;
    margin-top: {{ block.settings.grid_margin_top }}px;
  }

  @media screen and (min-width: 750px) {
    .mineral-identity-hero__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
      gap: {{ block.settings.grid_gap_desktop }}px;
    }
  }

  .mineral-identity-hero__grid-item-{{ ai_gen_id }} {
    padding: {{ block.settings.grid_item_padding }}px;
    background-color: {{ block.settings.grid_item_bg }};
    border-radius: {{ block.settings.grid_item_radius }}px;
    opacity: 0;
    transform: translateY(20px);
  }

  .mineral-identity-hero__grid-item-{{ ai_gen_id }}.animate {
    animation: fadeUpStagger-{{ ai_gen_id }} 0.6s ease-out forwards;
  }

  .mineral-identity-hero__label-{{ ai_gen_id }} {
    font-family: {{ block.settings.label_font.family }}, {{ block.settings.label_font.fallback_families }};
    font-weight: {{ block.settings.label_font.weight }};
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    margin: 0 0 {{ block.settings.label_margin }}px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .mineral-identity-hero__value-{{ ai_gen_id }} {
    font-family: {{ block.settings.value_font.family }}, {{ block.settings.value_font.fallback_families }};
    font-weight: {{ block.settings.value_font.weight }};
    font-size: {{ block.settings.value_size }}px;
    color: {{ block.settings.value_color }};
    margin: 0;
    line-height: 1.4;
  }

  @keyframes fadeUpStagger-{{ ai_gen_id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 749px) {
    .mineral-identity-hero-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }

    .mineral-identity-hero__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .mineral-identity-hero__tagline-{{ ai_gen_id }} {
      font-size: {{ block.settings.tagline_size_mobile }}px;
    }

    .mineral-identity-hero__section-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.section_title_size_mobile }}px;
    }
  }
{% endstyle %}

<mineral-identity-hero-{{ ai_gen_id }} class="mineral-identity-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="mineral-identity-hero__container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <h2 class="mineral-identity-hero__section-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}

    {% if metaobject.display_name.value != blank %}
      <div class="mineral-identity-hero__header-{{ ai_gen_id }}">
        <h1 class="mineral-identity-hero__heading-{{ ai_gen_id }}">{{ metaobject.display_name.value }}</h1>
        {% if metaobject.color.value != blank %}
          <div 
            class="mineral-identity-hero__color-swatch-{{ ai_gen_id }}"
            style="background-color: {{ metaobject.color.value }};"
            aria-label="Color: {{ metaobject.color.value }}"
          ></div>
        {% endif %}
      </div>
    {% endif %}

    {% if metaobject.one_liner.value != blank %}
      <p class="mineral-identity-hero__tagline-{{ ai_gen_id }}">{{ metaobject.one_liner.value }}</p>
    {% endif %}

    <div class="mineral-identity-hero__grid-{{ ai_gen_id }}">
      {% if metaobject.chakra.value != blank %}
        <div class="mineral-identity-hero__grid-item-{{ ai_gen_id }}" data-index="0">
          <div class="mineral-identity-hero__label-{{ ai_gen_id }}">Chakra</div>
          <div class="mineral-identity-hero__value-{{ ai_gen_id }}">{{ metaobject.chakra.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.zodiac.value != blank %}
        <div class="mineral-identity-hero__grid-item-{{ ai_gen_id }}" data-index="1">
          <div class="mineral-identity-hero__label-{{ ai_gen_id }}">Zodiac</div>
          <div class="mineral-identity-hero__value-{{ ai_gen_id }}">{{ metaobject.zodiac.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.element.value != blank %}
        <div class="mineral-identity-hero__grid-item-{{ ai_gen_id }}" data-index="2">
          <div class="mineral-identity-hero__label-{{ ai_gen_id }}">Element</div>
          <div class="mineral-identity-hero__value-{{ ai_gen_id }}">{{ metaobject.element.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.origin.value != blank %}
        <div class="mineral-identity-hero__grid-item-{{ ai_gen_id }}" data-index="3">
          <div class="mineral-identity-hero__label-{{ ai_gen_id }}">Origin</div>
          <div class="mineral-identity-hero__value-{{ ai_gen_id }}">{{ metaobject.origin.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.chemical_formula.value != blank %}
        <div class="mineral-identity-hero__grid-item-{{ ai_gen_id }}" data-index="4">
          <div class="mineral-identity-hero__label-{{ ai_gen_id }}">Chemical Formula</div>
          <div class="mineral-identity-hero__value-{{ ai_gen_id }}">{{ metaobject.chemical_formula.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.mohs_hardness.value != blank %}
        <div class="mineral-identity-hero__grid-item-{{ ai_gen_id }}" data-index="5">
          <div class="mineral-identity-hero__label-{{ ai_gen_id }}">Mohs Hardness</div>
          <div class="mineral-identity-hero__value-{{ ai_gen_id }}">{{ metaobject.mohs_hardness.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.planets.value != blank %}
        <div class="mineral-identity-hero__grid-item-{{ ai_gen_id }}" data-index="6">
          <div class="mineral-identity-hero__label-{{ ai_gen_id }}">Planets</div>
          <div class="mineral-identity-hero__value-{{ ai_gen_id }}">{{ metaobject.planets.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.number.value != blank %}
        <div class="mineral-identity-hero__grid-item-{{ ai_gen_id }}" data-index="7">
          <div class="mineral-identity-hero__label-{{ ai_gen_id }}">Number</div>
          <div class="mineral-identity-hero__value-{{ ai_gen_id }}">{{ metaobject.number.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.archetype.value != blank %}
        <div class="mineral-identity-hero__grid-item-{{ ai_gen_id }}" data-index="8">
          <div class="mineral-identity-hero__label-{{ ai_gen_id }}">Archetype</div>
          <div class="mineral-identity-hero__value-{{ ai_gen_id }}">{{ metaobject.archetype.value }}</div>
        </div>
      {% endif %}

      {% if metaobject.musical_chord.value != blank %}
        <div class="mineral-identity-hero__grid-item-{{ ai_gen_id }}" data-index="9">
          <div class="mineral-identity-hero__label-{{ ai_gen_id }}">Musical Chord</div>
          <div class="mineral-identity-hero__value-{{ ai_gen_id }}">{{ metaobject.musical_chord.value }}</div>
        </div>
