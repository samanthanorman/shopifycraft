          {%- if rp.featured_image -%}
            <img class="crys-related-card__img" src="{{ rp.featured_image | image_url: width: 400 }}" alt="{{ rp.featured_image.alt | default: rp.title }}" loading="lazy">
          {%- endif -%}
          <div class="crys-related-card__info">
            <p class="crys-related-card__title">{{ rp.title }}</p>
            <p class="crys-related-card__price">{{ rp.price | money }}</p>
          </div>
        </a>
        {%- endfor -%}
      </div>
    </div>
  </div>
  {%- endif -%}
  {%- endif -%}

  {%- comment -%} ── GLOSSARY CTA ── {%- endcomment -%}
  {%- if section.settings.show_glossary_cta -%}
  <div class="crys-section">
    <div class="crys-glossary-cta">
      <p class="crys-glossary-cta__text">{{ section.settings.glossary_cta_text | default: 'Curious about more crystals? Explore the full Crystal Compendium.' }}</p>
      <a href="{{ section.settings.glossary_cta_url | default: '/pages/crystal-compendium' }}" class="crys-glossary-cta__btn">
        💎 Browse the Crystal Compendium →
      </a>
    </div>
  </div>
  {%- endif -%}

</div>

{%- comment -%} STRUCTURED DATA {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "url": "{{ shop.url }}{{ product.url }}",
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  "brand": {
    "@type": "Brand",
    "name": "Crystal Courtesan — Wax | Wane"
  },
  "image": [
    {%- for img in product.images limit: 5 -%}
      "{{ img | image_url: width: 800 }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": "USD",
    "price": "{{ product.price | money_without_currency }}",
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "seller": { "@type": "Organization", "name": "Wax | Wane" }
  }
  {%- if matched_mineral -%}
  ,"additionalProperty": [
    {%- if matched_mineral.mohs_hardness -%}
    { "@type": "PropertyValue", "name": "Mohs Hardness", "value": "{{ matched_mineral.mohs_hardness }}" },
    {%- endif -%}
    {%- if matched_mineral.chemical_formula -%}
    { "@type": "PropertyValue", "name": "Chemical Formula", "value": {{ matched_mineral.chemical_formula | json }} },
    {%- endif -%}
    {%- if matched_mineral.origin -%}
    { "@type": "PropertyValue", "name": "Origin", "value": {{ matched_mineral.origin | json }} },
    {%- endif -%}
    {%- if matched_mineral.chakra -%}
    { "@type": "PropertyValue", "name": "Chakra", "value": {{ matched_mineral.chakra | json }} }
    {%- endif -%}
  ]
  {%- endif -%}
}
</script>

<script>
  function crysQty(delta, id) {
    var inp = document.getElementById('crys-qty-' + id);
    inp.value = Math.max(1, parseInt(inp.value) + delta);
  }
  function crysVariantChange(sel, id) {
    document.getElementById('crys-variant-id-' + id).value = sel.value;
    var btn = document.querySelector('#crys-' + id + ' .crys-atc-btn') || document.querySelector('.crys-atc-btn');
    if (sel.options[sel.selectedIndex].disabled) {
      btn.disabled = true; btn.textContent = 'Sold Out';
    } else {
      btn.disabled = false; btn.textContent = '✦ Add to Cart';
    }
  }
</script>

{% schema %}
{
  "name": "Crystal Product Detail",
  "tag": "section",
  "class": "crystal-product-section",
  "settings": [
    { "type": "header", "content": "── COLORS ─────────────────────────────" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0d0d1a" },
    { "type": "color", "id": "accent_color", "label": "Primary Accent (Purple)", "default": "#c084fc" },
    { "type": "color", "id": "accent2_color", "label": "Secondary Accent (Cyan)", "default": "#67e8f9" },
    { "type": "color", "id": "gold_color", "label": "Price / Gold", "default": "#fbbf24" },
    { "type": "color", "id": "heading_color", "label": "Heading Text", "default": "#f1f5f9" },
    { "type": "color", "id": "body_color", "label": "Body Text", "default": "#94a3b8" },

    { "type": "header", "content": "── SPACING ─────────────────────────────" },
    { "type": "range", "id": "section_padding_top", "label": "Top Padding", "min": 0, "max": 120, "step": 8, "unit": "px", "default": 40 },
    { "type": "range", "id": "section_padding_bottom", "label": "Bottom Padding", "min": 0, "max": 120, "step": 8, "unit": "px", "default": 40 },
    { "type": "range", "id": "side_padding", "label": "Side Padding", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "main_gap", "label": "Media / Info Gap", "min": 16, "max": 100, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "block_padding", "label": "Section Block Padding", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 60 },

    { "type": "header", "content": "── EYEBROW ─────────────────────────────" },
    { "type": "text", "id": "eyebrow", "label": "Product Eyebrow Text", "default": "Crystal Courtesan" },

    { "type": "header", "content": "── MINERAL PROFILE ─────────────────────" },
    { "type": "checkbox", "id": "show_mineral_profile", "label": "Show Mineral Profile Section", "default": true },
    { "type": "text", "id": "mineral_eyebrow", "label": "Eyebrow", "default": "Crystal Profile" },
    { "type": "text", "id": "mineral_heading", "label": "Heading", "default": "Know Your Stone" },
    { "type": "textarea", "id": "mineral_subtitle", "label": "Subtitle", "default": "Every crystal carries its own identity. Here is everything about this one." },

    { "type": "header", "content": "── CARE GUIDE ─────────────────────────" },
    { "type": "checkbox", "id": "show_care", "label": "Show Care Guide Section", "default": true },
    { "type": "text", "id": "care_eyebrow", "label": "Eyebrow", "default": "Crystal Care" },
    { "type": "text", "id": "care_heading", "label": "Heading", "default": "How to Care for Your Stone" },

    { "type": "header", "content": "── HISTORY ─────────────────────────────" },
    { "type": "checkbox", "id": "show_history", "label": "Show History Section", "default": true },
    { "type": "text", "id": "history_eyebrow", "label": "Eyebrow", "default": "Through the Ages" },
    { "type": "text", "id": "history_heading", "label": "Heading", "default": "The History of This Crystal" },

    { "type": "header", "content": "── FAQ ─────────────────────────────────" },
    { "type": "checkbox", "id": "show_faq", "label": "Show FAQ Section", "default": true },
    { "type": "text", "id": "faq_eyebrow", "label": "Eyebrow", "default": "Questions & Answers" },
    { "type": "text", "id": "faq_heading", "label": "Heading", "default": "Crystal Courtesan FAQ" },

    { "type": "header", "content": "── RELATED PRODUCTS ─────────────────────" },
    { "type": "checkbox", "id": "show_related", "label": "Show Related Products", "default": true },
    { "type": "text", "id": "related_eyebrow", "label": "Eyebrow", "default": "Keep Exploring" },
    { "type": "text", "id": "related_heading", "label": "Heading", "default": "You Might Also Love" },

    { "type": "header", "content": "── GLOSSARY CTA ─────────────────────────" },
    { "type": "checkbox", "id": "show_glossary_cta", "label": "Show Glossary Link", "default": true },
    { "type": "textarea", "id": "glossary_cta_text", "label": "CTA Text", "default": "Curious about more crystals? Explore the full Crystal Compendium." },
    { "type": "url", "id": "glossary_cta_url", "label": "Glossary URL" }
  ],
  "presets": [
    { "name": "Crystal Product Detail" }
  ]
}
{% endschema %}
