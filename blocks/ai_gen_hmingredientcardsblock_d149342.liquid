<script>
  (function() {
    class SkincareExplorer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.ingredients = {
          '1,2-Hexanediol': {
            category: 'Solvents/Carriers • Alcohols',
            function: 'Humectant, emollient, preservative booster',
            description: 'A synthetic alcohol that helps to hydrate the skin, soften it, and enhance the preservation of cosmetic formulations.',
            culturalNote: 'Korean skincare emphasizes gentle, multi-functional ingredients like this. While American brands often focus on single-purpose actives, Korean formulations prefer ingredients that serve multiple roles without irritation.'
          },
          'Adenosine': {
            category: 'Actives/Treatments • Nucleosides',
            function: 'Anti-aging, soothing, skin-restoring',
            description: 'A yeast-derived ingredient with proven anti-wrinkle benefits, it helps to soothe and restore the skin.',
            culturalNote: 'Adenosine is a K-beauty favorite for its gentle anti-aging properties. Korean skincare philosophy prioritizes prevention and gentle treatment over aggressive correction, making adenosine perfect for daily use.'
          },
          'Allantoin': {
            category: 'Actives/Treatments • Urea Derivatives',
            function: 'Soothing, healing, moisturizing',
            description: 'A compound found naturally in the comfrey plant, it\'s widely used for its skin-soothing, healing, and moisturizing properties.',
            culturalNote: 'This healing ingredient reflects Korean skincare\'s focus on skin barrier repair and gentle care. Unlike American skincare\'s "no pain, no gain" mentality, Korean beauty emphasizes comfort and healing.'
          },
          'Ammonium Acryloyldimethyltaurate/VP Copolymer': {
            category: 'Emulsifiers/Surfactants • Polymers',
            function: 'Thickener, stabilizer, emulsifier',
            description: 'A synthetic polymer used to thicken and stabilize cosmetic formulations, and to help emulsify ingredients.',
            culturalNote: 'Korean formulations often use advanced polymers like this to create unique textures - from bouncy gels to lightweight essences. Texture innovation is a hallmark of K-beauty that American brands are now adopting.'
          },
          'Arginine': {
            category: 'Actives/Treatments • Amino Acids',
            function: 'Skin-restoring, antioxidant, hydrating',
            description: 'An amino acid that helps to restore the skin, acts as an antioxidant, and contributes to skin hydration.',
            culturalNote: 'Korean skincare pays careful attention to pH balance and amino acid benefits, using ingredients like arginine for their gentle yet effective skin-conditioning properties rather than harsh actives.'
          },
          'Hyaluronic Acid': {
            category: 'Moisturizers/Humectants • Polysaccharides',
            function: 'Intense hydration, plumping, moisture retention',
            description: 'A powerful humectant that can hold up to 1000 times its weight in water, providing deep hydration and plumping effects.',
            culturalNote: 'Hydration is fundamental in Korean skincare philosophy. While American routines often focus on treatment, Korean beauty prioritizes maintaining optimal moisture levels as the foundation of healthy skin.'
          },
          'Niacinamide': {
            category: 'Actives/Treatments • Vitamins',
            function: 'Pore refining, oil control, brightening',
            description: 'Vitamin B3 that helps regulate oil production, minimize pore appearance, and even skin tone with gentle effectiveness.',
            culturalNote: 'Korean formulations typically use lower, gentler concentrations of niacinamide (2-5%) for daily use, while American products often feature higher percentages for dramatic results. K-beauty values consistency over intensity.'
          },
          'Centella Asiatica': {
            category: 'Actives/Treatments • Plant Extracts',
            function: 'Calming, healing, anti-inflammatory',
            description: 'A traditional Korean medicinal herb known for its powerful calming and healing properties, perfect for sensitive or irritated skin.',
            culturalNote: 'This ingredient embodies Korean beauty\'s connection to traditional medicine and natural healing. Korean skincare often incorporates centuries-old herbal wisdom, contrasting with American beauty\'s focus on synthetic innovation.'
          },
          'Ceramides': {
            category: 'Moisturizers/Humectants • Lipids',
            function: 'Barrier repair, moisture retention, protection',
            description: 'Essential lipids that help restore and maintain the skin\'s natural barrier, preventing moisture loss and protecting against environmental damage.',
            culturalNote: 'Korean skincare emphasizes barrier health as preventive care, using ceramides to maintain skin integrity. American skincare often treats barrier damage after it occurs, while K-beauty focuses on prevention.'
          },
          'Snail Secretion Filtrate': {
            category: 'Actives/Treatments • Animal-derived',
            function: 'Regenerating, hydrating, healing',
            description: 'A K-beauty staple rich in glycoproteins, hyaluronic acid, and glycolic acid that promotes skin regeneration and healing.',
            culturalNote: 'This uniquely Korean ingredient showcases K-beauty\'s willingness to explore unconventional sources for skin benefits. While American consumers were initially skeptical, snail mucin\'s proven results have gained global acceptance.'
          }
        };
      }

      connectedCallback() {
        this.setupEventListeners();
        this.updateStats();
      }

      setupEventListeners() {
        const filterButtons = this.querySelectorAll('.ai-skincare-explorer__filter-btn-{{ ai_gen_id }}');
        const cards = this.querySelectorAll('.ai-skincare-explorer__card-{{ ai_gen_id }}');
        const modal = this.querySelector('#ingredient-modal-{{ ai_gen_id }}');
        const closeButton = this.querySelector('.ai-skincare-explorer__modal-close-{{ ai_gen_id }}');

        filterButtons.forEach(button => {
          button.addEventListener('click', () => {
            filterButtons.forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');
            this.filterIngredients(button.dataset.filter);
          });
        });

        cards.forEach(card => {
          card.addEventListener('click', () => {
            const ingredientName = card.dataset.ingredient;
            this.showModal(ingredientName);
          });
        });

        closeButton.addEventListener('click', () => {
          this.hideModal();
        });

        modal.addEventListener('click', (e) => {
          if (e.target === modal) {
            this.hideModal();
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            this.hideModal();
          }
        });
      }

      filterIngredients(filter) {
        const cards = this.querySelectorAll('.ai-skincare-explorer__card-{{ ai_gen_id }}');
        
        cards.forEach(card => {
          const category = card.dataset.category;
          const origin = card.dataset.origin;
          
          let shouldShow = false;
          
          if (filter === 'all') {
            shouldShow = true;
          } else if (filter === 'natural' && origin === 'natural') {
            shouldShow = true;
          } else if (filter === 'synthetic' && origin === 'synthetic') {
            shouldShow = true;
          } else if (category === filter) {
            shouldShow = true;
          }
          
          if (shouldShow) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });

        this.updateStats();
      }

      updateStats() {
        const visibleCards = this.querySelectorAll('.ai-skincare-explorer__card-{{ ai_gen_id }}:not(.hidden)');
        const naturalCount = Array.from(visibleCards).filter(card => card.dataset.origin === 'natural').length;
        const activeCount = Array.from(visibleCards).filter(card => card.dataset.category === 'Actives/Treatments').length;

        this.querySelector('#total-ingredients-{{ ai_gen_id }}').textContent = visibleCards.length;
        this.querySelector('#natural-count-{{ ai_gen_id }}').textContent = naturalCount;
        this.querySelector('#active-count-{{ ai_gen_id }}').textContent = activeCount;
      }

      showModal(ingredientName) {
        const ingredient = this.ingredients[ingredientName];
        if (!ingredient) return;

        this.querySelector('#modal-title-{{ ai_gen_id }}').textContent = ingredientName;
        this.querySelector('#modal-category-{{ ai_gen_id }}').textContent = ingredient.category;
        this.querySelector('#modal-function-{{ ai_gen_id }}').textContent = ingredient.function;
        this.querySelector('#modal-description-{{ ai_gen_id }}').textContent = ingredient.description;
        this.querySelector('#modal-cultural-note-{{ ai_gen_id }}').textContent = ingredient.culturalNote;

        const modal = this.querySelector('#ingredient-modal-{{ ai_gen_id }}');
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      hideModal() {
        const modal = this.querySelector('#ingredient-modal-{{ ai_gen_id }}');
        modal.classList.remove('active');
        document.body.style.overflow = '';
      }
    }

    customElements.define('skincare-explorer-{{ ai_gen_id }}', SkincareExplorer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Skincare explorer",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Haramoon Skincare Ingredients"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Discover the science behind Korean skincare with our interactive ingredient explorer. Learn about the cultural differences between South Korean and American beauty approaches."
