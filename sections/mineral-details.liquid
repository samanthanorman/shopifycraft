{% comment %}
  Mineral metaobject detail section (Craft theme)
  Uses field handles exactly as defined:
  display_name, summary, energy_properties, element, mohs_hardness, planetary_association,
  zodiac_sign, cleanse, recharge, safety_notes, image, gallery, color, origin_story, science,
  modern_uses, chemical_formula, body_part_center, numerology_number, seo_description,
  best_to_pair_with, product, one_liner
{% endcomment %}

{% assign m = metaobject %}

<section class="mineral-wrap">
  {%- comment -%} HERO {%- endcomment -%}
  {% if m.image %}
    <div class="mineral-hero">
      {{ m.image | image_url: width: 1600 | image_tag: alt: m.display_name, class: 'mineral-hero__img' }}
    </div>
  {% endif %}

  <header class="mineral-header">
    <h1 class="mineral-title">{{ m.display_name | default: m.one_liner }}</h1>
    {% if m.summary %}
      <p class="mineral-summary">{{ m.summary }}</p>
    {% elsif m.one_liner %}
      <p class="mineral-summary">{{ m.one_liner }}</p>
    {% endif %}
  </header>

  {%- comment -%} QUICK FACTS / CHIPS {%- endcomment -%}
  <section class="mineral-meta grid">
    <div class="meta-card">
      <h3>Quick facts</h3>
      <ul class="meta-list">
        {% if m.chemical_formula %}<li><strong>Formula:</strong> {{ m.chemical_formula }}</li>{% endif %}
        {% if m.mohs_hardness %}<li><strong>Hardness:</strong> Mohs {{ m.mohs_hardness }}</li>{% endif %}
        {% if m.color %}<li><strong>Color:</strong> {{ m.color }}</li>{% endif %}
        {% if m.element %}<li><strong>Element:</strong> {{ m.element }}</li>{% endif %}
        {% if m.planetary_association %}<li><strong>Planetary association:</strong> {{ m.planetary_association }}</li>{% endif %}
        {% if m.numerology_number %}<li><strong>Numerology:</strong> {{ m.numerology_number }}</li>{% endif %}
      </ul>
    </div>

    <div class="meta-card">
      <h3>Vibe match</h3>
      {% assign z = m.zodiac_sign %}
      {% if z %}
        {% assign z_list = z | replace: ';', ',' | split: ',' %}
        <div class="meta-row">
          <span class="meta-label">Zodiac:</span>
          <div class="chips">
            {% for item in z_list %}
              {% assign label = item | strip %}
              {% if label != blank %}<span class="chip">{{ label }}</span>{% endif %}
            {% endfor %}
          </div>
        </div>
      {% endif %}

      {% assign bc = m.body_part_center %}
      {% if bc %}
        {% assign bc_list = bc | replace: ';', ',' | split: ',' %}
        <div class="meta-row">
          <span class="meta-label">Body focus:</span>
          <div class="chips">
            {% for item in bc_list %}
              {% assign label = item | strip %}
              {% if label != blank %}<span class="chip">{{ label }}</span>{% endif %}
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>
  </section>

  {%- comment -%} NARRATIVE SECTIONS {%- endcomment -%}
 {% comment %}
  Mineral metaobject detail section (Craft theme) — Wide + Rich Text
{% endcomment %}

{% assign m = metaobject %}

<section class="mineral-hero-bleed">
  {% if m.image %}
    {{ m.image | image_url: width: 2400 | image_tag: alt: m.display_name, class: 'mineral-hero-bleed__img' }}
  {% endif %}
  <div class="mineral-hero-bleed__overlay">
    <h1 class="mineral-title">{{ m.display_name | default: m.one_liner }}</h1>
    {% if m.one_liner %}
      <p class="mineral-kicker">{{ m.one_liner }}</p>
    {% endif %}
  </div>
</section>

<section class="mineral-wrap">
  {% if m.summary %}
    <p class="mineral-summary">{{ m.summary | newline_to_br }}</p>
  {% endif %}

  <section class="mineral-meta grid">
    <div class="meta-card">
      <h3>Quick facts</h3>
      <ul class="meta-list">
        {% if m.chemical_formula %}<li><strong>Formula:</strong> {{ m.chemical_formula }}</li>{% endif %}
        {% if m.mohs_hardness %}<li><strong>Hardness:</strong> Mohs {{ m.mohs_hardness }}</li>{% endif %}
        {% if m.color %}<li><strong>Color:</strong> {{ m.color }}</li>{% endif %}
        {% if m.element %}<li><strong>Element:</strong> {{ m.element }}</li>{% endif %}
        {% if m.planetary_association %}<li><strong>Planetary association:</strong> {{ m.planetary_association }}</li>{% endif %}
        {% if m.numerology_number %}<li><strong>Numerology:</strong> {{ m.numerology_number }}</li>{% endif %}
      </ul>
    </div>

    {%- comment -%} ZODIAC CHIPS {%- endcomment -%}
{% assign zodiac = m.zodiac_sign
  | replace: '[', ''
  | replace: ']', ''
  | replace: '"', ''
%}
{% assign zodiac_list = zodiac | split: ',' %}
{% if zodiac_list.size > 0 and zodiac_list.first != '' %}
  <div class="meta-row">
    <span class="meta-label">Zodiac:</span>
    <div class="chips">
      {% for z in zodiac_list %}
        {% assign zt = z | strip %}
        {% if zt != blank %}<span class="chip">{{ zt }}</span>{% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %}
      {%- comment -%} BODY FOCUS CHIPS {%- endcomment -%}
{% assign bodycenters = m.body_part_center
  | replace: '[', ''
  | replace: ']', ''
  | replace: '"', ''
%}
{% assign bodycenters_list = bodycenters | split: ',' %}
{% if bodycenters_list.size > 0 and bodycenters_list.first != '' %}
  <div class="meta-row">
    <span class="meta-label">Body focus:</span>
    <div class="chips">
      {% for b in bodycenters_list %}
        {% assign bt = b | strip %}
        {% if bt != blank %}<span class="chip">{{ bt }}</span>{% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %}


  <section class="mineral-content">
    {% if m.origin_story %}
      <article><h2>Origin story</h2>{{ m.origin_story | metafield_tag }}</article>
    {% endif %}
    {% if m.science %}
      <article><h2>Science & geology</h2>{{ m.science | metafield_tag }}</article>
    {% endif %}
    {% if m.modern_uses %}
      <article><h2>Modern uses</h2>{{ m.modern_uses | metafield_tag }}</article>
    {% endif %}
    {% if m.energy_properties %}
      <article><h2>Physical / energy properties</h2><p>{{ m.energy_properties | newline_to_br }}</p></article>
    {% endif %}

    {% if m.cleanse or m.recharge or m.safety_notes %}
      <article class="mineral-care">
        <h2>Care & handling</h2>
        {% if m.cleanse %}<p><strong>Cleanse:</strong> {{ m.cleanse | newline_to_br }}</p>{% endif %}
        {% if m.recharge %}<p><strong>Recharge:</strong> {{ m.recharge | newline_to_br }}</p>{% endif %}
        {% if m.safety_notes %}<p class="note">⚠ {{ m.safety_notes | newline_to_br }}</p>{% endif %}
      </article>
    {% endif %}

    {% if m.best_to_pair_with %}
      <article><h2>Best to pair with</h2><p>{{ m.best_to_pair_with | newline_to_br }}</p></article>
    {% endif %}
  </section>

  {% if m.gallery and m.gallery.size > 0 %}
    <section class="mineral-gallery">
      <h2>Gallery</h2>
      <div class="gallery-grid">
        {% for img in m.gallery %}
          <figure class="gallery-item">
            {{ img | image_url: width: 1200 | image_tag: loading: 'lazy', alt: m.display_name }}
          </figure>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {% assign products = blank %}
  {% if m.product %}
    {% if m.product.size %}{% assign products = m.product %}
    {% else %}{% assign products = m.product | array %}{% endif %}
  {% endif %}

  {% if products and products.size > 0 %}
    <section class="mineral-related">
      <h2>Shop {{ m.display_name }}</h2>
      <div class="related-grid">
        {% for p in products %}
          <a class="product-card" href="{{ p.url }}">
            {{ p | image_url: width: 700 | image_tag: alt: p.title }}
            <div class="product-card__meta">
              <h3 class="product-card__title">{{ p.title }}</h3>
              {% if p.price %}<span class="product-card__price">{{ p.price | money }}</span>{% endif %}
            </div>
          </a>
        {% endfor %}
      </div>
    </section>
  {% endif %}
</section>

<style>
/* Full-bleed hero */
.mineral-hero-bleed{position:relative;width:100vw;left:50%;right:50%;margin-left:-50vw;margin-right:-50vw;overflow:hidden}
.mineral-hero-bleed__img{width:100%;height:42vh;object-fit:cover;display:block}
@media(min-width:980px){.mineral-hero-bleed__img{height:56vh}}
.mineral-hero-bleed__overlay{
  position:absolute;inset:auto 0 8%;display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:0 1rem;
}
.mineral-title{color:var(--color-foreground, #111);background:rgba(255,255,255,.85);padding:.3rem .8rem;border-radius:12px;
  font-size:clamp(1.8rem,3.5vw,2.6rem);display:inline-block}
.mineral-kicker{margin:.4rem 0 0;background:rgba(255,255,255,.8);padding:.2rem .6rem;border-radius:10px}

/* Content container */
.mineral-wrap{max-width:1200px;margin:0 auto;padding:clamp(14px,2vw,22px)}
.mineral-summary{color:#4b5563;margin:0 0 1rem}

/* Cards & grids */
.grid{display:grid;gap:14px;grid-template-columns:1fr;margin:16px 0}
@media(min-width:960px){.grid{grid-template-columns:1fr 1fr}}
.meta-card{background:#f7f7f7;border-radius:14px;padding:14px}
.meta-list{margin:0 0 6px;padding-left:16px}
.meta-row{display:flex;gap:.5rem;align-items:baseline;flex-wrap:wrap;margin:.35rem 0}
.meta-label{font-weight:600;min-width:120px}

.chips{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.25rem}
.chip{background:#eef0f2;border-radius:999px;padding:.25rem .6rem;font-size:.9rem}

/* Narrative sections */
.mineral-content article{margin:16px 0}
.mineral-content h2{font-size:1.2rem;margin:.6rem 0 .35rem}
.mineral-care .note{background:#fff7e6;padding:.5rem .75rem;border-radius:10px;border-left:4px solid #f5a623}

/* Gallery & related */
.mineral-gallery .gallery-grid,
.mineral-related .related-grid{display:grid;gap:12px;grid-template-columns:repeat(2,1fr)}
@media(min-width:1024px){
  .mineral-gallery .gallery-grid{grid-template-columns:repeat(3,1fr)}
  .mineral-related .related-grid{grid-template-columns:repeat(4,1fr)}
}
.gallery-item img{border-radius:12px}
.product-card{display:block;text-decoration:none;color:inherit;background:#fff;border-radius:14px;overflow:hidden;border:1px solid #eee}
.product-card__meta{padding:.6rem .75rem}
.product-card__title{margin:.2rem 0;font-size:1rem}
.product-card__price{color:#2f6f5f;font-weight:600}
</style>

{% schema %}
{
  "name": "Mineral details",
  "settings": [],
  "presets": [{ "name": "Mineral details" }]
}
{% endschema %}